  			if (in_array($groupID, array("139", "190"))) {	// PART DEEL + PART LEID
				if (empty($related_hoofdleiding_relid)) {
	    			wachthond($extdebug, 1, '<pre>### 4.5 RETRIEVE RELATED HOOFDLEIDING [groupID: $groupID] ###</pre>');

					$params_get_rel_hldn = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
				  		'select' => [
							'contact_id_a', 'contact_id_b', 'is_active', 'start_date', 'end_date', 'id',
  						],
	  					'where' => [
		      				['contact_id_a', 		'=', $contact_id],
      						['relationship_type_id','=', 17],
      						['start_date', 			'>=', $event_fiscalyear_start],
      						['end_date', 			'<=', $event_fiscalyear_einde],
			    			['is_active', 			'=', TRUE],
#							['xyz.Datum_kamp','=', 'this.fiscal_year'], // M61: datum kamp nog toevoegen aan custom fields van hldn rel
    					],
	      			];

					wachthond($extdebug, 3, '<pre>params_get_rel_hldn: $params_get_rel_hldn</pre>');
					$result_get_rel_hldn = civicrm_api4('Relationship', 'get', $params_get_rel_hldn);
					wachthond($extdebug, 4, '<pre>result_get_rel_hldn: $result_get_rel_hldn</pre>');
    				wachthond($extdebug, 1, '<pre>Related Hoofdleiding Relatie: opgehaald</pre>');

	 				$result_get_rel_hldn_count 	= $result_get_rel_hldn->count();
  					if ($result_get_rel_hldn_count == 1) {
						$related_hoofdleiding_id	= $result_get_rel_hldn[0]['contact_id_b'];
						$related_hoofdleiding_relid	= $result_get_rel_hldn[0]['id'];
					} else {
						$related_hoofdleiding_id	= NULL;
						$related_hoofdleiding_relid	= NULL;
						wachthond($extdebug, 1, '<pre>ERROR  : GEEN RELATED HOOFDLEIDING GEVONDEN: $errorData</pre>');
					}
					wachthond($extdebug, 2, '<pre>related_hoofdleiding_id   : $related_hoofdleiding_id</pre>');
