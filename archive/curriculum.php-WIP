					#if ($vogverzoekditjaar == 1) { // M61 indien VOG verzoek trek deze datum REF persoon dan gelijk (= vog verzoek + 30 dagen)
					#	$params_activity_refpersoon_change['values']['activity_date_time']	= $datum_vogaanvraag;
