					$newdate		 	= strtotime ('+42 day' , strtotime($part_register_date));	// ZET DEADLINE 42 DAGEN NA VERZOEK
					$datum_refpersoon  	= date ( 'Y-m-d H:i:s' , $newdate );
				}
				// ************************************************************************************************************
