  							'ACT_REF.ID_Kamp'					=> $part_eventid,
  							'ACT_REF.Kamp_kort_'				=> $welkkampkort,
  							'ACT_REF.Datum_kamp' 				=> $event_start_date,
  							'ACT_REF.REF_nodig' 				=> $refnodig,
    						'ACT_REF.Relatie_ID'				=> $referentie_relid,
    						'ACT_REF.Naam_referentie'			=> $referentie_name,
    						'ACT_REF.Voornaam_referentie'		=> $referentie_fn, 
    						'ACT_REF.Telefoon_referentie'		=> $referentie_phone, 							
  							'activity_date_time' 				=> $datum_refpersoon,
  							'status_id:name' 					=> $status_refpersoon,
  							'subject'							=> 'REF persoon gevraagd',
			   				'ACT_ALG.kampkort'					=> $welkkampkort,
			   				'ACT_ALG.kampfunctie' 				=> $part_functie,
			    			'ACT_ALG.kampstart' 				=> $event_start_date,
