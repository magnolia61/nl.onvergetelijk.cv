				wachthond($extdebug, 1, '<pre>evt_fscyear_einde: $event_fiscalyear_einde</pre>');

    			$event_locatie			= $result[0]['Event_Kenmerken.Kamplocatie'];
    			$event_plaats			= $result[0]['Event_Kenmerken.Kampplaats'];

