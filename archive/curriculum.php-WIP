					if ($extvog == 1)	{
						$result = civicrm_api4('Activity', 'update', $params_activity_vogverzoek_change);
						wachthond($extdebug, 2, '<pre>params_activity_vogverzoek_change EXECUTED [groupID: $groupID]</pre>');
						wachthond($extdebug, 4, '<pre>result_activity_vogverzoek_change: $result</pre>');
