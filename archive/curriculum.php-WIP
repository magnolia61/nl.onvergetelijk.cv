				// ************************************************************************************************************
				// 15.4 UPDATE ACTIVITY VOG AANVRAAG STATUS N.A.V. DAYS SINCE...	
				wachthond($extdebug, 1, '<pre>--- 15.4 UPDATE ACTIVITY VOG AANVRAAG STATUS N.A.V. DAYS SINCE ($dayssince_vogverzoek)</pre>');	
				// ************************************************************************************************************
				#if ((in_array($vogaanvraag_activity_status, array("1", "4", "5", "8")) AND in_array($vogontvangst_activity_status, array("2"))) AND $part_vogingediend) {
				#wachthond($extdebug, 2, '<pre>vogaanvraag_activity_id: $vogaanvraag_activity_id</pre>');
				#wachthond($extdebug, 2, '<pre>datum_aanvraag: $datum_vogaanvraag</pre>');
				#wachthond($extdebug, 2, '<pre>status_aanvraag: $status_vogaanvraag</pre>');

				if ($vogaanvraag_activity_id AND $datum_vogaanvraag AND $status_vogaanvraag) {

					$params_activity_vogaanvraag_change = [
  					'checkPermissions' => FALSE,
					'debug' => $apidebug,
	  					'where' => [
