						$datum_vogontvangst = date ( 'Y-m-d' , $newdate );
					} else {
						$newdate		 	= strtotime ( '+7 day' , strtotime ($event_start_date) ) ;
						$datum_vogontvangst = date ( 'Y-m-d' , $newdate );
