		$today_datetime 		= date("Y-m-d H:i:s");
		$today_datetimenext		= date('Y-m-d H:i:s', strtotime('+1 year', strtotime($today_datetime)) );		

		#####################################################################################################
		# 1.0 BEPAAL DE GRENZEN VAN HET HUIDIGE FISCALE JAAR
    	wachthond($extdebug, 1, '<pre>### 1.0 BEPAAL DE GRENZEN VAN HET HUIDIGE FISCALE JAAR [groupID: $groupID] [op: $op] ###</pre>');
		#####################################################################################################

		$today_fiscalyear 		= curriculum_civicrm_fiscalyear($today_datetime);
		$today_fiscalyear_start	= $today_fiscalyear['fiscalyear_start'];
		$today_fiscalyear_einde	= $today_fiscalyear['fiscalyear_einde'];
		$today_kampjaar			= date('Y', strtotime($today_fiscalyear_einde));	// M61 theorerisch niet 100% beter jaar van kampdatum zelf

		wachthond($extdebug, 2, "<pre>XXX today_datetime               : $today_datetime,TRUE).</pre>");
		wachthond($extdebug, 2, "<pre>YYY today_datetime               : $today_datetime.'</pre>");
		wachthond($extdebug, 2, "<pre>XXX today_datetime               : $today_datetime</pre>");

