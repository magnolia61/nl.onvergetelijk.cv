   					wachthond($extdebug, 2, '<pre>- conflict_account_name   : $conflict_account->name</pre>');
   					wachthond($extdebug, 2, '<pre>- conflict_account_mail   : $conflict_account->mail</pre>');
   					wachthond($extdebug, 2, '<pre>- conflict_account_uid    : $conflict_account->uid</pre>');

					$drupalaccount_safe2repair_account = 0; 						
				} else {
					wachthond($extdebug, 1, '<pre>2) SAFE2REPAIR: GREEN : VIA CMS IDENTIFIER ($cmsidentitier) GEEN DRUPAL ACCOUNT GEVONDEN</pre>');
					$drupalaccount_safe2repair_account = 1;	
				}
				#####################################################################################################
				# CHECK IF CONNECTED DRUPAL ID IS IN USER BY ANOTHER ACCOUNT AS CMS IDENTIFIER 
    			wachthond($extdebug, 1, '<pre>CHECK IF CONNECTED DRUPAL ID IS IN USER BY ANOTHER ACCOUNT AS CMS IDENTIFIER</pre>');
				#####################################################################################################
				$params_externalid = [
	  				'checkPermissions' => FALSE,
					'debug' => $apidebug,  					
