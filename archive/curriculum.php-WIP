						$params_ufmatchget = [
	  						'checkPermissions' => FALSE,
							'debug' => $apidebug,
  							'select' => [
    							'id', 
    							'uf_id', 
    							'contact_id',
  							],
  							'where' => [
    							['uf_id', '=', $drupal_uid],
  							],
						];
      					wachthond($extdebug, 3, '<pre>params_ufmatchget: $params_ufmatchget</pre>');
      					$result 		= civicrm_api4('UFMatch', 'get', $params_ufmatchget);
      					$ufmatch_id 	= $result[0]['id'];
      					$ufmatch_ufid 	= $result[0]['uf_id'];
	    				wachthond($extdebug, 4, '<pre>result_ufmatchget: $result</pre>');
	    				wachthond($extdebug, 2, '<pre>UFMatch_id: $ufmatch_id</pre>');				

						if ($ufmatch_id) {
							// DELETE EXISTING UF MATCH (die wijst naar lege nieuwe civicrm contact)
							$params_ufmatchdelete = [
	      						'id' => $ufmatch_id,
   	  						];
							wachthond($extdebug, 3, '<pre>params_ufmatchdelete: $params_ufmatchdelete</pre>');
      						$result = civicrm_api3('UFMatch', 'delete', $params_ufmatchdelete);
    						wachthond($extdebug, 2, '<pre>result_ufmatchdelete: $result</pre>');
    					}
					}
					#####################################################################################################
					# CREATE NEW UF MATCH WITH NEWLY CREATED DRUPAL USER (M61: match ook met evt verkeer dubbeld gevonden uid!!!)
					#####################################################################################################
    				wachthond($extdebug, 1, '<pre>------ f) CREATE NEW UF MATCH WITH NEWLY CREATED DRUPAL USER: ($drupal_uid) AND MATCH = 0: ($drupalufmatch_found) AND DITJAARDEEL</pre>');
					#####################################################################################################

					$params_ufmatchcreate = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
  						'values' => [
							'uf_id'			=> $drupal_uid,
      						'uf_name'		=> $user_email,
      						'contact_id'	=> $contact_id,
      						'domain_id'		=> 1,
  						],
					];

					wachthond($extdebug, 3, '<pre>params_ufmatchcreate: ($params_ufmatchcreate)</pre>');
      				$result = civicrm_api4('UFMatch', 'create', $params_ufmatchcreate);
    				wachthond($extdebug, 4, '<pre>result_ufmatchcreate: $result</pre>');

					// CHECK IF A CURRENT UF MATCH IS NOW PRESENT
					$params_ufmatchget = [
	  					'checkPermissions' => FALSE,
						'debug' => $apidebug,
  						'select' => [
    						'id', 
    						'uf_id', 
   							'contact_id',
  						],
  						'where' => [
    						['contact_id', '=', $contact_id],
  						],
					];
					wachthond($extdebug, 3, '<pre>params_ufmatchget: ($params_ufmatchget)</pre>');
      				$result = civicrm_api4('UFMatch', 'get', $params_ufmatchget);
      				if ($result !== false) {
      					$ufmatch_id 	= $result[0]['id'];
    					$ufmatch_ufid 	= $result[0]['uf_id'];
   					}

		    		if ($ufmatch_ufid) {
	    				wachthond($extdebug, 1, '<pre>------ f) PRIMA  : GOEDE UF MATCH GEVONDEN: $user_name | drupalid: $ufmatch_ufid</pre>');
    					$drupalufmatch_found = 1;
    					if ($drupal_uid == $ufmatch_ufid) {
				    		$params_contact['values']['external_identifier'] = $drupal_uid;
				    	}
    					#wachthond($extdebug, 2, '<pre>Current user UFMatch_id  : $ufmatch_id</pre>');
						#wachthond($extdebug, 2, '<pre>Current user UFMatch_ufid: $ufmatch_ufid</pre>');
    				} else {
	    				wachthond($extdebug, 1, '<pre>------ f) ERROR  : GEEN UF MATCH GEVONDEN VOOR CONTACT_ID: $contact_id</pre>');
    					$drupalufmatch_found = 0;
    				}
				}

  				if ($drupalaccount_safe2update == 0 AND $drupalaccount_nameconflict	== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED CREATE WANT DRUPAL ACCOUNT GEVONDEN MET ZELFDE NAAM: ($user_name)</pre>');
				}
				if ($drupalaccount_safe2update == 0 AND $drupalufmatchother_found 	== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED CREATE WANT CONFLICTERENDE UF MATCH GEVONDEN: ($ufmatch_ufid)</pre>');
				}
				if ($drupalaccount_safe2update == 0 AND $drupalname_danger 			== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED CREATE WANT CONNECTED CMS NAME ($connected_drupal_name) != CONSTRUCTED NAME ($user_name)</pre>');
				}
				if ($drupalaccount_safe2update == 0 AND $drupalid_danger 			== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED CREATE WANT CONNECTED CMS ID ($connected_drupal_id) != EXTERNAL IDENTIFIER ($cmsidentitier)</pre>');
				}
    		}

			##########################################################################################################################################
			wachthond($extdebug, 1, '<pre>###### G) UPDATE DRUPAL ACCOUNT & UF_MATCH [IF DRUPALÀCCOUNT     FOUND ($drupalaccount_found) AND UFMATCH     FOUND ($drupalufmatch_found)</pre>');
			##########################################################################################################################################
			if ($drupalaccount_found == 1 AND $drupalufmatch_found == 1) {
			##########################################################################################################################################
				wachthond($extdebug, 1, '<pre>*** UPDATE DRUPAL  ACCOUNT  :$user_name ***</pre>');	
				wachthond($extdebug, 1, '<pre>*** DRUPAL ACCOUNT FOUND    :$drupalaccount_found ***</pre>');		
				wachthond($extdebug, 1, '<pre>*** DRUPAL NAME    FOUND    :$drupalname_found ***</pre>');		
				wachthond($extdebug, 1, '<pre>*** DRUPAL MATCH   FOUND    :$drupalufmatch_found ***</pre>');		
				wachthond($extdebug, 1, '<pre>*** DRUPAL MATCH   CONFLICT :$drupalufmatchother_found *** (ERROR)</pre>');	
				wachthond($extdebug, 1, '<pre>*** DRUPAL NAME    CONFLICT :$drupalaccount_nameconflict *** (ERROR)</pre>');
				wachthond($extdebug, 1, '<pre>*** DRUPAL NAME    DANGER   :$drupalname_danger *** (ERROR)</pre>');
				wachthond($extdebug, 1, '<pre>*** DRUPAL ID      DANGER   :$drupalid_danger *** (ERROR)</pre>');
				if ($drupalaccount_nameconflict == 0 AND $drupalufmatchother_found == 0 AND $drupalname_danger == 0 AND $drupalid_danger == 0) {
					$drupalaccount_safe2update = 1;
				} else {
					$drupalaccount_safe2update = 0;
				}
				#####################################################################################################
				# UPDATE DRUPAL ACCOUNT & EMAIL WITH PRIMARY EMAIL (ONVERGETELIJK.NL VOOR STAF, PLACEHOLDER VOOR DEEL)
				#####################################################################################################
				wachthond($extdebug, 1, '<pre>------ g) CHANGE DRUPAL MAIL FOR MATCHID: $ufmatch_ufidto $user_email (PREPARING)</pre>');
				if ($user_name) { $drupal_name = $user_name; }

				wachthond($extdebug, 1, '<pre>------ g) CHANGE DRUPAL NAME FOR MATCHID: $ufmatch_ufidto $drupal_name (PREPARING)</pre>');
				###########################################
				# UPDATE DRUPAL USER USING DRUPAL API
				###########################################

				// load user object
				$existingUser = user_load($ufmatch_ufid);
				#wachthond($extdebug, 2, '<pre>existingUser: $existingUser</pre>');
				$existingUser->mail = $user_email;
				// always update username (for all roles)
				$existingUser->name = $user_name;

				#wachthond($extdebug, 2, '<pre>existingUser 		: $existingUser</pre>');
				wachthond($extdebug, 2, '<pre>existingUser->name 	: $existingUser->name</pre>');
				wachthond($extdebug, 2, '<pre>existingUser->mail 	: $existingUser->mail</pre>');
				wachthond($extdebug, 2, '<pre>existingUser->uid 	: $existingUser->uid</pre>');

				// save existing user
				if ($existingUser->uid AND $drupalaccount_safe2update == 1) {
					user_save((object) array('uid' => $existingUser->uid), (array) $existingUser);
					wachthond($extdebug, 1, '<pre>------ g) SUCCESS: Changed drupal mail for drupalid: $ufmatch_ufidto $user_email(UPDATED)</pre>');
					wachthond($extdebug, 1, '<pre>------ g) SUCCESS: Changed drupal name for drupalid: $ufmatch_ufidto $user_name(UPDATED)</pre>');
					$job_title 			= $user_name; // M61: om te updaten later in job_title
				}

				#####################################################################################################
				# UPDATE UF_MATCH WITH PROPER EMAIL
				#####################################################################################################

				// M61: HIER MOET NOG EEN IF OM HET ALLEEN TE UPDATEN ALS HET AFWIJKT
				if ($drupalaccount_safe2update == 1) {

					$params_ufmatchupdate = [
	  					'checkPermissions' => FALSE,
						'debug' => $apidebug,
	 					'where' => [
    						['contact_id', '=', $contact_id],
  						],
  						'values' => [
							'uf_name' => $user_email,
  						],
					];
					wachthond($extdebug, 3, '<pre>params_ufmatchupdate$params_ufmatchupdate</pre>');
      				$result 		= civicrm_api4('UFMatch', 'update', $params_ufmatchupdate);
					wachthond($extdebug, 4, '<pre>result_ufmatchupdate: $result</pre>');

					wachthond($extdebug, 1, '<pre>------ g) SUCCESS: Changed ufmatch mail for contact_id $contact_id to $user_email</pre>');
				}
 
				#####################################################################################################

				if ($drupalaccount_safe2update == 0 AND $drupalaccount_nameconflict	== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED UPDATE WANT DRUPAL ACCOUNT GEVONDEN MET ZELFDE NAAM: ($user_name)</pre>');
				}
				if ($drupalaccount_safe2update == 0 AND $drupalufmatchother_found 	== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED UPDATE WANT CONFLICTERENDE UF MATCH GEVONDEN: ($ufmatch_ufid)</pre>');
				}
				if ($drupalaccount_safe2update == 0 AND $drupalname_danger 			== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED UPDATE WANT CONNECTED CMS NAME ($connected_drupal_name) != CONSTRUCTED NAME ($user_name)</pre>');
				}
				if ($drupalaccount_safe2update == 0 AND $drupalid_danger 			== 1) {
					wachthond($extdebug, 1, '<pre>WARNING: SKIPPED UPDATE WANT CONNECTED CMS ID ($connected_drupal_id) != EXTERNAL IDENTIFIER ($cmsidentitier)</pre>');
				}
			}

			##########################################################################################################################################
			wachthond($extdebug, 1, '<pre>###### H) REPAIR DRUPAL ACCOUNT & UF_MATCH [IF DRUPALÀCCOUNT     FOUND ($drupalaccount_found) AND UFMATCH NOT FOUND ($drupalufmatch_found)</pre>');	
			##########################################################################################################################################
			if ($drupalaccount_found == 1 AND $drupalufmatch_found == 0) {
			##########################################################################################################################################

				if ($drupalaccount_orphan_same_name == 1 AND $drupalaccount_orphan_same_mail == 1) {

					#####################################################################################################
					# CREATE NEW UF MATCH WITH NEWLY CREATED DRUPAL USER (M61: match ook met evt verkeerd dubbeld gevonden uid!!!)
					#####################################################################################################

					$params_ufmatchcreate = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
 						'values' => [
							'uf_id'			=> $drupal_uid,
      						'uf_name'		=> $user_email,	
      						'contact_id'	=> $contact_id,
      						'domain_id'		=> 1,
  						],
					];

					wachthond($extdebug, 3, '<pre>params_ufmatchcreate: $params_ufmatchcreate</pre>');
      				$result_ufmatchcreate = civicrm_api4('UFMatch', 'create', $params_ufmatchcreate);
    				wachthond($extdebug, 4, '<pre>result_ufmatchcreate: $result_ufmatchcreate</pre>');

					// CHECK IF A CURRENT UF MATCH IS NOW PRESENT
					$params_ufmatchget = [
  						'checkPermissions' => FALSE,
						'debug' => $apidebug,
  						'select' => [
    						'id', 
    						'uf_id', 
   							'contact_id',
  						],
  						'where' => [
    						['contact_id', '=', $contact_id],
  						],
					];
					wachthond($extdebug, 3, '<pre>params_ufmatchget: $params_ufmatchget</pre>');
      				$result_ufmatchget = civicrm_api4('UFMatch', 'get', $params_ufmatchget);
      				if ($result !== false) {
      					$ufmatch_id 	= $result_ufmatchget[0]['id'];
    					$ufmatch_ufid 	= $result_ufmatchget[0]['uf_id'];
   					}

		    		if ($ufmatch_ufid) {
	    				wachthond($extdebug, 1, '<pre>------ h) PRIMA  : GOEDE UF MATCH GEVONDEN: $user_name | drupalid: $ufmatch_ufid</pre>');
    					$drupalufmatch_found = 1;
    					if ($drupal_uid == $ufmatch_ufid) {
				    		$params_contact['values']['external_identifier'] = $drupal_uid;
				    	}
    				} else {
	    				wachthond($extdebug, 1, '<pre>------ h) ERROR  : GEEN UF MATCH GEVONDEN VOOR CONTACT_ID: $contact_id</pre>');
    					$drupalufmatch_found = 0;
    				}
				}
			}

			#####################################################################################################
			if ($drupalufmatchother_found 	== 1) { $drupal_uid = NULL; }
			if ($drupalaccount_nameconflict	== 1) { $drupal_uid = NULL; }
			#####################################################################################################
		}
	}
	#####################################################################################################
	# 1.11 BEPAAL ENTITY ID - GEEN IDEE MEER WAAROM (LET OP) 
