    			$event_hoofdleiding2_image_bn  = basename($event_hoofdleiding2_image);
    			$event_hoofdleiding2_image_bn  = str_replace("imagefile?photo=", "", $event_hoofdleiding2_image_bn);
    			$event_hoofdleiding2_phone 	   = $result2[0]['phone'];
    			$event_hoofdleiding2_dontphone = $result2[0]['contact_id.do_not_phone'];
				wachthond($extdebug, 2, '<pre>hoofdleiding2_displname: $event_hoofdleiding2_displname</pre>');
    		} else {
    			$event_hoofdleiding2_displname = "";
    			$event_hoofdleiding2_firstname = "";
    			$event_hoofdleiding2_image 	   = "";
    			$event_hoofdleiding2_phone 	   = "";
    			$event_hoofdleiding2_dontphone = "";
    		}
    		#####################################################################################################
    		// HOOFDLEIDING 3
    		#####################################################################################################
    		$params_contact_hl3 = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,				
  				'select' => [
    				'display_name', 'first_name', 'image_URL',
  				],
  				'where' => [
    				['id', 'IN', [$event_hoofdleiding3_id ]],
  				],
			];
			$params_phone = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,				
  				'select' => [
    				'phone', 'contact_id.do_not_phone',
  				],
  				'where' => [
    				['contact_id', 		 'IN', [$event_hoofdleiding3_id]],
    				['location_type_id', '=', 1],
  				],
			];
			$result1 = civicrm_api4('Contact', 'get', $params_contact_hl3);
			$result2 = civicrm_api4('Phone', 'get', $params_phone);
			wachthond($extdebug, 4, '<pre>results_contact: $result</pre>');
 	 		if (isset($event_hoofdleiding3_id))	{
    			$event_hoofdleiding3_displname = $result1[0]['display_name'];
    			$event_hoofdleiding3_firstname = $result1[0]['first_name'];
    			$event_hoofdleiding3_image 	   = $result1[0]['image_URL'];
    			$event_hoofdleiding3_image_bn  = basename($event_hoofdleiding3_image);
    			$event_hoofdleiding3_image_bn  = str_replace("imagefile?photo=", "", $event_hoofdleiding3_image_bn);
    			$event_hoofdleiding3_phone 	   = $result2[0]['phone'];
    			$event_hoofdleiding3_dontphone = $result2[0]['contact_id.do_not_phone'];
    			wachthond($extdebug, 2, '<pre>hoofdleiding3_displname: $event_hoofdleiding3_displname</pre>');
    		} else {
    			$event_hoofdleiding3_displname = "";
    			$event_hoofdleiding3_firstname = "";
    			$event_hoofdleiding3_image 	   = "";
    			$event_hoofdleiding3_phone 	   = "";
    			$event_hoofdleiding3_dontphone = "";
    		}

    		#####################################################################################################
    		// BEPAAL WELKKAMPLANG EN WEEKNUMMER VOOR KKBKTKJK & TOP
    		#####################################################################################################
			$welkkamplang = $event_type_label;
			$welkkampkort = $event_kamp_kort;
			if ($event_kamp_kort 	== 'TOP') 			{ $welkkamplang = "$welkkamplang"." "."$event_kampjaar"; }
			if ($part_welkkampleid 	== 'bestuurstaken') { $welkkamplang = "bestuurstaken"; }

			# BEPAAL WELKE WEEK ADHV DE AFKORTING VAN HET KAMP
			$welkeweeknr  = substr($event_kamp_kort, -1);
			if (!in_array($welkeweeknr, array("1", "2"))) {	$welkeweeknr = "";}

			wachthond($extdebug, 2, '<pre>welkkampkort: $welkkampkort</pre>');
			wachthond($extdebug, 2, '<pre>welkkamplang: $welkkamplang</pre>');
			wachthond($extdebug, 2, '<pre>welkeweeknr: $welkeweeknr</pre>');
		}
	}

	wachthond($extdebug, 1, '<pre>### 2.1 BEPAAL NIEUWE NETTO CV DEEL & LEID (& EERSTE + LAATSTE) [groupID: $groupID] ###</pre>');   

		#####################################################################################################
   		if ($extcv == 1 AND in_array($groupID, array("225", "139", "190"))) {	// PART DEEL + PART LEID
		#####################################################################################################

 			#############################################################################################################
			# 2.1 BEPAAL NIEUWE NETTO CV DEEL & LEID (& EERSTE + LAATSTE)
    		wachthond($extdebug, 1, '<pre>### 2.1 BEPAAL NIEUWE NETTO CV DEEL & LEID (& EERSTE + LAATSTE) [groupID: $groupID] ###</pre>');   			
 			#############################################################################################################
			# 2.1a bereken x geannuleerd als deelnemer obv geannuleerde event registraties
    		wachthond($extdebug, 1, '<pre>### 2.1a bereken x geannuleerd als deelnemer obv geannuleerde event registraties [groupID: $groupID] ###</pre>');
			######	DEEL  ###############################################################################################
			# poging om totaal aantal keren mee als deelnemer te berekenen obv GEANNULEERDE event registraties
			#############################################################################################################
			$cancv_deel_array = [];
			$params_part_deel_canceled = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesdeel],
    				['status_id', 'IN', [4]], 		 // gebruik GEANNULEERDE event registraties
    				['is_test', 'IN', [TRUE, FALSE]], 
    				['contact_id', '=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
				'debug' => $apidebug,  				
			];
			wachthond($extdebug, 3, '<pre>params_part_deel_canceled: $params_part_deel_canceled</pre>');
			$part_deel_canceled = civicrm_api4('Participant', 'get', $params_part_deel_canceled);
			wachthond($extdebug, 4, '<pre>result_part_deel_canceled: $part_deel_canceled</pre>');
			foreach ($part_deel_canceled as $participant_deel_canceled) {
				$line_deel_canceled = $participant_deel_canceled['event_id.start_date'];
				#wachthond($extdebug, 2, '<pre>line_deel_canceled: $line_deel_canceled</pre>');
				$cancv_deel_array[] = date('Y', strtotime($line_deel_canceled));
				#wachthond($extdebug, 2, '<pre>participant_deel_canceled: $participant_deel_canceled</pre>');
			}
 			if ($cancv_deel_array) 	{
 				arsort($cancv_deel_array);
 				$cancv_deel = implode('', $cancv_deel_array);
 				wachthond($extdebug, 2, '<pre>evtcv_deel_canceled_array: $cancv_deel_array</pre>');
 			} else {
 				$cancv_deel_array 	= [];
 				$cancv_deel 		= NULL;
 			}
 			#############################################################################################################
			# 2.1b bereken x mee als deelnemer obv event registraties
    		wachthond($extdebug, 1, '<pre>### 2.1b bereken x mee als deelnemer obv event registraties [groupID: $groupID] ###</pre>');
			######	DEEL  ###############################################################################################
   			# poging om totaal aantal keren mee als deelnemer te berekenen obv event registraties
   			#############################################################################################################

			$params_part_deel = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesdeel],
    				['status_id', 'IN', [1, 2, 5, 6, 15]], 
    				['is_test', 'IN', [TRUE, FALSE]], 
    				['contact_id', '=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];
			wachthond($extdebug, 3, '<pre>params_part_deel: $params_part_deel</pre>');
			$part_deel = civicrm_api4('Participant', 'get', $params_part_deel);
			wachthond($extdebug, 4, '<pre>result_part_deel: $part_deel</pre>');

			foreach ($part_deel as $participant_deel) {
				$line_deel = $participant_deel['event_id.start_date'];
				#wachthond($extdebug, 2, '<pre>line_deel: $line_deel</pre>');
				$evtcv_deel_array[] = date('Y', strtotime($line_deel));
				#wachthond($extdebug, 2, '<pre>participant_deel: $participant_deel</pre>');
			}

 			if ($curcv_deel_array) {
 				arsort($curcv_deel_array); // M61 not sure if this sort works 	
 				$curcv_deel 		= implode('', $curcv_deel_array);
 			} else {
 				$curcv_deel_array 	= [];
 				$curcv_deel 		= NULL;
 			}
 			if ($evtcv_deel_array) {
   				arsort($evtcv_deel_array);
				$evtcv_deel 		= implode('', $evtcv_deel_array);
 			} else {
				$evtcv_deel_array 	= [];
 				$evtcv_deel 		= NULL;
 			}
 			if ($tagcv_deel_array) {
 				arsort($tagcv_deel_array);
 				$tagcv_deel 		= implode('', $tagcv_deel_array);
 			} else {
				$tagcv_deel_array 	= [];
 				$tagcv_deel 		= NULL;
 			}

 			#############################################################################################################
			# 2.1c bereken x mee als deelnemer topkamp obv event registraties
    		wachthond($extdebug, 1, '<pre>### 2.1c bereken x mee als deelnemer topkamp obv event registraties [groupID: $groupID] ###</pre>');
			######	DEEL  ###############################################################################################
   			# poging om totaal aantal keren mee als deelnemer te berekenen obv event registraties
   			#############################################################################################################

			$params_part_deel_top = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesdeeltop],
    				['status_id', 'IN', [1, 2, 5, 6, 15]], 
    				['is_test', 'IN', [TRUE, FALSE]], 
    				['contact_id', '=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];
			wachthond($extdebug, 3, '<pre>params_part_deel_top: $params_part_deel_top</pre>');
			$part_deel_top = civicrm_api4('Participant', 'get', $params_part_deel_top);
			wachthond($extdebug, 4, '<pre>result_part_deel_top: $part_deel_top</pre>');

			foreach ($part_deel_top as $participant_deel_top) {
				$line_deel_top = $participant_deel_top['event_id.start_date'];
				#wachthond($extdebug, 2, '<pre>line_deel_top: $line_deel_top</pre>');
				$evtcv_deel_top_array[] = date('Y', strtotime($line_deel_top));
				#wachthond($extdebug, 2, '<pre>participant_deel_top: $participant_deel_top</pre>');
			}
 			if ($curcv_deel_top_array) {
 				arsort($curcv_deel_top_array); // M61 not sure if this sort works 	
 				$curcv_deel_top 	= implode('', $curcv_deel_top_array);
 			} else {
 				$curcv_deel_top_array 	= [];
 				$curcv_deel_top 		= NULL;
 			}
   			#############################################################################################################

   			#############################################################################################################
   			# 2.1d RETREIVE TAGS (DEEL & LEID)
    		wachthond($extdebug, 1, '<pre>### 2.1d SYNCRONISE TAGS WITH CV WHEN CV IS EMPTY [groupID: $groupID] ###</pre>');
   			#############################################################################################################
   			if ($exttag == 1) {

				$params_tags_deel = [
  				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'select' => [
    					'tag.id', 
    					'row_count', 
	    				'tag.name', 
    					'tag.description', 
    					'tag.parent_id:label',
  					],
	  				'join' => [
		    			['Tag AS tag', TRUE, 'EntityTag'],
  					],
  					'where' => [
    					['id', '=', $contact_id], 
    					['tag.parent_id', '=', 37], 
	    				['tag.name', 'LIKE', 'D%'],
  					],
				];

				wachthond($extdebug, 3, '<pre>params_tags_deel: $params_tags_deel</pre>');
				$result_deel = civicrm_api4('Contact', 'get', $params_tags_deel);
				wachthond($extdebug, 3, '<pre>result_tags_deel: $result_deel</pre>');
				$tagnr_deel 		= $result_deel->count();
				$tagcv_deel_array	= $result_deel->column('tag.description');  // maakt een array met alleen de velden voor id
	   			$tagcv_deel_array 	= array_unique($tagcv_deel_array);
   				asort($tagcv_deel_array);
	   			$tagcv_deel 		= implode('', $tagcv_deel_array);	
				#if ($tagcv_deel == '') {$tagcv_deel = NULL; }

				wachthond($extdebug, 3, '<pre>tagcv_deel_array: $tagcv_deel_array</pre>');
				wachthond($extdebug, 2, '<pre>tagnr_deel    : $tagnr_deel</pre>');
				wachthond($extdebug, 2, '<pre>tagcv_deel    : $tagcv_deel</pre>');

				$params_tags_leid = [
  				'checkPermissions' => FALSE,
				'debug' => $apidebug,
	  				'select' => [
    					'tag.id', 
    					'row_count', 
    					'tag.name', 
    					'tag.description', 
	    				'tag.parent_id:label',
  					],
  					'join' => [
	    				['Tag AS tag', TRUE, 'EntityTag'],
	  				],
  					'where' => [
    					['id', '=', $contact_id], 
    					['tag.parent_id', '=', 27], 
    					['tag.name', 'LIKE', 'L%'],
	  				],
				];

				wachthond($extdebug, 3, '<pre>params_tags_leid: $params_tags_leid</pre>');
				$result_leid = civicrm_api4('Contact', 'get', $params_tags_leid);
				wachthond($extdebug, 3, '<pre>result_tags_leid: $result_leid</pre>');
				$tagnr_leid 		= $result_leid->count();
				$tagcv_leid_array	= $result_leid->column('tag.description');  // maakt een array met alleen de velden voor id
	   			$tagcv_leid_array 	= array_unique($tagcv_leid_array);
   				asort($tagcv_leid_array);
   				$tagcv_leid 		= implode('', $tagcv_leid_array);	
				#if ($tagcv_leid == '') {$tagcv_leid = NULL; }

				wachthond($extdebug, 3, '<pre>tagcv_leid_array: $tagcv_leid_array</pre>');
				wachthond($extdebug, 2, '<pre>tagnr_leid    : $tagnr_leid</pre>');
				wachthond($extdebug, 2, '<pre>tagcv_leid    : $tagcv_leid</pre>');
    		}

   			#############################################################################################################
   			#############################################################################################################
 			// MAKE SURE EVEN EMPTY ARRAYS ARE ARRAYS
			if (empty($oldcv_deel_array))	{ $oldcv_deel_array = []; }
			if (empty($curcv_deel_array))	{ $curcv_deel_array = []; }
			if (empty($evtcv_deel_array))	{ $evtcv_deel_array = []; }
			if (empty($tagcv_deel_array))	{ $tagcv_deel_array = []; }

			// M61: bij deelnemers geboren na 2007-08-1 is de event_cv de juiste en kan de max_cv overschrijven
			if ($birth_date > "2007-08-1") {
				wachthond($extdebug, 2, '<pre>Birthdate >2007: $birth_date</pre>');
/*
				wachthond($extdebug, 2, '<pre>UPDATE DEEL CV 3 want birth_date $birth_dateis bigger than 2006-08-01 en deze deelnemer kan alleen civicrm hebben gebruik voor registratie:  $evtcv_deel</pre>');
*/				
				$maxcv_deel_array = $evtcv_deel_array;
			} else {
				wachthond($extdebug, 2, '<pre>Birthdate <2007: $birth_date</pre>');
				$maxcv_deel_array 	= array_merge($oldcv_deel_array, $curcv_deel_array, $evtcv_deel_array, $tagcv_deel_array);
//				$maxcv_deel_array 	= array_merge($curcv_deel_array, $evtcv_deel_array, $tagcv_deel_array);
//				$maxcv_deel_array 	= array_merge($curcv_deel_array, $evtcv_deel_array);
			}

			$topcv_deel_array 	= $evtcv_deel_top_array;
   			$oldcv_deel_array 	= array_unique($oldcv_deel_array);
   			$maxcv_deel_array 	= array_unique($maxcv_deel_array);
   			$topcv_deel_array 	= array_unique($topcv_deel_array);

 			#wachthond($extdebug, 2, '<pre>oldcv_deel_0_array: $oldcv_deel_array</pre>');
 			#wachthond($extdebug, 2, '<pre>curcv_deel_0_array: $curcv_deel_array</pre>');
 			#wachthond($extdebug, 2, '<pre>evtcv_deel_0_array: $evtcv_deel_array</pre>');
			#wachthond($extdebug, 2, '<pre>tagcv_deel_0_array: $tagcv_deel_array</pre>');
   			#wachthond($extdebug, 2, '<pre>maxcv_deel_0_array: $maxcv_deel_array</pre>');

 			#wachthond($extdebug, 2, '<pre>curcv_deel_top_0_array: $curcv_deel_top_array</pre>');
 			#wachthond($extdebug, 2, '<pre>evtcv_deel_top_0_array: $evtcv_deel_top_array</pre>');
			#wachthond($extdebug, 2, '<pre>tagcv_deel_top_0_array: $tagcv_deel_top_array</pre>');
   			#wachthond($extdebug, 2, '<pre>maxcv_deel_top_0_array: $topcv_deel_array</pre>');

			// SORTEER DE ARRAYS

			$avoid_year_array = array(1970,1971,1972,1973,1974,1975,1976,1977,1978);

			$oldcv_deel_array = array_diff($oldcv_deel_array, $avoid_year_array);
   			$oldcv_deel_array = array_unique($oldcv_deel_array);
   			asort($oldcv_deel_array);
   			$oldcv_deel = implode('', $oldcv_deel_array);
   			$oldcv_deel	= ''.$oldcv_deel.'';

			$curcv_deel_array = array_diff($curcv_deel_array, $avoid_year_array);
   			$curcv_deel_array = array_unique($curcv_deel_array);
   			asort($curcv_deel_array);
   			$curcv_deel = implode('', $curcv_deel_array);
   			$curcv_deel	= ''.$curcv_deel.'';

			$evtcv_deel_array = array_diff($evtcv_deel_array, $avoid_year_array);
			$evtcv_deel_array = array_diff($evtcv_deel_array, array($nonpossiblekampjaren));
   			$evtcv_deel_array = array_unique($evtcv_deel_array);
   			asort($evtcv_deel_array);
   			$evtcv_deel = implode('', $evtcv_deel_array);	
   			$evtcv_deel	= ''.$evtcv_deel.'';

			$maxcv_deel_array = array_diff($maxcv_deel_array, $avoid_year_array);
   			$maxcv_deel_array = array_unique($maxcv_deel_array);
   			asort($maxcv_deel_array);
   			$maxcv_deel = implode('', $maxcv_deel_array);
   			$maxcv_deel	= ''.$maxcv_deel.'';					// ZORG (VOOR CHECKBOX) DAT DE SEPERATOR OOK VOOR & ACHTERAAN STAAT

			$topcv_deel_array = array_diff($topcv_deel_array, $avoid_year_array);
   			$topcv_deel_array = array_unique($topcv_deel_array);
   			asort($topcv_deel_array);
   			$maxcv_deel_top = implode('', $topcv_deel_array);
   			$maxcv_deel_top	= ''.$maxcv_deel_top.'';			// ZORG (VOOR CHECKBOX) DAT DE SEPERATOR OOK VOOR & ACHTERAAN STAAT   			
			// BEPAAL OF HET HUIDIGE JAAR ER JUIST EXTRA BIJ MOET OF AF MOET
			if ($diteventdeelyes == 1) {
				array_push($maxcv_deel_array, $event_kampjaar);
				wachthond($extdebug, 2, '<pre>maxcv_deel (+ $event_kampjaar] want dit event telt ook mee): $maxcv_deel</pre>');
				// VOEG HUIDIG EVENTJAAR TOE AAN ARRAY INDIEN HET ER NOG NIET INZAT
			} elseif ($diteventdeelmss == 1 OR $diteventdeelnot == 1 AND $event_kampjaar) {
				$maxcv_deel_array = array_diff($maxcv_deel_array, array($event_kampjaar));
				$evtcv_deel_array = array_diff($evtcv_deel_array, array($event_kampjaar)); // gevaarlijk maar terecht als er dit jaar geen deelname is. Misschien  nog een IF voor part_status is geannulleerd
				wachthond($extdebug, 2, '<pre>maxcv_deel (- $event_kampjaar] want dit event telt niet mee): $maxcv_deel</pre>');
				// VERWIJDER HUIDIG EVENTJAAR UIT ARRAY INDIEN HET ER INZAT
			}
  			
			// PREVENT EMPTY VALUES THAT ARE NOT ACCEPTED
			if ($oldcv_deel == '') 	{ $oldcv_deel = NULL; }
			if ($evtcv_deel == '') 	{ $evtcv_deel = NULL; }
			if ($tagcv_deel == '') 	{ $tagcv_deel = NULL; }
			if ($maxcv_deel == '') 	{ $maxcv_deel = NULL; }
			if (empty($oldcv_deel)) { $oldcv_deel = NULL; }
			if (empty($evtcv_deel)) { $evtcv_deel = NULL; }
			if (empty($tagcv_deel)) { $tagcv_deel = NULL; }
			if (empty($maxcv_deel)) { $maxcv_deel = NULL; }

			$oldcv_deel_nr 	= count(array_filter($oldcv_deel_array));
			$curcv_deel_nr 	= count(array_filter($curcv_deel_array));
			$evtcv_deel_nr	= count(array_filter($evtcv_deel_array));
			$tagcv_deel_nr	= count(array_filter($tagcv_deel_array));
			$maxcv_deel_nr	= count(array_filter($maxcv_deel_array));
			$deel_nr_diff  	= abs($maxcv_deel_nr - $curcv_deel_nr);

 			wachthond($extdebug, 3, '<pre>avoid_year_array: $avoid_year_array</pre>');
 			wachthond($extdebug, 3, '<pre>oldcv_deel_array: $oldcv_deel_array</pre>');
 			wachthond($extdebug, 3, '<pre>curcv_deel_array: $curcv_deel_array</pre>');
 			wachthond($extdebug, 3, '<pre>evtcv_deel_array: $evtcv_deel_array</pre>');
			wachthond($extdebug, 3, '<pre>tagcv_deel_array: $tagcv_deel_array</pre>');
   			wachthond($extdebug, 3, '<pre>maxcv_deel_array: $maxcv_deel_array</pre>');

			wachthond($extdebug, 1, '<pre>oldcv_deel     : $oldcv_deel</pre>');
			wachthond($extdebug, 1, '<pre>curcv_deel     : $curcv_deel</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_deel     : $evtcv_deel</pre>');
			wachthond($extdebug, 1, '<pre>cancv_deel     : $cancv_deel</pre>');
			wachthond($extdebug, 1, '<pre>tagcv_deel     : $tagcv_deel</pre>');
			wachthond($extdebug, 1, '<pre>maxcv_deel     : $maxcv_deel</pre>');

			wachthond($extdebug, 1, '<pre>oldcv_deel_nr  : $oldcv_deel_nr</pre>');
			wachthond($extdebug, 1, '<pre>curcv_deel_nr  : $curcv_deel_nr</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_deel_nr  : $evtcv_deel_nr</pre>');
			wachthond($extdebug, 1, '<pre>tagcv_deel_nr  : $tagcv_deel_nr</pre>');
			wachthond($extdebug, 1, '<pre>maxcv_deel_nr  : $maxcv_deel_nr</pre>');
			wachthond($extdebug, 1, '<pre>deel_nr_diff   : $deel_nr_diff</pre>');

			$eerstedeel  = min(array_filter($maxcv_deel_array));
			wachthond($extdebug, 1, '<pre>eerstedeel     : $eerstedeel</pre>');			
   			// M61: #1 GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALLEEN ALS ER BIJKOMT, VERMINDER ALLEEN ALS DE NIEUWE WAARDE SLECHTS 1 JAAR AFWIJKT   			
			if (($maxcv_deel_nr > $curcv_deel_nr) OR ($maxcv_deel_nr < $curcv_deel_nr AND $deel_nr_diff == 1)) {
				wachthond($extdebug, 2, '<pre>UPDATE DEEL CV 1 want maxcv_deel_nr: $maxcv_deel_nrdiffers with [$deel_nr_diff] from curcv_deel_nr: $curcv_deel_nr</pre>');
				if ($maxcv_deel_nr == 0) { $maxcv_deel = NULL; } // gevaarlijk maar wel terecht hier ingebed
				$welkedeel 		= $maxcv_deel;
			} else {
				$welkedeel 		= $curcv_deel;
				wachthond($extdebug, 2, '<pre>CANCEL UPDATE van DEEL CV want zou omlaag gaan met slechts $deel_nr_diff t.o.v. curcv_deel_nr: $curcv_deel_nr</pre>');			
			}		

/*
			// M61: #2 GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALS DIT JAAR MEE + DIFF = 1 EN (TODO) EEN OF ANDERE STAFFEL
			if ($evtcv_deel_nr < $curcv_deel_nr AND $ditjaardeelyes == 1 AND $evtcv_deel_nr < 5 AND $curcv_deel_nr < 6 AND $maxcv_deel_nr < 7 AND $deel_nr_diff <= 1 AND $eerstedeel > 2015) {
				wachthond($extdebug, 2, '<pre>UPDATE DEEL CV 2 want evtcv_deel_nr: $evtcv_deel_nrdiffers with [$deel_nr_diff] from curcv_deel_nr: $curcv_deel_nr</pre>');	
				if ($maxcv_deel_nr == 0) { $maxcv_deel = NULL; } // gevaarlijk maar wel terecht hier ingebed (M61: TODO: klopt dit?)
				$welkedeel 		= $evtcv_deel;
			}

			// M61: #3 GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALS DIT JAAR MEE + DIFF = 1 EN EERSTE KEER MEE > 2015
			if ($evtcv_deel_nr == 1 AND $ditjaardeelyes == 1 AND $deel_nr_diff = 1 AND $eerstedeel > 2015) {
				wachthond($extdebug, 2, '<pre>UPDATE DEEL CV 3 want evtcv_deel_nr: $evtcv_deel_nrdiffers with [$deel_nr_diff] from curcv_deel_nr: $curcv_deel_nr</pre>');	
				if ($maxcv_deel_nr == 0) {
					$maxcv_deel = NULL;		// gevaarlijk maar wel terecht hier ingebed
				}
				$welkedeel 		= $evtcv_deel;
			}
*/
			// M61: bij deelnemers geboren na 2007-08-1 is de event_cv de juiste en kan de max_cv overschrijven
			if ($birth_date > "2007-08-1") {
				wachthond($extdebug, 2, '<pre>Birthdate >2007: $birth_date (event_cv is leidend)</pre>');
				$welkedeel 		= $evtcv_deel;
			} else {
				wachthond($extdebug, 2, '<pre>Birthdate <2007: $birth_date (event_cv niet leidend)</pre>');
			}

			// M61: tbv checks
			wachthond($extdebug, 1, '<pre>welkedeel      : $welkedeel</pre>');

 			#############################################################################################################
			# 2.1e bereken x mee als kampstaf obv event registraties
    		wachthond($extdebug, 1, '<pre>### 2.1e bereken x mee als kampstaf obv event registraties [groupID: $groupID] ###</pre>');
			######	MEET  ###############################################################################################
			# poging om array te maken van geregistreerde events meeting kampstaf voor leiding
			#############################################################################################################

			$params_part_meet = [
  				'select' => [
    				'event_id',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesmeet],
    				['event_id.start_date',	   '>',  $today_fiscalyear_start],
    				['contact_id', 		 	   '=',  $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];
			wachthond($extdebug, 3, '<pre>params_part_meet: $params_part_meet</pre>');
			$result_meet = civicrm_api4('Participant', 'get', $params_part_meet);
			wachthond($extdebug, 4, '<pre>result_meet: $result_meet</pre>');

			$meetcount 			= $result_meet->count();
			$evtcv_meet_array	= $result_meet->column('event_id');  // maakt een array met alleen de velden voor id
			asort($evtcv_meet_array); // sort by value

			wachthond($extdebug, 3, '<pre>meetcount: $meetcount</pre>');
			wachthond($extdebug, 2, '<pre>evtcv_meet_array: $evtcv_meet_array</pre>');

 			#############################################################################################################
			# 2.1f bereken x geannuleerd als leiding obv geannuleerde event registraties
    		wachthond($extdebug, 1, '<pre>### 2.1f bereken x geannuleerd als leiding obv geannuleerde event registraties [groupID: $groupID] ###</pre>');
			######	LEID  ###############################################################################################
			# poging om totaal aantal keren mee als leiding te berekenen obv GEANNULEERDE event registraties
			#############################################################################################################
			$cancv_leid_array = [];
			$params_part_leid_canceled = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesleid],
    				['status_id', 	'IN', [4]], 		 // gebruik GEANNULEERDE event registraties
    				['is_test', 	'IN', [TRUE, FALSE]], 
    				['contact_id', 	'=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];			
			wachthond($extdebug, 3, '<pre>params_part_leid_canceled: $params_part_leid_canceled</pre>');
			$part_leid_canceled = civicrm_api4('Participant', 'get', $params_part_leid_canceled);
			wachthond($extdebug, 4, '<pre>result_part_leid_canceled: $part_leid_canceled</pre>');
			foreach ($part_leid_canceled as $participant_leid_canceled) {
				$line_leid_canceled = $participant_leid_canceled['event_id.start_date'];
				wachthond($extdebug, 5, '<pre>line_leid_canceled: $line_leid_canceled</pre>');
				$cancv_leid_array[] = date('Y', strtotime($line_leid_canceled));
				wachthond($extdebug, 5, '<pre>participant_leid_canceled: $participant_leid_canceled</pre>');
			}
 			if ($cancv_leid_array) 	{
 				arsort($cancv_leid_array);
 				$cancv_leid = implode('', $cancv_leid_array);
 				wachthond($extdebug, 2, '<pre>cancv_leid_array: $cancv_leid_array</pre>');
 			} else {
 				$cancv_leid_array 	= [];
 				$cancv_leid 		= NULL;
 			}
			######	LEID  ###############################################################################################
			# poging om totaal aantal keren mee als leiding te berekenen obv event registraties met als functie kampstaf
			#############################################################################################################
			$evtcv_staf_array = [];
			$params_part_leid_stafjaar = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesleid],
    				['PART_LEID.Functie', 'IN', ['bestuurslid', 'kampstaf']],
    				['status_id', 	'IN', [1, 2, 5, 6, 15]], 
    				['is_test', 	'IN', [TRUE, FALSE]], 
    				['contact_id', 	'=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];			
			wachthond($extdebug, 3, '<pre>params_part_leid_stafjaar: $params_part_leid_stafjaar</pre>');
			$part_leid_stafjaar = civicrm_api4('Participant', 'get', $params_part_leid_stafjaar);
			wachthond($extdebug, 4, '<pre>result_part_leid_stafjaar: $part_leid_stafjaar</pre>');
			foreach ($part_leid_stafjaar as $participant_leid_stafjaar) {
				$line_leid_stafjaar = $participant_leid_stafjaar['event_id.start_date'];
				wachthond($extdebug, 5, '<pre>line_leid_stafjaar: $line_leid_stafjaar</pre>');
				$evtcv_staf_array[] = date('Y', strtotime($line_leid_stafjaar));
				wachthond($extdebug, 5, '<pre>participant_leid_stafjaar: $participant_leid_stafjaar</pre>');
			}
 			if ($evtcv_staf_array) 	{
 				arsort($evtcv_staf_array);
 				$evtcv_staf = implode('', $evtcv_staf_array);
 				wachthond($extdebug, 2, '<pre>evtcv_staf_array: $evtcv_staf_array</pre>');
 			} else {
 				$evtcv_staf_array 	= [];
 				$evtcv_staf 		= NULL;
 			} 			
 			#############################################################################################################
			# 2.1g bereken x mee als leiding obv event registraties
    		wachthond($extdebug, 1, '<pre>### 2.1g bereken x mee als leiding obv event registraties [groupID: $groupID] ###</pre>');
			######	LEID  ###############################################################################################
			# poging om totaal aantal keren mee als leiding te berekenen obv event registraties
			#############################################################################################################
			$params_part_leid = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id',  'IN', $eventypesleid],
    				['status_id', 	'IN', [1, 2, 5, 6, 15]],
    				['is_test', 	'IN', [TRUE, FALSE]],
    				['contact_id', 	'=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];			
			wachthond($extdebug, 3, '<pre>params_part_leid: $params_part_leid</pre>');
			$part_leid = civicrm_api4('Participant', 'get', $params_part_leid);
			wachthond($extdebug, 4, '<pre>result_part_leid: $part_leid</pre>');
			foreach ($part_leid as $participant_leid) {
				$line_leid = $participant_leid['event_id.start_date'];
				wachthond($extdebug, 5, '<pre>line_leid: $line_leid</pre>');
				$evtcv_leid_array[] = date('Y', strtotime($line_leid));
				wachthond($extdebug, 5, '<pre>participant_leid: $participant_leid</pre>');
			}
			wachthond($extdebug, 2, '<pre>evtcv_leid_array                 : $evtcv_leid_array</pre>');
			#############################################################################################################			
			### VERMINDER DE LEIDING ARRAY MET DE JAREN ALS STAF (NIET FYSIEK MEE, WEL ACTIEF ALS STAF) 
			$evtcv_leid_array = array_diff($evtcv_leid_array, $evtcv_staf_array);
			#wachthond($extdebug, 2, '<pre>evtcv_leid_array (minus stafjaren): $evtcv_leid_array</pre>');
			#############################################################################################################

 			if ($oldcv_leid_array)	{
 				arsort($oldcv_leid_array); // M61 not sure if this sort works 	
 				$oldcv_leid 		= implode('', $oldcv_leid_array);
 			} else {
 				$oldcv_leid_array 	= [];
 				$oldcv_leid 		= NULL;
 			}
 			if ($curcv_leid_array)	{
 				arsort($curcv_leid_array); // M61 not sure if this sort works 	
 				$curcv_leid 		= implode('', $curcv_leid_array);
 			} else {
 				$curcv_leid_array 	= [];
 				$curcv_leid 		= NULL;
 			}
 			if ($evtcv_leid_array) 	{
 				arsort($evtcv_leid_array);
 				$evtcv_leid 		= implode('', $evtcv_leid_array);
 			} else {
 				$evtcv_leid_array 	= [];
 				$evtcv_leid 		= NULL;
 			}
 			if ($evtcv_staf_array) 	{
 				arsort($evtcv_staf_array);
 				$evtcv_staf 		= implode('', $evtcv_staf_array);
 			} else {
 				$evtcv_staf_array 	= [];
 				$evtcv_staf 		= NULL;
 			} 			
   			if ($tagcv_leid_array)	{
   				arsort($tagcv_leid_array);
   				$tagcv_leid 		= implode("", $tagcv_leid_array);
   			} else {
 				$tagcv_leid_array 	= [];
 				$tagcv_leid 		= NULL; 			
   			}
 
 			// MAKE SURE EVEN EMPTY ARRAYS ARE ARRAYS
			if (empty($oldcv_leid_array))	{ $oldcv_leid_array = []; }
			if (empty($curcv_leid_array))	{ $curcv_leid_array = []; }
			if (empty($evtcv_leid_array))	{ $evtcv_leid_array = []; }
			if (empty($evtcv_staf_array))	{ $evtcv_staf_array = []; }
			if (empty($evtcv_meet_array))	{ $evtcv_meet_array = []; }
			if (empty($tagcv_leid_array))	{ $tagcv_leid_array = []; }

			// M61: bij leiding met eerstejaar leid >=2013 is de event_cv de juiste en kan de max_cv overschrijven
			$maxcv_leid_array = array_merge($oldcv_leid_array, $curcv_leid_array, $evtcv_leid_array, $tagcv_leid_array);
			$eersteleid  = min(array_filter($maxcv_leid_array));
			if ($eersteleid >= 2013) {
				wachthond($extdebug, 2, '<pre>Eerste keer leiding >=2013: $eersteleid</pre>');
				$maxcv_leid_array = $evtcv_leid_array;
			} else {
				wachthond($extdebug, 2, '<pre>Eerste keer leiding <=2013: $eersteleid</pre>');
//				$maxcv_leid_array = array_merge($oldcv_leid_array, $curcv_leid_array, $evtcv_leid_array, $tagcv_leid_array);
				$maxcv_leid_array = array_merge($curcv_leid_array, $evtcv_leid_array, $tagcv_leid_array);
//				$maxcv_leid_array = array_merge($curcv_leid_array, $evtcv_leid_array);
			}

 			wachthond($extdebug, 3, '<pre>curcv_leid_0_array: $curcv_leid_array</pre>');
 			wachthond($extdebug, 3, '<pre>evtcv_leid_0_array: $evtcv_leid_array</pre>');
			wachthond($extdebug, 3, '<pre>tagcv_leid_0_array: $tagcv_leid_array</pre>');
   			wachthond($extdebug, 3, '<pre>maxcv_leid_0_array: $maxcv_leid_array</pre>');

			// BEPAAL OF HET HUIDIGE JAAR ER JUIST EXTRA BIJ MOET OF AF MOET
			if ($diteventleidyes == 1) {
				array_push($maxcv_leid_array, $event_kampjaar);
				wachthond($extdebug, 2, '<pre>maxcv_leid (+ $event_kampjaar] want dit event telt ook mee): $maxcv_leid</pre>');
				// VOEG HUIDIG EVENTJAAR TOE AAN ARRAY INDIEN HET ER NOG NIET INZAT
			} elseif ($diteventleidmss == 1 OR $diteventleidnot == 1) {
				$maxcv_leid_array = array_diff($maxcv_leid_array, array($event_kampjaar));
				$evtcv_leid_array = array_diff($evtcv_leid_array, array($event_kampjaar)); // gevaarlijk maar terecht als er dit jaar geen deelname is. Misschien hier nog een IF voor part_status is geannulleerd
				wachthond($extdebug, 2, '<pre>maxcv_leid (- $event_kampjaar] want dit event telt niet mee): $maxcv_leid</pre>');
				// VERWIJDER HUIDIG EVENTJAAR UIT ARRAY INDIEN HET ER INZAT
			}

			$avoid_year_array = array(1970,1971,1972,1973,1974,1975,1976,1977,1978);

			$oldcv_leid_array = array_diff($oldcv_leid_array, $avoid_year_array);
   			$oldcv_leid_array = array_unique($oldcv_leid_array);
   			asort($oldcv_leid_array);
   			$oldcv_leid = implode('', $oldcv_leid_array);
   			$oldcv_leid	= ''.$oldcv_leid.'';

			$curcv_leid_array = array_diff($curcv_leid_array, $avoid_year_array);
   			$curcv_leid_array = array_unique($curcv_leid_array);
   			asort($curcv_leid_array);
   			$curcv_leid = implode('', $curcv_leid_array);
   			$curcv_leid	= ''.$curcv_leid.'';

			$evtcv_leid_array = array_diff($evtcv_leid_array, $avoid_year_array);
   			$evtcv_leid_array = array_unique($evtcv_leid_array);
   			asort($evtcv_leid_array);
   			$evtcv_leid = implode('', $evtcv_leid_array);
   			$evtcv_leid	= ''.$evtcv_leid.'';

			$evtcv_staf_array = array_diff($evtcv_staf_array, $avoid_year_array);
			$evtcv_staf_array = array_unique($evtcv_staf_array);
			asort($evtcv_staf_array);
   			$evtcv_staf = implode('', $evtcv_staf_array);
   			$evtcv_staf	= ''.$evtcv_staf.'';   			

			$evtcv_meet_array = array_diff($evtcv_meet_array, $avoid_year_array);
   			$evtcv_meet_array = array_unique($evtcv_meet_array);
   			asort($evtcv_meet_array);
   			$evtcv_meet = implode('', $evtcv_meet_array);
   			$evtcv_meet	= ''.$evtcv_meet.'';

			$maxcv_leid_array = array_diff($maxcv_leid_array, $avoid_year_array);
   			$maxcv_leid_array = array_unique($maxcv_leid_array);
   			asort($maxcv_leid_array);
   			$maxcv_leid = implode('', $maxcv_leid_array);
   			$maxcv_leid	= ''.$maxcv_leid.'';

   			#wachthond($extdebug, 2, '<pre>maxcv_leid_array: $maxcv_leid_array</pre>');
			wachthond($extdebug, 2, '<pre>maxcv_leid      : $maxcv_leid</pre>');
   			
			// PREVENT EMPTY VALUES THAT ARE NOT ACCEPTED
			if ($oldcv_leid == '') 	{ $oldcv_leid = NULL; }
			if ($evtcv_leid == '') 	{ $evtcv_leid = NULL; }
			if ($evtcv_staf == '') 	{ $evtcv_staf = NULL; }
			if ($evtcv_meet == '') 	{ $evtcv_meet = NULL; }
			if ($tagcv_leid == '') 	{ $tagcv_leid = NULL; }
			if ($maxcv_leid == '') 	{ $maxcv_leid = NULL; }
			if (empty($oldcv_leid)) { $oldcv_leid = NULL; }
			if (empty($evtcv_leid)) { $evtcv_leid = NULL; }
			if (empty($evtcv_staf)) { $evtcv_staf = NULL; }
			if (empty($evtcv_meet)) { $evtcv_meet = NULL; }
			if (empty($tagcv_leid)) { $tagcv_leid = NULL; }
			if (empty($maxcv_leid)) { $maxcv_leid = NULL; }

			$oldcv_leid_nr 	= count(array_filter($oldcv_leid_array));
			$curcv_leid_nr 	= count(array_filter($curcv_leid_array));
			$evtcv_leid_nr	= count(array_filter($evtcv_leid_array));
			$evtcv_staf_nr	= count(array_filter($evtcv_staf_array));
			$evtcv_meet_nr	= count(array_filter($evtcv_meet_array));
			$tagcv_leid_nr	= count(array_filter($tagcv_leid_array));
			$maxcv_leid_nr	= count(array_filter($maxcv_leid_array));
			$leid_nr_diff  	= abs($maxcv_leid_nr - $curcv_leid_nr);

 			wachthond($extdebug, 3, '<pre>avoid_year_array: $avoid_year_array</pre>');
 			wachthond($extdebug, 3, '<pre>oldcv_leid_array: $oldcv_leid_array</pre>');
 			wachthond($extdebug, 3, '<pre>curcv_leid_array: $curcv_leid_array</pre>');
 			wachthond($extdebug, 3, '<pre>evtcv_leid_array: $evtcv_leid_array</pre>');
 			wachthond($extdebug, 3, '<pre>evtcv_staf_array: $evtcv_staf_array</pre>');
 			wachthond($extdebug, 3, '<pre>evtcv_meet_array: $evtcv_meet_array</pre>');
			wachthond($extdebug, 3, '<pre>tagcv_leid_array: $tagcv_leid_array</pre>');
   			wachthond($extdebug, 3, '<pre>maxcv_leid_array: $maxcv_leid_array</pre>');

			wachthond($extdebug, 1, '<pre>oldcv_leid      : $oldcv_leid</pre>');
			wachthond($extdebug, 1, '<pre>curcv_leid      : $curcv_leid</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_leid      : $evtcv_leid</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_staf      : $evtcv_staf</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_meet      : $evtcv_meet</pre>');
			wachthond($extdebug, 1, '<pre>cancv_leid      : $cancv_leid</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_staf      : $evtcv_staf</pre>');
			wachthond($extdebug, 1, '<pre>tagcv_leid      : $tagcv_leid</pre>');
			wachthond($extdebug, 1, '<pre>maxcv_leid      : $maxcv_leid</pre>');

			wachthond($extdebug, 1, '<pre>oldcv_leid_nr   : $oldcv_leid_nr</pre>');
			wachthond($extdebug, 1, '<pre>curcv_leid_nr   : $curcv_leid_nr</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_leid_nr   : $evtcv_leid_nr</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_staf_nr   : $evtcv_staf_nr</pre>');
			wachthond($extdebug, 1, '<pre>evtcv_meet_nr   : $evtcv_meet_nr</pre>');
			wachthond($extdebug, 1, '<pre>tagcv_leid_nr   : $tagcv_leid_nr</pre>');
			wachthond($extdebug, 1, '<pre>maxcv_leid_nr   : $maxcv_leid_nr</pre>');
			wachthond($extdebug, 1, '<pre>leid_nr_diff    : $leid_nr_diff</pre>');

   			// M61: GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALLEEN ALS ER BIJKOMT, VERMINDER ALLEEN ALS DE NIEUWE WAARDE SLECHTS 1 JAAR AFWIJKT			
			if (($maxcv_leid_nr > $curcv_leid_nr) OR ($maxcv_leid_nr < $curcv_leid_nr AND $leid_nr_diff == 1)) {
				wachthond($extdebug, 2, '<pre>UPDATE LEID CV want maxcv_leid_nr: $maxcv_leid_nrdiffers with [$leid_nr_diff] from curcv_leid_nr: $curcv_leid_nr</pre>');
				if ($maxcv_leid_nr == 0) { $maxcv_leid = NULL; } // gevaarlijk maar wel terecht hier ingebed
				$welkeleid 		= $maxcv_leid;
			} else {
				$welkeleid 		= $curcv_leid;
				wachthond($extdebug, 2, '<pre>CANCEL UPDATE LEID CV want zou omlaag gaan met meer dan 1 (nl: $leid_nr_diff) t.o.v. curcv_leid_nr: $curcv_leid_nr</pre>');					
			}

			// M61: bij leiding met eerstejaar leid >=2013 is de event_cv de juiste en kan de max_cv overschrijven
			$eersteleid  = min(array_filter($maxcv_leid_array));
			if ($eersteleid >= 2013) {
				wachthond($extdebug, 2, '<pre>Eerste keer leiding >=2013: $eersteleid</pre>');
				$welkeleid 		= $evtcv_leid;
			} else {
				wachthond($extdebug, 2, '<pre>Eerste keer leiding <=2013: $eersteleid</pre>');
			}

			#asort($welkeleid);
			wachthond($extdebug, 2, '<pre>welkeleid        : $welkeleid</pre>');

			// poging om totaal aantal keren mee als deelnemer van het Topkamp te berekenen obv event registraties
			$params_countpart_top = [
				'status_id'  	=> array("Registered", "Deelgenomen", "Pending from pay later", "Pending from incomplete transaction", "Partially paid"),
      			'role_id' 	 	=> "Deelnemer Topkamp",
      			'contact_id' 	=> $contact_id,
      			#'fee_amount' => ['>' => 1],
			];
			#wachthond($extdebug, 3, '<pre>params_countpart_deel: $params_countpart_deel</pre>');
			$kereneventtop = civicrm_api3('Participant', 'getcount', $params_countpart_top);
   			wachthond($extdebug, 1, '<pre>kereneventtop    : $kereneventtop</pre>');

			#####################################################################################################
			// BEPAAL EERSTE EN LAATSTE JAAR DEEL
			#####################################################################################################
			if (!empty($maxcv_deel_array)) {
				if ($maxcv_deel_nr > 0) {
					$eerstedeel  = min(array_filter($maxcv_deel_array));
					$laatstedeel = max(array_filter($maxcv_deel_array));
					wachthond($extdebug, 2, '<pre>eerstedeel       : $eerstedeel</pre>');
					wachthond($extdebug, 2, '<pre>laatstedeel      : $laatstedeel</pre>');
				}
				if ($maxcv_deel_nr == 1) {
					$eerstexdeel 			= 'eerstex';
					$part_ditjaar1stdeel 	= 'eerstex';
					wachthond($extdebug, 2, '<pre>eerstexdeel      : $eerstexdeel</pre>');
				} else {
					$eerstexdeel 			= NULL;
					$part_ditjaar1stdeel 	= NULL;
				}
			}
			// BEPAAL EERSTE EN LAATSTE JAAR DEEL_TOP
			if (!empty($topcv_deel_array)) {
				if ($maxcv_deel_nr > 0) {
					$eerstedeeltop  = min(array_filter($topcv_deel_array));
					$laatstedeeltop = max(array_filter($topcv_deel_array));
					wachthond($extdebug, 1, '<pre>eerstedeeltop    : $eerstedeeltop</pre>');
					wachthond($extdebug, 1, '<pre>laatstedeeltop   : $laatstedeeltop</pre>');
				}
			}
   			// BEPAAL EERSTE EN LAATSTE JAAR LEID
			if (!empty($maxcv_leid_array)) {
				if ($maxcv_leid_nr > 0) {
					$eersteleid  = min(array_filter($maxcv_leid_array));
					$laatsteleid = max(array_filter($maxcv_leid_array));
					wachthond($extdebug, 2, '<pre>eersteleid       : $eersteleid</pre>');
					wachthond($extdebug, 2, '<pre>laatsteleid      : $laatsteleid</pre>');
				}
				if ($maxcv_leid_nr == 1) {
					$eerstexleid 			= 'eerstex';
					$part_ditjaar1stleid 	= 'eerstex';
					wachthond($extdebug, 2, '<pre>eerstexleid      : $eerstexleid</pre>');
				} else {
					$eerstexleid 			= NULL;
					$part_ditjaar1stleid 	= NULL;
				}
			}

			$maxcv_deel_text = implode(', ', array_filter($maxcv_deel_array));
			$maxcv_leid_text = implode(', ', array_filter($maxcv_leid_array));

			// BEPAAL EERSTE EN LAATSTE JAAR TOTAAL
			$totaalmee   = $maxcv_deel_nr + $maxcv_leid_nr;
			$eerstekeer  = $maxcv_deel_nr > 0 ? $eerstedeel  : $eersteleid;
			$laatstekeer = $maxcv_leid_nr > 0 ? $laatsteleid : $laatstedeel;

			#wachthond($extdebug, 2, '<pre>eerstedeel      : $eerstedeel</pre>');
			#wachthond($extdebug, 2, '<pre>laatstedeel     : $laatstedeel</pre>');
			#wachthond($extdebug, 2, '<pre>eersteleid      : $eersteleid</pre>');
			#wachthond($extdebug, 2, '<pre>laatsteleid     : $laatsteleid</pre>');
			wachthond($extdebug, 1, '<pre>eerstekeer       : $eerstekeer</pre>');
			wachthond($extdebug, 1, '<pre>laatstekeer      : $laatstekeer</pre>');

			if ($extcv == 1) {
				$eventverschildeel	= $evtcv_deel_nr - $curcv_deel_nr;
				$eventverschilleid	= $evtcv_leid_nr - $curcv_leid_nr;
			}
			if ($exttag == 1) {
				$tagverschildeel	= $tagnr_deel - $curcv_deel_nr;
				$tagverschilleid	= $tagnr_leid - $curcv_leid_nr;
			}

			#####################################################################################################
			# 2.2 BEPAAL OF DIT HET EERSTE JAAR IS VOOR DEZE PERSOON ALS DEEL OF LEID
   			wachthond($extdebug, 1, '<pre>### 2.2 BEPAAL OF DIT HET EERSTE JAAR IS VOOR DEZE PERSOON ALS DEEL OF LEID [groupID: $groupID] ###</pre>');
			#####################################################################################################

			$part_ditjaar1stdeel = CRM_Core_DAO::VALUE_SEPARATOR . $eerstexdeel . CRM_Core_DAO::VALUE_SEPARATOR;
			$part_ditjaar1stleid = CRM_Core_DAO::VALUE_SEPARATOR . $eerstexleid . CRM_Core_DAO::VALUE_SEPARATOR;

   			wachthond($extdebug, 2, '<pre>eerstexdeel_0         : $eerstexdeel</pre>');
   			wachthond($extdebug, 2, '<pre>eerstexleid_0         : $eerstexleid</pre>');
   			wachthond($extdebug, 2, '<pre>part_ditjaar1stdeel_0 : $part_ditjaar1stdeel</pre>');
   			wachthond($extdebug, 2, '<pre>part_ditjaar1stleid_0 : $part_ditjaar1stleid</pre>');

   			if ($maxcv_deel_nr == 1 AND $ditjaardeelyes == 1) {
	   			$part_ditjaar1stdeel 	= 'eerstex';
   				$eerstexdeel 			= 'eerstex';
   			} else {
   				$part_ditjaar1stdeel 	= NULL;
	   			$eerstexdeel 			= NULL;
   			}
   			if ($maxcv_leid_nr == 1 AND $ditjaarleidyes == 1) {
	   			$part_ditjaar1stleid 	= 'eerstex';
	   			$eerstexleid 			= 'eerstex';
	   		} else {
		   		$part_ditjaar1stleid 	= NULL;
		   		$eerstexleid 			= NULL;
		   	}

   			wachthond($extdebug, 2, '<pre>eerstexdeel_1         : $eerstexdeel</pre>');
   			wachthond($extdebug, 2, '<pre>eerstexleid_1         : $eerstexleid</pre>');
   			wachthond($extdebug, 2, '<pre>part_ditjaar1stdeel_1 : $part_ditjaar1stdeel</pre>');
   			wachthond($extdebug, 2, '<pre>part_ditjaar1stleid_1 : $part_ditjaar1stleid</pre>');

			#####################################################################################################
			# 2.3 REGISTER DEZE LEIDER VOOR EVENT IN THE PAST EN MAAK EVT HET EVENT AAN
   			wachthond($extdebug, 1, '<pre>### 2.3 REGISTER DEZE LEIDER VOOR EVENT IN THE PAST EN MAAK EVT HET EVENT AAN [groupID: $groupID] ###</pre>');
			#####################################################################################################

			if ($curcv_leid_nr > 0) {

				#wachthond($extdebug, 2, '<pre>curcv_leid_array: $curcv_leid_array</pre>');
				#wachthond($extdebug, 2, '<pre>evtcv_leid_array: $evtcv_leid_array</pre>');

				# GEBRUIK DE GEANNULEERDE KAMPJAREN ALS LEIDING OOK VOOR DEZE BEREKENING
				$evtcv_leid_totaal_array 	= array_merge($evtcv_leid_array, $evtcv_staf_array, $cancv_leid_array);
				$notcv_leid_array 			= array_diff($curcv_leid_array, $evtcv_leid_totaal_array);

				wachthond($extdebug, 2, '<pre>evtcv_leid_array  : $evtcv_leid_array</pre>');
				wachthond($extdebug, 2, '<pre>evtcv_staf_array  : $evtcv_staf_array</pre>');
				wachthond($extdebug, 2, '<pre>cancv_leid_array  : $cancv_leid_array</pre>');
				wachthond($extdebug, 2, '<pre>notcv_leid_array  : $notcv_leid_array</pre>');

				foreach ($notcv_leid_array as $jaarleid) {
					$evt_startdate 	= date("1-1-$jaarleid");
					$evt_enddate 	= date("31-12-$jaarleid");

					$params_event = [
  						'checkPermissions' 	=> FALSE,
						'debug' 			=> $apidebug,
  						'select' => [
    						'id', 'event_type_id', 'title', 'row_count',
  						],
  						'where' => [
    						['event_type_id', 'IN', $eventypesleid],
    						['title', 'NOT LIKE', '%TEST%'],
							['start_date', '>', $evt_startdate],
							['start_date', '<', $evt_enddate],
							['start_date', '<', $today_datetime],	// only events in the past
  						],
					];

					wachthond($extdebug, 3, '<pre>params_event: $params_event</pre>');
					$result_event = civicrm_api4('Event', 'get', $params_event);
					wachthond($extdebug, 4, '<pre>result_event: $result_event</pre>');
					$old_event_id = $result_event[0]['id'];
	   				wachthond($extdebug, 2, '<pre>Deze persoon geregistreerd voor kampjaar $jaarleid bij eventid: $old_event_id</pre>');

					$params_participant_create = [
						'checkPermissions' 	=> FALSE,
						'debug'  			=> $apidebug,
						'values' => [
    						'contact_id' 	=> $contact_id, 
    						'event_id' 		=> $old_event_id,
							'register_date' => $evt_startdate,
    						'status_id'		=> 2,
    						'role_id' 		=> [6],	// rol = leiding
    						'PART_LEID.Functie:name' => 'leiding',
  						],
					];
					wachthond($extdebug, 3, '<pre>params_participant_create: $params_participant_create</pre>');
					if ($old_event_id > 0 AND (!in_array($old_event_id, $kampids_all))) { // M61: maak alles aan behalve van huidige fiscale jaar
						$participant_create = civicrm_api4('Participant', 'create', $params_participant_create);
					}
					wachthond($extdebug, 4, '<pre>result_participant_create: $participant_create</pre>');
				}
			}
		}

		#####################################################################################################
   		if (in_array($groupID, array("225", "139", "190"))) {	// PART DEEL + PART LEID
		#####################################################################################################

			#####################################################################################################
			# 3.1 CORRIGEER ROLLEN DEELNEMER / LEIDING / LEIDING TOPKAMP
   			wachthond($extdebug, 1, '<pre>### 3.1 CORRIGEER ROLLEN DEELNEMER / LEIDING / LEIDING TOPKAMP: $part_eventid ###</pre>');
			#####################################################################################################

			$arrayint 		= array_intersect($part_role_id, array("6", "9"));
			$arrayintcount 	= count(array_intersect($part_role_id, array("6", "9")));
			wachthond($extdebug, 2, '<pre>arrayint: $arrayint</pre>');
			wachthond($extdebug, 2, '<pre>arrayintcount: $arrayintcount</pre>');

			if ((count(array_intersect($part_role_id, array("6", "9"))) > 0 ) OR in_array($part_role_id, array("6", "9"))) {
				// ROLE_ID = LEIDING OF LEIDING TOPKAMP
				# M61: HIERBOVEN COMPLEXE MANIER OM twee arrrays te intersecten maar ook om te gaan als part_role_id geen array is
			}

			#####################################################################################################
			# 3.1b GET AMOUNT PAID & SALDO HORENDE BIJ DEZE PARTICIPANT & CONTRIBUTION
  			wachthond($extdebug, 1, '<pre>### 3.1b GET AMOUNT PAID & SALDO HORENDE BIJ DEZE PARTICIPANT & CONTRIBUTION [groupID: $groupID] ###</pre>');
			#####################################################################################################

        	$params_saldo_get = [
          		'checkPermissions' => FALSE,
          		'debug'   => FALSE,
          		'select'  => [
            		'paid_amount', 
            		'balance_amount',
          		],
          		'where' => [
            		['contact_id', 			'=', $contact_id],
            		['financial_type_id', 	'IN', [4,14,15]],            		
   					['receive_date', 		'>=', $event_fiscalyear_start],
					['receive_date', 		'<=', $event_fiscalyear_einde],
          		],
        	];
			wachthond($extdebug, 3, '<pre>params_saldo_get: $params_saldo_get</pre>');        	
        	$result_saldo_get   = civicrm_api4('Contribution', 'get', $params_saldo_get);
			wachthond($extdebug, 4, '<pre>result_saldo_get: $result_saldo_get</pre>');        	

        	$saldo_paid     = $result_saldo_get[0]['paid_amount'];
        	$saldo_balance  = $result_saldo_get[0]['balance_amount'];

    		if ($saldo_balance) {
    			$params_participant['values']['PART_KAMPGELD.betaald']	= $saldo_paid;
    			$params_participant['values']['PART_KAMPGELD.balance']	= $saldo_balance;
    		}

        	wachthond($extdebug, 2, '<pre>saldo_paid               : $saldo_paid</pre>');
        	wachthond($extdebug, 2, '<pre>saldo_balance            : $saldo_balance</pre>');

			if ($diteventdeelyes == 1 OR $diteventleidyes == 1) {

   			#####################################################################################################
			# 3.2a BEPAAL OF ER VOOR DEZE AANMELDING TOERISTENBELASTING MOET WORDEN BETAALD (EDE)
			wachthond($extdebug, 1, '<pre>### 3.2a BEPAAL OF ER VOOR DEZE AANMELDING TOERISTENBELASTING MOET WORDEN BETAALD EDE [groupID: $groupID] ###</pre>');
			#####################################################################################################

			$params_addresses = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,				
  				'select' => [
					'row_count',
  				],
 				'where' => [
    				['contact_id', '=', $contact_id],
    				['Adresgegevens.Gemeente', '=', 'Ede'], 
  				],
			];
			wachthond($extdebug, 3, '<pre>params_addresses: $params_addresses</pre>');
			$result_ede 	= civicrm_api4('Address', 'get', $params_addresses);
			$group_ede  	= $result_ede->count();
			wachthond($extdebug, 4, '<pre>result_addresses: $result_ede</pre>');
			wachthond($extdebug, 2, '<pre>group_ede: $group_ede</pre>');

			#####################################################################################################
			# 3.2b BEPAAL OF ER VOOR DEZE AANMELDING TOERISTENBELASTING MOET WORDEN BETAALD
  			wachthond($extdebug, 1, '<pre>### 3.2b BEPAAL OF ER VOOR DEZE AANMELDING TOERISTENBELASTING MOET WORDEN BETAALD GAVE [groupID: $groupID] ###</pre>');
			#####################################################################################################

			$params_lineitem = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,				
  				'select' => [
  					'row_count',
  				],
 				'where' => [
    				['contribution_id.contact_id', '=', $contact_id],
	    			['price_field_value_id', 'IN', [302, 301, 498, 472, 473, 497]],
					['qty', '=', 1],
					['contribution_id.receive_date', '>=', $event_fiscalyear_start],
					['contribution_id.receive_date', '<=', $event_fiscalyear_einde],
  				],
			];
			wachthond($extdebug, 3, '<pre>params_gave: $params_lineitem</pre>');
			$result_gave 	= civicrm_api4('LineItem', 'get', $params_lineitem);
			$group_gave  	= $result_gave->count();
			wachthond($extdebug, 4, '<pre>result_gave: $result_gave</pre>');			
			wachthond($extdebug, 2, '<pre>group_gave: $group_gave</pre>');

			if ($group_gave >= 1) {
	    	    wachthond($extdebug, 2, '<pre>TOERISTENBELASTING: [3] nee, via St.Gave</pre>');
	    		$toeristenbelasting	= 3;
    		} elseif ($diteventdeelyes == 1 AND $group_ede == 0) {
    			wachthond($extdebug, 2, '<pre>TOERISTENBELASTING: [1] ja, als deelnemer</pre>');
	    		$toeristenbelasting	= 1;
    		} elseif ($diteventleidyes == 1 AND $group_ede == 0) {
    		    wachthond($extdebug, 2, '<pre>TOERISTENBELASTING: [2] ja, als leiding</pre>');
    			$toeristenbelasting	= 2;
	    	} elseif ($group_ede == 1) {
    			wachthond($extdebug, 2, '<pre>TOERISTENBELASTING: [4] nee, woont in gemeente Ede</pre>');
    			$toeristenbelasting	= 4;
    		} elseif ($diteventdeelmss) {
    			$toeristenbelasting	= "";		
    		}
    		if ($toeristenbelasting) {
				$params_toer = [
  				'checkPermissions' => FALSE,
				'debug' => $apidebug,
	 				'where' => [
    					['id', 				'=', $part_id],
  					],
  					'values' => [
						'PART.PART_Toeristenbelasting' 	=> $toeristenbelasting,
  					],
				];
			}
			if ($part_id) {
				#wachthond($extdebug, 3, '<pre>params_toer: $params_toer</pre>');
				#$result_toer = civicrm_api4('Participant', 'update', $params_toer);
#				$params_participant['values']['PART.PART_Toeristenbelasting']	= $toeristenbelasting;
				wachthond($extdebug, 4, '<pre>results_toer: $result_toer</pre>');
			}
		}
		#####################################################################################################
		# 3.3 CORRIGEER DATUM DRIJFVEREN & BELANGSTELLING
  		wachthond($extdebug, 1, '<pre>### 3.3 CORRIGEER DATUM DRIJFVEREN & BELANGSTELLING: $part_eventid ###</pre>');
		#####################################################################################################

   		wachthond($extdebug, 2, '<pre>datum_belangstelling   : $datum_belangstelling</pre>');
		wachthond($extdebug, 2, '<pre>datum_bio_ingevuld     : $bioingevuld</pre>');
		wachthond($extdebug, 2, '<pre>datum_bio_gecheckt     : $biogecheckt</pre>');
		wachthond($extdebug, 2, '<pre>part_naw_gecheckt      : $part_naw_gecheckt</pre>');
		wachthond($extdebug, 2, '<pre>part_bio_gecheckt      : $part_bio_gecheckt</pre>');
		wachthond($extdebug, 2, '<pre>new_datum_bio_ingevuld : $new_datum_bio_ingevuld</pre>');
		wachthond($extdebug, 2, '<pre>new_datum_bio_gecheckt : $new_datum_bio_gecheckt</pre>');		
		if (empty($biogecheckt)) {
			$biogecheckt = $bioingevuld;
		}

   		if (($part_bio_gecheckt AND !$biogecheckt) OR strtotime($part_bio_gecheckt)	> strtotime($biogecheckt)) {
			$new_datum_bio_gecheckt = $part_bio_gecheckt;
			wachthond($extdebug, 2, '<pre>UPDATE biogecheckt naar part_bio_gecheckt (want part_bio_gecheckt $part_bio_gecheckt > biogecheckt $biogecheckt)</pre>');
		} else {
			wachthond($extdebug, 2, '<pre>GEEN UPDATE biogecheckt naar part_bio_gecheckt (want niet nieuwer dan biogecheckt): $part_vogdatum</pre>');
		}	

   		if (($biogecheckt AND !$part_bio_gecheckt) OR strtotime($biogecheckt) 		> strtotime($part_bio_gecheckt)) {
			$new_datum_bio_gecheckt = $biogecheckt;
			wachthond($extdebug, 2, '<pre>UPDATE biogecheckt naar biogecheckt (want biogecheckt $biogecheckt > part_bio_gecheckt $part_bio_gecheckt)</pre>');
		} else {
			wachthond($extdebug, 2, '<pre>GEEN UPDATE biogecheckt naar biogecheckt (want niet nieuwer dan part_bio_gecheckt): $part_vogdatum</pre>');
		}

   		if ($bioingevuld AND $biogecheckt 			AND strtotime($bioingevuld)		> strtotime($biogecheckt)) {
			$new_datum_bio_gecheckt = $bioingevuld;
			wachthond($extdebug, 2, '<pre>UPDATE biogecheckt naar drijf_ingevuld (want drijf_ingevuld $bioingevuld > biogecheckt $biogecheckt)</pre>');
		} else {
			wachthond($extdebug, 2, '<pre>GEEN UPDATE biogecheckt naar drijf_ingevuld (want niet nieuwer dan biogecheckt): $part_vogdatum</pre>');
		}

		if ($biogecheckt AND empty($bioingevuld)) {
			$new_datum_bio_ingevuld = $biogecheckt;
			wachthond($extdebug, 2, '<pre>UPDATE lege drijf_ingevuld met ingevulde datum_biogecheckt: $biogecheckt</pre>');	
		}
		if ($bioingevuld AND empty($datum_belangstelling) AND $curcv_leid_nr == 0) {
			$datum_belangstelling = $bioingevuld;
			wachthond($extdebug, 2, '<pre>datum_belangstelling_van_drijf_ingevuld: $datum_belangstelling</pre>');	
		}

		if ($bioingevuld AND (empty($biogecheckt) OR empty($part_bio_gecheckt)) AND $maxcv_leid_nr == 1) {
   			$new_datum_naw_gecheckt = $bioingevuld;
			wachthond($extdebug, 2, '<pre>GEBRUIK DATUM DRIJF INGEVULD ALS GECHECKED BIJ NIEUWE LEIDING: $bioingevuld</pre>');
		}
		if ($extchk == 1) {
	    	if ($datum_belangstelling)		{ $params_contact['values']['Werving_promotie.Datum_belangstelling']= $datum_belangstelling;	}
			if ($new_datum_bio_ingevuld) 	{ $params_contact['values']['INTAKE.BIO_ingevuld'] 					= $new_datum_bio_ingevuld; 	}
			if ($new_datum_bio_gecheckt)	{ $params_contact['values']['INTAKE.BIO_gecheckt'] 					= $new_datum_bio_gecheckt;	}
			if ($new_datum_naw_gecheckt) 	{ $params_participant['values']['PART.BIO_gecheckt'] 				= $new_datum_naw_gecheckt;	}
			if ($new_datum_bio_gecheckt) 	{ $params_participant['values']['PART.BIO_gecheckt']				= $new_datum_bio_gecheckt;	}

	   		wachthond($extdebug, 2, '<pre>datum_belangstelling_1     : $datum_belangstelling</pre>');
			wachthond($extdebug, 2, '<pre>bioingevuld_1              : $new_datum_bio_ingevuld</pre>');
			wachthond($extdebug, 2, '<pre>datum_biogecheckt_1        : $new_datum_bio_gecheckt</pre>');
			wachthond($extdebug, 2, '<pre>part_bio_gecheckt_1        : $new_datum_bio_gecheckt</pre>');
			wachthond($extdebug, 2, '<pre>part_naw_gecheckt_1        : $new_datum_bio_gecheckt</pre>');
   			wachthond($extdebug, 4, '<pre>params_contact_dusver      : $params_contact</pre>');
   			wachthond($extdebug, 4, '<pre>params_participant_dusver  : $params_participant</pre>');
		}

		#####################################################################################################
		# 'CORRIGEER' VELDEN RONDOM BELANGSTELLING
		#####################################################################################################

		$belangstelling_week 	= $result_cont[0]['Werving_promotie.Welke_kampweek'];
		$belangstelling_groep	= $result_cont[0]['Werving_promotie.Welke_leeftijdsgroep'];
		$belangstelling_kamp	= $result_cont[0]['Werving_promotie.Welke_kampweken'];
		$belangstelling_array	= [];

		wachthond($extdebug, 2, '<pre>belangstelling_week     : $belangstelling_week</pre>');
		wachthond($extdebug, 2, '<pre>belangstelling_groep    : $belangstelling_groep</pre>');

		if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('kinderkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'KK1');
		}
		if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('kinderkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'KK2');
		}
		if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('brugkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'BK1');
		}
		if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('brugkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'BK2');
		}
		if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('tienerkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'TK1');
		}
		if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('tienerkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'TK2');
		}
		if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('jeugdkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'JK1');
		}
		if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('jeugdkamp', $belangstelling_groep)) 	{
			array_push($belangstelling_array, 'JK2');
		}

		#wachthond($extdebug, 2, '<pre>belangstelling_kampen: $belangstelling_kamp</pre>');
		wachthond($extdebug, 2, '<pre>belangstelling_kampen: $belangstelling_array</pre>');

		#####################################################################################################
		# 'CORRIGEER' VELDEN RONDOM DATUM CHECK
		#####################################################################################################

		wachthond($extdebug, 2, '<pre>tab  nawgecheckt     : $nawgecheckt</pre>');
		wachthond($extdebug, 2, '<pre>part nawgecheckt     : $part_naw_gecheckt</pre>');

		if ($nawgecheckt AND empty($part_naw_gecheckt)) {
			$part_naw_gecheckt = $nawgecheckt;
			wachthond($extdebug, 1, '<pre>naw_gecheckt      ($nawgecheckt) > part_naw_gecheckt ($part_naw_gecheckt)</pre>');
		}
		if ($part_naw_gecheckt AND empty($nawgecheckt)) {
			$nawgecheckt = $part_naw_gecheckt;
			wachthond($extdebug, 1, '<pre>part_naw_gecheckt ($part_naw_gecheckt) > naw_gecheckt        ($nawgecheckt)</pre>');
		}
		if (strtotime($part_naw_gecheckt) 	>= strtotime($nawgecheckt)) {
			$nawgecheckt 	= $part_naw_gecheckt;
			wachthond($extdebug, 1, '<pre>part_naw_gecheckt ($part_naw_gecheckt) > naw_gecheckt ($nawgecheckt)</pre>');			
		}
		if (strtotime($nawgecheckt) 		>= strtotime($part_naw_gecheckt) AND strtotime($event_start_date) >= strtotime($event_fiscalyear_start)) {
			$part_naw_gecheckt = $nawgecheckt;
			wachthond($extdebug, 1, '<pre>naw_gecheckt      ($nawgecheckt) > part_naw_gecheckt ($part_naw_gecheckt)</pre>');
		}

		if ($maxcv_leid_nr == 1 AND $ditjaarleidyes == 1) {
		#if ($eerstexleid = 'eerstex' AND empty($nawgecheckt) {
			$nawgecheckt 		= $part_register_date;
			$part_naw_gecheckt	= $part_register_date;
		}

		if ($nawgecheckt)		{ $params_contact['values']['INTAKE.NAW_gecheckt'] 			= $nawgecheckt; 		}
		if ($part_naw_gecheckt)	{ $params_participant['values']['PART.NAW_gecheckt'] 		= $part_naw_gecheckt;	}

		wachthond($extdebug, 1, '<pre>tab  nawgecheckt : $nawgecheckt</pre>');
		wachthond($extdebug, 1, '<pre>part nawgecheckt : $part_naw_gecheckt</pre>');

		#####################################################################################################
		# 3.3b WERVING MEE VOLGEND JAAR
  		wachthond($extdebug, 1, '<pre>### 3.3b WERVING MEE VOLGEND JAAR: $part_eventid ###</pre>');
		#####################################################################################################

		if ($werving_mee_update) {
			//NEEM DATUM VAN LAATSTE UPDATE OVER 'MEE KOMEND KAMP' EN LEIDT DAARUIT HET KAMPJAAR AF

			$mee_fiscalyear_array	= curriculum_civicrm_fiscalyear($werving_mee_update);
			$mee_fiscalyear_start	= $mee_fiscalyear_array['fiscalyear_start'];
			$mee_fiscalyear_einde	= $mee_fiscalyear_array['fiscalyear_einde'];

			wachthond($extdebug, 2, '<pre>mee_fiscalyear_start      : $mee_fiscalyear_start</pre>');
			wachthond($extdebug, 2, '<pre>mee_fiscalyear_einde      : $mee_fiscalyear_einde</pre>');
			wachthond($extdebug, 2, '<pre>datum_mee_ingevuld        : $werving_mee_update</pre>');
		}

		if ($part_evaluatie > empty($werving_mee_update)) {	// M61: repair voor als werving update niet was ingevuld maar evaluatie wel
			$werving_mee_update = $part_evaluatie;
    		if ($werving_mee_update) 	{ $params_contact['values']['Werving_promotie.mee_update']	= $werving_mee_update; 	}
		}


		if ($werving_mee_update) {
			### NEXTV FROM EVENT
			$mee_update_year			= date('Y', $werving_mee_update);
			$mee_update_next_date		= date('Y-m-d H:i:s', strtotime ( '+1 year' , strtotime ($werving_mee_update)));
			$mee_update_next_year		= date('Y',           strtotime ( '+1 year' , strtotime ($werving_mee_update)));	
			if ($mee_update_next_year == $laatstekeer) {$mee_update_next_year = $mee_update_next_year + 1;}
			// M61 KLEINE SAFEGUARD: ALS komendkampjaar zelfde is als laatstekeer dan + 1 jaar

			$params_nextkampfromthisdate = [
  				'checkPermissions' => FALSE,
				'debug' 	=> $apidebug,
				'limit' 	=> 1,
  				'select' 	=> [
    				'title', 
    				'start_date',
  				],
  				'where' => [
    				['start_date', 		'>', $werving_mee_update], 
    				['start_date', 		'<', $mee_update_next_date],
//	   				['event_type_id', 	'=', 1],
	   				['event_type_id', 	'=', $part_eventtypeid], // M61: zoek next event van zelfde event_type_id (todo: kan evt missen)
  				],
			];
      		wachthond($extdebug, 3, '<pre>params_nextkampfromthisdate: $params_nextkampfromthisdate</pre>');
			$nextevent = civicrm_api4('Event', 'get', $params_nextkampfromthisdate);
      		wachthond($extdebug, 4, '<pre>result_nextkampfromthisdate: $nextevent</pre>');

			$mee_event_next_date = $nextevent[0]['start_date'];
			$mee_event_next_year = date('Y', strtotime($mee_event_next_date));
			$mee_event_past_date = date('Y-m-d', strtotime ( '-12 months' , strtotime ($mee_event_next_year)));
		}

		$params_activity_mee_get = [
			'checkPermissions' => FALSE,
			'debug' => $apidebug,
  			'select' => [
				'id', 'activity_date_time', 'status_id', 'status_id:name', 'subject', 'activity_contact.contact_id',
  			],
			'join' => [
    			['ActivityContact AS activity_contact', 'INNER'],
			],
			'where' => [
    			['activity_contact.contact_id', 	'=', $contact_id],
    			['activity_contact.record_type_id', '=', 3],
 				['activity_type_id:name', 			'=', 'werving_mee_ditjaar'],
    			['activity_date_time', 				'>=', $mee_fiscalyear_start],
    			['activity_date_time', 				'<=', $mee_fiscalyear_einde],
  			],
  			'limit' => 1,
		];

		wachthond($extdebug, 3, '<pre>params_activity_mee_get    : $params_activity_mee_get</pre>');
	  	$result_mee_get 	  = civicrm_api4('Activity', 'get', $params_activity_mee_get);
	  	$result_mee_get_count = $result_mee_get->count();
	  	wachthond($extdebug, 4, '<pre>result_activity_mee_get: $result_mee_get</pre>');  	
	  	wachthond($extdebug, 2, '<pre>result_mee_count        : $result_mee_get_count</pre>');

	  	if ($result_mee_get_count == 1) {
	  		$mee_activity_id			= $result_mee_get[0]['id'];
	  		$mee_activity_status_id		= $result_mee_get[0]['status_id'];
	  		$mee_activity_status_name	= $result_mee_get[0]['status_id:name'];
	  		$mee_activity_datum			= $result_mee_get[0]['activity_date_time'];
			wachthond($extdebug, 1, '<pre>mee_activity_id       : $mee_activity_id</pre>');
			wachthond($extdebug, 2, '<pre>mee_activity_status_id: $mee_activity_status_id</pre>');
			wachthond($extdebug, 2, '<pre>mee_activity_status   : $mee_activity_status_name</pre>');
			wachthond($extdebug, 2, '<pre>mee_activity_datum    : $mee_activity_datum</pre>');
	  	} else {
			$mee_activity_id		= NULL;
	  		$mee_activity_status	= NULL;
  			$mee_activity_datum		= NULL;
  			wachthond($extdebug, 1, '<pre>mee_activity_id       : No Activity Found</pre>');
 		}

		if ($werving_mee_update AND $result_mee_get_count == 0) {

			wachthond($extdebug, 1, '<pre>################################################################</pre>');
	   		wachthond($extdebug, 2, '<pre>CREATE werving_mee_verwachting   : $werving_mee_verwachting</pre>');
   			wachthond($extdebug, 2, '<pre>CREATE werving_mee_toelichting   : $werving_mee_toelichting</pre>');
			wachthond($extdebug, 1, '<pre>################################################################</pre>');

			$params_activity_mee_create = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
 				'values' => [
	    			'source_contact_id' 		=> $contact_id,
					'target_contact_id' 		=> $contact_id,
 					'activity_type_id:name' 	=> 'werving_mee_ditjaar',
    				'activity_date_time' 		=> $werving_mee_update,					
 					'subject' 					=> "Mee in '.$werving_mee_komendkamp.' : '.$werving_mee_verwachting.'",
					'status_id:name' 			=> 'Completed',
				    'ACT_MEE.kampjaar' 			=> $mee_event_next_year,
				    'ACT_MEE.komendkamp' 		=> $mee_event_next_date,
				    'ACT_MEE.rol' 				=> $werving_mee_rol,
				    'ACT_MEE.verwachting' 		=> $werving_mee_verwachting, 
				    'ACT_MEE.toelichting' 		=> $werving_mee_toelichting, 
				    'ACT_MEE.update' 			=> $werving_mee_update,
					'ACT_ALG.modified' 			=> $today_datetime,
    				'ACT_ALG.kampkort'			=> $welkkampkort,
   					'ACT_ALG.kampfunctie' 		=> $part_functie,
    				'ACT_ALG.kampstart' 		=> $event_start_date,
    				'ACT_ALG.kampeinde' 		=> $event_einde_date,
    				'ACT_ALG.kampjaar'			=> $event_kampjaar,
  				],
  			];
			wachthond($extdebug, 1, '<pre>params_activity_mee_create: $params_activity_mee_create</pre>');
			$result_activity_mee_create = civicrm_api4('Activity', 'create', $params_activity_mee_create);
			wachthond($extdebug, 1, '<pre>result_activity_mee_create: $result_activity_mee_create</pre>');
  		}

		if ($werving_mee_update AND $result_mee_get_count == 1) {

			wachthond($extdebug, 1, '<pre>################################################################</pre>');
	   		wachthond($extdebug, 2, '<pre>UPDATE werving_mee_verwachting   : $werving_mee_verwachting</pre>');
   			wachthond($extdebug, 2, '<pre>UPDATE werving_mee_toelichting   : $werving_mee_toelichting</pre>');
			wachthond($extdebug, 1, '<pre>################################################################</pre>');

			$params_activity_mee_update = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
				'where' => [
					['id', 					'=', $mee_activity_id],
				],				
 				'values' => [
	    			'source_contact_id' 		=> $contact_id,
					'target_contact_id' 		=> $contact_id,
 					'activity_type_id:name' 	=> 'werving_mee_ditjaar',
    				'activity_date_time' 		=> $werving_mee_update,
 					'subject' 					=> "Mee in '.$werving_mee_komendkamp.' : '.$werving_mee_verwachting.'",
					'status_id:name' 			=> 'Completed',
				    'ACT_MEE.kampjaar' 			=> $mee_event_next_year,
				    'ACT_MEE.komendkamp' 		=> $mee_event_next_date,
				    'ACT_MEE.rol' 				=> $werving_mee_rol,
				    'ACT_MEE.verwachting' 		=> $werving_mee_verwachting,
				    'ACT_MEE.toelichting' 		=> $werving_mee_toelichting,
				    'ACT_MEE.update' 			=> $werving_mee_update,
					'ACT_ALG.modified' 			=> $today_datetime,
    				'ACT_ALG.kampkort'			=> $welkkampkort,
   					'ACT_ALG.kampfunctie' 		=> $part_functie,
    				'ACT_ALG.kampstart' 		=> $event_start_date,
    				'ACT_ALG.kampeinde' 		=> $event_einde_date,
    				'ACT_ALG.kampjaar'			=> $event_kampjaar,
  				],
  			];
			wachthond($extdebug, 3, '<pre>params_activity_mee_update: $params_activity_mee_update</pre>');
			$result_activity_mee_update = civicrm_api4('Activity', 'update', $params_activity_mee_update);
			wachthond($extdebug, 4, '<pre>result_activity_mee_update: $result_activity_mee_update</pre>');
  		}

			$today_nextkamp_date = $tdy_event_next_date;
			$today_nextkamp_jaar = $tdy_event_next_year;

			wachthond($extdebug, 1, '<pre>event_start_date     	: $event_start_date</pre>');
			wachthond($extdebug, 1, '<pre>event_einde_date     	: $event_einde_date</pre>');
			wachthond($extdebug, 2, '<pre>today_nextkamp_date  	: $today_nextkamp_date</pre>');
			wachthond($extdebug, 2, '<pre>today_nextkamp_jaar  	: $today_nextkamp_jaar</pre>');

			wachthond($extdebug, 2, '<pre>mee_update_next_year 	: $mee_update_next_year</pre>');
			wachthond($extdebug, 2, '<pre>mee_event_past_date  	: $mee_event_past_date</pre>');
			wachthond($extdebug, 2, '<pre>mee_event_next_date  	: $mee_event_next_date</pre>');
			wachthond($extdebug, 2, '<pre>mee_event_next_year  	: $mee_event_next_year</pre>');

		#####################################################################################################
		# 3.4 BEPAAL VELDEN RONDOM TIJDSLOT BRENGEN & HALEN
   		wachthond($extdebug, 1, '<pre>### 3.4 BEPAAL VELDEN RONDOM TIJDSLOT BRENGEN & HALEN: $part_eventid ###</pre>');
		#####################################################################################################

		if ((count(array_intersect($part_role_id, array("7", "8"))) > 0 ) OR in_array($part_role_id, array("7", "8"))) {
			// ROLE_ID = DEELNEMER of DEELNEMER TOPKAMP
			# M61: HIERBOVEN COMPLEXE MANIER OM twee arrrays te intersecten maar ook om te gaan als part_role_id geen array is
			$part_functie 					= 'deelnemer';
			$part_groepklas 				= $result_part[0]['PART_DEEL.Groep_klas'];
			$part_groepsvoorkeur 			= $result_part[0]['PART_DEEL.Voorkeur'];
			$part_brengen_tijdslot 			= $result_part[0]['PART_DEEL.Tijdslot_brengen'];
			$part_halen_tijdslot 			= $result_part[0]['PART_DEEL.Tijdslot_halen'];

			if ($part_halen_tijdslot)	{
