 			wachthond($extdebug, 2, '<pre>------ b) connected_account_mail  : $connected_account->mail</pre>');
   			wachthond($extdebug, 2, '<pre>------ b) connected_account_uid   : $connected_account->uid</pre>');

   			if ($connected_account->name == $user_name AND $connected_account->name == $drupalnaam) {
				wachthond($extdebug, 1, '<pre>------ b) PRIMA: GEVONDEN DRUPALNAME ($connected_account->name) VIA CMSIDENTIFIER ($cmsidentitier) IS GELIJK AAN CONTRUCTED USERNAME ($user_name) AND civcrm_jobtitle ($drupalnaam)</pre>');
					$drupalaccount_orphan_same_name = 1;
   			}
   			if ($connected_account->mail == $user_email) {
				wachthond($extdebug, 1, '<pre>------ b) PRIMA: GEVONDEN DRUPALMAIL ($connected_account->mail) VIA CMSIDENTIFIER ($cmsidentitier) IS GELIJK AAN PRIMARY CIVICRM EMAIL ($user_email)</pre>');
					$drupalaccount_orphan_same_mail = 1;
   			}   				

			#####################################################################################################
  			if ($drupalid_danger == 1) {
			#####################################################################################################

				#####################################################################################################
	    		# CHECK IF CMS IDENTIFIER ($cmsidentitier) HAS A MATCH
    			wachthond($extdebug, 1, '<pre>###### CHECK IF CMS IDENTIFIER ($cmsidentitier) HAS A MATCH</pre>');
				#####################################################################################################
				$params_ufmatchget = [
	  				'checkPermissions' => FALSE,
					'debug' => $apidebug,
