			   		wachthond($extdebug, 2, '<pre>- ufmatch contact_id      : $ufmatch_cid</pre>');
					wachthond($extdebug, 1, '<pre>1) SAFE2REPAIR: DANGER: VIA CMS IDENTIFIER ($cmsidentitier) EEN CONFLICTERENDE UFMATCH GEVONDEN (MATCHID: $ufmatch_id / DRUPALID: $ufmatch_ufid / CONTACTID: $ufmatch_cid)</pre>');
					$drupalaccount_safe2repair_match = 0;
    			} else {
					wachthond($extdebug, 1, '<pre>1) SAFE2REPAIR: GREEN : VIA CMS IDENTIFIER ($cmsidentitier) GEEN CONFLICTERENDE UFMATCH GEVONDEN</pre>');
					$drupalaccount_safe2repair_match = 1;
    			}
 				
				global $conflict_account;
				$conflict_account = user_load($cmsidentitier);

				if ($conflict_account->uid == $cmsidentitier) {
