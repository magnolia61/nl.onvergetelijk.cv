      			$result 		= civicrm_api4('OptionValue', 'get', $params_optionshalen);
      			wachthond($extdebug, 4, '<pre>result_optionshalen: $result</pre>');

      			$part_halen_tijdslot 		= $result[0]['label'];
      			$part_halen_aankomst 	= $result[0]['description'];

				wachthond($extdebug, 2, '<pre>part_groepklas        : $part_groepklas</pre>');
				wachthond($extdebug, 2, '<pre>part_groepsvoorkeur   : $part_groepsvoorkeur</pre>');
				wachthond($extdebug, 2, '<pre>part_brengen_tijdslot : $part_brengen_tijdslot</pre>');
				wachthond($extdebug, 2, '<pre>part_halen_tijdslot   : $part_halen_tijdslot</pre>');
				wachthond($extdebug, 2, '<pre>part_halen_aankomst   : $part_halen_aankomst</pre>');
			}
		}

		if (in_array($part_functie, array('hoofdleiding', 'bestuurslid', 'kampstaf'))) {

		#####################################################################################################
		# 3.5a VOEG VOOR HOOFDLEIDING DOORGEGEVEN EMAIL TOE AAN GROEP DIE KAMPSTAF EMAIL ONTVANGT
    	wachthond($extdebug, 1, '<pre>### 3.5a VOEG VOOR HOOFDLEIDING DOORGEGEVEN EMAIL TOE AAN GROEP DIE KAMPSTAF EMAIL ONTVANGT ###</pre>');
		#####################################################################################################	

		#wachthond($extdebug, 2, '<pre>home_id: $email_home_id</pre>');
		#wachthond($extdebug, 2, '<pre>othr_id: $email_othr_id</pre>');
		#wachthond($extdebug, 2, '<pre>email_notif_deel_id: $notif_deel_id</pre>');
      	#wachthond($extdebug, 2, '<pre>email_notif_leid_id: $notif_leid_id</pre>');
      	#wachthond($extdebug, 2, '<pre>email_notif_kamp_id: $notif_kamp_id</pre>');
      	#wachthond($extdebug, 2, '<pre>email_notif_staf_id: $notif_staf_id</pre>');

    	wachthond($extdebug, 2, '<pre>home_email       : $email_home_email</pre>');
      	wachthond($extdebug, 2, '<pre>othr_email       : $email_othr_email</pre>');
      	wachthond($extdebug, 2, '<pre>email_notif_deel : $notif_deel_email</pre>');
      	wachthond($extdebug, 2, '<pre>email_notif_leid : $notif_leid_email</pre>');
      	wachthond($extdebug, 2, '<pre>email_notif_kamp : $notif_kamp_email</pre>');
      	wachthond($extdebug, 2, '<pre>email_notif_staf : $notif_staf_email</pre>');

		#wachthond($extdebug, 2, '<pre>cont_notificatie_deel: $cont_notificatie_deel</pre>');
		#wachthond($extdebug, 2, '<pre>cont_notificatie_leid: $cont_notificatie_leid</pre>');
		#wachthond($extdebug, 2, '<pre>cont_notificatie_kamp: $cont_notificatie_kamp</pre>');
		#wachthond($extdebug, 2, '<pre>cont_notificatie_staf: $cont_notificatie_staf</pre>');

		#wachthond($extdebug, 2, '<pre>part_notificatie_deel: $part_notificatie_deel</pre>');
		#wachthond($extdebug, 2, '<pre>part_notificatie_leid: $part_notificatie_leid</pre>');
		#wachthond($extdebug, 2, '<pre>part_notificatie_kamp: $part_notificatie_kamp</pre>');
		#wachthond($extdebug, 2, '<pre>part_notificatie_staf: $part_notificatie_staf</pre>');

		if (!empty($cont_notificatie_deel) AND empty($part_notificatie_deel)) 	{ $part_notificatie_deel = $cont_notificatie_deel; }
		if (!empty($cont_notificatie_leid) AND empty($part_notificatie_leid)) 	{ $part_notificatie_leid = $cont_notificatie_leid; }
		if (!empty($cont_notificatie_kamp) AND empty($part_notificatie_kamp)) 	{ $part_notificatie_kamp = $cont_notificatie_kamp; }
		if (!empty($cont_notificatie_staf) AND empty($part_notificatie_staf))	{ $part_notificatie_staf = $cont_notificatie_staf; }

		if ($part_notificatie_deel == 1) {
			# ALLEEN IN DE MAILBOX VAN JOUW KAMP (SWS)
			$notif_deel_new = NULL;
			$results = civicrm_api4('Email', 'delete', [ 'where' => [ ['id', '=', $notif_deel_id], ],]);
		} elseif ($part_notificatie_deel == 2) {
			# OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
			$notif_deel_new = $email_onvr_email;
		} elseif ($part_notificatie_deel == 3) {
			# OOK OP JE PRIVE EMAILADRES
			$notif_deel_new = $email_home_email;
		} else {
			$part_notificatie_deel	= 3; 
			$notif_deel_new 		= $email_home_email;
		}

		if ($part_notificatie_leid == 1) {
			# ALLEEN IN DE MAILBOX VAN JOUW KAMP (SWS)
			$notif_leid_new = NULL;
			$results = civicrm_api4('Email', 'delete', [ 'where' => [ ['id', '=', $notif_leid_id], ],]);
		} elseif ($part_notificatie_leid == 2) {
			# OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
			$notif_leid_new = $email_onvr_email;
		} elseif ($part_notificatie_leid == 3) {
			# OOK OP JE PRIVE EMAILADRES
			$notif_leid_new = $email_home_email;
		} else {
			$part_notificatie_leid	= 3; 
			$notif_leid_new 		= $email_home_email;
		}

		if ($part_notificatie_kamp == 1) {
			# ALLEEN IN DE MAILBOX VAN JOUW KAMP (SWS)
			$notif_kamp_new = NULL;
			$results = civicrm_api4('Email', 'delete', [ 'where' => [ ['id', '=', $notif_kamp_id], ],]);
		} elseif ($part_notificatie_kamp == 2) {
			# OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
			$notif_kamp_new = $email_onvr_email;
		} elseif ($part_notificatie_kamp == 3) {
			# OOK OP JE PRIVE EMAILADRES
			$notif_kamp_new = $email_home_email;
		} else {
			$part_notificatie_kamp	= 3; 
			$notif_kamp_new 		= $email_home_email;
		}

		if ($part_notificatie_staf == 1) {
			$notif_staf_new = $email_onvr_email;
		} elseif ($part_notificatie_staf == 2) {
			$notif_staf_new = $email_home_email;
		} else {
			$part_notificatie_staf	= 2; 
			$notif_staf_new 		= $email_home_email;
		}

      	wachthond($extdebug, 2, '<pre>notif_deel_new  : $notif_deel_new</pre>');
      	wachthond($extdebug, 2, '<pre>notif_leid_new  : $notif_leid_new</pre>');
      	wachthond($extdebug, 2, '<pre>notif_kamp_new  : $notif_kamp_new</pre>');
      	wachthond($extdebug, 2, '<pre>notif_staf_new  : $notif_staf_new</pre>');

		if ($part_notificatie_deel AND $notif_deel_new AND in_array($part_functie, array('hoofddeeling'))) {
			$params_email_notif_deel_create = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'values' => [
    					'location_type_id:name' => 'notif_deel', 
    					'email' 	=> $notif_deel_new,
    					'contact_id'=> $contact_id, 
    					'is_primary'=> FALSE,
  					],
				];
			if ($notif_deel_id AND $notif_deel_email != $notif_deel_new) {
				//M61: Het lukt niet om bij een bestaand email-id het email adres zelf via api te wijzigen. 
				//M61: Wel via de explorer, niet hier in code. Dus daarom verwijderen en aanmaken
				$results = civicrm_api4('Email', 'delete', [ 'where' => [ ['id', '=', $notif_deel_id], ],]);
				wachthond($extdebug, 2, '<pre>notif_deel verwijderd (tbv opnieuw aanmaken): $notif_deel_email</pre>');
			}
			wachthond($extdebug, 3, '<pre>params_email_notif_deel_create: $params_email_notif_deel_create</pre>');
			$result = civicrm_api4('Email', 'create', $params_email_notif_deel_create);
			wachthond($extdebug, 2, '<pre>2 notif_deel aangemaakt voor: $notif_deel_new</pre>');	
		}
		if ($part_notificatie_leid AND $notif_leid_new AND in_array($part_functie, array('hoofdleiding'))) {
			$params_email_notif_leid_create = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'values' => [
    					'location_type_id:name' => 'notif_leid', 
    					'email' 	=> $notif_leid_new,
    					'contact_id'=> $contact_id, 
    					'is_primary'=> FALSE,
  					],
				];
			if ($notif_leid_id AND $notif_leid_email != $notif_leid_new) {
				$results = civicrm_api4('Email', 'delete', [ 'where' => [ ['id', '=', $notif_leid_id], ],]);
				wachthond($extdebug, 2, '<pre>notif_leid verwijderd (tbv opnieuw aanmaken): $notif_leid_email</pre>');
			}
			wachthond($extdebug, 3, '<pre>params_email_notif_leid_create: $params_email_notif_leid_create</pre>');
			$result = civicrm_api4('Email', 'create', $params_email_notif_leid_create);
			wachthond($extdebug, 2, '<pre>2 notif_leid aangemaakt voor: $notif_leid_new</pre>');	
		}
		if ($part_notificatie_kamp AND $notif_kamp_new AND in_array($part_functie, array('hoofdleiding'))) {
			$params_email_notif_kamp_create = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'values' => [
    					'location_type_id:name' => 'notif_kamp', 
