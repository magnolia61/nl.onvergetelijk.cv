  				wachthond($extdebug, 2, '<pre>refgevraagd_activity_id: $refverzoek_activity_id</pre>');
  				wachthond($extdebug, 2, '<pre>part_refgevraagd: $part_refgevraagd</pre>');

				if ($refverzoek_activity_id AND $part_refgevraagd) {

