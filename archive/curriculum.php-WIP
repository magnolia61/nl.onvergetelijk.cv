    	}
    	*/
   		#####################################################################################################
		# GET CONTACT INFO WHEN TABS ARE CHECKED INSTEAD OF PARTICIPANT INFO IS EDITED
		#####################################################################################################

		$params_contactinfo = [
			'checkPermissions' => FALSE,
			'debug' => $apidebug,
			'select' => [
    			'id',
    			'contact_id',
    			'birth_date', 
