				#####################################################################################################
	    		wachthond($extdebug, 1, '<pre>###### d) CHECK IF CONSTRUCTED MAIL ($user_email) HAS A CONFLICTING UF MATCH</pre>');
				#####################################################################################################
				$params_ufmatchget = [
					'checkPermissions' => FALSE,
					'debug' => $apidebug,
					'select' => [
     					'row_count', 
						'id', 
						'uf_id', 
						'contact_id',	
					],
					'where' => [
						['uf_name', 	'=',  $user_email],
						['contact_id', 	'!=', $contact_id],
					],
				];
      			wachthond($extdebug, 3, '<pre>params_ufmatchget: $params_ufmatchget</pre>');
				$result = civicrm_api4('UFMatch', 'get', $params_ufmatchget);
      			wachthond($extdebug, 4, '<pre>result_ufmatchget: $result</pre>');
      			wachthond($extdebug, 3, '<pre>rowcount_ufmatchget: $result->count()</pre>');
				if ($result->count() > 0 ){
					$ufmatch_contact_id = $result[0]['contact_id'];
				#}
    			#if ($ufmatch_contact_id) {
					wachthond($extdebug, 1, '<pre>------ d) ERROR  : VIA CONSTRUCTED MAIL ($user_email) EEN CONFLICTERENDE UF MATCH GEVONDEN (contactid: $ufmatch_contact_id)</pre>');
    				$drupalufmatchother_found = 1;
    			} else {
					wachthond($extdebug, 1, '<pre>------ d) PRIMA  : VIA CONSTRUCTED MAIL ($user_email) GEEN CONFLICTERENDE UF MATCH GEVONDEN</pre>');    				
    				$drupalufmatchother_found = 0;
    			}
    		#}
    			
				#####################################################################################################
    			wachthond($extdebug, 1, '<pre>###### e) CHECK IF CONSTRUCTED USERNAME ($user_name) IS ALREADY PRESENT (WITH user_load_by_name)</pre>');
				#####################################################################################################
				// M61: mogelijk security risk omdat ander account met dezelfde naam gekoppeld kan worden!!!
				// Misschien moet hier nog het emailadres aan een check toegevoegd worden
				$drupal_loadname	= user_load_by_name($user_name);
				$drupal_uid 		= $drupal_loadname->uid;
				wachthond($extdebug, 3, '<pre>drupal_loadname: $drupal_loadname</pre>');

				if ($drupal_uid > 0 AND $drupal_uid != $ufmatch_ufid) {
					wachthond($extdebug, 1, '<pre>------ e) ERROR  : VIA CONSTRUCTED NAAM ($user_name) VIA DRUPALID ($drupal_uid) CONFLICTERENDE DRUPAL NAAM GEVONDEN</pre>');
					$drupalaccount_found 		= 1;					
					$drupalaccount_nameconflict = 1;
				}
				if ($drupal_uid > 0 AND $drupal_uid == $ufmatch_ufid) {
					wachthond($extdebug, 1, '<pre>------ e) PRIMA  : VIA CONSTRUCTED NAAM ($user_name) VIA DRUPALID ($drupal_uid) CORRECTE UF MATCH GEVONDEN ($ufmatch_id)</pre>');
					$drupalaccount_found 		= 1;
					$drupalaccount_nameconflict = 0;
				}
				if (empty($drupal_uid)) {
					wachthond($extdebug, 1, '<pre>------ e) LETOP  : VIA CONSTRUCTED NAAM ($user_name) DRUPAL ACCOUNT NIET GEVONDEN</pre>');
					$drupalaccount_found 		= 0;
					$drupalaccount_nameconflict = 0;	// M61: als er geen drupal account gevonden is kan deze wel op 0. Volgende regels overrulen
				}
				#####################################################################################################
				// M61: ALS HET GOED IS IS DEZE EXTERNAL IDENTIFIER UNIEK OMDAT HET DE WAARDE IS DIE KOMT  UIT DE WERKELIJK GEKOPPELDE DRUPAL ACCOUNT
				// ALS EXTRA CHECK OOK DAT $connected_drupal_id = $connected_account->uid
				// ER ZOU NOG EEN CHECK KUNNEN OF DIT DRUPALID ERGENS VOORKOMT IN DE UF MATCH TABLE
				if ($connected_drupal_id > 0 AND $connected_drupal_id == $connected_account->uid AND $cmsidentitier == NULL) {
			    	$params_contact['values']['external_identifier'] = $connected_drupal_id;
					wachthond($extdebug, 1, '<pre>REPAIR : VOEG IN CIVICRM DE MISSENDE EXTERNAL IDENTIFIER TOE: $connected_drupal_id</pre>');
				}
				#####################################################################################################

			wachthond($extdebug, 1, '<pre>*** CREATE DRUPAL  ACCOUNT   :$user_name ***</pre>');
			wachthond($extdebug, 1, '<pre>*** DRUPAL ACCOUNT FOUND     :$drupalaccount_found ***</pre>');
			wachthond($extdebug, 1, '<pre>*** DRUPAL NAME    FOUND     :$drupalname_found ***</pre>');	
			wachthond($extdebug, 1, '<pre>*** DRUPAL MATCH   FOUND     :$drupalufmatch_found ***</pre>');
			wachthond($extdebug, 1, '<pre>*** DRUPAL MATCH   CONFLICT  :$drupalufmatchother_found *** (ERROR)</pre>');
			wachthond($extdebug, 1, '<pre>*** DRUPAL NAME    CONFLICT  :$drupalaccount_nameconflict *** (ERROR)</pre>');
			wachthond($extdebug, 1, '<pre>*** DRUPAL NAME    DANGER    :$drupalname_danger *** (ERROR)</pre>');
			wachthond($extdebug, 1, '<pre>*** DRUPAL ID      DANGER    :$drupalid_danger *** (ERROR)</pre>');
			if ($drupalaccount_nameconflict == 0 AND $drupalufmatchother_found == 0 AND $drupalname_danger == 0 AND $drupalid_danger == 0) {
				$drupalaccount_safe2update = 1;
			} else {
				$drupalaccount_safe2update = 0;
			}

			###############################################################################################################################
			# SET JOB_TITLE IF MISSING
  			wachthond($extdebug, 1, '<pre>SET JOB_TITLE IF MISSING</pre>');
			###############################################################################################################################
			wachthond($extdebug, 1, '<pre>drupalnaam: $drupalnaam</pre>');	
			wachthond($extdebug, 1, '<pre>user_name : $user_name</pre>');	

			if (empty($drupalnaam) AND $user_name) {
				$job_title 			= $user_name; // M61: om te updaten later in job_title
			}

			wachthond($extdebug, 1, '<pre>job_title : $job_title</pre>');			
			###############################################################################################################################

			#####################################################################################################
			wachthond($extdebug, 1, '<pre>###### F) CREATE DRUPAL ACCOUNT & UF_MATCH [IF DRUPALÀCCOUNT NOT FOUND ($drupalaccount_found) AND UFMATCH NOT FOUND ($drupalufmatch_found)</pre>');				
			##########################################################################################################################################
			if ($drupalname_found == 0 AND $drupalufmatch_found == 0) {
			##########################################################################################################################################

   				if ($drupalaccount_found == 0 AND $drupalaccount_safe2update == 1) {
					#####################################################################################################
					# CREATE DRUPAL USER
					#####################################################################################################
					$new_user 	= array(
 						'name'	 => $user_name,		// M61: TODO hier moet nog een check of niet account met zelfde naam wordt gemaakt (want anders error)
  						'pass'	 => $user_pwd, 		// note: do not md5 the password
  						'mail'	 => $user_email,	// M61: dit was placholder email (voor kids) omdat dubbele emails niet konden in drupal
 						'status' => 1,
  						'init'   => $user_email,
						'roles'  => array(
	   							DRUPAL_AUTHENTICATED_RID => 'authenticated user',
   								11 => 'custom role',
							),
					);
					wachthond($extdebug, 2, '<pre>Drupal user create params: $new_user</pre>');
					// The first parameter is sent blank so a new user is created.
					$account 		= user_save(NULL, $new_user);
					$drupal_uid 	= $account->uid;
					$job_title 		= $user_name;	// M61: if voor job title verderop

					#####################################################################################################
					# LADEN VAN ZOJUIST GEMAAKTE DRUPAL ACCOUNT
					#####################################################################################################
					if ($drupal_uid) {
	  					wachthond($extdebug, 1, '<pre>------ f) SUCCESS: DRUPAL USER CREATED: $user_name | drupalid: $drupal_uid</pre>');
