					$datum_vogontvangst = $part_vogontvangst;											// ZET DATUM ONTVANGST VAN ACTIVITY GELIJK AAN ONTVANGSTDATUM
				} elseif ($part_vogingediend) {
					$newdate		 	= strtotime ( '+49 day' , strtotime ($part_vogingediend) ) ;	// ZET 'DEADLINE' ONTVANGST OP 7 WEKEN NA INDIENEN AANVRAAG
					$datum_vogontvangst = date ( 'Y-m-d H:i:s' , $newdate );
				} else {																			// FICTIEVE DATUM  ACTIVITY ONTVANGST 10 WEKEN NA VERZOEKDATUM
					$datum_vogontvangst = $event_start_date;
				}

				// als nieuwe datum ontvangst > start kamp is (en binnen fiscal year) dan scheduled datum ontvangst = start kamp - 1wk DUBBELCHECK!
				if (strtotime($datum_vogontvangst) >= strtotime($event_start_date) AND strtotime($datum_vogontvangst) <= strtotime($event_fiscalyear_einde))	{
