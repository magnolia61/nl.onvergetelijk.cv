				$connected_drupal_name 	= $result_drupal['values'][0]['name'];			
				wachthond($extdebug, 3, '<pre>connected_drupal_id  	: $connected_drupal_id</pre>');
				wachthond($extdebug, 3, '<pre>connected_drupal_name	: $connected_drupal_name</pre>');
			}

  			if ($connected_drupal_name) {
	    		wachthond($extdebug, 1, '<pre>------ a) PRIMA  : VIA CID: $contact_id EEN CONNECTED DRUPAL NAAM GEVONDEN: $connected_drupal_name MET CONNECTED DRUPAL ID: $connected_drupal_id)</pre>');
  				$drupalname_found = 1;
  			} else {
				wachthond($extdebug, 1, '<pre>------ a) ERROR  : VIA CID: $contact_id GEEN DRUPAL NAAM GEVONDEN VIA CIVICRM API</pre>');
	   			wachthond($extdebug, 4, '<pre>result_drupaluser: $result_drupal</pre>');
    			$drupalname_found = 0;
  			}

			if ($user_name AND $connected_drupal_name AND $connected_drupal_name != $user_name) {
	    		wachthond($extdebug, 1, '<pre>------ a) WARNING: GEVONDEN DRUPALNAME ($connected_drupal_name) IS NIET GELIJK AAN CONSTRUCTED NAAM ($user_name)</pre>');			
    			$drupalname_danger = 1;
			} else {
    			$drupalname_danger = 0;				
			}
			if ($cmsidentitier AND $connected_drupal_id AND $connected_drupal_id != $cmsidentitier) {
