  					],
				];
      			wachthond($extdebug, 3, '<pre>params_externalid: $params_externalid</pre>');
      			$result_check 		= civicrm_api4('Contact', 'get', $params_externalid);
      			wachthond($extdebug, 4, '<pre>result_externalid: $result_check</pre>');
				if ($result_check->count() > 0 ) {
					$check_contactid 	= trim($result_check[0]['id']);
 					$check_displaynaam	= trim($result_check[0]['display_name']);
 					$check_drupalnaam	= trim($result_check[0]['job_title']);
 					$check_extid		= trim($result_check[0]['external_identifier']);
   					wachthond($extdebug, 2, '<pre>- extcheck_display_name   : $check_displaynaam</pre>');
   					wachthond($extdebug, 2, '<pre>- extcheck_account_name   : $check_drupalnaam</pre>');
   					wachthond($extdebug, 2, '<pre>- extcheck_account_uid    : $check_contactid</pre>');					
 				}
 				if ($check_contactid AND $check_contactid != $contact_id) {
					wachthond($extdebug, 1, '<pre>3) SAFE2REPAIR: DANGER: VIA CMS IDENTIFIER ($cmsidentitier) EEN ANDER CIVICRM ACCOUNT GEVONDEN WAAR DIT IN GEBRUIK IS: $check_displaynaam (contact_id: $check_contactid)</pre>');
					$drupalaccount_safe2repair_extidavailable = 0; 
 				} else {
					wachthond($extdebug, 1, '<pre>3) SAFE2REPAIR: GREEN : VIA CMS IDENTIFIER ($cmsidentitier) GEEN ANDER CIVICRM ACCOUNT GEVONDEN WAAR DIT IN GEBRUIK IS</pre>');
					$drupalaccount_safe2repair_extidavailable = 1;	 					
 				}

				#####################################################################################################
				if ($drupalaccount_safe2repair_match == 1 AND $drupalaccount_safe2repair_account == 1 AND $drupalaccount_safe2repair_extidavailable == 1) {
					wachthond($extdebug, 1, '<pre>!! SAFE2REPAIR: REPLACE CMS IDENTIFIER ($cmsidentitier) MET DRUPAL ID ($connected_drupal_id) WANT ($cmsidentitier) BESTAAT NIET (MEER)</pre>');
		    		$params_contact['values']['external_identifier'] = $connected_drupal_id;
				} else {
					wachthond($extdebug, 1, '<pre>!! SAFE2REPAIR: UPDATE CANCELLED BECAUSE OF SATETY CHECKS (CMS IDENTIFIER: $cmsidentitier)</pre>');		
				}
			 }

			#####################################################################################################
  			#if ($drupalname_found == 0) {
