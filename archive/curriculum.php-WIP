   				$intakestatusbio 	= 'ongecheckt';
   				wachthond($extdebug, 2, '<pre>DATUM BIO INGEVULD [$bioingevuld] IS OUDER DAN START VAN AFGELOPEN 3 FISCALE JAREN (INCL.HUIDIGE)[>$grensvognoggoed] DUS: [$bionodig] STATUS: [$intakestatusbio]</pre>');
