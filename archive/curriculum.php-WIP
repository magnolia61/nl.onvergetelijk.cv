				if ($part_vogingediend) { // TODO: als leiding datum in de toekomst ingaf, dat corrigeren naar datum van verzenden formulier
					$datum_vogaanvraag  = $part_vogingediend;										// ZET DATUM AANVRAAG VAN ACTIVITY GELIJK AAN AANVRAAGDATUM
				} else {
					$newdate		 	= strtotime ( '+30 day' , strtotime ($part_vogverzocht) ) ;	// ZET DEADLINE AANVRAAG OP 30 DAGEN NA VERZOEK
					$datum_vogaanvraag  = date ( 'Y-m-d H:i:s' , $newdate );
				}
				wachthond($extdebug, 2, '<pre>*. scheduled_datum_aanvraag: $datum_vogaanvraag</pre>');				
				// als nieuwe datum aanvraag > start kamp is (en binnen fiscal year) dan scheduled datum aanvraag = start kamp - 1wk DUBBELCHECK!
				if (strtotime($datum_vogaanvraag) >= strtotime($event_start_date) AND strtotime($datum_vogaanvraag) <= strtotime($event_fiscalyear_einde))	{				
					if ($welkeweeknr == 2) {
						$newdate			= strtotime ( '+7 day' , strtotime ($event_start_date) ) ;
						$datum_vogaanvraag 	= date ( 'Y-m-d' , $newdate );
					} else {
						$datum_vogaanvraag 	= $event_start_date;
					}

					wachthond($extdebug, 1, '<pre>AANVRAAG > STARTDATE: nieuwe datum aanvraag ivm weeknr $welkeweeknr: $datum_vogaanvraag</pre>');
				}

				if (empty($part_vogingediend) AND $part_vogdatum) {
					$datum_vogaanvraag = $part_vogdatum;
