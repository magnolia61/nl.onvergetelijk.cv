  				wachthond($extdebug, 1, '<pre>--- 13.4 CREATE AN ACTIVITY VOGAANVRAAG  (ALS VOG AANVRAAG IS VERZOCHT OF INGEDIEND EN ER IS NOG GEEN BIJBEHORENDE ACTIVITY)</pre>');

