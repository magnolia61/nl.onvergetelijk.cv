					if ($extvog == 1)	{
						$result = civicrm_api4('Activity', 'update', $params_activity_vogaanvraag_change);
						wachthond($extdebug, 2, '<pre>params_activity_vogaanvraag_change EXECUTED [groupID: $groupID]</pre>');
						wachthond($extdebug, 4, '<pre>result_activity_vogaanvraag_change: $result</pre>');
					}
				}
				// *****************************************************************************************************************
				// 15.5 UPDATE ACTIVITY VOG ONTVANGST STATUS NAV DAYS SINCE...
				wachthond($extdebug, 1, '<pre>--- 15.5 UPDATE ACTIVITY VOG ONTVANGST STATUS NAV DAYS SINCE ($dayssinceaanvraag)</pre>');	
				// *****************************************************************************************************************
				#if ((in_array($vogontvangst_activity_status, array("1", "4", "5", "8")) AND in_array($vogaanvraag_activity_status, array("2"))) AND $part_vogdatum AND $vognodig != 'noggoed') {
				if ($vogontvangst_activity_id AND $datum_vogontvangst AND $status_vogontvangst) {

					$params_activity_vogontvangst_change = [
  					'checkPermissions' => FALSE,
					'debug' => $apidebug,
	  					'where' => [
    						['id', 					'=', $vogontvangst_activity_id],
  						],
  						'values' => [
							'activity_date_time'	 	=> $datum_vogontvangst,
  							'status_id:name'		 	=> $status_vogontvangst,
  							'assignee_contact_id'	 	=> $related_hoofdleiding_id,
  							'ACT_VOG.datum_verzoek'	 	=> $part_vogverzocht,
  							'ACT_VOG.datum_aanvraag' 	=> $part_vogingediend,
  							'ACT_VOG.datum_ontvangst'	=> $part_vogontvangst,
  							'ACT_VOG.datum_kamp'	 	=> $event_start_date,
			   				'ACT_ALG.kampkort'			=> $welkkampkort,
			   				'ACT_ALG.kampfunctie' 		=> $part_functie,
			    			'ACT_ALG.kampstart' 		=> $event_start_date,
			    			'ACT_ALG.kampeinde' 		=> $event_einde_date, 				
			   				'ACT_ALG.kampjaar'			=> $event_kampjaar,
							'ACT_ALG.modified' 			=> $today_datetime,  							
  						],
					];

  					wachthond($extdebug, 3, '<pre>params_activity_vogontvangst_change: $params_activity_vogontvangst_change</pre>');
					if ($extvog == 1)	{
						$result = civicrm_api4('Activity', 'update', $params_activity_vogontvangst_change);
						wachthond($extdebug, 2, '<pre>params_activity_vogontvangst_change EXECUTED [groupID: $groupID]</pre>');
						wachthond($extdebug, 4, '<pre>result_activity_vogontvangst_change: $result</pre>');
					}
				}
			}

			#####################################################################################################
			# BEPAAL DE WAARDE VAN INTAKE NODIG
 			#####################################################################################################

			wachthond($extdebug, 2, '<pre>intnodig_ditjaar : $intnodig</pre>');
			wachthond($extdebug, 2, '<pre>bionodig_ditjaar : $bionodig</pre>');
			wachthond($extdebug, 2, '<pre>refnodig_ditjaar : $refnodig</pre>');
    		wachthond($extdebug, 2, '<pre>vognodig_ditjaar : $vognodig</pre>');

    		wachthond($extdebug, 2, '<pre>part_functie: $part_functie</pre>');
    		#if ($vognodignextyear == 1) 			{ $bionodig = 'noggoed';; $refnodig = 'noggoed'; }
    		#if ($ditjaarleidnot == 1)				{ $vognodig = ''	   ; $refnodig = ''; 		}

			### STATUS EERSTE KEER

			if ($vognodig == 'eerstex') {		// M61: TREK INTNODIG GELIJK MET VOGNODIG
				$intnodig  = 'eerstex';
				$nawnodig  = 'eerstex';				
			}

			### STATUS NOG GOED

			if ($vognodig == 'noggoed') {		// M61: TREK INTNODIG GELIJK MET VOGNODIG
				$intnodig  = 'noggoed';
			}

			### STATUS OPNIEUW

			if ($bionodig == 'opnieuw' AND $refnodig == 'opnieuw' AND $vognodig == 'opnieuw') {
				$intnodig  = 'opnieuw';
			}
			if ($vognodig == 'opnieuw') {		// M61: TREK INTNODIG GELIJK MET VOGNODIG
				$intnodig  = 'opnieuw';
				$bionodig  = 'opnieuw';
				#$refnodig  = 'opnieuw';
			}

			if (in_array($part_functie, array('hoofdleiding', 'bestuurslid', 'kampstaf'))) {
				$intnodig  = 'elkjaar';
				$bionodig  = 'elkjaar';
				#$refnodig  = 'elkjaar';
				$vognodig  = 'elkjaar';
			}

			### STATUS INHAAL

			if (in_array($refnodig, array("inhaal"))) {
				$intnodig 	= 'inhaal';
			}						

			wachthond($extdebug, 2, '<pre>intnodig_ditjaar : $intnodig</pre>');
			wachthond($extdebug, 2, '<pre>bionodig_ditjaar : $bionodig</pre>');
			wachthond($extdebug, 2, '<pre>refnodig_ditjaar : $refnodig</pre>');
    		wachthond($extdebug, 2, '<pre>vognodig_ditjaar : $vognodig</pre>');
    		#wachthond($extdebug, 2, '<pre>vognodig_nextyear: $vognodignextyear</pre>');

   			wachthond($extdebug, 2, '<pre>intakestatusint  : $intakestatusint</pre>');
   			wachthond($extdebug, 2, '<pre>intakestatusbio  : $intakestatusbio</pre>');
   			wachthond($extdebug, 2, '<pre>intakestatusref  : $intakestatusref</pre>');
			wachthond($extdebug, 2, '<pre>intakestatusvog  : $intakestatusvog</pre>');	

			#####################################################################################################
			# BEPAAL DE WAARDE VAN INTAKE STATUS
			#####################################################################################################
			wachthond($extdebug, 1, '<pre>### BEPAAL DE INTAKE STATUS [groupID: $groupID] [op: $op] ###</pre>');

			$intakestatusinttodo = 0;
			$intakestatusintdone = 0;

			if (in_array($bionodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakebionodig	= 1; }
			if (in_array($refnodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakerefnodig = 1; }
			if (in_array($vognodig,array("eerstex","elkjaar","opnieuw","inhaal"))) 	{	$intakevognodig	= 1; }

			wachthond($extdebug, 1, '<pre>------#########################################################</pre>');

			if (in_array($bionodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($intakestatusbio, array("noggoed", "bijgewerkt"))) 						{
				$intakestatusbiotodo	= 1;
			}

			if (in_array($refnodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND 
				in_array($intakestatusref, array("noggoed", "bekend", "gevraagd", "ontvangen"))) 	{
				$intakestatusreftodo	= 1;
			}

			if (in_array($vognodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($intakestatusvog, array("noggoed", "ingediend","ontvangen"))) 				{
				$intakestatusvogtodo	= 1;
			}

			wachthond($extdebug, 1, '<pre>intakestatusbiotodo  : $intakestatusbiotodo</pre>');
			wachthond($extdebug, 1, '<pre>intakestatusreftodo  : $intakestatusreftodo</pre>');
			wachthond($extdebug, 1, '<pre>intakestatusvogtodo  : $intakestatusvogtodo</pre>');

			$intakestatusnodig 		= $intakebionodig 		+ $intakerefnodig 		+ $intakevognodig;
			$intakestatusinttodo 	= $intakestatusbiotodo 	+ $intakestatusreftodo 	+ $intakestatusvogtodo;

			wachthond($extdebug, 1, '<pre>------#########################################################</pre>');

			if (in_array($intakestatusbio, array("noggoed", "bijgewerkt"))) 						{	$intakestatusbiodone	= 1;	}
			if (in_array($intakestatusref, array("noggoed", "ontvangen"))) 							{	$intakestatusrefdone	= 1;	}
			if (in_array($intakestatusvog, array("noggoed", "ontvangen"))) 							{	$intakestatusvogdone	= 1;	}

			wachthond($extdebug, 1, '<pre>intakestatusbiodone  : $intakestatusbiodone</pre>');
			wachthond($extdebug, 1, '<pre>intakestatusrefdone  : $intakestatusrefdone</pre>');
			wachthond($extdebug, 1, '<pre>intakestatusvogdone  : $intakestatusvogdone</pre>');

			$intakestatusintdone = $intakestatusbiodone + $intakestatusrefdone + $intakestatusvogdone;

			wachthond($extdebug, 1, '<pre>------#########################################################</pre>');

			wachthond($extdebug, 2, '<pre>intakestatusinttodo  : $intakestatusinttodo</pre>');
			wachthond($extdebug, 2, '<pre>intakestatusintdone  : $intakestatusintdone</pre>');
			wachthond($extdebug, 2, '<pre>intakestatusint      : $intakestatusint</pre>');

			wachthond($extdebug, 1, '<pre>------#########################################################</pre>');

			if ($intakestatusinttodo < $intakestatusnodig AND $intakestatusinttodo > 0) {
				$intakestatusint  	= 'gedeeltelijk';
			}
			if ($intakestatusinttodo == 0 AND in_array($intakestatusvog, array("verzocht"))) {
				$intakestatusint  	= 'nognix';
			}
			if ($intakestatusintdone == $intakestatusnodig) {
				$intakestatusint  	= 'compleet';
			}
			if ($intakestatusintdone < $intakestatusnodig AND $intakestatusinttodo == $intakestatusnodig) {
				$intakestatusint  	= 'afwachting';
			}
			if (in_array($intakestatusvog, array("klaarzetten"))) {
				$intakestatusint  	= 'klaarzetten';
			}

			wachthond($extdebug, 1, '<pre>intakestatusinttodo  : $intakestatusinttodo</pre>');
			wachthond($extdebug, 1, '<pre>intakestatusintdone  : $intakestatusintdone</pre>');
			wachthond($extdebug, 1, '<pre>intakestatusint      : $intakestatusint</pre>');

			wachthond($extdebug, 1, '<pre>------#########################################################</pre>');

			if ($ditjaarleidyes == 1 OR $ditjaarleidstf == 1) {

				if ($intnodig)		{ $params_participant['values']['PART.PART_intnodig:name']	= $intnodig;	}	#PART NODIG INT
				if ($nawnodig)		{ $params_participant['values']['PART.PART_nawnodig:name']	= $nawnodig;	}	#PART NODIG NAW
				if ($bionodig)		{ $params_participant['values']['PART.PART_bionodig:name']	= $bionodig;	}	#PART NODIG BIO
				if ($refnodig)		{ $params_participant['values']['PART.PART_refnodig:name']	= $refnodig; 	}	#PART NODIG REF
				if ($vognodig)		{ $params_participant['values']['PART.PART_vognodig:name']	= $vognodig;	}	#PART NODIG VOG

				if ($intnodig)		{ $params_contact['values']['INTAKE.DITJAAR_INT_nodig'] 	= $intnodig;	}	#TAB  NODIG INT
// M61: TODO: nawnodig veld is weg bij contact_intake maar staat nog wel in part_intake: TODO: kijken of dit op meer plekken wegkan
#				if ($nawnodig)		{ $params_contact['values']['INTAKE.DITJAAR_NAW_nodig']		= $nawnodig;	}	#TAB  NODIG NAW
				if ($bionodig)		{ $params_contact['values']['INTAKE.DITJAAR_BIO_nodig']		= $bionodig;	}	#TAB  NODIG BIO
				if ($refnodig)		{ $params_contact['values']['INTAKE.DITJAAR_REF_nodig'] 	= $refnodig;	}	#TAB  NODIG VOG
				if ($vognodig)		{ $params_contact['values']['INTAKE.DITJAAR_VOG_nodig'] 	= $vognodig;	}	#TAB  NODIG REF

				wachthond($extdebug, 1, '<pre>intnodig_ditjaar : $intnodig</pre>');
				wachthond($extdebug, 1, '<pre>nawnodig_ditjaar : $nawnodig</pre>');
				wachthond($extdebug, 1, '<pre>bionodig_ditjaar : $bionodig</pre>');
				wachthond($extdebug, 1, '<pre>refnodig_ditjaar : $refnodig</pre>');
    			wachthond($extdebug, 1, '<pre>vognodig_ditjaar : $vognodig</pre>');

				if ($intakestatusint)	{ $params_contact['values']['INTAKE.Status_INT'] 	= $intakestatusint; }
				if ($intakestatusnaw)	{ $params_contact['values']['INTAKE.Status_NAW'] 	= $intakestatusnaw; }
				if ($intakestatusbio)	{ $params_contact['values']['INTAKE.Status_BIO'] 	= $intakestatusbio; }	
				if ($intakestatusref)	{ $params_contact['values']['INTAKE.Status_REF'] 	= $intakestatusref; }
				if ($intakestatusvog)	{ $params_contact['values']['INTAKE.Status_VOG'] 	= $intakestatusvog; }

				wachthond($extdebug, 1, '<pre>intakestatusint  : $intakestatusint</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusnaw  : $intakestatusnaw</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusbio  : $intakestatusbio</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusref  : $intakestatusref</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusvog  : $intakestatusvog</pre>');
			}

			if ($extvog == 1 AND (in_array($groupID, array("140", "213")))) {
			###############################################################################################################
			### 16. DELETE ACTIVITIES (indien: 1. ze waren aangemaakt maar VOG nog goed was 2. er dit jaar geen verzoek was 3. de status niet completed was
			###############################################################################################################
				wachthond($extdebug, 1, '<pre>### 16. VOG ACTIVITIES [DELETE] [groupID: $groupID] [op: $op] ###</pre>');
				if ($extvog == 1 AND (in_array($intnodig, array("noggoed")) OR $ditjaarleidnot == 1)) {
					#wachthond($extdebug, 2, '<pre>ditjaarleidnot: $ditjaarleidnot</pre>');
					#wachthond($extdebug, 2, '<pre>vogverzoek_activity_status: $vogverzoek_activity_status</pre>');

					wachthond($extdebug, 2, '<pre>refpersoon_activity_id: $refpersoon_activity_id</pre>');
					wachthond($extdebug, 2, '<pre>refverzoek_activity_id: $refverzoek_activity_id</pre>');

					wachthond($extdebug, 2, '<pre>vogverzoek_activity_id: $vogverzoek_activity_id</pre>');
					wachthond($extdebug, 2, '<pre>vogontvangst_activity_id: $vogontvangst_activity_id</pre>');

			    	if ($refpersoon_activity_id 	AND $refpersoon_activity_status != 2)	{
			    		$result = civicrm_api3('Activity', 'delete', array('id' => $refpersoon_activity_id,));
			    		wachthond($extdebug, 1, '<pre>ACTIVITY VERWIJDERD refpersoon: $refpersoon_activity_id</pre>');
			    	}			    	
			    	if ($refverzoek_activity_id 	AND $refverzoek_activity_status != 2)	{
			    		$result = civicrm_api3('Activity', 'delete', array('id' => $refverzoek_activity_id,));
			    		wachthond($extdebug, 1, '<pre>ACTIVITY VERWIJDERD refverzoek: $refverzoek_activity_id</pre>');
			    	}			    	

			    	if ($vogverzoek_activity_id 	AND $vogverzoek_activity_status != 2)	{
			    		$result = civicrm_api3('Activity', 'delete', array('id' => $vogverzoek_activity_id,));
			    		wachthond($extdebug, 1, '<pre>ACTIVITY VERWIJDERD vogverzoek: $vogverzoek_activity_id</pre>');
			    	}
			    	if ($vogaanvraag_activity_id 	AND $vogaanvraag_activity_status != 2)	{
			    		$result = civicrm_api3('Activity', 'delete', array('id' => $vogaanvraag_activity_id,));
			    		wachthond($extdebug, 1, '<pre>ACTIVITY VERWIJDERD vogaanvraag: $vogaanvraag_activity_id</pre>');
			    	}
			    	if ($vogontvangst_activity_id 	AND $vogontvangst_activity_status != 2)	{
			    		$result = civicrm_api3('Activity', 'delete', array('id' => $vogontvangst_activity_id,));
			    		wachthond($extdebug, 1, '<pre>ACTIVITY VERWIJDERD vogontvangst: $vogontvangst_activity_id</pre>');
			    	}
				}
			}
			####################################################################################################
			### 17 GET ACTIVITIES MBT. VOG
			###############################################################################################################
   				wachthond($extdebug, 1, '<pre>### 17. VOG ACTIVITIES [GET] [groupID: $groupID] [op: $op] ###</pre>');
				// ************************************************************************************************************
				// 17.1 GET ACTIVITIES 'VOG VERZOEK'
				// ************************************************************************************************************
				$params_activity_2_vogverzoek_get = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'select' => [
	    				'id', 'activity_date_time', 'status_id', 'status_id:name', 'subject',
  					],
					'join' => [
    					['ActivityContact AS activity_contact', 'INNER'],
					],
		   			'where' => [
    					['activity_contact.contact_id', 	'=', $contact_id],
    					['activity_contact.record_type_id', '=', 3],
    					['activity_type_id:name', 			'=', 'VOG_verzoek'],
    					['activity_date_time', 				'BETWEEN', array("$event_fiscalyear_start", "$event_fiscalyear_einde")],
  					],
				];

  				#wachthond($extdebug, 3, '<pre>params_activity_2_vogverzoek_get: $params_activity_2_vogverzoek_get</pre>');
  				$result_vogverzoek 			= civicrm_api4('Activity', 'get', $params_activity_2_vogverzoek_get);
  				$result_vogverzoek_count 	= $result_vogverzoek->count();
  				#wachthond($extdebug, 3, '<pre>result_activity_2_vogverzoek_get_: $result_vogverzoek</pre>');
  				wachthond($extdebug, 4, '<pre>result_count_vogverzoek: $result_vogverzoek_count</pre>');
  				if ($result_vogverzoek_count == 1) {
  					$vogverzoek_activity_2_id				= $result_vogverzoek[0]['id'];
  					$vogverzoek_activity_2_status			= $result_vogverzoek[0]['status_id'];
  					$vogverzoek_activity_2_status_name		= $result_vogverzoek[0]['status_id:name'];
  					$vogverzoek_activity_2_datum			= $result_vogverzoek[0]['activity_date_time'];
	  				wachthond($extdebug, 2, '<pre>vogverzoek_activity_2_id: $vogverzoek_activity_2_id</pre>');
					#wachthond($extdebug, 2, '<pre>vogverzoek_activity_2_status: $vogverzoek_activity_2_status</pre>');
					wachthond($extdebug, 2, '<pre>vogverzoek_activity_2_status_name: $vogverzoek_activity_2_status_name</pre>');
					wachthond($extdebug, 2, '<pre>vogverzoek_activity_2_datum: $vogverzoek_activity_2_datum</pre>');
  				} else {
					$vogverzoek_activity_2_id		= NULL;
  					$vogverzoek_activity_2_status	= NULL;
  					wachthond($extdebug, 2, '<pre>vogverzoek_activity_2_id: No Activity Found (VOG verzocht: $part_vogverzocht</pre>');
  				}
				// ************************************************************************************************************
				// 17.2 GET ACTIVITIES 'VOG AANVRAAG'
				// ************************************************************************************************************
				$params_activity_2_vogaanvraag_get = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'select' => [
	    				'id', 'activity_date_time', 'status_id', 'status_id:name', 'subject',
  					],
					'join' => [
    					['ActivityContact AS activity_contact', 'INNER'],
					],
		   			'where' => [
    					['activity_contact.contact_id', 	'=', $contact_id],
    					['activity_contact.record_type_id', '=', 3],
    					['activity_type_id:name', 			'=', 'VOG_aanvraag'],
    					['activity_date_time', 				'BETWEEN', array("$event_fiscalyear_start", "$event_fiscalyear_einde")],
  					],
				];

  				#wachthond($extdebug, 3, '<pre>params_activity_2_vogaanvraag_get: $params_activity_2_vogaanvraag_get</pre>');
   				$result_vogaanvraag 		= civicrm_api4('Activity', 'get', $params_activity_2_vogaanvraag_get);
   				$result_vogaanvraag_count 	= $result_vogaanvraag->count();
  				#wachthond($extdebug, 3, '<pre>result_activity_2_vogaanvraag_get: $result_vogaanvraag</pre>');
  				wachthond($extdebug, 4, '<pre>result_count_vogaanvraag: $result_vogaanvraag_count</pre>');
  				if ($result_vogaanvraag_count == 1) {
  					$vogaanvraag_activity_2_id				= $result_vogaanvraag[0]['id'];
  					$vogaanvraag_activity_2_status			= $result_vogaanvraag[0]['status_id'];
  					$vogaanvraag_activity_2_status_name		= $result_vogaanvraag[0]['status_id:name'];
  					$vogaanvraag_activity_2_datum			= $result_vogaanvraag[0]['activity_date_time'];
	  				wachthond($extdebug, 2, '<pre>vogaanvraag_activity_2_id: $vogaanvraag_activity_2_id</pre>');
  					#wachthond($extdebug, 2, '<pre>vogaanvraag_activity_2_status: $vogaanvraag_activity_2_status</pre>');
  					wachthond($extdebug, 2, '<pre>vogaanvraag_activity_2_status_name: $vogaanvraag_activity_2_status_name</pre>');
					wachthond($extdebug, 2, '<pre>vogaanvraag_activity_2_datum: $vogaanvraag_activity_2_datum</pre>');
  				} else {
					$vogaanvraag_activity_2_id		= NULL;
  					$vogaanvraag_activity_2_status	= NULL;
  					wachthond($extdebug, 2, '<pre>vogaanvraag_activity_2_id: No Activity Found (VOG ingediend: $part_vogingediend</pre>');
  				}

				// ************************************************************************************************************
				// 17.3 GET ACTIVITIES 'VOG ONTVANGST'
				// ************************************************************************************************************
				$params_activity_2_vogontvangst_get = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
  					'select' => [
	    				'id', 'activity_date_time', 'status_id', 'status_id:name', 'subject',
  					],
					'join' => [
    					['ActivityContact AS activity_contact', 'INNER'],
					],
		   			'where' => [
    					['activity_contact.contact_id', 	'=', $contact_id],
    					['activity_contact.record_type_id', '=', 3],
    					['activity_type_id:name', 			'=', 'VOG_ontvangst'],
    					['activity_date_time', 				'BETWEEN', array("$event_fiscalyear_start", "$event_fiscalyear_einde")],
  					],
				];

  				#wachthond($extdebug, 3, '<pre>params_activity_2_vogontvangst_get: $params_activity_2_vogontvangst_get</pre>');
  				$result_vogontvangst 		= civicrm_api4('Activity', 'get', $params_activity_2_vogontvangst_get);
   				$result_vogontvangst_count 	= $result_vogontvangst->count();
  				wachthond($extdebug, 4, '<pre>params_activity_2_vogontvangst_get: $result_vogontvangst</pre>');
  				wachthond($extdebug, 4, '<pre>result_count_ontvangst: $result_vogaanvraag_count</pre>');
  				if ($result_vogontvangst_count == 1) {
  					$vogontvangst_activity_2_id				= $result_vogontvangst[0]['id'];
  					$vogontvangst_activity_2_status			= $result_vogontvangst[0]['status_id'];
  					$vogontvangst_activity_2_status_name	= $result_vogontvangst[0]['status_id:name'];
  					$vogontvangst_activity_2_datum			= $result_vogontvangst[0]['activity_date_time'];
	  				wachthond($extdebug, 2, '<pre>vogontvangst_activity_2_id: $vogontvangst_activity_2_id</pre>');
					#wachthond($extdebug, 2, '<pre>vogontvangst_activity_2_status: $vogontvangst_activity_2_status</pre>');
					wachthond($extdebug, 2, '<pre>vogontvangst_activity_2_status_name: $vogontvangst_activity_2_status_name</pre>');
					wachthond($extdebug, 2, '<pre>vogontvangst_activity_2_datum: $vogontvangst_activity_2_datum</pre>');
  				} else {
					$vogontvangst_activity_2_id		= NULL;
  					$vogontvangst_activity_2_status	= NULL;
  					wachthond($extdebug, 2, '<pre>vogaanvraag_activity_2_id: No Activity Found (VOG ontvangst: $part_vogontvangst</pre>');
  				}
    		}

	###############################################################################################################
	### 99 WRITE CONTACT & PARTICIPANT DATA TO DB
	###############################################################################################################
	wachthond($extdebug, 1, '<pre>### 99. WRITE CONTACT & PARTICIPANT DATA TO DB [groupID: $groupID] [op: $op] ###</pre>');
	###############################################################################################################

	if (!empty($params_contact)) {

		ksort($params_contact['values']);
		#$params_contact['reload']			= TRUE;
		$params_contact['checkPermissions']	= FALSE;
		$params_contact['debug']			= $apidebug;		
		if ($contact_id) {
			wachthond($extdebug, 1, '<pre>params_contact: $params_contact</pre>');
			$result = civicrm_api4('Contact', 'update', $params_contact);
			wachthond($extdebug, 1, '<pre>params_contact CV UPDATE EXECUTED [groupID: $groupID]</pre>');
			wachthond($extdebug, 4, '<pre>result_contact: $result</pre>');
		}
	}

	if (!empty($params_participant)) {

		ksort($params_participant);
		#$params_participant['reload']			= TRUE;
		$params_participant['checkPermissions']	= FALSE;
		$params_participant['debug']			= $apidebug;
		if ($part_id) {
			wachthond($extdebug, 1, '<pre>params_participant: $params_participant</pre>');
			$result = civicrm_api4('Participant', 'update', $params_participant);
			wachthond($extdebug, 1, '<pre>params_participant CV UPDATE EXECUTED [groupID: $groupID]</pre>');
			wachthond($extdebug, 4, '<pre>result_participant $result</pre>');
		}
	}
    if (in_array($groupID, array("190", "140"))) { 	// CV & PART
	   	wachthond($extdebug, 1, '<pre>*** END EXTENSION VOG [groupID: $groupID] [op: $op] [entityID: $entityID] $part_functie: $displayname] ***</pre>');
	}
    if (in_array($groupID, array("225", "139"))) { // CV & PART
	   	wachthond($extdebug, 1, '<pre>*** END EXTENSION CV [groupID: $groupID] [op: $op] [entityID: $entityID] $part_functie: $displayname] ***</pre>');
	}	
}

