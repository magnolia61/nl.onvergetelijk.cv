require_once 'curriculum.civix.php';


/**
 * This example compares the submitted value of a field with its current value.
 *
 * @param string $op
 *   The type of operation being performed.
 * @param int $groupID
 *   The custom group ID.
 * @param int $entityID
 *   The entityID of the row in the custom table.
 * @param array $params
 *   The parameters that were sent into the calling function.
 */

function implode_recursive(string $separator, array $array): string
{
    $string = '';
    foreach ($array as $i => $a) {
        if (is_array($a)) {
            $string .= implode_recursive($separator, $a);
        } else {
            $string .= $a;
            if ($i < count($array) - 1) {
                $string .= $separator;
            }
        }
    }

    return $string;
}

function wachthond (int $extdebug, int $severity, string $message) {

	if ($severity <= $extdebug) {
		watchdog('php', $message, NULL, WATCHDOG_DEBUG);
    }
}

function curriculum_civicrm_customPre(string $op, int $groupID, int $entityID, array &$params): void {

  	$extdebug	= 2; // 1 = basic // 2 = verbose // 3 = params / 4 = results

  	#wachthond($extdebug, 1, '<pre>op                    : $op</pre>');
  	#wachthond($extdebug, 1, '<pre>groupID               : $groupID</pre>');
  	#wachthond($extdebug, 1, '<pre>entityID              : $entityID</pre>');
  	#wachthond($extdebug, 1, '<pre>params                : $params</pre>');

  	if ($params[0]['table_name'] 	== 'civicrm_value_aandachtspunten_gedrag_1') 	{
   		$deltacategory = 'gedrag';
  	}
  	if ($params[0]['table_name'] 	== 'civicrm_value_medisch_148') 				{
   		$deltacategory = 'medisch';
  	}
#  	if ($params[0]['column_name'] == 'ditjaar_voorkeur_1208') 						{
#  		$deltacategory = 'voorkeur';
#  	}

	#wachthond($extdebug, 1, '<pre>deltacategory       	: $deltacategory</pre>');
	#$keys = array_keys(array_combine(array_keys($params), array_column($params, 'table_name')),'civicrm_value_aandachtspunten_gedrag_1');  	
  	#wachthond($extdebug, 1, '<pre>keys met gedrag       	: $keys</pre>');

  	if (in_array($deltacategory, array('gedrag', 'medisch', 'voorkeur'))) {

  		foreach ($params as $field) {

			$oldarray = [];
			$newarray = [];
			$oldvalue = NULL;
			$newvalue = NULL;
			$oldflat  = NULL;
			$newflat  = NULL;

			#wachthond($extdebug, 1, '<pre>field        		: $field</pre>');

			$fieldname	= $field['column_name'];
			$fieldid	= $field['custom_field_id'];
  			$newvalue 	= $field['value'];

       		$oldvalue 	= civicrm_api3('Contact', 'getvalue', [
       			'id'     => $field['entity_id'],				// ik denk dat dit alleen klopt bij contact id en niet als het part id is
       			'return' => "custom_{$field['custom_field_id']}",
       		]);

  			if (empty($oldvalue)) {
#  				$oldvalue = NULL;
  			}
  			if (empty($newvalue)) {
#  				$newvalue = NULL;
  			} 

			if (is_array($oldvalue)) {
				$oldflat 		= implode(" / ",$oldvalue);
#				if (!empty($oldflat))	{
#					$oldarray		= array_filter($oldvalue);
					$oldarray		= $oldvalue;
#				}
				$oldvaluetype 	= "array";
			} else {
				$oldflat		= trim($oldvalue);
				$oldvaluetype 	= "strng";
			}

			$newvalue 	= trim($newvalue, '');
			$newvalue 	= str_replace('', ' / ', trim($newvalue));
			$newflat 	= trim($newvalue);

			$newsec = strtotime($newflat);
			#wachthond($extdebug, 1, '<pre>newsec  ($fieldname)    : $newsec</pre>');
			$newdate = date("Y-m-d H:i:s", $newsec);  
			#wachthond($extdebug, 1, '<pre>newdate                     : $newdate ($fieldname)</pre>');
			if ($newdate == $oldflat) {
				$newflat = $newdate;
			}

			#wachthond($extdebug, 1, '<pre>oldvalue 0 ($oldvaluetype)          : $oldvalue</pre>');
			wachthond($extdebug, 1, '<pre>oldflat  0 ($oldvaluetype)          : $oldflat</pre>');
			#wachthond($extdebug, 1, '<pre>newvalue 0 ($oldvaluetype)          : $newvalue</pre>');
			wachthond($extdebug, 1, '<pre>newflat  0 ($oldvaluetype)          : $newflat</pre>');

			if ($oldflat != $newflat) {

  				##############################
  				#### OLDVALUE ARRAY ####
  				##############################

				#wachthond($extdebug, 1, '<pre>optionvalue old             : $optionvalue</pre>');				
				$customFields = civicrm_api4('CustomField', 'get', [
					'select' => [
				    	'label',
				    	'data_type',
				    	'html_type',
				    	'option_group_id'
  					],
  					'where' => [
   						['id', '=', $fieldid],
 					],
  					'limit' => 1,
  					'checkPermissions' => FALSE,
				]);
				$customFieldName 		= $customFields[0]['label'];
				$customFieldDataType	= $customFields[0]['data_type'];
				$customFieldHtmlType	= $customFields[0]['html_type'];
				$customFieldOptionGroup = $customFields[0]['option_group_id'];
				$customFieldNameLenght	= strlen($customFieldName);

				wachthond($extdebug, 2, '<pre>################################################################</pre>');
				wachthond($extdebug, 2, '<pre>### customFieldName (old)   : $customFieldName ($customFieldDataType / $customFieldHtmlType) $customFieldOptionGroup</pre>');
				wachthond($extdebug, 2, '<pre>################################################################</pre>');

				wachthond($extdebug, 1, '<pre>oldvalue 1 ($oldvaluetype)          : $oldvalue</pre>');
  				wachthond($extdebug, 1, '<pre>newvalue 1 ($oldvaluetype)          : $newvalue</pre>');

				if ($customFieldNameLenght < 24 AND $customFieldNameLenght >= 16) {
					$tab = "\t";
				} elseif ($customFieldNameLenght < 16 AND $customFieldNameLenght >= 8) {
					$tab = "\t\t";
				} elseif ($customFieldNameLenght < 8) {
					$tab = "\t\t\t";
				} else {
					$tab = "\t";						
				}				

				if (empty($oldvalue))	{ $oldvalue = '(was leeg)'; 	}

				if (in_array($customFieldDataType, array("Boolean"))) {

					if ($oldvalue == '1') 	{ $oldvalue = 'ja';  			}
					if ($oldvalue == '0') 	{ $oldvalue = 'nee'; 			}					

					wachthond($extdebug, 2, '<pre>OLDVALUE (boolean)          : $oldvalue</pre>');
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;	

				} elseif (in_array($customFieldHtmlType, array("Select Date"))) {

					wachthond($extdebug, 2, '<pre>OLDVALUE (date)              : $oldvalue</pre>');
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;	

				} elseif (in_array($customFieldHtmlType, array("Text","TextArea"))) {

					if (empty($oldvalue))	{ $oldvalue = '(was leeg)'; 	}
					wachthond($extdebug, 2, '<pre>OLDVALUE (string)           : $oldvalue</pre>');
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;	

				} elseif (in_array($customFieldHtmlType, array("Radio", "Select"))) {

						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $oldvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						wachthond($extdebug, 3, '<pre>params_optionvalues: $params_optionvalues</pre>');
