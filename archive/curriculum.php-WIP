		wachthond($extdebug, 3, '<pre>params_partinfo_get: $params_partinfo</pre>');
		if ($params_var) { $result_part = civicrm_api4('Participant', 'get', $params_partinfo); }
		wachthond($extdebug, 4, '<pre>result_partinfo_get: $result_part</pre>');

		#####################################################################################################
		# BEKIJK NU OF ER INDERDAAD EEN GELDIG PARTICIPANT RECORD IS
		#####################################################################################################

		if ($result_part->count() == 0) {
			wachthond($extdebug, 1, '<pre>2ERROR  : GEEN PARTICIPANT INFO GEVONDEN</pre>');
		}
		if ($result_part->count() == 1) {
			wachthond($extdebug, 1, '<pre>2SUCCESS: 1 PARTICIPANT RECORD GEVONDEN</pre>');
			$part_status_id 		= $result_part[0]['status_id'];
		}
		if ($result_part->count() > 1) {
			wachthond($extdebug, 1, '<pre>2ERROR  : MEER DAN 1 PARTICIPANT RECORDS GEVONDEN</pre>'); // M61: hier juiste vd 2 bepalen
		}

