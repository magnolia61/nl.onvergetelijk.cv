			if ($welkkampkort == 'JK1')	{ $related_hoofdleiding_id = 14203;}
			if ($welkkampkort == 'JK2')	{ $related_hoofdleiding_id = 14204;}
			if ($welkkampkort == 'TOP')	{ $related_hoofdleiding_id = 14205;}

  			if (in_array($groupID, array("139", "190"))) {	// PART DEEL + PART LEID
				if (empty($related_hoofdleiding_relid) AND $related_hoofdleiding_id > 0) {

		    		wachthond($extdebug, 1, '<pre>### 4.5 CREATE RELATED HOOFDLEIDING [groupID: $groupID] ###</pre>');
					$params_create_rel_hldn = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
  						'values' => [
    	  					'contact_id_a' 			=> $contact_id,
      						'contact_id_b' 			=> $related_hoofdleiding_id,
      						'relationship_type_id' 	=> 17,
      						'start_date' 			=> $event_fiscalyear_start,
      						'end_date' 				=> $event_fiscalyear_einde,
	      					'is_active'				=> 1,
	      				],
	      			];
					wachthond($extdebug, 3, '<pre>params_create_rel_hldn: $params_create_rel_hldn</pre>');
					$result_create_rel_hldn = civicrm_api4('Relationship', 'create', $params_create_rel_hldn);
					wachthond($extdebug, 4, '<pre>result_create_rel_hldn: $result_create_rel_hldn</pre>');
    				wachthond($extdebug, 1, '<pre>Related Hoofdleiding Relatie: aangemaakt</pre>');
	      		}
  			}
  		}

		#####################################################################################################
		# 4.5b UPDATE RELATED HOOFDLEIDING
		#####################################################################################################
	    if ($extrel == 1 AND ($ditjaardeelyes == 1 OR $ditjaarleidyes == 1 OR $ditjaardeelmss == 1 OR $ditjaarleidmss == 1)) {
	    // M61: hier van maken dat het ook op voorgaande jaren werkt
		#####################################################################################################
  			if (in_array($groupID, array("139", "190"))) {	// PART DEEL + PART LEID
				if ($related_hoofdleiding_relid > 0) {
	    			wachthond($extdebug, 1, '<pre>### 4.5 UPDATE RELATED HOOFDLEIDING [groupID: $groupID] ###</pre>');

					$params_update_rel_hldn = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
	  					'where' => [
    						['id', 				'=', $related_hoofdleiding_relid],
    						['contact_id_a',	'=', $contact_id],
    					],
  						'values' => [
							'id' 					=> $related_hoofdleiding_relid,
    	  					'contact_id_a' 			=> $contact_id,
      						'contact_id_b' 			=> $related_hoofdleiding_id,
      						'relationship_type_id' 	=> 17,
      						'start_date' 			=> $event_fiscalyear_start,
      						'end_date' 				=> $event_fiscalyear_einde,
	      					'is_active'				=> 1,
	      				],
	      			];
					wachthond($extdebug, 3, '<pre>params_update_rel_hldn: $params_update_rel_hldn</pre>');
					$result_update_rel_hldn = civicrm_api4('Relationship', 'update', $params_update_rel_hldn);
					wachthond($extdebug, 4, '<pre>result_update_rel_hldn: $result_update_rel_hldn</pre>');
    				wachthond($extdebug, 1, '<pre>Related Hoofdleiding Relatie: bijgewerkt</pre>');
	      		}
 			}
 		}
  	}

	// ************************************************************************************************************
	// 5.1 GET ACTIVITIES 'EVALUATIE'
	// ************************************************************************************************************
	wachthond($extdebug, 1, '<pre>------#########################################################</pre>');
	wachthond($extdebug, 1, '<pre>--- 5.1 GET ACTIVITY EVALUATIE</pre>');	

	$params_activity_evaluatie_get = [
		'checkPermissions' => FALSE,
		'debug' => $apidebug,
  		'select' => [
			'id', 'activity_date_time', 'status_id', 'status_id:name', 'subject', 'activity_contact.contact_id',
  		],
		'join' => [
    		['ActivityContact AS activity_contact', 'INNER'],
		],
		'where' => [
    		['activity_contact.contact_id', 	'=', $contact_id],
    		['activity_contact.record_type_id', '=', 3],
#			['activity_type_id', 	 			'=', 150],
   			['activity_type_id:name', 			'=', 'Evaluatie'],
    		['activity_date_time', 				'>=', $event_fiscalyear_start],
    		['activity_date_time', 				'<=', $event_fiscalyear_einde],    		
  		],
  	  	'orderBy' => [
    		'id' => 'ASC',
  		],
  		'limit' => 1,
	];

	wachthond($extdebug, 3, '<pre>params_activity_evaluatie_get    : $params_activity_evaluatie_get</pre>');
  	$result_evaluatie_get 		= civicrm_api4('Activity', 'get', $params_activity_evaluatie_get);
  	$result_evaluatie_get_count = $result_evaluatie_get->count();
  	wachthond($extdebug, 4, '<pre>result_activity_evaluatie_get    : $result_evaluatie_get</pre>');  	
  	wachthond($extdebug, 3, '<pre>result_evaluatie_count           : $result_evaluatie_get_count</pre>');

  	if ($result_evaluatie_get_count == 1) {
  		$evaluatie_activity_id				= $result_evaluatie_get[0]['id'];
  		$evaluatie_activity_status_id		= $result_evaluatie_get[0]['status_id'];
  		$evaluatie_activity_status_name		= $result_evaluatie_get[0]['status_id:name'];
  		$evaluatie_activity_datum			= $result_evaluatie_get[0]['activity_date_time'];
		wachthond($extdebug, 1, '<pre>evaluatie_activity_id            : $evaluatie_activity_id</pre>');
		wachthond($extdebug, 1, '<pre>evaluatie_activity_status_id     : $evaluatie_activity_status_id</pre>');
		wachthond($extdebug, 1, '<pre>evaluatie_activity_status_name   : $evaluatie_activity_status_name</pre>');
		wachthond($extdebug, 1, '<pre>evaluatie_activity_datum         : $evaluatie_activity_datum</pre>');
  	} else {
		$evaluatie_activity_id		= NULL;
  		$evaluatie_activity_status	= NULL;
  		$evaluatie_activity_datum	= NULL;
  		wachthond($extdebug, 1, '<pre>evaluatie_activity_id            : No Activity Found</pre>');
 	}


	// ************************************************************************************************************
	// 5.2 BEPAAL (NIEUWE) STATUS ACTIVITEIT EVALUATIE
	// ************************************************************************************************************
	wachthond($extdebug, 1, '<pre>--- 5.2 BEPAAL (NIEUWE) STATUS ACTIVITEIT EVALUATIE</pre>');
	// ************************************************************************************************************
	$diffsince_evaluatieverzoek	= date_diff(date_create($event_einde_date),date_create($today_datetime));
	$dayssince_evaluatieverzoek	= $diffsince_evaluatieverzoek->format('%a');
	if ($dayssince_evaluatieverzoek >= 0)		{ $status_evaluatie = "Pending"; 		} // AFWACHTING
	if ($dayssince_evaluatieverzoek >= 14)		{ $status_evaluatie = "Left Message";	} // HERINNERD
	if ($dayssince_evaluatieverzoek >= 28)		{ $status_evaluatie = "Unreachable"; 	} // ONBEREIKBAAR
	if ($dayssince_evaluatieverzoek >= 42)		{ $status_evaluatie = "No_show"; 		} // VERLOPEN
	if ($dayssince_evaluatieverzoek >= 270)		{ $status_evaluatie = "Bounced"; 		} // GEFAALD		
	if ($part_evaluatie) 						{ $status_evaluatie = 'Completed';		} // AFGEROND (OVERRULE STATUS ALS EVALUATIE IS INGEVULD)

	$eventendplus30		= strtotime ( '+30 day' , strtotime ($event_einde_date) ) ;
	$eventendplus60		= strtotime ( '+60 day' , strtotime ($event_einde_date) ) ;
	$eventendplus60date = date ( 'Y-m-d H:i' , $eventendplus60 );	
	wachthond($extdebug, 2, '<pre>datum evaluatie                  : $part_evaluatie</pre>');
	wachthond($extdebug, 2, '<pre>dayssince_evaluatieverzoek       : $dayssince_evaluatieverzoek</pre>');
	wachthond($extdebug, 2, '<pre>event end date                   : $event_einde_date</pre>');
	wachthond($extdebug, 2, '<pre>event end date + 60              : $eventendplus60date</pre>');

	// ************************************************************************************************************
	// 5.3 CREATE AN ACTIVITY 'EVALUATIE' ALS PERSOON MEEGAAT EN ER IS NOG GEEN BIJBEHORENDE ACTIVITY
	// ************************************************************************************************************

	wachthond($extdebug, 1, '<pre>--- 5.3 CREATE AN ACTIVITY EVALUATIE INDIEN NODIG</pre>');
	if (empty($evaluatie_activity_id)) {

		$evaluatie_activity_status_name = 'Scheduled';  // initial status ingepland

    	if (($ditjaardeelyes == 1 OR $ditjaarleidyes == 1 ) AND $event_einde_date <= $today_datetime) {
			$params_activity_evaluatie_create = [
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
  				'values' => [
			    	'source_contact_id' 	=> 1,
    				'target_contact_id' 	=> $contact_id,
 #  				'activity_type_id' 		=> 150,
    				'activity_type_id:name' => 'Evaluatie',
    				'activity_date_time' 	=> $eventendplus60date,
    				'subject' 				=> 'Evaluatie '. $welkkampkort. ' door '. $displayname,
					'status_id:name' 		=> $evaluatie_activity_status_name,
    				'ACT_ALG.kampkort'		=> $welkkampkort,
   					'ACT_ALG.kampfunctie' 	=> $part_functie,    				
    				'ACT_ALG.kampstart' 	=> $event_start_date,
    				'ACT_ALG.kampeinde' 	=> $event_einde_date, 
    				'ACT_ALG.kampjaar'		=> $event_kampjaar,
					'ACT_ALG.modified' 		=> $today_datetime,	
					'ACT_ALG.afgerond' 		=> $part_evaluatie,
  				],
			];
			wachthond($extdebug, 3, '<pre>params_activity_evaluatie_create: $params_activity_evaluatie_create</pre>');
			$result_evaluatie_create = civicrm_api4('Activity', 'create', $params_activity_evaluatie_create);
			wachthond($extdebug, 2, '<pre>params_activity_evaluatie_create EXECUTED [groupID: $groupID]</pre>');
			wachthond($extdebug, 4, '<pre>result_activity_evaluatie_create RESULT: $result_evaluatie_create</pre>');
		  	if (empty($evaluatie_activity_id))			{ $evaluatie_activity_id			= $result_evaluatie_create[0][id]; }
			if (empty($evaluatie_activity_status_id))	{ $evaluatie_activity_status_id		= $result_evaluatie_create[0][status_id]; }
  			if (empty($evaluatie_activity_datum)) 		{ $evaluatie_activity_datum			= $result_evaluatie_create[0]['activity_date_time']; }
			wachthond($extdebug, 1, '<pre>evaluatie_activity_id            : $evaluatie_activity_id</pre>');
			wachthond($extdebug, 1, '<pre>evaluatie_activity_status_id     : $evaluatie_activity_status_id</pre>');
			wachthond($extdebug, 1, '<pre>evaluatie_activity_status_name   : $evaluatie_activity_status_name</pre>');
			wachthond($extdebug, 1, '<pre>evaluatie_activity_datum         : $evaluatie_activity_datum</pre>');			
		}
	} else {
			wachthond($extdebug, 1, '<pre>evaluatie_activity_id bestaat al : $evaluatie_activity_id</pre>');
	}

	// *****************************************************************************************************************
	// 5.4 UPDATE ACTIVITY EVALUATIE
	// *****************************************************************************************************************

	if ($status_evaluatie != $evaluatie_activity_status_name) {
		wachthond($extdebug, 1, '<pre>--- 5.4 UPDATE ACTIVITY EVALUATIE: V (WANT NIEUWE STATUS: $status_evaluatie)</pre>');
		$evaluatie_activity_update = 1;
			} else {
		wachthond($extdebug, 1, '<pre>--- 5.4 UPDATE ACTIVITY EVALUATIE: X (GEEN NIEUWE STATUS: $status_evaluatie)</pre>');
		$evaluatie_activity_update = 1;
	}

	if ($evaluatie_activity_id AND $evaluatie_activity_update == 1 AND $event_einde_date) {

		$params_activity_evaluatie_change = [
			'checkPermissions' => FALSE,
			'debug' => $apidebug,
			'where' => [
				['id', 					'=', $evaluatie_activity_id],
			],
			'values' => [
				'source_contact_id' 	=> 1,
				'target_contact_id' 	=> $contact_id,
				'activity_date_time' 	=> $eventendplus60date,
				'subject' 				=> 'Evaluatie '. $welkkampkort. ' door '. $displayname,
				'status_id:name' 		=> $status_evaluatie,
   				'ACT_ALG.kampkort'		=> $welkkampkort,
   				'ACT_ALG.kampfunctie' 	=> $part_functie,
    			'ACT_ALG.kampstart' 	=> $event_start_date,
    			'ACT_ALG.kampeinde' 	=> $event_einde_date,
   				'ACT_ALG.kampjaar'		=> $event_kampjaar,
				'ACT_ALG.modified' 		=> $today_datetime,
				'ACT_ALG.afgerond' 		=> $part_evaluatie,
			],
		];

		wachthond($extdebug, 3, '<pre>params_activity_evaluatie_change: $params_activity_evaluatie_change</pre>');
		$result = civicrm_api4('Activity', 'update', $params_activity_evaluatie_change);
		wachthond($extdebug, 2, '<pre>params_activity_evaluatie_change EXECUTED [groupID: $groupID]</pre>');
		wachthond($extdebug, 4, '<pre>result_activity_evaluatie_change RESULT: $result</pre>');
	}	

	wachthond($extdebug, 1, '<pre>------#########################################################</pre>');

	###############################################################################################################	
	###############################################################################################################
   	wachthond($extdebug, 1, '<pre>*** END EXTENSION CV [groupID: $groupID] [op: $op] [entityID: $entityID] $part_functie: $displayname] ***</pre>');
	###############################################################################################################
	###############################################################################################################

	if ($extvog == 1 AND (in_array($groupID, array("190", "140", "213", "225"))) AND ($ditjaarleidyes == 1 OR $diteventleidyes == 1 OR $diteventleidstf == 1)) {
		###############################################################################################################
		### 10. EXTENSION VOG/REF
		###############################################################################################################

		$intnodig				= $result_part[0]['contact_id.INTAKE.DITJAAR_INT_nodig'];
		$refnodig				= $result_part[0]['contact_id.INTAKE.DITJAAR_REF_nodig'];
		$vognodig				= $result_part[0]['contact_id.INTAKE.DITJAAR_VOG_nodig'];

		$part_nawupdate			= $result_part[0]['INTAKE.NAW_gecheckt'];
		$part_bioupdate			= $result_part[0]['INTAKE.BIO_gecheckt'];

		$nawingevuld			= $result_part[0]['contact_id.INTAKE.NAW_gecheckt'];
		$bioingevuld			= $result_part[0]['contact_id.INTAKE.BIO_ingevuld'];
		$biogecheckt			= $result_part[0]['contact_id.INTAKE.BIO_gecheckt'];

		$refrecent 				= $result_part[0]['contact_id.INTAKE.LAATSTE_REF_datum'];
		$refkenmerk 			= $result_part[0]['contact_id.INTAKE.LAATSTE_REF_naam'];
		$part_refpersoon 		= $result_part[0]['PART_LEID_REF.REF_persoon'];
		$part_refgevraagd 		= $result_part[0]['PART_LEID_REF.REF_gevraagd'];
		$part_reffeedback 		= $result_part[0]['PART_LEID_REF.REF_feedback'];

		$vogrecent 				= $result_part[0]['contact_id.INTAKE.Datum_meest_recente_VOG'];
		$vogkenmerk 			= $result_part[0]['contact_id.INTAKE.Kenmerk_VOG']; 
		$part_vogverzocht 		= $result_part[0]['PART_LEID_VOG.Datum_verzoek'];
		$part_vogingediend 		= $result_part[0]['PART_LEID_VOG.Datum_aanvraag'];
		$part_vogontvangst 		= $result_part[0]['PART_LEID_VOG.Datum_ontvangst'];
		$part_vogdatum 			= $result_part[0]['PART_LEID_VOG.Datum_nieuwe_VOG'];
		$part_vogkenmerk 		= $result_part[0]['PART_LEID_VOG.Kenmerk_VOG'];

   		// MEEDITJAAR ALS LEIDING + PART LEID + PART LEID REF + PART LEID REFERENTIE
   		if (empty($contact_id)) { // GA ALLEEN DOOR ALS CONTACT ID NIET LEEG IS (DEZE CHECK IS EERDER OOK AL GEDAAN)
			wachthond($extdebug, 1, '<pre>--- SKIP EXTENSION VOG-REF (empty contact_id) [groupID: $groupID] [op: $op]---</pre>');
			return; //   if not, get out of here
		}
	   	wachthond($extdebug, 1, '<pre>*** 10. START EXTENSION VOG-REF [groupID: $groupID] [op: $op] [entityID: $entityID] $part_functie: $displayname] ***</pre>');

		###############################################################################################################	   	

		wachthond($extdebug, 1, '<pre>part_id              : $part_id</pre>');
		wachthond($extdebug, 1, '<pre>part_eventid         : $part_eventid</pre>');
		wachthond($extdebug, 1, '<pre>part_status_id       : $part_status_id</pre>');
		wachthond($extdebug, 1, '<pre>part_welkkamp        : $part_welkkampleid</pre>');
		wachthond($extdebug, 1, '<pre>part_functie         : $part_functie</pre>');

		wachthond($extdebug, 1, '<pre>tab_bioingevuld      : $bioingevuld</pre>');
		wachthond($extdebug, 1, '<pre>tab_biogecheckt      : $biogecheckt</pre>');
		wachthond($extdebug, 1, '<pre>part_biogecheckt     : $part_bioupdate</pre>');
			
		wachthond($extdebug, 1, '<pre>tab_refrecent        : $refrecent</pre>');
		wachthond($extdebug, 1, '<pre>part_refpersoon      : $part_refpersoon</pre>');
		wachthond($extdebug, 1, '<pre>part_refgevraagd     : $part_refgevraagd</pre>');
		wachthond($extdebug, 1, '<pre>part_reffeedback     : $part_reffeedback</pre>');

		wachthond($extdebug, 1, '<pre>tab_vogrecent        : $vogrecent</pre>');
		wachthond($extdebug, 1, '<pre>part_vogverzocht     : $part_vogverzocht</pre>');
		wachthond($extdebug, 1, '<pre>part_vogingediend    : $part_vogingediend</pre>');
		wachthond($extdebug, 1, '<pre>part_vogontvangst    : $part_vogontvangst</pre>');
		wachthond($extdebug, 1, '<pre>part_vogdatum        : $part_vogdatum</pre>');
		wachthond($extdebug, 1, '<pre>part_vogkenmerk      : $part_vogkenmerk</pre>');		

		###############################################################################################################
		### BASIS WAARDEN INTAKE NODIG
		###############################################################################################################

		$nawnodig			= 'elkjaar';	// M61 Overrule naw nodig naar jaarlijkse check voor iedereen
		$bionodig			= 'elkjaar';	// M61 Overrule bio nodig naar jaarlijkse check voor iedereen
		$intakestatusint  	= 'onbekend';
		$intakestatusnaw  	= 'onbekend';
		$intakestatusbio 	= 'onbekend';
		$intakestatusref 	= 'onbekend';
		$intakestatusvog 	= 'onbekend';

		$curcv_keer_leid	= $result_cont[0]['Curriculum.Keren_Leid'];		// keren leid
		wachthond($extdebug, 4, '<pre>$curcv_keer_leid        : $curcv_keer_leid</pre>');

		#	if (in_array($curcv_keer_leid , array(4, 7, 10, 13, 16, 19, 22, 25, 28, 31, 34, 37))) 	{
		#		$intnodig = 'opnieuw';
		#	} else {
		#		$intnodig = 'noggoed';
		#	}
		if (in_array($part_ditjaar1stleid[0], array('eerstex'))) {
			$intnodig = 'eerstex';
		}
		if (in_array($part_functie, array("hoofdleiding", "kampstaf", "bestuurslid"))) {
			$intnodig = 'elkjaar';
		}

		if (empty($nawgecheckt)) {
			$intakestatusnaw 	= 'ongecheckt';
		} else {
			$intakestatusnaw 	= 'bijgewerkt';	
		}

		###############################################################################################################
		// 10.1 BEPAAL OF DE BIO NOG GOED IS, HET DE EERSTE KEER IS, OF ER OPNIEUW EEN BIO MOET WORDEN AANGEVRAAGD 
		wachthond($extdebug, 1, '<pre>--- 10.1 BEPAAL OF DE BIO NOG GOED IS, HET DE EERSTE KEER IS, OF ER OPNIEUW EEN BIO MOET WORDEN AANGEVRAAGD</pre>');
		###############################################################################################################
		#wachthond($extdebug, 2, '<pre>strtotime(biorecent): strtotime($biogecheckt)</pre>');

    	if ($biogecheckt) {
    		if ($biogecheckt AND strtotime($biogecheckt) < strtotime($event_fiscalyear_start) AND strtotime($biogecheckt) >= strtotime($grensvognoggoed)) { // Datum BIO in previous 2 fiscal years
    			$biodatethisyear 	= 0;
    			$intakestatusbio 	= 'ongecheckt';
    			wachthond($extdebug, 2, '<pre>DATUM BIO GECHECKT [$biogecheckt] VALT BINNEN AFGELOPEN 3 FISCALE JAREN (INCL.HUIDIGE) [>$grensvognoggoed] DUS: [$bionodig]</pre>');
    		}
    		if ($biogecheckt AND strtotime($biogecheckt) >= strtotime($event_fiscalyear_start))	{ // Datum BIO binnen het huidige fiscal year
   				$biodatethisyear 	= 1;
				$intakestatusbio 	= 'bijgewerkt';
				if ($curcv_keer_leid == 1) { $bionodig = 'eerstex'; } elseif ($curcv_keer_leid >= 2) { $bionodig = 'opnieuw'; } else { $bionodig = 'onbekend'; }
   				wachthond($extdebug, 2, '<pre>DATUM BIO GECHECKT [$biogecheckt] VALT BINNEN HET HUIDIGE FISCAL YEAR [>$event_fiscalyear_start] DUS: [$bionodig] STATUS: [$intakestatusbio]</pre>');
   			}
   			if ($biogecheckt AND strtotime($biogecheckt) >= strtotime($grensvognoggoed) AND strtotime($biogecheckt) < strtotime($grensvognoggoedplusone))	{ 	// Datum BIO binnen het eerste fiscal year na grensnoggoed
   				$bionodignextyear 	= 1;
   				$intakestatusbio 	= 'ongecheckt';
   				wachthond($extdebug, 2, '<pre>DATUM BIO GECHECKT [$biogecheckt] MAAKT BIO VOLGEND JAAR NODIG [>$grensvognoggoedplusone] DUS: [$bionodig] STATUS: [$intakestatusbio]</pre>');
   			}
   			if ($biogecheckt AND strtotime($biogecheckt) < strtotime($grensvognoggoed))		{ // Datum BIO ouder dan 3 fiscale jaren
   				$biodatethisyear 	= 0;
   				$intakestatusbio 	= 'ongecheckt';
