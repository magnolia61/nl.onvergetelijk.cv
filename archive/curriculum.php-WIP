					wachthond($extdebug, 1, '<pre>*. part_vogverzocht      	: $part_vogverzocht</pre>');
					wachthond($extdebug, 1, '<pre>*. part_vogingediend    	: $part_vogingediend</pre>');					
				}
			}

//			if ($extact == 1 AND (in_array($groupID, array("190", "140", "213"))) AND ($vogverzoekditjaar == 1 OR $refverzoekditjaar == 1)) {
			if ($extact == 1 AND (in_array($groupID, array("140", "213")))) {
			###############################################################################################################
			### 14. UPDATE ACTIVITIES
			###############################################################################################################
				wachthond($extdebug, 1, '<pre>### 14. VOG/REF ACTIVITIES [UPDATE] [groupID: $groupID] [op: $op] ###</pre>');

				// ************************************************************************************************************
				// 14.1 BEPAAL (NIEUWE) STATUS ACTIVITEIT REF PERSOON
				wachthond($extdebug, 1, '<pre>--- 14.1 BEPAAL (NIEUWE) STATUS ACTIVITEIT REF PERSOON</pre>');
				// ************************************************************************************************************
				wachthond($extdebug, 2, '<pre>intakestatusref  : $intakestatusref</pre>');
				#if ($part_refpersoon) { $act_refpersoon = $part_refpersoon; } else { $act_refpersoon = $today_datetime; }
				$diffsince_refpersoon	= date_diff(date_create($part_refpersoon),date_create($today_datetime));
				$dayssince_refpersoon	= $diffsince_refpersoon->format('%a');
				if ($dayssince_refpersoon >= 0  AND $dayssince_refpersoon < 7)			{ $status_refpersoon = "Pending"; 		} // AFWACHTING
				if ($dayssince_refpersoon >= 7  AND $dayssince_refpersoon < 21)			{ $status_refpersoon = "Left Message";  } // HERINNERD
				if ($dayssince_refpersoon >= 21 AND $dayssince_refpersoon < 35)			{ $status_refpersoon = "Unreachable"; 	} // ONBEREIKBAAR
				if ($dayssince_refpersoon >= 35)										{ $status_refpersoon = "No_show"; 		} // VERLOPEN
				if ($dayssince_refpersoon >= 270)										{ $status_refpersoon = "Bounced"; 		} // GEFAALD
//				if (strtotime($today_datetime) > strtotime($event_einde_date) AND $status_refpersoon != "Completed")	{
//					$status_refpersoon = "Bounced";
// 					Failed nadat de startdag van kamp gepasseerd is
//					wachthond($extdebug, 2, '<pre>activity refpersoon > status bounced want event inmiddels voorbij</pre>');
//				}
				// M61 zet refstatus op ontbreekt voor leiding waarbij die mist die al vaker zijn meegeweest
				if (empty($refrecent) AND $curcv_keer_leid > 2) {
					$intakestatusref 	= 'ontbreekt';
				}
				// M61 zet refstatus op inhaal voor leiding waarbij die mist die al vaker zijn meegeweest
				if (empty($refrecent) AND $curcv_keer_leid > 1) {
					$refnodig 			= 'inhaal';
					$intakestatusref 	= 'ontbreekt';
				}

				// M61 zet refstatus op ontbreekt voor leiding waarbij die mist die al vaker zijn meegeweest
				if ($vognodignextyear == 1 AND empty($refrecent) AND $curcv_keer_leid >= 10) {
					$status_refpersoon 	= 'Not Required';
					$refnodig 			= 'volgendjaar';
					$intakestatusref 	= 'ontbreekt';
				}
				// M61 trek refnodig gelijk met vognodig voor leiding vaker dan 9 (totdat alles weer gelijk is)
				if (empty($refrecent) AND in_array($vognodig, array("noggoed")) AND $curcv_keer_leid >= 5) {
					$status_refpersoon 	= 'Not Required';
					$refnodig 			= 'noggoed';
					$intakestatusref 	= 'ontbreekt';
				}
				// M61 trek refnodig gelijk met vognodig voor leiding vaker dan 2
				if ($refrecent AND in_array($vognodig, array("noggoed")) AND $curcv_keer_leid > 2) {
					$status_refpersoon 	= 'Not Required';
					$refnodig 			= 'noggoed';
					$intakestatusref 	= 'noggoed';
				}

				// M61 zorg dat de REF persoon activity en mails pas starten zodra de VOG klaargezet is (1 mail met intake todo's)
				if (in_array($vognodig, array("eerstex", "elkjaar", "opnieuw")) AND $vogverzoekditjaar == 1) {
					$status_refpersoon 	= 'Scheduled';
					wachthond($extdebug, 1, '<pre>status_refpersoon : $status_refpersoon vog verzocht dus trigger ook referentie en verstuur de bredere intake email</pre>');
				}
				// M61 zorg dat de REF persoon activity en mails pas starten zodra de VOG klaargezet is (1 mail met intake todo's)
				if (in_array($vognodig, array("eerstex", "elkjaar", "opnieuw")) AND $vogverzoekditjaar != 1) {
					$status_refpersoon 	= 'Available';
					wachthond($extdebug, 1, '<pre>status_refpersoon : $status_refpersoon in afwachting van VOG verzoek</pre>');					
				}

				if ($refpersoon_activity_id AND $referentie_cid) 	{
					$status_refpersoon 	= 'Completed';
					$intakestatusref 	= 'bekend';
				}
				if ($refpersoon_activity_id AND $part_refgevraagd) 	{
					$status_refpersoon 	= 'Completed';
					$intakestatusref 	= 'gevraagd';
				}
/*
				if ($part_refpersoon) {
					$status_refpersoon 	= 'Completed';
				}
*/
/*				
				} elseif (empty($part_refpersoon)) {
					$status_refpersoon 	= 'Available';
					wachthond($extdebug, 1, '<pre>status_refpersoon : $status_refpersoon in afwachting van VOG verzoek</pre>');
				} elseif ($referentie_cid > 0) {
					$status_refpersoon 	= 'Complete';					
					wachthond($extdebug, 1, '<pre>status_refpersoon : $status_refpersoon: referentie al doorgegeven voor vogverzoek</pre>');
				}
*/
				wachthond($extdebug, 2, '<pre>dayssince_refpersoon: $dayssince_refpersoon</pre>');				
				wachthond($extdebug, 2, '<pre>vognodignextyear: $vognodignextyear</pre>');
				wachthond($extdebug, 2, '<pre>(new) act_status ref_persoon: $status_refpersoon</pre>');

				wachthond($extdebug, 1, '<pre>refnodig_ditjaar : $refnodig</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusref  : $intakestatusref</pre>');

				// ************************************************************************************************************
				// 14.2 BEPAAL (NIEUWE) STATUS ACTIVITEIT REF VERZOEK
				wachthond($extdebug, 1, '<pre>--- 14.2 BEPAAL (NIEUWE) STATUS ACTIVITEIT REF GEVRAAGD</pre>');
				// ************************************************************************************************************
				#if ($part_refpersoon) { $act_refpersoon = $part_refpersoon; } else { $act_refpersoon = $today_datetime; }
				$diffsince_refverzoek	= date_diff(date_create($part_refgevraagd),date_create($today_datetime));
				$dayssince_refverzoek	= $diffsince_refverzoek->format('%a');
				if ($dayssince_refverzoek >= 0  AND $dayssince_refverzoek < 7)			{ $status_refverzoek = "Pending"; 		} // AFWACHTING
				if ($dayssince_refverzoek >= 7  AND $dayssince_refverzoek < 21)			{ $status_refverzoek = "Left Message";  } // HERINNERD
				if ($dayssince_refverzoek >= 21 AND $dayssince_refverzoek < 35)			{ $status_refverzoek = "Unreachable"; 	} // ONBEREIKBAAR
				if ($dayssince_refverzoek >= 35)										{ $status_refverzoek = "No_show"; 		} // VERLOPEN
				if ($dayssince_refverzoek >= 270)										{ $status_refverzoek = "Bounced"; 		} // GEFAALD
//				if (strtotime($today_datetime) > strtotime($event_einde_date) AND $status_refaanvraag != "Completed")	{
//					$status_refaanvraag = "Bounced";
//					wachthond($extdebug, 2, '<pre>activity refverzoek > status bounced want event inmiddels voorbij</pre>');
//				}
				// Failed nadat de startdag van kamp gepasseerd is
				if ($vognodignextyear == 1 AND in_array($refnodig, array("noggoed"))) {
					$status_refverzoek 	= 'Not Required';
				}
				if ($refverzoek_activity_id AND ($part_reffeedback OR $referentie_feedback)) {
					$status_refverzoek 	= 'Completed';
					$intakestatusref 	= 'ontvangen';
				}
				wachthond($extdebug, 2, '<pre>dayssince_refverzoek: $dayssince_refverzoek</pre>');
				wachthond($extdebug, 2, '<pre>(new) act_status ref_verzoek: $status_refverzoek</pre>');

				wachthond($extdebug, 1, '<pre>refnodig_ditjaar : $refnodig</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusref  : $intakestatusref</pre>');

				// ************************************************************************************************************
				// 14.3 BEPAAL (NIEUWE) STATUS ACTIVITEIT VOG AANVRAAG
				wachthond($extdebug, 1, '<pre>--- 14.3 BEPAAL (NIEUWE) STATUS ACTIVITEIT VOG AANVRAAG</pre>');
				// ************************************************************************************************************
				wachthond($extdebug, 2, '<pre>intakestatusvog  : $intakestatusvog</pre>');

				if (empty($part_vogverzocht)) {
					$intakestatusvog = 'klaarzetten';
				}
				if ($vogrecent AND in_array($vognodig, array('noggoed'))) {
					$intakestatusvog = 'noggoed';
				}
				if (strtotime($part_vogverzocht) >= strtotime($event_fiscalyear_start))	{
					$intakestatusvog = 'verzocht';
				}
				$diffsince_vogverzoek	= date_diff(date_create($part_vogverzocht),date_create($today_datetime));
				$dayssince_vogverzoek	= $diffsince_vogverzoek->format('%a');				

				if ($dayssince_vogverzoek >= 0  AND $dayssince_vogverzoek < 14)			{ $status_vogaanvraag = "Pending"; 		} // AFWACHTING
				if ($dayssince_vogverzoek >= 14 AND $dayssince_vogverzoek < 21)			{ $status_vogaanvraag = "Left Message"; } // HERINNERD
				if ($dayssince_vogverzoek >= 21 AND $dayssince_vogverzoek < 30)			{ $status_vogaanvraag = "Unreachable"; 	} // ONBEREIKBAAR
				if ($dayssince_vogverzoek >= 30)										{ $status_vogaanvraag = "No_show"; 		} // VERLOPEN
				if ($dayssince_vogverzoek >= 270)										{ $status_vogaanvraag = "Bounced"; 		} // GEFAALD/GEBOUNCED
//				if (strtotime($today_datetime) > strtotime($event_einde_date) AND $status_vogaanvraag != "Completed")	{
//					$status_vogaanvraag = "Bounced";
//					wachthond($extdebug, 2, '<pre>activity vogaanvraag > status bounced want eventdate $event_einde_dateinmiddels voorbij</pre>');
//				} 
				// Failed nadat de startdag van kamp gepasseerd is

				// LET OP: DE VOLGENDE 2 REGELS NOG EVEN HEEL ERG GOED DUBBELCHECKEN!!!
				if (strtotime($part_vogingediend) >= strtotime($event_fiscalyear_start))	{ // hier een between van maken (of liever nog een functie)
					#wachthond($extdebug, 2, '<pre>A. part_vogingediend: strtotime($part_vogingediend)</pre>');
					#wachthond($extdebug, 2, '<pre>B. fiscalyear_start: strtotime($event_fiscalyear_start)</pre>');
					wachthond($extdebug, 1, '<pre>STATUS VOG AANVRAAG AANGEPAST VAN: $status_vogaanvraag NAAR Completed (omdat part_vogingediend: $part_vogingediend >= $event_fiscalyear_start)</pre>');
					$status_vogaanvraag = "Completed";
					$intakestatusvog 	= 'ingediend';
				}

				if (strtotime($part_vogdatum)	  >= strtotime($event_fiscalyear_start) AND $status_vogaanvraag != 'Completed')	{ // hier een between van maken (of liever nog een functie)
					#wachthond($extdebug, 2, '<pre>A. part_vogdatum: strtotime($part_vogdatum)</pre>');
					#wachthond($extdebug, 2, '<pre>B. fiscalyear_start: strtotime($event_fiscalyear_start)</pre>');
					wachthond($extdebug, 1, '<pre>STATUS VOG AANVRAAG AANGEPAST VAN: $status_vogaanvraag NAAR Completed (omdat part_vogdatum: $part_vogdatum >= $event_fiscalyear_start)</pre>');
					$status_vogaanvraag	= "Completed";
					$intakestatusvog 	= 'ingediend';
				}

				#if ($part_vogverzocht)						{ $intakestatusvog = 'verzocht'; 	}
				#if ($part_vogingediend)					{ $intakestatusvog = 'ingediend'; 	}
				if ($part_vogontvangst)						{ $intakestatusvog = 'ontvangen'; 	}

				if (strtotime($part_vogingediend) < strtotime($event_fiscalyear_start) AND strtotime($part_vogdatum) < strtotime($event_fiscalyear_start))	{
					// als part_vogdatum binnen huidige fiscal year valt kan activity op completed (nu alleen later dan fiscal year start)
					wachthond($extdebug, 2, '<pre>a. part_vogverzocht: $part_vogverzocht</pre>');
					#wachthond($extdebug, 2, '<pre>b. diffsinceverzoek: $diffsince_vogverzoek</pre>');
					wachthond($extdebug, 2, '<pre>b. dagen_sinds_verzoek: $dayssince_vogverzoek</pre>');
				}

				wachthond($extdebug, 2, '<pre>c. (new) status_aanvraag: $status_vogaanvraag</pre>');

				wachthond($extdebug, 1, '<pre>vognodig_ditjaar : $vognodig</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusvog  : $intakestatusvog</pre>');

				// ************************************************************************************************************
				// 14.4 BEPAAL (NIEUWE) STATUS ACTIVITEIT VOG ONTVANGST
				wachthond($extdebug, 1, '<pre>--- 14.4 BEPAAL (NIEUWE) STATUS ACTIVITEIT VOG ONTVANGST</pre>');
				// ************************************************************************************************************
				$diffsinceaanvraag	= date_diff(date_create($part_vogingediend),date_create($today_datetime));
				$dayssinceaanvraag	= $diffsinceaanvraag->format('%a');
				if ($dayssinceaanvraag >= 0  AND $dayssinceaanvraag < 21)			{ $status_vogontvangst = "Pending"; 		} // AFWACHTING
				if ($dayssinceaanvraag >= 21 AND $dayssinceaanvraag < 35)			{ $status_vogontvangst = "Left Message"; 	} // HERINNERD
				if ($dayssinceaanvraag >= 35)										{ $status_vogontvangst = "Unreachable"; 	} // ONBEREIKBAAR
				if ($dayssinceaanvraag >= 270)										{ $status_vogontvangst = "Bounced"; 		} // GEFAALD/GEBOUNCED

//				if (strtotime($today_datetime) > strtotime($event_einde_date) AND $status_vogontvangst != "Completed") {
//					$status_vogontvangst = "Bounced";
//					wachthond($extdebug, 2, '<pre>activity vogaanvraag > status bounced want eventdate $event_einde_dateinmiddels voorbij</pre>');				
//				}

				// if ($dayssince_vogverzoek  >= 21 AND $status_vogontvangst == "Pending") { $status_vogontvangst = "Left Message"; }
				// Als aanvraag Unreachable of Bounced is -> schedule dan alsnog een reminder rond geplande ontvangstdatum
				
				// LET OP: DE VOLGENDE 1 REGEL NOG EVEN HEEL ERG GOED DUBBELCHECKEN!!!
				if ($status_vogaanvraag != "Completed")								{
					$status_vogontvangst	= "Available";
				} 
				// Maak status Activiteit ONTVANGST = Available als status AANVRAAG nog niet Completed is (civirules proof?)

				// LET OP: DE VOLGENDE 1 REGEL NOG EVEN HEEL ERG GOED DUBBELCHECKEN!!!
				if (strtotime($part_vogdatum) >= strtotime($event_fiscalyear_start))		{
					$status_vogontvangst 	= "Completed";
					$intakestatusvog 		= 'ontvangen';
				} else {
					wachthond($extdebug, 2, '<pre>a. part_vogingediend: $part_vogingediend</pre>');
					#wachthond($extdebug, 2, '<pre>b. diffsinceaanvraag: $diffsinceaanvraag</pre>');
					wachthond($extdebug, 2, '<pre>b. dagen_sinds_aanvraag: $dayssinceaanvraag</pre>');
				} // als part_vogdatum binnen huidige fiscal year valt kan activity op completed
				wachthond($extdebug, 2, '<pre>c. (new) status_ontvangst: $status_vogontvangst</pre>');

				wachthond($extdebug, 1, '<pre>vognodig_ditjaar : $vognodig</pre>');
				wachthond($extdebug, 1, '<pre>intakestatusvog  : $intakestatusvog</pre>');

				// *****************************************************************************************************************
				// 15.1 UPDATE ACTIVITY REF PERSOON
				wachthond($extdebug, 1, '<pre>--- 15.1 UPDATE ACTIVITY REF PERSOON</pre>');	
				// *****************************************************************************************************************
//				if ($refpersoon_activity_id AND $referentie_cid) {
				if ($refpersoon_activity_id) {
					$params_activity_refpersoon_change = [
  					'checkPermissions' => FALSE,
					'debug' => $apidebug,
	  					'where' => [
    						['id', 					'=', $refpersoon_activity_id],
  						],
  						'values' => [
							'ACT_REF.Naam_aanvrager'			=> $displayname,
  							'ACT_REF.Voornaam_aanvrager'		=> $first_name,
  							'ACT_REF.Functie_aanvrager'			=> $part_functie,
  							'ACT_REF.Kamp_aanvrager'			=> $welkkamplang,
  							'ACT_REF.ID_aanvrager'				=> $contact_id,
