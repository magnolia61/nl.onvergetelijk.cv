						wachthond($extdebug, 1, '<pre>vognodig_ditjaar           : $vognodig</pre>');						
					}

					wachthond($extdebug, 1, '<pre>vogaanvraag_activity_id    : $vogaanvraag_activity_id</pre>');
					wachthond($extdebug, 1, '<pre>vogaanvraag_activity_status: $vogaanvraag_activity_status</pre>');

				} elseif (empty($vogaanvraag_activity_id)){
					wachthond($extdebug, 1, '<pre>*. datum_vogaanvraag       : $datum_vogaanvraag</pre>');
					wachthond($extdebug, 1, '<pre>*. part_vogverzocht        : $part_vogverzocht</pre>');
					wachthond($extdebug, 1, '<pre>*. part_vogingediend       : $part_vogingediend</pre>');					
				}

				// ************************************************************************************************************
				// 13.5 CREATE AN ACTIVITY 'VOGONTVANGST' ALS VOG AANVRAAG IS INGEDIEND OF ONTVANGST BEVESTIGD EN ER IS NOG GEEN BIJBEHORENDE ACTIVITY
				// ************************************************************************************************************
				wachthond($extdebug, 1, '<pre>--- 13.5 CREATE AN ACTIVITY VOGONTVANGST (ALS VOG AANVRAAG IS INGEDIEND OF ONTVANGST BEVESTIGD EN ER IS NOG GEEN BIJBEHORENDE ACTIVITY)</pre>');

				if (empty($vogontvangst_activity_id) AND $datum_vogontvangst AND ($part_vogverzocht OR $part_vogingediend)) {

  					if ($extvog == 1 AND in_array($intnodig,array("eerstex","elkjaar","inhaal")) AND in_array($vognodig,array("eerstex","elkjaar","opnieuw"))) {
						$params_activity_vogontvangst_create = [
  						'checkPermissions' => FALSE,
						'debug' => $apidebug,
  							'values' => [
						    	'source_contact_id' 	=> 1, 
    							'target_contact_id' 	=> $contact_id,
	  							'assignee_contact_id'	=> $related_hoofdleiding_id,
    							'activity_type_id' 		=> 120, 
    							'activity_date_time' 	=> $datum_vogontvangst, 
    							'subject' 				=> 'VOG ontvangst bevestigd', 
    							'status_id:name' 		=> 'Available', // initial status draft
				   				'ACT_ALG.kampkort'		=> $welkkampkort,
				   				'ACT_ALG.kampfunctie' 	=> $part_functie,
				    			'ACT_ALG.kampstart' 	=> $event_start_date,
				    			'ACT_ALG.kampeinde' 	=> $event_einde_date, 				
				   				'ACT_ALG.kampjaar'		=> $event_kampjaar,
								'ACT_ALG.modified' 		=> $today_datetime,	    							
  							],
						];
						wachthond($extdebug, 3, '<pre>params_activity_vogontvangst_create: $params_activity_vogontvangst_create</pre>');
						if ($extvog == 1)	{
							$result = civicrm_api4('Activity', 'create', $params_activity_vogontvangst_create);
							wachthond($extdebug, 2, '<pre>params_activity_vogontvangst_create EXECUTED [groupID: $groupID]</pre>');
							#wachthond($extdebug, 3, '<pre>params_activity_vogontvangst_create RESULT: $result</pre>');
						}
					  	if (empty($vogontvangst_activity_id))		{ $vogontvangst_activity_id		= $result[0]['id']; }
						if (empty($vogontvangst_activity_status))	{ $vogontvangst_activity_status	= $result[0]['status_id']; }
						wachthond($extdebug, 1, '<pre>vogontvangst_activity_id 		: $vogontvangst_activity_id</pre>');
						wachthond($extdebug, 1, '<pre>vogontvangst_activity_status 	: $vogontvangst_activity_status</pre>');
					} else {
