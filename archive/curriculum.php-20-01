		} elseif ($leeftijd_vantoday_decimalen < 18) {							// GEBRUIK BIJ  <18 EMAIL_PLAC
			$new_email_othr_email = $email_plac_email;
		} elseif ($leeftijd_vantoday_decimalen >= 18 AND $email_deel_email) {	// GEBRUIK BIJ >=18 EMAIL_DEEL
			$new_email_othr_email = $email_deel_email;
		} elseif ($email_home_email) {
			$new_email_othr_email = $email_home_email;		// VOORKEUR DAARNA VOOR EMAIL_HOME
