		  	wachthond($extdebug,3, "contrib_count", 					$contrib_count);

			$contrib_id = NULL;

			if ($contrib_count == 1) {

		    	$contrib_id     = $result_saldo_get[0]['id'] 				?? NULL;

		    	$amount_level   = $result_saldo_get[0]['amount_level'] 		?? NULL;
   				$amount_level 	= preg_replace('/[^ \w-]/','',$amount_level);	// keep only letters and numbers and dashes

				$saldo_bedrag   = $result_saldo_get[0]['total_amount'] 		?? NULL;
			   	$saldo_paid     = $result_saldo_get[0]['paid_amount'] 		?? NULL;
		    	$saldo_balance  = $result_saldo_get[0]['balance_amount']	?? NULL;

