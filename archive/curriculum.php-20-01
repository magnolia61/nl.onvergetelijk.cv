	wachthond($extdebug,1, $divider,				$today_datetime);
*/
	wachthond($extdebug,1, "########################################################################");
	if (in_array($groupID, $profilepartleid)) { 	// PROFILE PARTICIPANT
		wachthond($extdebug,1, "### EINDE EXTENSION INTAKE VOOR $displayname", 	"[GroupID: $groupID] [op: $op]", 
		"[$ditevent_part_functie: $displayname]");
	} else {
		wachthond($extdebug,1, "### EINDE EXTENSION CV VOOR $displayname", 		"[GroupID: $groupID] [op: $op] [entityID: $entityID]", 
		"[$ditevent_part_functie: $displayname]");
	}
	wachthond($extdebug,1, "########################################################################");

}

