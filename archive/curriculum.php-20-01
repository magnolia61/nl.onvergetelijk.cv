   			  	wachthond($extdebug,3, "saldo_paid", 			$saldo_paid);
   			  	wachthond($extdebug,3, "saldo_balance", 		$saldo_balance);

				$saldo_bedrag	= number_format( $saldo_bedrag,	 2, '.', ''  );
	    		$saldo_paid		= number_format( $saldo_paid, 	 2, '.', ''  );
	    		$saldo_balance	= number_format( $saldo_balance, 2, '.', ''  );

   			  	wachthond($extdebug,1, "saldo_bedrag", 			$saldo_bedrag);
   			  	wachthond($extdebug,1, "saldo_paid", 			$saldo_paid);
   			  	wachthond($extdebug,1, "saldo_balance", 		$saldo_balance);

				if ($new_kampgeldregeling == 'ja_stgave') {
					$saldo_bedrag	= 0;
		    		$saldo_paid		= 0;
		    		$saldo_balance	= 0;
				}

   			  	$contribution_kenmerk = "Kampgeld $eventkamp_kampkort_cap $eventkamp_kampjaar $first_name";

