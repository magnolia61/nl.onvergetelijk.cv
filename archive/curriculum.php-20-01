            wachthond($extdebug,2,  "DIT JAAR: UIT $ditjaar_all_count PARTICIPANTS $ditjaar_pos_count POSITIEVE DEELNAME GEVONDEN [D/L]","$ditjaar_pos_part_id ($ditjaar_pos_kampkort $ditjaar_refyear)");
