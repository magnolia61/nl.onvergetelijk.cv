		$ditjaar_pos_kampfunctie 			= $array_allpart_ditjaar['result_allpart_pos_kampfunctie'];
		$ditjaar_pos_deel_kampfunctie 		= $array_allpart_ditjaar['result_allpart_pos_deel_kampfunctie'];
