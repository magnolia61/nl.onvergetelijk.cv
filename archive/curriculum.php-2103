*/

		// INDIEN BIOGECHECKT > PART_BIOGECHECKT

		if ( date_bigger($org_ditjaar_biogecheckt, $org_ditpart_biogecheckt) == 1) {
			$new_ditjaar_biogecheckt = $org_ditjaar_biogecheckt;
			wachthond($extdebug,3, "bio_gecheckt ($org_ditjaar_biogecheckt) > part_biogecheckt ($org_ditpart_biogecheckt)", "[ditjaar_biogecheckt = biogecheckt]");
		}
		// INDIEN BIOGECHECKT < PART_BIOGECHECKT
		if ( date_bigger($org_ditpart_biogecheckt, $org_ditjaar_biogecheckt) == 1) {
			$new_ditjaar_biogecheckt = $org_ditpart_biogecheckt;
			wachthond($extdebug,3, "part_biogecheckt ($org_ditpart_biogecheckt) > bio_gecheckt ($org_ditjaar_biogecheckt)", "[ditjaar_biogecheckt = part_biogecheckt]");
		}

		$bioingevuld_infiscalyear_ditjaar  						= infiscalyear($new_ditjaar_bioingevuld,$today_datetime,'bioingevuld','ditjaar');

		$org_ditjaar_biogecheckt_infiscalyear_ditjaar  			= infiscalyear($new_ditjaar_biogecheckt,$today_datetime,'biogecheckt','ditjaar');
//		$org_ditjaar_biogecheckt_infiscalyear_ditevent 			= infiscalyear($new_ditjaar_biogecheckt,$ditevent_event_start,'biogecheckt','ditevent');
		$org_ditjaar_biogecheckt_infiscalyear_ditevent 			= infiscalyear($new_ditpart_biogecheckt,$ditevent_event_start,'biogecheckt','ditevent');

		$org_ditpart_biogecheckt_infiscalyear_ditjaar 			= infiscalyear($org_ditpart_biogecheckt,$ditevent_event_start,'part_biogecheckt','ditjaar');

		wachthond($extdebug,2, 'biogecheckt_infiscalyear_ditjaar', 		$org_ditjaar_biogecheckt_infiscalyear_ditjaar);
		wachthond($extdebug,2, 'biogecheckt_infiscalyear_ditevent', 	$org_ditjaar_biogecheckt_infiscalyear_ditevent);

		// UPDATE BIO INGEVULD INDIEN LEEG EN BIOGECHECKT WEL INGEVULD IS
		if ($new_ditjaar_biogecheckt AND empty($org_ditjaar_bioingevuld)) {
			$new_bioingevuld = $new_ditjaar_biogecheckt;
			wachthond($extdebug,3, "bio_ingevuld = leeg en bio_gecheckt = ('.$new_ditjaar_biogecheckt.')", "Update bio_ingevuld");
			if ($new_bioingevuld) { $params_contact['values']['INTAKE.BIO_ingevuld'] = $new_ditjaar_biogecheckt; }
		}

		// BIOCHECK VALT BINNEN FISCAAL JAAR DAT BIJ DIT EVENT HOORT [DUS UPDATEN IS OK]
		if ($org_ditjaar_biogecheckt_infiscalyear_ditevent == 1) {

			// ALS PART_BIOGECHECKT BESTAAT MAAR CONT BIOGECHECKT NIEUWER IS (BINNEN FISCALYEAR VAN DIT EVENT)
			if ( date_bigger($org_ditjaar_biogecheckt, $org_ditpart_biogecheckt) == 1) {
				$ditpart_biogecheckt = $org_ditjaar_biogecheckt;
				wachthond($extdebug,3, "bio_gecheckt ($org_ditjaar_biogecheckt) > part_biogecheckt ($org_ditpart_biogecheckt)", "[part_biogecheckt was ouder]");
			}
			// ALS PART_BIOGECHECKT LEEG IS EN CONT BIOGECHECKT BESTAAT (BINNEN FISCALYEAR VAN DIT EVENT)
			if (empty($org_ditpart_biogecheckt)) {
				$ditpart_biogecheckt = $org_ditjaar_biogecheckt;
				wachthond($extdebug,3, "bio_gecheckt ($org_ditjaar_biogecheckt) > part_biogecheckt ($org_ditpart_biogecheckt)", "[part_biogecheckt was leeg]");		
			}
		}

		// PART BIO CHECK VALT BUITEN FISCAAL JAAR DAT BIJ DIT EVENT HOORT [DUS STAAT FOUTIEF IN DIT PART]
		if ($org_ditjaar_biogecheckt_infiscalyear_ditevent == 0) {
			if ( date_bigger($org_ditjaar_biogecheckt, $org_ditpart_biogecheckt) == 1) {
				$ditpart_biogecheckt = "";
				wachthond($extdebug,3, "part_bio_gecheckt ($org_ditpart_biogecheckt) BUITEN EVENT FISCAALJAAR DUS MAAK LEEG", "[$ditevent_kampjaar]");
			}			
		}

		################################################################################################
		### BEPAAL STATUS BIO
		################################################################################################

		$org_ditjaar_biogecheckt_infiscalyear_ditjaar  			= infiscalyear($new_ditjaar_biogecheckt,$today_datetime,'biogecheckt','ditjaar');
		$org_ditjaar_biogecheckt_infiscalyear_ditevent 			= infiscalyear($new_ditjaar_biogecheckt,$ditevent_event_start,'biogecheckt','ditevent');

		wachthond($extdebug,2, 'biogecheckt_infiscalyear_ditjaar', 		$org_ditjaar_biogecheckt_infiscalyear_ditjaar);
		wachthond($extdebug,2, 'biogecheckt_infiscalyear_ditevent', 	$org_ditjaar_biogecheckt_infiscalyear_ditevent);

		if ($org_ditjaar_biogecheckt_infiscalyear_ditjaar == 1) {
			$new_ditjaar_biostatus = 'bijgewerkt';
		} else {
			$new_ditjaar_biostatus = 'ongecheckt';
		}

		if ($org_ditjaar_biogecheckt_infiscalyear_ditevent == 1) {
			$new_ditpart_biostatus = 	'bijgewerkt';
			wachthond($extdebug,1, 	"DATUM BIOGECHECKT [$new_ditjaar_biogecheckt] VALT BINNEN HET HUIDIGE FISCAL JAAR VAN DIT EVENT [> $ditevent_fiscalyear_start]",
									"DUS: [$new_ditjaar_bionodig] STATUS: [$new_ditjaar_biostatus]");
		} else {
			$new_ditpart_biostatus = 'ongecheckt';
		}

		#######

		if (infiscalyear($new_ditjaar_biogecheckt,$ditevent_event_start,'ditjaar_biogecheckt','ditevent') == 1) 		{
   			$biodatethisyear 	= 0;
			$new_ditjaar_biostatus 	= 'bijgewerkt';
			wachthond($extdebug,1, "DATUM BIOGECHECKT [$new_ditjaar_biogecheckt] VALT BINNEN HET HUIDIGE FISCAL JAAR VAN DIT EVENT [> $ditevent_fiscalyear_start]", "DUS: [$new_ditjaar_bionodig] STATUS: [$new_ditjaar_biostatus]");
		}
		if (infiscalyear($new_ditjaar_biogecheckt,$ditevent_event_start,'ditjaar_biogecheckt','ditevent') == "before") 	{
   			$biodatethisyear 	= 0;
			$new_ditjaar_biostatus 	= 'ongecheckt';
			wachthond($extdebug,1, "DATUM BIOGECHECKT [$new_ditjaar_biogecheckt] IS OUDER DAN START VAN FICALE JAAR VAN DIT EVENT)[> $ditevent_fiscalyear_start]", "DUS: [$new_ditjaar_bionodig] STATUS: [$new_ditjaar_biostatus]");
		}

		if (empty($new_bioingevuld)) {
			$new_ditjaar_biostatus 	= 'nogleeg';
		}
		if (empty($new_ditjaar_biogecheckt)) {
			$new_ditjaar_biostatus 	= 'ongecheckt';
		}
/*
		// M61: ditjaar_biogecheckt is (als het goed is) eerder gevuld. If not: vul het met huidige waarde

		if (empty($new_bioingevuld) AND $bioingevuld) 	{
			$new_bioingevuld 			= $bioingevuld;
			wachthond($extdebug,1, "new_bioingevuld was nog leeg. Vul met bioingevuld",		$new_bioingevuld);
		}
		if (empty($new_ditjaar_biogecheckt) AND $org_ditjaar_biogecheckt) 	{
			$new_ditjaar_biogecheckt 	= $org_ditjaar_biogecheckt;
			wachthond($extdebug,1, "ditjaar_biogecheckt was nog leeg. Vul met biogecheckt", $new_ditjaar_biogecheckt);
		}
		if (empty($new_ditjaar_bionodig) AND $bionodig) 	{
			$new_ditjaar_bionodig 		= $bionodig;
			wachthond($extdebug,1, "ditjaar_bionodig was nog leeg. Vul met bionodig", 		$new_ditjaar_bionodig);
		}
		if (empty($new_ditjaar_biogecheckt) AND $org_ditjaar_biogecheckt) 	{
			$new_ditjaar_biogecheckt 	= $org_ditjaar_biogecheckt;
			wachthond($extdebug,1, "ditjaar_biogecheckt was nog leeg. Vul met biogecheckt", $new_ditjaar_biogecheckt);
		}
*/

		wachthond($extdebug,3, 'new_ditjaar_bionodig',		$new_ditjaar_bionodig);
		wachthond($extdebug,3, 'new_ditpart_bionodig',		$new_ditpart_bionodig);
		wachthond($extdebug,1, 'new_ditjaar_biogecheckt',	$new_ditjaar_biogecheckt);
		wachthond($extdebug,1, 'new_ditpart_biogecheckt',	$new_ditpart_biogecheckt);
		wachthond($extdebug,3, 'new_ditjaar_biostatus',		$new_ditjaar_biostatus);
		wachthond($extdebug,3, 'new_ditpart_biostatus',		$new_ditpart_biostatus);

		wachthond($extdebug,7, 'params_cont_dusver', 		$params_contact);
		wachthond($extdebug,7, 'params_part_dusver', 		$params_part_ditevent);

		################################################################################################
		### BEPAAL PARAMS UPDATE NAW & BIO
		################################################################################################

//		if ($ditjaarleidyes == 1 OR $ditjaardeelyes == 1 OR $ditjaarleidmss == 1 OR $ditjaardeelmss == 1 OR $ditjaardeeltop == 1) {

			if ($new_ditjaar_nawnodig) 		{ $params_contact['values']['INTAKE.NAW_nodig'] 	= $new_ditjaar_nawnodig; 	}
			if ($new_ditjaar_nawgecheckt)	{ $params_contact['values']['INTAKE.NAW_gecheckt'] 	= $new_ditjaar_nawgecheckt; }
			if ($new_ditjaar_nawstatus) 	{ $params_contact['values']['INTAKE.NAW_status'] 	= $new_ditjaar_nawstatus; 	}

			if ($new_ditjaar_bionodig) 		{ $params_contact['values']['INTAKE.BIO_nodig'] 	= $new_ditjaar_bionodig; 	}
			if ($new_ditjaar_biogecheckt)	{ $params_contact['values']['INTAKE.BIO_gecheckt'] 	= $new_ditjaar_biogecheckt; }
			if ($new_ditjaar_biostatus) 	{ $params_contact['values']['INTAKE.BIO_status'] 	= $new_ditjaar_biostatus; 	}

			if ($new_ditpart_nawnodig)		{ $params_part_ditevent['values']['PART_LEID_INTERN.NAW_nodig:name']	= $new_ditpart_nawnodig;	}	#PART NODIG NAW
			if ($new_ditpart_bionodig)		{ $params_part_ditevent['values']['PART_LEID_INTERN.BIO_nodig:name']	= $new_ditpart_bionodig;	}	#PART NODIG BIO
			if ($new_ditpart_nawstatus)		{ $params_part_ditevent['values']['PART_LEID_INTERN.NAW_status'] 		= $new_ditpart_nawstatus; 	}
			if ($new_ditpart_biostatus)		{ $params_part_ditevent['values']['PART_LEID_INTERN.BIO_status'] 		= $new_ditpart_biostatus; 	}	
			if ($new_ditpart_nawgecheckt)	{ $params_part_ditevent['values']['PART.NAW_gecheckt'] 					= $new_ditpart_nawgecheckt;	}
			if ($new_ditpart_biogecheckt)	{ $params_part_ditevent['values']['PART.BIO_gecheckt'] 					= $new_ditpart_biogecheckt; }

//		}

		wachthond($extdebug,7, 'params_cont_dusver', 	$params_contact);
		wachthond($extdebug,7, 'params_part_dusver', 	$params_part_ditevent);

		if (infiscalyear($new_ditjaar_biogecheckt,$today_datetime,'$new_ditjaar_biogecheckt','ditjaar') == 1 AND $diteventleidyes == 0 AND $diteventleidmss == 0) {

			if ($kerenleid >= 1) { $new_ditjaar_intnodig = "opnieuw"; } else { $new_ditjaar_intnodig = "eerstex"; } 

			$new_ditjaar_intstatus 	= "gedeeltelijk";

			if ($new_ditjaar_intnodig) 		{ $params_contact['values']['INTAKE.INT_nodig:name'] = $new_ditjaar_intnodig;	}
			if ($new_ditjaar_intstatus) 	{ $params_contact['values']['INTAKE.INT_status'] 	 = $new_ditjaar_intstatus;	}
		}

	}

	################################################################################################
	if ($extchk == 1 AND in_array($groupID, $profilecv)) { 		// PROFILE CONT + PART (BASIC)
	################################################################################################

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.1 A CONSTRUCT USERNAME FROM FIRSTNAME / LASTNAME", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,2, "########################################################################");

		### CONSTRUCT A PASSWORD
		$user_pwd		= bin2hex(openssl_random_pseudo_bytes(8));

		### CONSTRUCT THE USER_NAME
		if ($first_name) 	{	$firstname 	= $first_name 	?? NULL; 			}
		if ($middle_name) 	{	$middlename = $middle_name 	?? NULL; 			}
		if ($last_name) 	{	$lastname 	= $last_name 	?? NULL; 			}
		if ($nick_name) 	{	$nickname 	= $nick_name 	?? NULL; 			}

		if ($first_name) 	{ 	wachthond($extdebug,3, "INITIAL VALUES");		}
		if ($firstname) 	{ 	wachthond($extdebug,3, "0 FN", $firstname);		}
		if ($middlename) 	{ 	wachthond($extdebug,3, "0 MN", $middlename);	}
		if ($lastname) 		{ 	wachthond($extdebug,3, "0 LN", $lastname);		}
		if ($nickname) 		{ 	wachthond($extdebug,3, "0 NN", $nickname);		}

		// 1. REMOVE ACCENTS
		$firstname 		= transliterator_transliterate('NFKC; [:Nonspacing Mark:] Remove; Any-Latin; Latin-ASCII', $firstname);
		$middlename 	= transliterator_transliterate('NFKC; [:Nonspacing Mark:] Remove; Any-Latin; Latin-ASCII', $middlename);
		$lastname 		= transliterator_transliterate('NFKC; [:Nonspacing Mark:] Remove; Any-Latin; Latin-ASCII', $lastname);
		$nickname 		= transliterator_transliterate('NFKC; [:Nonspacing Mark:] Remove; Any-Latin; Latin-ASCII', $nickname);

		if ($firstname) 	{ 	wachthond($extdebug,3, "A. TRANSLITERATE ACCENTS & SPECIAL ASCII CHARACTERS");		}
		if ($firstname) 	{ 	wachthond($extdebug,3, "1 FN", $firstname)	?? NULL;	}
		if ($middlename) 	{ 	wachthond($extdebug,3, "1 MN", $middlename)	?? NULL;	}
		if ($lastname) 		{ 	wachthond($extdebug,3, "1 LN", $lastname)	?? NULL;	}
		if ($nickname) 		{ 	wachthond($extdebug,3, "1 NN", $nickname)	?? NULL;	}

		// 2. KEEP ONLY LETTERS & NUMBERS & DASHES + STRTOLOWER
		// ^   = beginning of the line
		// \w- = match a "word" character (alphanumeric plus "_")
		$firstname 		= preg_replace('/[^ \w-]/','',strtolower(trim($firstname)));	
		$middlename 	= preg_replace('/[^ \w-]/','',strtolower(trim($middlename)));
		$lastname 		= preg_replace('/[^ \w-]/','',strtolower(trim($lastname)));
		$nickname 		= preg_replace('/[^ \w-]/','',strtolower(trim($nickname)));

		if ($firstname) 			{ 	wachthond($extdebug,3, "B. PREG_REPLACE & KEEP ONLY LETTERS/NUMBERS/DASHES");		}
		if ($firstname) 			{ 	wachthond($extdebug,3, "2 FN", $firstname); 	}
		if ($middlename) 			{ 	wachthond($extdebug,3, "2 MN", $middlename);	}
		if ($lastname) 				{ 	wachthond($extdebug,3, "2 LN", $lastname);		}
		if ($nickname) 				{ 	wachthond($extdebug,3, "2 NN", $nickname);		}

		// 3. REPLACE SPACES WITH UNDERSCORES
		if ($firstname) 			{	$underscore_firstname 	= str_replace(' ', '_', $firstname)		?? NULL;	}
		if ($middlename) 			{	$underscore_middlename 	= str_replace(' ', '_', $middlename)	?? NULL;	}
		if ($lastname) 				{	$underscore_lastname 	= str_replace(' ', '_', $lastname)		?? NULL;	}
		if ($nickname) 				{	$underscore_nickname 	= str_replace(' ', '_', $nickname)		?? NULL;	}

		if ($underscore_firstname) 	{ 	wachthond($extdebug,3, "C1. STR_REPLACE SPACES WITH UNDERSCORES");	}
		if ($underscore_firstname) 	{ 	wachthond($extdebug,3, "3 FN", $underscore_firstname);				}
		if ($underscore_middlename) { 	wachthond($extdebug,3, "3 MN", $underscore_middlename);				}
		if ($underscore_lastname) 	{ 	wachthond($extdebug,3, "3 LN", $underscore_lastname);				}
		if ($underscore_nickname) 	{ 	wachthond($extdebug,3, "3 NN", $underscore_nickname);				}

		// 3. REPLACE UNDERSCORES WITH NOTHING
		if ($firstname) 			{	$nospace_firstname 		= str_replace(' ', '', $firstname) 		?? NULL;	}
		if ($middlename) 			{	$nospace_middlename 	= str_replace(' ', '', $middlename)		?? NULL;	}
		if ($lastname) 				{	$nospace_lastname 		= str_replace(' ', '', $lastname)		?? NULL;	}
		if ($nickname) 				{	$nospace_nickname 		= str_replace(' ', '', $nickname)		?? NULL;	}

		if ($nospace_firstname) 	{ 	wachthond($extdebug,3, "C2. STR_REPLACE REMOVE");					}
		if ($nospace_firstname) 	{ 	wachthond($extdebug,3, "3 FN [nospace]", $nospace_firstname);		}
		if ($nospace_middlename) 	{ 	wachthond($extdebug,3, "3 MN [nospace]", $nospace_middlename);		}
		if ($nospace_lastname) 		{ 	wachthond($extdebug,3, "3 LN [nospace]", $nospace_lastname);		}
		if ($nospace_nickname) 		{ 	wachthond($extdebug,3, "3 NN [nospace]", $nospace_nickname);		}

		// 4. CONSTRUCT FINAL USER_NAME
		if ($firstname AND $middlename AND $lastname) {
			$user_name 		= $nospace_firstname.".".$nospace_middlename."".$nospace_lastname;
			$user_name_org 	= $underscore_firstname.".".$underscore_middlename.".".$underscore_lastname;
		} elseif ($firstname AND empty($middlename) AND $lastname) {
			$user_name		= $firstname.".".$lastname;
			$user_name_org  = $underscore_firstname.".".$underscore_lastname;
		} elseif ($firstname AND empty($middlename) AND empty($lastname)) {
			$user_name		= $firstname;
			$user_name_org	= $underscore_firstname;
		} elseif (empty($firstname)) {
			$user_name		= NULL;
			$user_name_org	= NULL;
		} else {
			$user_name		= NULL;
			$user_name_org	= NULL;
		}

//		$user_name			= strtolower(trim($user_name));				// lowercase username
		#$user_name 		= preg_replace('/[^ \w-]/','',$user_name);	// keep only letters and numbers and dashes
		#$user_name 		= normalizer_normalize($user_name);			// remove accent marks using PHP's *intl*

//		if ($firstname) 	{ 	wachthond($extdebug,3, ".4 FINALY STRTOLOWER & TRIM");		}
//		wachthond($extdebug,3, "2 user_name    [firstname.middle.last]", 			$user_name);		

		// USERNAME OBV MEISJESNAAM (HANDIG OM TE CHECKEN OF DUBBBEL ACCOUNT TOCH ZELFDE PERSOON IS)
		if (!empty($nickname)) {
			$user_name_nick		= $firstname.".".$nospace_nickname;
		} else {
			$user_name_nick		= $user_name;	
		}

		wachthond($extdebug,2, "user_name_org  [firstname.middle.last]", 			$user_name_org);		
		wachthond($extdebug,2, "user_name_new  [firstname.middle_last] / NO _",		$user_name);
		wachthond($extdebug,2, "user_name_nick [firstname.nickname]",				"$user_name_nick\t[EVT OBV MEISJESNAAM]");

		$user_name_unique 		= $user_name ."_". $contact_id;
		wachthond($extdebug,2, "user_name_unq  [firstname.middle.last_contactid]", 	"$user_name_unique\t[UNIQUE + CID]");

		// M61: MAAK DE SWITCH van [firstname.middle.last] NAAR [firstname.middlelast]
		if ($user_name_chk) { $user_name = $user_name_nos; }

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.1 B CHECK IF CONSTRUCTED USERNAME IS UNIQUE", "[$user_name]");
		wachthond($extdebug,2, "########################################################################");

		################################################################################################
		# CHECK IF CONSTRUCTED USER_NAME IS IN USE AND/OR CONNECTED TO CURRENT CONTACT
		# M61: TODO: KAN ZO ZIJN DAT ER >1 JAN.JANSEN's ZIJN EN EEN UNIQUE USER_NAME MOET WORDEN GEGENEREERD
		################################################################################################

		$drupal_loadbyname  		= NULL;
		$drupal_loadbyname			= user_load_by_name($user_name);
		$drupal_loadbyname_found 	= 0;

		wachthond($extdebug,3, "drupal_loadbyname->uid", 	$drupal_loadbyname->uid);
		wachthond($extdebug,3, "drupal_loadbyname->mail", 	$drupal_loadbyname->mail);
		wachthond($extdebug,3, "drupal_loadbyname->name", 	$drupal_loadbyname->name);
		wachthond($extdebug,4, "drupal_loadbyname", 		$drupal_loadbyname);

		################################################################################################
		// HANDLE LOGIC [DIAGNOSE UFMATCH]
		################################################################################################

		$cid_ufmatch 			= NULL;
		$cid_ufmatch_found 		= NULL;
		$cid_ufmatch			= find_ufmatch('contactid', $contact_id) ?? NULL;
		$cid_ufmatch_found 		= (is_object($cid_ufmatch) == true ?  1 : 0 );
		wachthond($extdebug,4, "cid_ufmatch_result", 		$cid_ufmatch);
		wachthond($extdebug,3, "cid_ufmatch_found", 		$cid_ufmatch_found);

		if ($drupal_loadbyname->uid > 0) {
			wachthond($extdebug,1, "VIA USERNAAM ($user_name) EEN DRUPAL ACCOUNT ($drupal_loadbyname->uid) GEVONDEN");
		} else {
			wachthond($extdebug,1, "VIA USERNAAM ($user_name) DRUPAL ACCOUNT NIET GEVONDEN", "[KAN WORDEN AANGEMAAKT]");
			$safe2update_account = 1;
			
			wachthond($extdebug,2, "SAFE2  UPDATE DRUPALACCOUNT", 	$safe2update_account);
		}

		if ($drupal_loadbyname->uid > 0) {

			if ($drupal_loadbyname->uid > 0 AND $drupal_loadbyname->uid == $crm_externalid) {
				$valid_username 		= $user_name;
				$valid_drupalid 		= $drupal_loadbyname->uid;
				$safe2update_account 	= 1;
				wachthond($extdebug,2, "SAFE2  UPDATE DRUPALACCOUNT", 	$safe2update_account);
				wachthond($extdebug,1, "VIA USERNAAM ($user_name) GEVONDEN DRUPAL ACCOUNT", "PRIMA! [MATCH MET EXTID]");
			}

			if ($drupal_loadbyname->uid > 0 AND $drupal_loadbyname->uid != $crm_externalid) {

				wachthond($extdebug,1, "VIA USERNAAM ($user_name) GEVONDEN DRUPAL ACCOUNT", "CHECK! [GEEN EXTID MATCH]"); // MOGELIJK WEL UFMATCH

				// LOGIC: INDIEN GEVONDEN DRUPAL ACCOUNT VIA EXTID GEKOPPELD IS: LEUK!
				// LOGIC: INDIEN NIET DAN IS HET ALSNOG MOGELIJK DAT ER EEN UF_MATCH IS

				// LOGIC: INDIEN EEN GEVONDEN UFMATCH WIJST NAAR HEEL ANDERE CONTACT DAN NIET SAFE
				// LOGIC: INDIEN OOK GEEN UFMATCH DAN IS DRUPAL ACCOUNT EEN ORPHAN (EN KAN MOGELIJK VIA NIEUWE UFMATCH GEKOPPELD WORDEN)

				$drupal_loadbyname_findcontact 	= find_contact('drupalid', 	$drupal_loadbyname->uid);
				if ($drupal_loadbyname_findcontact->id > 0) {
					wachthond($extdebug,1, "VIA USERNAAM ($user_name) GEVONDEN DRUPAL ACCOUNT HEEFT WEL CIVICRM CONTACT $drupal_loadbyname_findcontact->naam"); // MOGELIJK WEL UFMATCH

					if ($drupal_loadbyname_findcontact->id == $contact_id) {
						wachthond($extdebug,1, "VIA ($user_name) GEVONDEN ACCOUNT HEEFT EXTID MATCH MET DIT CONTACT", 	"PRIMA! [WEL UPDATE EXTID NODIG VOOR [$check_did_ufmatch_findcontact->naam]");
					} else {
						wachthond($extdebug,1, "VIA ($user_name) GEVONDEN ACCOUNT HEEFT EXTID MATCH MET ANDER CID", 	"ERROR! [CONFLICT MET $check_did_ufmatch_findcontact->naam]");						
					}
				}

				$check_did_ufmatch				= find_ufmatch('drupalid', 	$drupal_loadbyname->uid) ?? NULL;
				$check_did_ufmatch_found 		= (is_object($check_did_ufmatch) == true ?  1 : 0 );
				wachthond($extdebug,4, "check_did_ufmatch_result", 			$check_did_ufmatch);
				wachthond($extdebug,3, "check_did_ufmatch_found", 			$check_did_ufmatch_found);

				if ($check_did_ufmatch_found == 1) {
					$check_did_ufmatch_findcontact = find_contact('contactid', $check_did_ufmatch->cid);

					if ($check_did_ufmatch->cid != $contact_id) {
						wachthond($extdebug,1, "VIA USERNAAM ($user_name) GEVONDEN DRUPAL ACCOUNT HEEFT UFMATCH MET ANDER CID", 	"ERROR! [$check_did_ufmatch_findcontact->naam]");
						// M61: IN DIT GEVAL MOET EEN ALTERNATIEVE USER_NAME GEBRUIKT WORDEN (KAN ZIJN DAT JUISTE USERNAME HANGT AAN EMPTY PLACEHOLDER VAN ZELFDE CONTACT)
						$valid_username 		= $user_name ."_". $contact_id;
						$need2update_jobtitle = 1;
					}
					if ($check_did_ufmatch->cid == $contact_id) {
						wachthond($extdebug,1, "VIA USERNAAM ($user_name) GEVONDEN DRUPAL ACCOUNT HEEFT UFMATCH MET DIT CONTACT", 	"HOERA! [$check_did_ufmatch_findcontact->naam]");
						// M61: IN DIT GEVAL MOET DE CRM_EXTERNALID WORDEN GEUPDATE NAAR $check_did_ufmatch->cid OF $drupal_loadbyname->uid;
						$valid_username 		= $user_name;
						$valid_drupalid 		= $drupal_loadbyname->uid;
						$need2update_externalid = 1;
					}

				} else {
					wachthond($extdebug,1, "VIA USERNAAM ($user_name) GEVONDEN DRUPAL ACCOUNT KAN GEKOPPELD WORDEN!", "ORPHAN [GEEN UFMATCH / EXTID MATCH VOOR UID: $drupal_loadbyname->uid]");					
					// M61: IN DIT GEVAL MOET DE UF_MATCH WORDEN GEUPDATE OF AANGEMAAKT 					
					$valid_drupalid 			= $drupal_loadbyname->uid;

					if ($cid_ufmatch->id > 0) {
						$need2update_ufmatch 	= 1;
					} else {
						$need2create_ufmatch 	= 1;
						$safe2create_ufmatch 	= 1;

					}
				}
			}
		}

		wachthond($extdebug,3, "crm_drupalnaam (job_title)",	$crm_drupalnaam);
		wachthond($extdebug,3, "user_name (constructed)", 		$user_name);
		wachthond($extdebug,3, "user_name_nick (meisjesnaam)",	$user_name_nick);

		wachthond($extdebug,3, "valid_username", 				$valid_username);
		wachthond($extdebug,3, "valid_drupalid", 				$valid_drupalid);

		wachthond($extdebug,3, "need2update_externalid", 		$need2update_externalid);
		wachthond($extdebug,3, "need2update_jobtitle", 			$need2update_jobtitle);

		wachthond($extdebug,3, "need2repair_ufmatch", 			$need2repair_ufmatch);
		wachthond($extdebug,3, "need2update_ufmatch", 			$need2update_ufmatch);
		wachthond($extdebug,3, "need2create_ufmatch", 			$need2create_ufmatch);
		wachthond($extdebug,3, "safe2update_ufmatch", 			$safe2update_ufmatch);
		wachthond($extdebug,3, "safe2create_ufmatch", 			$safe2create_ufmatch);

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.1 C DIAGNOSE UFMATCH", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,2, "########################################################################");

		if ($cid_ufmatch_found == 1) {

			$diag_ufmatch 			= diag_ufmatch('contactid', $contact_id, $cid_ufmatch, $user_name, $crm_drupalnaam, $crm_externalid);
			$diag_ufmatch_found 	= (is_object($diag_ufmatch) == true ?  1 : 0 );
			wachthond($extdebug,3, "diag_ufmatch", 				$diag_ufmatch);
			wachthond($extdebug,3, "diag_ufmatch_found", 		$diag_ufmatch_found);

			$need2update_externalid = $diag_ufmatch->need2_update_extid;
			$need2update_jobtitle 	= $diag_ufmatch->need2_update_jobtitle;
			wachthond($extdebug,3, "need2update_externalid", 	$need2update_externalid);
			wachthond($extdebug,3, "need2update_jobtitle", 		$need2update_jobtitle);

			$safe2update_externalid	= $diag_ufmatch->safe2_update_extid;
			$safe2update_jobtitle	= $diag_ufmatch->safe2_update_jobtitle;
			wachthond($extdebug,3, "safe2update_externalid", 	$safe2update_externalid);
			wachthond($extdebug,3, "safe2update_jobtitle", 		$safe2update_jobtitle);
/*
			if ($valid_drupalid 	AND $need2update_externalid AND $safe2update_externalid)	{
				$params_contact['values']['external_identifier'] 	= $valid_drupalid;
				wachthond($extdebug,3, "DOE UPDATE VAN EXTERNAL ID (CMSEXTID) MET DRUPALID", $valid_drupalid);
			}
		    if ($valid_username 	AND $need2update_jobtitle 	AND $safe2update_jobtitle)		{
		    	$params_contact['values']['job_title'] 			= $valid_username;
				wachthond($extdebug,3, "DOE UPDATE VAN CRMUSERNAME (JOBTITLE) MET USERNAME", $valid_username);
		    }
*/
		}

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.2 STATUS PROFIELFOTO", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,2, "########################################################################");

		wachthond($extdebug,3, 'contact_foto', $contact_foto);

		$intakestatusfot = "";
		wachthond($extdebug,3, '0 intakestatusfot', $intakestatusfot);

		if (empty($contact_foto)) {
			$intakestatusfot 	= "";
#			$contact_foto		= "https://www.onvergetelijk.nl/civicrm/contact/imagefile?photo=placeholder_29c31679575384c30fb02292a2b0106e.png";
			if ($contact_foto)		{ $params_contact['values']['image_URL'] 		 = $contact_foto;	}
		} 
		if (str_contains($contact_foto, 'imagefile') 	AND  str_contains($contact_foto, 'placeholder')) 	{
			$intakestatusfot 	= "0";
		} 
		if (str_contains($contact_foto, 'uploads') 		AND !str_contains($contact_foto, 'placeholder')) 	{
			$intakestatusfot 	= "1";
		} 
		if (str_contains($contact_foto, 'imagefile') 	AND !str_contains($contact_foto, 'placeholder')) 	{
			$intakestatusfot 	= "1";
		} 
		if (str_contains($contact_foto, 'profielfotos')	AND  str_contains($contact_foto, 'instagram')) 		{
			$intakestatusfot 	= "1";
		} 
		if (str_contains($contact_foto, 'profielfotos')	AND  str_contains($contact_foto, 'square')) 		{
			$intakestatusfot 	= "2";
		} 

		wachthond($extdebug,3, '1 intakestatusfot', $intakestatusfot);

		if ($intakestatusfot >= 0)	{ $params_contact['values']['INTAKE.FOT_status'] = $intakestatusfot;}

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.3 DEFINE POSTAL & EMAIL GREETING", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,2, "########################################################################");

   		// FIRST SET DEFAULT
		$email_greeting_id		= 1;
		$communication_style_id	= 'familiar';

		if (in_array($groupID, array("139"))) { 		// PART DEEL
			$email_greeting_id 		= 2; 				// OUDER VERZORGER
			$communication_style_id = 'formal'; 		// FORMEEL
		}
		if (in_array($groupID, array("190"))) { 		// PART DEEL
			$email_greeting_id 		= 1; 				// HALLO VOORNAAM
			$communication_style_id = 'familiar'; 		// INFORMEEL
		}		

		if (in_array($groupID, $profilepart)) { 		// PROFILE PARTICIPANT
   			if ($ditjaareventdeelyes == 1 OR $ditjaareventdeelmss == 1) {
				$email_greeting_id 		= 2; 			// OUDER VERZORGER
				$communication_style_id = 'formal'; 	// FORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want part deel]', $email_greeting_id);
			}
			if ($ditjaareventdeelyes == 1 AND $eventkamp_event_kampkort == 'top') {
				$email_greeting_id 		= 1; 			// HALLO VOORNAAM
				$communication_style_id = 'familiar'; 	// INFORMEEL 
				wachthond($extdebug,3, 'email_greeting_id [want part top]', $email_greeting_id);
			}
			if ($ditjaareventleidyes == 1 OR $ditjaareventleidmss == 1) {
				$email_greeting_id 		= 1; 			// HALLO VOORNAAM (LEIDING)
				$communication_style_id = 'familiar';	// INFORMEEL 
				wachthond($extdebug,3, 'email_greeting_id [want part leid]', $email_greeting_id);
			}
		}
		if (in_array($groupID, $profilecont)) { 		// PROFILE PARTICIPANT
   			if ($ditjaardeelyes == 1 OR $ditjaardeelmss == 1) {
				$email_greeting_id 		= 2; 			// OUDER VERZORGER
				$communication_style_id = 'formal'; 	// FORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want deel]', $email_greeting_id);
			}
			if ($leeftijd_nextkamp_rondjaren < 18) {
				$email_greeting_id 		= 2; 			// OUDER VERZORGER
				$communication_style_id = 'formal'; 	// FORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want < 18]', $email_greeting_id);
			}
			if ($leeftijd_nextkamp_rondjaren >= 18) { 
				$email_greeting_id 		= 1; 			// HALLO VOORNAAM
				$communication_style_id = 'familiar'; 	// INFORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want >= 18]', $email_greeting_id);
			}
			if ($kereneventtop >= 1) {
				$email_greeting_id 		= 1; 			// HALLO VOORNAAM
				$communication_style_id = 'familiar'; 	// INFORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want x evttop >= 1]', $email_greeting_id);
			}
			if ($kerenleid >= 1) {
				$email_greeting_id 		= 1;			// HALLO VOORNAAM
				$communication_style_id = 'familiar'; 	// INFORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want x leid >= 1]', $email_greeting_id);
			}
   			if ($ditjaardeeltop == 1) {
				$email_greeting_id 		= 1;			// HALLO VOORNAAM
				$communication_style_id = 'familiar'; 	// INFORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want deel top]', $email_greeting_id);
			}
			if ($leeftijd_nextkamp_rondjaren >= 60) {
				$email_greeting_id 		= 1; 			// HALLO VOORNAAM
				$communication_style_id = 'formal'; 	// FORMEEL
				wachthond($extdebug,3, 'email_greeting_id [want >= 60]', $email_greeting_id);
			}
		}

		if ($email_greeting_id)			{ $params_contact['values']['email_greeting_id']			= $email_greeting_id;		}
		if ($communication_style_id)	{ $params_contact['values']['communication_style_id:name']	= $communication_style_id;	}

		wachthond($extdebug,2, 'email_greeting_id', 		$email_greeting_id);
		wachthond($extdebug,2, 'communication_style_id', 	$communication_style_id);

		################################################################################################
		# VELDEN RONDOM INGEVULDE EVALUATIES
		################################################################################################

		if ($extdjpart == 1 AND in_array($groupID, $profilepart) AND ($diteventleidyes == 1 OR $diteventdeelyes == 1)) {

			$ditevent_eval_terugblik	= $result_partditevent[0]['PART_EVALUATIE.TERUGBLIK:label'] 			?? NULL;
			$ditevent_eval_inhoud		= $result_partditevent[0]['PART_EVALUATIE.INHOUDELIJK:label'] 			?? NULL;
			$ditevent_eval_spellen		= $result_partditevent[0]['PART_EVALUATIE.ACTIVITEITEN:label'] 			?? NULL;
			$ditevent_eval_slapen		= $result_partditevent[0]['PART_EVALUATIE.Hoe_was_het_slapen_op_kamp_:label'] ?? NULL;
			$ditevent_eval_aanbeveel	= $result_partditevent[0]['PART_EVALUATIE.Zou_je_onze_kampen_aanbevelen_aan_andere_ouders_:label'] 	?? NULL;
			$ditevent_eval_kampthema	= $result_partditevent[0]['PART_EVALUATIE.Wat_vond_je_van_het_kampthema_dit_jaar_:label'] 			?? NULL;		

			$ditevent_eval_eten			= $result_partditevent[0]['PART_EVALUATIE.ETEN_DRINKEN:label'] 			?? NULL;
			$ditevent_eval_brengen		= $result_partditevent[0]['PART_EVALUATIE.Brengen_halen:label'] 		?? NULL;
			$ditevent_eval_kampinfo		= $result_partditevent[0]['PART_EVALUATIE.Informatievoorziening:label'] ?? NULL;

			if (in_array($ditevent_eval_terugblik, 	array(1, 2, 3, 4, 5, 6))) 			{ $score_terugblik_low 	= 1; } else { $score_terugblik_low = NULL; 	}
			if (in_array($ditevent_eval_inhoud, 	array(1, 2, 3, 4, 5, 6))) 			{ $score_inhoud_low 	= 1; } else { $score_inhoud_low = NULL;		}
