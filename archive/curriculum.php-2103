			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 13.4 CREATE AN ACTIVITY VOGAANVRAAG VOOR $displayname", "[ALS VOG AANVRAAG IS INGEDIEND]");
