				wachthond($extdebug,4, "part_refpersoon", 			$part_refpersoon);
				wachthond($extdebug,4, "new_ditpart_refnodig", 		$new_ditpart_refnodig);
				wachthond($extdebug,4, "new_ditjaar_refnodig", 		$new_ditjaar_refnodig);
