				}

			} else {
				wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit VOGAANVRAAG aangemaakt", "[aid: $vogaanvraag_activity_id]");
				wachthond($extdebug,4, "vogaanvraag_activity_id", 	$vogaanvraag_activity_id);
				wachthond($extdebug,4, "datum_vogaanvraag", 		$ditjaar_vogaanvraag_actdatetime);
				wachthond($extdebug,4, "part_vogaanvraag", 			$part_vogingediend);
				wachthond($extdebug,4, "new_ditpart_vognodig", 		$new_ditpart_vognodig);
				wachthond($extdebug,4, "new_ditjaar_vognodig", 		$new_ditjaar_vognodig);
			}

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 13.4 CREATE AN ACTIVITY VOGONTVANGST VOOR $displayname", "[ALS VOG AANVRAAG IS INGEDIEND]");
			wachthond($extdebug,3, "########################################################################");

			if (empty($vogontvangst_activity_id) AND $ditjaar_vogontvangst_actdatetime) {

				// M61: set part vogverzocht naar todaydatetime om de tijd mee te krijgen (TODO: moet anders want kan ook andere datum zijn in het verleden
				//if (empty($part_vogverzocht)) { $part_vogverzocht = $today_datetime; }

				if ($extvog == 1 AND in_array($new_ditjaar_vognodig, array('eerstex', 'opnieuw', 'elkjaar', 'inhaal'))) 	{
					$params_activity_vogontvangst_create = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
