			wachthond($extdebug,3, 'diteventjaarleidyes F', 			$diteventjaarleidyes);
			wachthond($extdebug,3, 'diteventjaardeelmss F', 			$diteventjaardeelmss);
			wachthond($extdebug,3, 'diteventjaarleidmss F', 			$diteventjaarleidmss);
		}

		if ($result_partditjaar_all_count >= 1) {
			wachthond($extdebug,3, 	"########################################################################");
			wachthond($extdebug,1, 	"DITJAAR      $today_kampjaar GAAT $displayname $ditjaardeeltxt MEE ALS DEELNEMER", 	
									"[EID $ditjaar_pos_deel_part_eventid / TYPE $ditjaar_pos_deel_event_type_id / $ditjaar_pos_deel_part_kampkort]");
			wachthond($extdebug,1, 	"DITJAAR      $today_kampjaar GAAT $displayname $ditjaarleidtxt MEE ALS LEIDING",
									"[EID $ditjaar_pos_leid_part_eventid / TYPE $ditjaar_pos_leid_event_type_id / $ditjaar_pos_leid_part_kampkort]");
		} else {
			wachthond($extdebug,1, 	"DITJAAR $today_kampjaar [GAAT $displayname NIET MEE OP KAMP]");
		}
		if ($result_partditevent_count >= 1) {

			// M61: DEZE SECTIE NIET LATEN ZIEN INDIEN CONTACT WORDT GEWIJZIGD / ALLEEN BIJ EDIT PARTICIPANT
			wachthond($extdebug,3, 	"########################################################################");
			wachthond($extdebug,1, 	"DITEVENT     $ditevent_kampjaar GAAT $displayname $diteventdeeltxt MEE ALS DEELNEMER",
									"[EID $ditevent_part_eventid / TYPE $ditevent_event_type_id / $ditevent_event_kampkort]");
			wachthond($extdebug,1, 	"DITEVENT     $ditevent_kampjaar GAAT $displayname $diteventleidtxt MEE ALS LEIDING",
									"[EID $ditevent_part_eventid / TYPE $ditevent_event_type_id / $ditevent_event_kampkort]");
			wachthond($extdebug,3, "########################################################################");
		} else {
			wachthond($extdebug,1, 	"DITEVENT     [ER WORDT GEEN EVENT BEWERKT]");
		}

		if ($result_eventjaar_all_count >= 1) {

			wachthond($extdebug,1, 	"DITEVENTJAAR $ditevent_kampjaar GAAT $displayname $diteventjaardeeltxt MEE ALS DEELNEMER",
									"[EID $diteventjaar_pos_deel_part_eventid / TYPE $diteventjaar_pos_deel_event_type_id / $diteventjaar_pos_deel_part_kampkort]");
			wachthond($extdebug,1, 	"DITEVENTJAAR $ditevent_kampjaar GAAT $displayname $diteventjaarleidtxt MEE ALS LEIDING",
									"[EID $diteventjaar_pos_leid_part_eventid / TYPE $diteventjaar_pos_leid_event_type_id / $diteventjaar_pos_leid_part_kampkort]");
			wachthond($extdebug,3, 	"########################################################################");
		} else {
			wachthond($extdebug,1, 	"DITEVENTJAAR [ER WORDT GEEN EVENT BEWERKT]");
		}


		if (in_array($groupID, $profilepartmax)) { // PROFILE PARTICIPANT MAX

			################################################################################################
			# 1.12 GET EVENT INFO VAN HET KAMP (IGV LEIDING RETREIVE DIT VANUIT HET EVENT VAN HET KAMP, NIET HET LEIDING EVENT) 
			// M61: TODO: dit overschrijft mogelijk waarden van de participant get, met name event_id. Beter query op event_id bij deelnemers

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 1.12 GET EVENT INFO TO RETREIVE KAMPINFO", "[params_eventkamp] ");
			wachthond($extdebug,3, "########################################################################");

	    	if (
	    		($extdjpart == 1 OR $extdjcont == 1 OR $extref == 1 OR $extvog == 1)
	    		AND 
	    		(in_array($ditevent_event_type_id, $eventtypesdeel) OR in_array($ditevent_event_type_id, $eventtypesleid))  
	    		// M61 voor kampevents van alle statussen
	    	   ) {

				################################################################################################
	  			### DITEVENT_EVENTKAMP
				################################################################################################

				$params_var_ditevent 		= NULL;
				$params_var_ditevent_note 	= NULL;

	   			if (in_array($ditevent_event_type_id, $eventtypesdeel)) {
	   				$params_var_ditevent = [
		    			['event_type_id', 	'IN', 	$eventtypesdeel],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],	// maakt editen eerdere events mogelijk
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],		    			
	   					['id', 				'=', 	$ditevent_part_eventid],		// eventid of specific kamp
	  					['Event_Kenmerken.testevent', '!=', 1],
	   				];
	   				$params_var_ditevent_note = "DITEVENT DEEL";
	   			}
	  			if (in_array($ditevent_event_type_id, $eventtypesleid)) {			// Eventtype = LEID (zoek kamp waar leiding zich voor opgaf)
	  				$params_var_ditevent = [
		    			['event_type_id', 	'IN', 	$eventtypesdeel],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],
	  					['Event_Kenmerken.kampkort',  '=', strtolower(trim($ditevent_leid_welkkamp))], // search for kampkort lowercase
	  					['Event_Kenmerken.testevent', '!=', 1],
	  				];
	   				$params_var_ditevent_note = "DITEVENT LEID";
	  			}

				################################################################################################
	  			### DITJAAR_EVENTKAMP
				################################################################################################
/*
				$params_var_ditjaar 	 	= NULL;
				$params_var_ditjaar_note 	= NULL;

	   			if (in_array($ditjaar_pos_leid_event_type_id, $eventtypesdeel)) {			
	   				$params_var_ditjaar = [
		    			['event_type_id', 	'IN', 	$eventtypesdeel],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],		// maakt editen eerdere events mogelijk
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],		    			
	   					['id', 				'=', 	$ditjaar_pos_deel_part_eventid],	// eventid of specific kamp
	  					['Event_Kenmerken.testevent', '!=', 1],
	   				];
	   				$params_var_ditjaar_note = "PARAMS_VAR: DITJAAR DEEL";
	   			}
	  			if (in_array($ditjaar_pos_leid_event_type_id, $eventtypesleid)) {		// Eventtype = LEID (kamp waar leiding zich voor opgaf)
	  				$params_var_ditjaar = [
		    			['event_type_id', 	'IN', 	$eventtypesdeel],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],
	  					['Event_Kenmerken.kampkort',  '=', strtolower(trim($ditjaar_pos_leid_leid_welkkamp))], // search for kampkort lowercase
	  					['Event_Kenmerken.testevent', '!=', 1],
	  				];
	   				$params_var_ditjaar_note = "PARAMS_VAR: DITJAAR LEID";	  				
	  			}
*/
				################################################################################################
	  			### DITEVENT_EVENTKAMP (BESTUURSLID)
				################################################################################################

				if (in_array($ditevent_part_functie, array('bestuurslid'))) {
				   	$params_var_ditevent = [
		    			['event_type_id', 	'IN', 	$eventtypesleid],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],	
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],		    			
	   					['id', 				'=', 	$ditevent_part_eventid],		// eventid of specific kamp
	  					['Event_Kenmerken.testevent', '!=', 1],
	   				];
	   				$params_var_note = "PARAMS_VAR: DITEVENT BESTUUR";	   				
				}

				################################################################################################
	  			### DITEVENT_EVENTKAMP (TESTEVENTS)
				################################################################################################

	   			if (in_array($ditevent_event_type_id, $eventtypesdeeltest)) {
	   				$params_var_ditevent = [
		    			['event_type_id', 	'IN', 	$eventtypesdeeltest],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],	// niet alleen in dit fiscale jaar
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],		    			
	   					['id', 				'=', 	$ditevent_part_eventid],		// eventid of specific kamp
#	  					['Event_Kenmerken.testevent', '=', 1],
	   				];
	   				$params_var_note = "PARAMS_VAR: DITEVENT DEEL TEST";
	   			}
	  			if (in_array($ditevent_event_type_id, $eventtypesleidtest)) {		// Eventtype = LEID (zoek kamp waar leiding zich voor opgaf)
	  				$params_var_ditevent = [
		    			['event_type_id', 	'IN', 	$eventtypesdeeltest],
	    				['start_date', 		'>=', 	$ditevent_fiscalyear_start],
	    				['start_date', 		'<=', 	$ditevent_fiscalyear_einde],
	  					['Event_Kenmerken.kampkort',  '=', strtolower(trim($ditevent_leid_welkkamp))], // search for kampkort lowercase
