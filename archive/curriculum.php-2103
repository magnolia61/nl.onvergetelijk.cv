					$params_activity_refpersoon_create = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
						'values' => [
					    	'source_contact_id' 		=> 1,
							'target_contact_id' 		=> $contact_id,
							'activity_type_id' 			=> 139,
#							'activity_type_id:name' 	=> 'REF_persoon', 	// type_id: 139
							'activity_date_time' 		=> $today_datetime,
							'subject' 					=> 'REF persoon',
							'status_id:name' 			=> 'Scheduled', 	// initial status ingepland

			   				'ACT_ALG.actcontact_naam'	=> $displayname,
			   				'ACT_ALG.actcontact_cid'	=> $contact_id,
			   				'ACT_ALG.actcontact_pid'	=> $ditevent_part_id,
			   				'ACT_ALG.actcontact_eid'	=> $ditevent_part_eventid,

		   					'ACT_ALG.kampnaam'			=> $eventkamp_event_kampkort_cap,
			   				'ACT_ALG.kampkort'			=> $eventkamp_event_kampkort_low,
							'ACT_ALG.kampfunctie' 		=> $ditevent_part_functie,
							'ACT_ALG.kampstart' 		=> $eventkamp_event_start,
							'ACT_ALG.kampeinde' 		=> $eventkamp_event_einde,
							'ACT_ALG.kampjaar'			=> $eventkamp_kampjaar,

							'ACT_ALG.modified' 			=> $today_datetime,
			    			'ACT_ALG.prioriteit:label'	=> 'Normaal',
						],
					];
					wachthond($extdebug,7, 'params_activity_refpersoon_create', 	$params_activity_refpersoon_create);
