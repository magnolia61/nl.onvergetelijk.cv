		];

//		wachthond($extdebug,7, 'params_event_test', 			$params_event_leidtest);
		$result_event_leidtest = civicrm_api4('Event', 'get', 	$params_event_leidtest);
//		wachthond($extdebug,9, 'result_event_test', 			$result_event_leidtest);

		$kampids_leidtest = $result_event_leidtest->column('id'); // maakt een array met alleen de velden voor id
		ksort($kampids_leidtest);

		$kampids_deel_top 	= array_merge($kampids_deel, $kampids_top);
		$kampids_deel_all 	= array_merge($kampids_deel, $kampids_top, 			$kampids_deeltest);
		$kampids_leid_all 	= array_merge($kampids_leid, $kampids_leidtest);
		$kampids_deel_leid 	= array_merge($kampids_deel, $kampids_top, 			$kampids_leid);
		$kampids_all 		= array_merge($kampids_deel, $kampids_top, 			$kampids_leid, $kampids_deeltest, $kampids_leidtest);

		wachthond($extdebug,4, "kampids_deel", 		$kampids_deel);
		wachthond($extdebug,4, "kampids_top", 		$kampids_top);
		wachthond($extdebug,4, "kampids_deel_top", 	$kampids_deel_top);
		wachthond($extdebug,4, "kampids_leid", 		$kampids_leid);
		wachthond($extdebug,4, "kampids_meet", 		$kampids_meet);
		wachthond($extdebug,4, "kampids_deeltest", 	$kampids_deeltest);
		wachthond($extdebug,4, "kampids_leidtest", 	$kampids_leidtest);
		wachthond($extdebug,4, "kampids_deel_leid", $kampids_deel_leid);		
		wachthond($extdebug,4, "kampids_all", 		$kampids_all);

    	################################################################################################
    	# VOER EERST DE QUERY UIT VAN HET PART EVENT DAT WERD GEEDIT
    	################################################################################################

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "### 0.2a CHECK PART STATUS DIT EVENT", "[EntityID: $entityID]");
		wachthond($extdebug,3, "########################################################################");

    	# A. als partitipant wordt bewerkt dan zoek dan de participant info van dat event
    	# B. indien participant die wordt bewerkt is gecancelled dan kijken of er een andere registratie is die niet gecancceled is
    	# C. indien contact wordt geedit (en geen participant), dan kijken of er een actieve registratie in dit fiscal jaar is
    	# D. indien dit allemaal niet het geval is, gewoon basic info ophalen voor het contact

		// 101  EVENT KENMERKEN
		// 139	PART DEEL
		// 190	PART LEID
		// (140	PART LEID VOG)
		// 106	TAB  WERVING
		// 103	TAB  CURRICULUM
		// 149  TAB  TALENT
		// 150	TAB  PROMOTIE
		// 165	PART REFERENTIE
		// 213  PART LEID REF
		// 205  PART 
		// 225  JAAROVERZICHT

    	################################################################################################
		# BEPAAL HET CONTACT ID
		################################################################################################

		$result_partditevent_count = 0;

		if (in_array($groupID, $profilepartmax)) { 	// PROFILE PARTICIPANT MAX

			$params_partditevent = [
				'checkPermissions' => FALSE,
				'debug' => $apidebug,
	  			'orderBy' => [
	    			'event_id' => 'ASC',
	  			],
				'limit' => 1,
				'select' => [
					'row_count',
	    			'id', 
	    			'contact_id',
	    			'contact_id.first_name',
	    			'status_id',
	    			'status_id:name',
	    			'role_id', 
	    			'register_date',

					'event_id',						// event_id stored in participant table
					'event.id',						// event_id stored in joined event table
					'event.title',
					'event.event_type_id',			// integer 			       bv. 21
		    		'event.event_type_id:label',	// zelfde als naam event:  bv. Kinderkamp week 2
					'event.start_date',
					'event.end_date',

					'event.Event_Kenmerken.kampnaam',				
					'event.Event_Kenmerken.kampkort',
					'event.Event_Kenmerken.typekamp',
					'event.Event_Kenmerken.kamptype_naam',
					'event.Event_Kenmerken.kamptype_naam:label',
					'event.Event_Kenmerken.kamptype_id',
					'event.Event_Kenmerken.kampsoort',

	        		'PART.PART_kamplang',
	    			'PART.PART_kampkort',
	    			'PART.PART_1xkeer_deel',
	    			'PART.PART_1xkeer_leid',
	    			'PART_DEEL.Groep_klas',
	    			'PART_DEEL.Voorkeur',
	    			'PART.PART_kamptype_id',
	    			'PART.PART_kampfunctie',
	    			'PART.PART_kamprol',
	    			'PART.PART_datum_check',

	    			'PART_DEEL.Tijdslot_brengen',
	    			'PART_DEEL.Tijdslot_halen',
	    			'PART_INTERN.Groepje',
	    			'PART_INTERN.Groepjeskleur',
					'PART_INTERN.groep_letter',
					'PART_INTERN.groep_kleur',
	    			'PART_INTERN.Slaapzaal',

					'PART_KAMPGELD.contribid',

	    			'PART_KAMPGELD.regeling',
	    			'PART_KAMPGELD.regeling:label',

					'PART_DEEL_INTERN.criteria_indicatie',
					'PART_DEEL_INTERN.criteria_beoordeling',

					'PART_EVALUATIE.DATUM_evaluatie',

				    'PART_EVALUATIE.TERUGBLIK:label',
				    'PART_EVALUATIE.Hoe_was_het_slapen_op_kamp_:label',
				    'PART_EVALUATIE.ETEN_DRINKEN:label',
				    'PART_EVALUATIE.INHOUDELIJK:label',
				    'PART_EVALUATIE.ACTIVITEITEN:label',
				    'PART_EVALUATIE.Brengen_halen:label',
				    'PART_EVALUATIE.Informatievoorziening:label',
				    'PART_EVALUATIE.Zou_je_onze_kampen_aanbevelen_aan_andere_ouders_:label',
				    'PART_EVALUATIE.Wat_vond_je_van_het_kampthema_dit_jaar_:label',

	    			'PART_LEID.Welk_kamp',
	    			'PART_LEID.Functie',

	    			'PART_LEID_INTERN.INT_nodig',
	    			'PART_LEID_INTERN.NAW_nodig',
	    			'PART_LEID_INTERN.BIO_nodig',
	    			'PART_LEID_INTERN.REF_nodig',
				    'PART_LEID_INTERN.VOG_nodig',

				    'PART.NAW_gecheckt',
				    'PART.BIO_gecheckt',

	    			'PART_LEID_REF.REF_persoon',
	    			'PART_LEID_REF.REF_gevraagd',
	    			'PART_LEID_REF.REF_feedback',

	    			'PART_LEID_VOG.Datum_verzoek',
	    			'PART_LEID_VOG.Datum_aanvraag',
	    			'PART_LEID_VOG.Datum_ontvangst',
	    			'PART_LEID_VOG.Datum_nieuwe_VOG',
	    			'PART_LEID_VOG.Kenmerk_VOG',

	    			'PART_LEID_HOOFD.notificatie_deel',
	    			'PART_LEID_HOOFD.notificatie_leid',
	    			'PART_LEID_HOOFD.notificatie_kamp',
	    			'PART_LEID_HOOFD.notificatie_staf',
					'PART_LEID_HOOFD.Jouw_prive_emailadres',
				],
	  			'join' => [
	    			['Event AS event', 'INNER', ['event_id', '=', 'event.id']],
	  			],
	  			'where' => [
		    		['id', '=',  $entityID],
	  			],
			];

			wachthond($extdebug,3, 'params_partditevent', 				$params_partditevent);
			$result_partditevent = civicrm_api4('Participant', 'get', 	$params_partditevent);
			wachthond($extdebug,3, 'result_partditevent', 				$result_partditevent);

			if ($result_partditevent) {
				$result_partditevent_count  = $result_partditevent->count();
			}

		}

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "### 0.2b BEPAAL HET CONTACT ID (DANGEROUS!)", "[EntityID: $entityID]");
		wachthond($extdebug,3, "########################################################################");

		if ($result_partditevent_count == 1) {

	    	################################################################################################
			### IGV PROFILE PART MAX
	    	################################################################################################

			if (in_array($groupID, $profilepartmax)) {

				$ditevent_part_id 	= $result_partditevent[0]['id'] 		?? NULL;
				$contact_id 		= $result_partditevent[0]['contact_id'] ?? NULL;
				wachthond($extdebug,1, "CONTACTID: USE THE VALUE IN PART RESULT", 				"$contact_id [WANT EDIT CONT]");			

			} else {
				wachthond($extdebug,3, "CONTACTID: DO NOT USE PART_RESULT AS A VALUE", 			$contact_id);
			}

		}

    	################################################################################################
		### IGV PROFILE CONT MAX
    	################################################################################################

		if ($result_partditevent_count == 0) {

			if (in_array($groupID, $profilecontmax)) {

				$contact_id = $entityID;
				wachthond($extdebug,1, "CONTACTID: USE THE VALUE OF ENTITYID", 					"$contact_id [WANT EDIT CONT]");		

			} else {
				wachthond($extdebug,3, "CONTACTID: DO NOT USE ENTITYID AS A VALUE", 			$contact_id);
			}

		}

    	################################################################################################
		### IF NO CONTACTID
    	################################################################################################

		if (empty($contact_id)) {
			wachthond($extdebug,1, "CONTACTID - ERROR : CONTACT INFO LEEG > RETURN", 			$result_partditevent[0]);
			return; //    if not, get out of here
		} else {
			wachthond($extdebug,3, "CONTACTID: ER IS EEN WAARDE GEVONDEN", 						"$contact_id [PRIMA]");
		}

    	################################################################################################
		### IF CONTACTID == PARTID
    	################################################################################################

		if ($contact_id > 0 AND $ditevent_part_id > 0 AND $contact_id == $ditevent_part_id) {
			wachthond($extdebug,1, "CONTACTID - ERROR CONTACTID ($contact_id) == PART_ID ($ditevent_part_id)", "[RETURN!]");
			wachthond($extdebug,1, "ERROR : HEEL UITZONDERLIJK - WELLICHT ANDERE OORZAAK", 		$result_partditevent);
			return; //    if not, get out of here
		} else {
			wachthond($extdebug,3, "CONTACTID IS NOT THE SAME AS THE PARTID", 					"$contact_id [PRIMA]");
		}

//		wachthond($extdebug,4, 'CONTACTID', $contact_id);

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "### 0.2c BEKIJK HOEVEEL REGISTRATIES ER ZIJN GEVONDEN EN REAGEER", "[EntityID: $entityID]");
		wachthond($extdebug,3, "########################################################################");

		if ($result_partditevent) {
			wachthond($extdebug,1, "DITEVENT CHECK : $result_partditevent_count PARTICIPANT RECORDS GEVONDEN", "[cid: $contact_id]");
		} else {
			wachthond($extdebug,3, "DITEVENT ERROR : GEEN RESULT DITEVENT GEVONDEN", "[entityID: $entityID]");
		}

		if ($result_partditevent_count == 0) {
			wachthond($extdebug,3, "DITEVENT ERROR : GEEN PARTICIPANT INFO GEVONDEN", "[entityID: $entityID]");
		}

		if ($result_partditevent_count > 1) {
			wachthond($extdebug,3, "DITEVENT ERROR : >1 ($result_partditevent_count) PARTICIPANT RECORDS GEVONDEN", "[entityID: $entityID]");
					// M61: zou niet moeten kunnen als op specifiek part_id wordt gezocht
			return; // if not, get out of here (pretty drastic but prevents loops)
		}

		if ($result_partditevent_count == 1) {

			wachthond($extdebug,3, "DITEVENT PRIMA : EXACT 1 PARTICIPANT RECORD GEVONDEN", "[entityID: $entityID]");			

	    	################################################################################################

            $ditevent_part_contact_id 		= $result_partditevent[0]['contact_id'] 			?? NULL;
            $ditevent_part_eventid          = $result_partditevent[0]['event_id'] 				?? NULL;
            $ditevent_part_id               = $result_partditevent[0]['id'] 					?? NULL;
            $ditevent_part_role_id          = $result_partditevent[0]['role_id'] 				?? NULL;
            $ditevent_part_status_id        = $result_partditevent[0]['status_id'] 				?? NULL;
            $ditevent_part_status_name      = $result_partditevent[0]['status_id:name'] 		?? NULL;

            $ditevent_event_title           = $result_partditevent[0]['event.title'] 			?? NULL;            
//          $ditevent_event_eventid         = $result_partditevent[0]['event.id'] 				?? NULL;
            $ditevent_event_type_id         = $result_partditevent[0]['event.event_type_id'] 	?? NULL;

			$ditevent_event_start			= $result_partditevent[0]['event.start_date'] 		?? NULL;
			$ditevent_event_einde			= $result_partditevent[0]['event.end_date'] 		?? NULL;
			$ditevent_fiscalyear 			= curriculum_civicrm_fiscalyear($ditevent_event_start);
			$ditevent_fiscalyear_start		= $ditevent_fiscalyear['fiscalyear_start'] 			?? NULL;
			$ditevent_fiscalyear_einde		= $ditevent_fiscalyear['fiscalyear_einde'] 			?? NULL;
            $ditevent_kampjaar              = date('Y', strtotime($ditevent_event_start));
            $ditevent_kampjaarkort          = date('y', strtotime($ditevent_event_start));
			$ditevent_register_date			= $result_partditevent[0]['register_date'] 			?? NULL;

            $ditevent_part_kampnaam         = $result_partditevent[0]['PART.PART_kamplang'] 	?? NULL;
            $ditevent_part_kampkort         = $result_partditevent[0]['PART.PART_kampkort'] 	?? NULL;

            $ditevent_part_rol              = $result_partditevent[0]['PART.PART_kamprol'] 		?? NULL;  	// KAMPROL     PART
            $ditevent_part_functie          = $result_partditevent[0]['PART.PART_kampfunctie'] 	?? NULL; 	// KAMPFUNCTIE PART
            $ditevent_leid_functie          = $result_partditevent[0]['PART_LEID.Functie'] 		?? NULL;  	// FUNCTIE     PART_LEID
            $ditevent_leid_welkkamp        	= $result_partditevent[0]['PART_LEID.Welk_kamp'] 	?? NULL; 	// WELK KAMP   PART_LEID

			if (in_array($ditevent_event_type_id, $eventtypesdeelall)) {
				$ditevent_part_functie 	= 'deelnemer';
				$ditevent_part_rol 		= 'deelnemer';
			}
			if (in_array($ditevent_event_type_id, $eventtypesleidall)) {
				$ditevent_part_functie 	= $ditevent_leid_functie;
				$ditevent_part_rol 		= 'leiding';
			}
			// M61: ditevent_leid_functie zou bij aanmelding niet leeg moeten kunnen zijn
			if ($ditevent_event_type_id == 1 AND empty($ditevent_leid_functie)) {
				$ditevent_leid_functie 			= 'kampleiding';
				$ditevent_part_functie 			= 'kampleiding';
				$ditevent_part_rol 				= "leiding";
			}

			$ditevent_part_contact_id 			= $result_partditevent[0]['contact_id'] 			?? NULL;
			$ditevent_part_id 					= $result_partditevent[0]['id'] 					?? NULL;
			$ditevent_part_role_id 				= $result_partditevent[0]['role_id'] 				?? NULL;
			$ditevent_part_status_id 			= $result_partditevent[0]['status_id'] 				?? NULL;
			$ditevent_part_status_name 			= $result_partditevent[0]['status_id:name'] 		?? NULL;

			$ditevent_part_eventid 				= $result_partditevent[0]['event_id'] 				?? NULL;
//			$ditevent_event_eventid 			= $result_partditevent[0]['event.id'] 				?? NULL;
			$ditevent_event_type_id				= $result_partditevent[0]['event.event_type_id'] 	?? NULL;
			$ditevent_event_title				= $result_partditevent[0]['event.title'] 			?? NULL;
			$ditevent_event_kampnaam			= $result_partditevent[0]['event.Event_Kenmerken.kampnaam'] ?? NULL;
			$ditevent_event_kampkort			= $result_partditevent[0]['event.Event_Kenmerken.kampkort'] ?? NULL;

			// M61: komt verderop ook uit eventinfo. Hier tbv VOG/REF die eventinfo overslaat
			$ditevent_part_kampnaam 			= $result_partditevent[0]['PART.PART_kamplang'] 	?? NULL;
			$ditevent_part_kampkort 			= $result_partditevent[0]['PART.PART_kampkort'] 	?? NULL;

			$ditevent_event_kampkort_low 		= preg_replace('/[^ \w-]/','',strtolower(trim($ditevent_event_kampkort)));	// only letters/numbers/dashes
			$ditevent_event_kampkort_cap 		= preg_replace('/[^ \w-]/','',strtoupper(trim($ditevent_event_kampkort)));	// only letters/numbers/dashes

	    	################################################################################################

			$ditevent_event_kamptype			= $result_partditevent[0]['event.Event_Kenmerken.kamptype_naam'] 		?? NULL;
			$ditevent_event_kamptype_naam		= $result_partditevent[0]['event.Event_Kenmerken.kamptype_naam'] 		?? NULL;
			$ditevent_event_kamptype_label		= $result_partditevent[0]['event.Event_Kenmerken.kamptype_naam:label'] 	?? NULL;
			$ditevent_event_kamptype_id			= $result_partditevent[0]['event.Event_Kenmerken.kamptype_id'] 			?? NULL;
			$ditevent_event_kampsoort			= $result_partditevent[0]['event.Event_Kenmerken.kampsoort'] 			?? NULL;

	    	################################################################################################

			$ditevent_part_1stdeel 				= $result_partditevent[0]['PART.PART_1xkeer_deel'] 		?? NULL;
			$ditevent_part_1stleid 				= $result_partditevent[0]['PART.PART_1xkeer_leid'] 		?? NULL;

			$ditevent_part_nawgecheckt			= $result_partditevent[0]['PART.NAW_gecheckt'] 			?? NULL;
			$ditevent_part_biogecheckt			= $result_partditevent[0]['PART.BIO_gecheckt'] 			?? NULL;

			$org_ditpart_nawgecheckt 			= $ditevent_part_nawgecheckt;
			$new_ditpart_nawgecheckt 			= $ditevent_part_nawgecheckt;

			$org_ditpart_biogecheckt 			= $ditevent_part_biogecheckt;
			$new_ditpart_biogecheckt 			= $ditevent_part_biogecheckt;

			$ditevent_part_groepklas			= $result_partditevent[0]['PART_DEEL.Groep_klas'] 		?? NULL;
			$ditevent_part_voorkeur				= $result_partditevent[0]['PART_DEEL.Voorkeur'] 		?? NULL;
			$ditevent_part_letter 				= $result_partditevent[0]['PART_INTERN.groep_letter'] 	?? NULL;
			$ditevent_part_kleur 				= $result_partditevent[0]['PART_INTERN.groep_kleur'] 	?? NULL;
			$ditevent_part_slaapzaal			= $result_partditevent[0]['PART_INTERN.Slaapzaal'] 		?? NULL;

			$ditevent_part_criteriaindicatie 	= $result_partditevent[0]['PART_DEEL_INTERN.criteria_indicatie'] 	?? NULL;
			$ditevent_part_criteriaoordeel 		= $result_partditevent[0]['PART_DEEL_INTERN.criteria_beoordeling'] 	?? NULL;

			$ditevent_part_notificatie_deel		= $result_partditevent[0]['PART_LEID_HOOFD.notificatie_deel'] 		?? NULL;
			$ditevent_part_notificatie_leid		= $result_partditevent[0]['PART_LEID_HOOFD.notificatie_leid'] 		?? NULL;
			$ditevent_part_notificatie_kamp		= $result_partditevent[0]['PART_LEID_HOOFD.notificatie_kamp'] 		?? NULL;
			$ditevent_part_notificatie_staf		= $result_partditevent[0]['PART_LEID_HOOFD.notificatie_staf'] 		?? NULL;
			$ditevent_part_notificatie_priv		= $result_partditevent[0]['PART_LEID_HOOFD.Jouw_prive_emailadres'] 	?? NULL;

			$ditevent_part_kampgeld_contribid	= $result_partditevent[0]['PART_KAMPGELD.contribid'] 		?? NULL;
			$ditevent_part_kampgeld_regeling	= $result_partditevent[0]['PART_KAMPGELD.regeling'] 		?? NULL;

			if (in_array($ditevent_event_type_id, $eventtypesleidall)) {
				$ditevent_part_vogverzocht 		= $result_partditevent[0]['PART_LEID_VOG.Datum_verzoek'] 	?? NULL;
				$ditevent_part_vogingediend 	= $result_partditevent[0]['PART_LEID_VOG.Datum_aanvraag'] 	?? NULL;
				$ditevent_part_vogontvangst 	= $result_partditevent[0]['PART_LEID_VOG.Datum_ontvangst'] 	?? NULL;
				$ditevent_part_vogdatum 		= $result_partditevent[0]['PART_LEID_VOG.Datum_nieuwe_VOG'] ?? NULL;
				$ditevent_part_vogkenmerk 		= $result_partditevent[0]['PART_LEID_VOG.Kenmerk_VOG'] 		?? NULL;
            }
		}

		if ($result_partditevent_count == 1) {

			wachthond($extdebug,2, 'entityID', 							$entityID); 
            wachthond($extdebug,2, 'ditevent_contact_id',           	$ditevent_part_contact_id);

            wachthond($extdebug,2, 'ditevent_part_id',              	$ditevent_part_id);
            wachthond($extdebug,2, 'ditevent_part_eventid',         	$ditevent_part_eventid);
//          wachthond($extdebug,2, 'ditevent_event_eventid',        	$ditevent_event_eventid);
            wachthond($extdebug,2, 'ditevent_event_type_id',        	$ditevent_event_type_id);

            wachthond($extdebug,2, 'ditevent_part_status_id',       	$ditevent_part_status_id);
            wachthond($extdebug,2, 'ditevent_part_status_name',     	$ditevent_part_status_name);

            wachthond($extdebug,2, 'ditevent_event_title',          	$ditevent_event_title);
            wachthond($extdebug,2, 'ditevent_event_kampnaam',       	$ditevent_event_kampnaam);
            wachthond($extdebug,2, 'ditevent_event_kampkort',       	$ditevent_event_kampkort);

