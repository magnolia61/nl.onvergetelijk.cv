			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 13.2 CREATE AN ACTIVITY REFVERZOEK VOOR $displayname", "[ALS REF PERSOON IS VERZOCHT]");
			wachthond($extdebug,3, "########################################################################");

			if (empty($refverzoek_activity_id) AND $part_refgevraagd) {

				// M61: set part refgevraagd naar todaydatetime om de tijd mee te krijgen
				// (TODO: moet anders want kan ook andere datum zijn in het verleden
				if (empty($part_refgevraagd)) { $part_refgevraagd = $today_datetime; }

				if ($extref == 1 AND in_array($new_ditjaar_refnodig,array("eerstex","elkjaar","opnieuw","inhaal"))) {
					$params_activity_refverzoek_create = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
						'values' => [
					    	'source_contact_id' 		=> 1, 
							'target_contact_id' 		=> $contact_id, 
							'assignee_contact_id' 		=> $referentie_cid,
							'activity_type_id' 			=> 117,
#    						'activity_type_id:name' 	=> 'REF_verzoek',		// type_id: 117
							'activity_date_time' 		=> $part_refgevraagd,
							'subject' 					=> 'REF feedback', 
							'status_id:name' 			=> 'Scheduled', 		// initial status ingepland

			   				'ACT_ALG.actcontact_naam'	=> $displayname,
			   				'ACT_ALG.actcontact_cid'	=> $contact_id,
			   				'ACT_ALG.actcontact_pid'	=> $ditevent_part_id,
			   				'ACT_ALG.actcontact_eid'	=> $ditevent_part_eventid,

		   					'ACT_ALG.kampnaam'			=> $eventkamp_event_kampkort_cap,
			   				'ACT_ALG.kampkort'			=> $eventkamp_event_kampkort_low,
							'ACT_ALG.kampfunctie' 		=> $ditevent_part_functie,
							'ACT_ALG.kampstart' 		=> $eventkamp_event_start,
							'ACT_ALG.kampeinde' 		=> $eventkamp_event_einde,
							'ACT_ALG.kampjaar'			=> $eventkamp_kampjaar,

							'ACT_ALG.modified' 			=> $today_datetime,
			    			'ACT_ALG.prioriteit:label'	=> 'Normaal',
						],
					];
					wachthond($extdebug,7, 'params_activity_refverzoek_create', 		$params_activity_refverzoek_create);

					if ($extwrite == 1)	{
						$result_refverzoek_create = civicrm_api4('Activity', 'create', 	$params_activity_refverzoek_create);
						wachthond($extdebug,7, 'params_activity_refverzoek_create', 				"EXECUTED");
						wachthond($extdebug,7, 'params_activity_refverzoek_create RESULT', 			$result_refverzoek_create);
						wachthond($extdebug,7, 'params_activity_refverzoek_create RESULTS 0', 		$result_refverzoek_create[0]);
						wachthond($extdebug,7, 'params_activity_refverzoek_create RESULTS 0 ID', 	$result_refverzoek_create[0]['id']);
					}
				  	if (empty($refverzoek_activity_id))			{ $refverzoek_activity_id			= $result_refverzoek_create[0]['id'] 		?? NULL; }
					if (empty($refverzoek_activity_status))		{ $refverzoek_activity_status		= $result_refverzoek_create[0]['status_id'] ?? NULL; }
					wachthond($extdebug,2, "(new) refverzoek_activity_id", 		$refverzoek_activity_id);
					wachthond($extdebug,2, "(new) refverzoek_activity_status", 	$refverzoek_activity_status);

				} else {
