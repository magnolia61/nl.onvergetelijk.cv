			wachthond($extdebug,3, 'ditjaareventleidyes F', 			$ditjaareventleidyes);
			wachthond($extdebug,3, 'ditjaareventdeelmss F', 			$ditjaareventdeelmss);
			wachthond($extdebug,3, 'ditjaareventleidmss F', 			$ditjaareventleidmss);
		}

		if ($result_eventjaar_all_count 	>= 1) {
