						wachthond($extdebug,2, "params_activity_refpersoon_create", 			"EXECUTED");
						wachthond($extdebug,7, 'params_activity_refpersoon_create RESULT', 		$result_persoon_create);
						wachthond($extdebug,7, 'params_activity_refpersoon_create RESULTS 0', 	$result_persoon_create[0]);
						wachthond($extdebug,7, 'params_activity_refpersoon_create RESULTS 0 ID',$result_persoon_create[0]['id']);						
					}
				  	if (empty($refpersoon_activity_id))		{ $refpersoon_activity_id		= $result_persoon_create[0]['id'] 		 ?? NULL; }
					if (empty($refpersoon_activity_status))	{ $refpersoon_activity_status	= $result_persoon_create[0]['status_id'] ?? NULL; }
					wachthond($extdebug,2, "(new) refpersoon_activity_id", 		$refpersoon_activity_id);
					wachthond($extdebug,2, "(new) refpersoon_activity_status", 	$refpersoon_activity_status);

