		################################################################################################
		# 7.5a CREATE RELATED HOOFDLEIDING
		################################################################################################
	    if ($extrel == 1 AND ($ditjaareventdeelyes == 1 OR $ditjaareventleidyes == 1 OR $ditjaareventdeelmss == 1 OR $ditjaareventleidmss == 1)) {
