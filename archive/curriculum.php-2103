		} else {
			#$email_othr_id 	= NULL;
			#$email_othr_email 	= NULL;
  			wachthond($extdebug,1, 'GEEN EMAILADRESSEN GEVONDEN VOOR DIT CONTACT', 	"$contact_id $displayname");
		}

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.5a CORRIGEER DATUM BELANG", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,2, "########################################################################");

		if ($datum_belangstelling) {

			$belangstelling_week 	= $result_contact[0]['WERVING.Welke_kampweek'] 			?? NULL;
			$belangstelling_groep	= $result_contact[0]['WERVING.Welke_leeftijdsgroep'] 	?? NULL;
			$belangstelling_kamp	= $result_contact[0]['WERVING.Welke_kampweken'] 		?? NULL;
			$belangstelling_array	= [];

			wachthond($extdebug,4, 'belangstelling_week', 	$belangstelling_week);
			wachthond($extdebug,4, 'belangstelling_groep', 	$belangstelling_groep);

			if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('kinderkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'KK1');
			}
			if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('kinderkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'KK2');
			}
			if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('brugkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'BK1');
			}
			if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('brugkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'BK2');
			}
			if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('tienerkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'TK1');
			}
			if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('tienerkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'TK2');
			}
			if (($belangstelling_week == 'week1' OR $belangstelling_week == 'maaktnietuit') AND in_array('jeugdkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'JK1');
			}
			if (($belangstelling_week == 'week2' OR $belangstelling_week == 'maaktnietuit') AND in_array('jeugdkamp', 	$belangstelling_groep)) 	{
				array_push($belangstelling_array, 'JK2');
			}

			wachthond($extdebug,2, 'belangstelling_kamp', 	$belangstelling_kamp);
			wachthond($extdebug,2, 'belangstelling_groep', 	$belangstelling_groep);
			wachthond($extdebug,2, 'belangstelling_array', 	$belangstelling_array);

			################################################################################################
			# VUL VELDEN VERWACHTING 'MEE DIT JAAR' OP BASIS VAN DATUM BELANGSTELLING
			################################################################################################

			wachthond($extdebug,3, 'last_event_einde_year', 	$last_event_einde_year);
			wachthond($extdebug,3, 'datum_belangstelling', 		$datum_belangstelling);
			wachthond($extdebug,3, 'next_event_start_year', 	$next_event_start_year);

			if (date_biggerequal($datum_belangstelling, $werving_mee_update, 'belang', 'meeupdate') == 1 OR empty($werving_mee_update)) {

				$belangstelling_fiscalyear 			= curriculum_civicrm_fiscalyear($datum_belangstelling);
				$belangstelling_fiscalyear_einde	= $belangstelling_fiscalyear['fiscalyear_einde'] ?? NULL;

				$new_werving_mee_update 	 		= $datum_belangstelling;
				$new_werving_mee_update_year 		= date('Y', strtotime($belangstelling_fiscalyear_einde));
				// M61: gebruik fiscal year van datum belangstelling omdat het soms al najaar voorafgaang kan worden ingevuld

				$params_contact['values']['WERVING.mee_update'] 			= $new_werving_mee_update;
	   			$params_contact['values']['WERVING.mee_komendkampjaar'] 	= $new_werving_mee_update_year;

				wachthond($extdebug,2, "UPDATE MEE-DITJAAR OBV DATUM BELANGSTELLING", $datum_belangstelling);
				wachthond($extdebug,2, 'werving_mee_update', 		$new_werving_mee_update);
				wachthond($extdebug,2, 'werving_mee_update_year', 	$new_werving_mee_update_year);
			}

			wachthond($extdebug,3, 'laatstekeer', 				$laatstekeer);		
			wachthond($extdebug,3, 'werving_mee_verwachting', 	$werving_mee_verwachting);		

			// INDIEN BELANGSTELLING NA START AFGELOPEN KAMP DAN MEE VERWACHTING KOMEND JAAR MISSCHIEN
			if (date_biggerequal($datum_belangstelling, $last_event_einde_date, 'belang', 'lastyear') == 1 AND $laatstekeer != $last_event_einde_year) {

				if (in_array($werving_mee_verwachting, array('zekerniet','waarschijnlijkniet','weetnogniet')) OR empty($werving_mee_verwachting)) {
					$new_werving_mee_verwachting 							= "misschien";
					$params_contact['values']['WERVING.mee_verwachting'] 	= $new_werving_mee_verwachting;
					wachthond($extdebug,2, 'werving_mee_verwachting', 	$new_werving_mee_verwachting);					
					wachthond($extdebug,2, "ZET VERWACHTING OP 'MISSCHIEN' ($new_werving_mee_verwachting) IVM BELANGSTELLING DIT JAAR", $datum_belangstelling);
				}
			}
		}

		wachthond($extdebug,2, "########################################################################");
		wachthond($extdebug,1, "### 3.6 WERVING MEE VOLGEND JAAR", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,2, "########################################################################");

		// M61: little overkill to put this here. But it resolves a notice.
		$result_mee_get_count 	= 0;
		$werving_mee_rol 		= NULL;
		$new_werving_mee_update = $werving_mee_update;	// set default new with value of current 

		if ($ditevent_event_type_id) {
			$current_event_type = $ditevent_event_type_id;
		} else {
			$current_event_type = 1;
		}

		if ($leeftijd_nextkamp_rondjaren  < 18) {
			$werving_mee_rol = 'deelnemer';
		}
		if ($leeftijd_nextkamp_rondjaren >= 24) {
			$werving_mee_rol = 'leiding';
		}

		if ($ditevent_part_evaluatie > $new_werving_mee_update OR empty($new_werving_mee_update)) {
			// M61: repair voor als werving update t.o.v. ingevulde evaluatie
			$new_werving_mee_update = $ditevent_part_evaluatie;
			if ($new_werving_mee_update) 	{ $params_contact['values']['WERVING.mee_update']	= $new_werving_mee_update; 	}
		}

		if (date_bigger($new_werving_mee_update, $birth_date) == 1) {
			//NEEM DATUM VAN LAATSTE UPDATE OVER 'MEE KOMEND KAMP' EN LEIDT DAARUIT HET KAMPJAAR AF

			$mee_fiscalyear_array	= curriculum_civicrm_fiscalyear($new_werving_mee_update);
			$mee_fiscalyear_start	= $mee_fiscalyear_array['fiscalyear_start'] ?? NULL;
			$mee_fiscalyear_einde	= $mee_fiscalyear_array['fiscalyear_einde'] ?? NULL;

			wachthond($extdebug,2, "mee_fiscalyear_start", 		$mee_fiscalyear_start);
			wachthond($extdebug,2, "mee_fiscalyear_einde", 		$mee_fiscalyear_einde);
			wachthond($extdebug,2, "new_werving_mee_update", 	$new_werving_mee_update);
		}

		if (date_bigger($new_werving_mee_update, $birth_date) == 1) {
			### NEXTV FROM EVENT
			$mee_update_year			= date('Y',           strtotime($new_werving_mee_update));
			$mee_update_next_date		= date('Y-m-d H:i:s', strtotime ( '+1 year' , strtotime ($new_werving_mee_update)));
			$mee_update_next_year		= date('Y',           strtotime ( '+1 year' , strtotime ($new_werving_mee_update)));
