				wachthond($extdebug,2, "########################################################################");
				wachthond($extdebug,1, "### 3.4 H CREATE NOTIFICATION EMAIL_PRIV", "[groupID: $groupID] [op: $op]");
				wachthond($extdebug,2, "########################################################################");

				if ($email_priv_id AND $email_priv_id > 0) {

