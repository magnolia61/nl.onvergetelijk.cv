function curriculum_civicrm_customPre(string $op, int $groupID, int $entityID, array &$params): void {

  	$extdebug		= 1; // 1 = basic // 2 = verbose // 3 = params / 4 = results
    $deltacategory 	= '';

// 	wachthond($extdebug,1, 'customPre params', 			$params);

	if ($params[0]['entity_table'] == 'civicrm_contact') {
//	  	wachthond($extdebug,1, 'customPre entity_table', 	$params[0]['entity_table']);
	} else {
		return; //	if not, get out of here		
	}

  	if ($params[0]['entity_table'] == 'civicrm_participant') 						{
		return; //	if not, get out of here
  	}

  	#if ($extdebug >= 1) { watchdog('php', '<pre>op                    : '.print_r($op,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
  	#if ($extdebug >= 1) { watchdog('php', '<pre>groupID               : '.print_r($groupID,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
  	#if ($extdebug >= 1) { watchdog('php', '<pre>entityID              : '.print_r($entityID,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
  	#if ($extdebug >= 1) { watchdog('php', '<pre>params customPre       ', $params,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

//	wachthond($extdebug,1, 'params customPre participant', $params);

/*
  	if ($params[0]['column_name'] == 'ditjaar_voorkeur_1208') 						{
  		$deltacategory = 'voorkeur';
		if ($extdebug >= 1) { watchdog('php', '<pre>deltacategory       : '.print_r($deltacategory,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
  	}

  	if ($params[0]['column_name'] == 'ditjaar_fietshuur_1173') 						{
  		$deltacategory = 'fietshuur';
  	}
*/	
  	if ($params[0]['table_name'] 	== 'civicrm_value_ditjaar_199') 				{
//   		$deltacategory = 'ditjaar';
 		#if ($extdebug >= 1) { watchdog('php', '<pre>params customPre    ', $params,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
  	}

  	if ($params[0]['table_name'] 	== 'civicrm_value_aandachtspunten_gedrag_1') 	{	$deltacategory = 'gedrag';	}
  	if ($params[0]['table_name'] 	== 'civicrm_value_medisch_148') 				{	$deltacategory = 'medisch';	}
  	if ($params[0]['table_name'] 	== 'civicrm_value_drijfveren_69') 				{	$deltacategory = 'bio';		}
  	if ($params[0]['table_name'] 	== 'civicrm_value_talent_149') 					{	$deltacategory = 'talent';	}

//	if ($extdebug >= 1) { watchdog('php', '<pre>deltacategory       	: '.print_r($deltacategory,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
	#$keys = array_keys(array_combine(array_keys($params), array_column($params, 'table_name')),'civicrm_value_aandachtspunten_gedrag_1');  	
  	#if ($extdebug >= 1) { watchdog('php', '<pre>keys met gedrag       	: '.print_r($keys,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

  	if (in_array($deltacategory, array('gedrag', 'medisch', 'bio', 'talent', 'fietshuur', 'voorkeur'))) {

  		foreach ($params as $field) {

			$oldarray = [];
			$newarray = [];
			$oldvalue = NULL;
			$newvalue = NULL;
			$oldflat  = NULL;
			$newflat  = NULL;

			#if ($extdebug >= 1) { watchdog('php', '<pre>field        		: '.print_r($field,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

			$fieldname	= $field['column_name'] ?? NULL;
			$fieldid	= $field['custom_field_id'] ?? NULL;
  			$newvalue 	= $field['value'] ?? NULL;

       		$oldvalue 	= civicrm_api3('Contact', 'getvalue', [
       			'id'     => $field['entity_id'],	// ik denk dat dit alleen klopt bij contact id en niet als het part id is
       			'return' => "custom_{$field['custom_field_id']}",
       		]);

  			if (empty($oldvalue)) {
#  				$oldvalue = NULL;
  			}
  			if (empty($newvalue)) {
#  				$newvalue = NULL;
  			} 

			if (is_array($oldvalue)) {
				$oldflat 		= implode(" / ",$oldvalue);
#				if (!empty($oldflat))	{
#					$oldarray		= array_filter($oldvalue);
					$oldarray		= $oldvalue;
#				}
				$oldvaluetype 	= "array";
			} else {
				$oldflat		= trim($oldvalue);
				$oldvaluetype 	= "strng";
			}

			$newvalue 	= trim($newvalue, '');
			$newvalue 	= str_replace('', ' / ', trim($newvalue));
			$newflat 	= trim($newvalue);

			$newsec = strtotime($newflat);
			#if ($extdebug >= 1) { watchdog('php', '<pre>newsec  ('.$fieldname.')    : '.print_r($newsec,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
			$newdate = date("Y-m-d H:i:s", $newsec);  
			#if ($extdebug >= 1) { watchdog('php', '<pre>newdate                     : '.print_r($newdate,TRUE).' ('.$fieldname.')</pre>',NULL,WATCHDOG_DEBUG);}
			if ($newdate == $oldflat) {
				$newflat = $newdate;
			}

			#if ($extdebug >= 1) { watchdog('php', '<pre>oldvalue 0 ('.$oldvaluetype.')          : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
//			if ($extdebug >= 1) { watchdog('php', '<pre>oldflat  0 ('.$oldvaluetype.')          : '.print_r($oldflat,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
			#if ($extdebug >= 1) { watchdog('php', '<pre>newvalue 0 ('.$oldvaluetype.')          : '.print_r($newvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
//			if ($extdebug >= 1) { watchdog('php', '<pre>newflat  0 ('.$oldvaluetype.')          : '.print_r($newflat,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

			if ($oldflat != $newflat) {

  				##############################
  				#### OLDVALUE ARRAY ####
  				##############################

				#if ($extdebug >= 1) { watchdog('php', '<pre>optionvalue old             : '.print_r($optionvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}				
				$customFields = civicrm_api4('CustomField', 'get', [
					'select' => [
				    	'label',
				    	'data_type',
				    	'html_type',
				    	'option_group_id'
  					],
  					'where' => [
   						['id', '=', $fieldid],
 					],
  					'limit' => 1,
  					'checkPermissions' => FALSE,
				]);
				$customFieldName 		= $customFields[0]['label'] ?? NULL;
				$customFieldDataType	= $customFields[0]['data_type'] ?? NULL;
				$customFieldHtmlType	= $customFields[0]['html_type'] ?? NULL;
				$customFieldOptionGroup = $customFields[0]['option_group_id'] ?? NULL;
				$messagelenght	= strlen($customFieldName);

				$prioriteit = 'Normaal'; // default

				### AANDACHTSPUNTEN ALGEMEEN
				if ($customFieldName == 'DITJAAR groep/klas') 	{
					$deltacategory	= 'Basis';
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}
				if ($customFieldName == 'Geboortedatum') 		{
					$deltacategory	= 'Basis';
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}

				### AANDACHTSPUNTEN MEDISCH
				if ($customFieldName == 'Medicijngebruik') 		{
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;				
				}
				if ($customFieldName == 'Toelichting medisch') 	{
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}

				### AANDACHTSPUNTEN GEDRAG
				if ($customFieldName == 'Aandachtspunten') 		{
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}
				if ($customFieldName == 'Toelichting gedrag') 	{
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}
				### AANDACHTSPUNTEN DIEET
				if ($customFieldName == 'Speciaal dieet') 		{
					$deltacategory	= 'Dieet';
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}							
				if ($customFieldName == 'Toelichting dieet') 	{
					$deltacategory	= 'Dieet';
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}							

				if ($customFieldName == 'DITJAAR voorkeur') 	{
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}
				if ($customFieldName == 'DITJAAR fietshuur') 	{
					$prioriteit 	= 'Urgent';
					$prioriteit_id 	= 1;
				}

				if ($extdebug >= 2) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG); 	   }
				if ($extdebug >= 2) { watchdog('php', '<pre>### customFieldName (old)   : '.print_r($customFieldName,TRUE).' ('.$customFieldDataType.' / '.$customFieldHtmlType.') '.$customFieldOptionGroup.'</pre>',NULL,WATCHDOG_DEBUG); 	    }
				if ($extdebug >= 2) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG); 	   }

				if ($extdebug >= 1) { watchdog('php', '<pre>oldvalue 1 ('.$oldvaluetype.')          : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
  				if ($extdebug >= 1) { watchdog('php', '<pre>newvalue 1 ('.$oldvaluetype.')          : '.print_r($newvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

				if ($messagelenght       < 24 AND $messagelenght >= 16) {
					$tab = "\t";
				} elseif ($messagelenght < 16 AND $messagelenght >= 8) {
					$tab = "\t\t";
				} elseif ($messagelenght < 8) {
					$tab = "\t\t\t";
				} else {
					$tab = "\t";					
				}				

				if (empty($oldvalue))	{ $oldvalue = '(was leeg)'; 	}

				if (in_array($customFieldDataType, array("Boolean"))) {

					if ($oldvalue == '1') 	{ $oldvalue = 'ja';  			}
					if ($oldvalue == '0') 	{ $oldvalue = 'nee'; 			}					

					if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (boolean)          : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;

				} elseif (in_array($customFieldHtmlType, array("Select Date"))) {

					if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (date)              : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;

				} elseif (in_array($customFieldHtmlType, array("Text","TextArea"))) {

					if (empty($oldvalue))	{ $oldvalue = '(was leeg)'; 	}
					if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (string)           : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;

				} elseif (in_array($customFieldHtmlType, array("Radio", "Select"))) {

						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $oldvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						wachthond($extdebug,7, 'params_optionvalues', 				$params_optionvalues);
						$result_optionvalues = civicrm_api4('OptionValue', 'get', 	$params_optionvalues);
						wachthond($extdebug,9, 'result_optionvalues', 				$result_optionvalues);
						$optionlabel = $result_optionvalues[0]['label'] ?? NULL;
   						if ($extdebug >= 3) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

   						$oldarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						if ($extdebug >= 3) { watchdog('php','<pre>oldarraylabels              : '.print_r($oldarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

						if (is_array($oldarraylabels)) {
							$oldarraystring[$deltacategory][$customFieldName] = implode(" / ",$oldarraylabels[$deltacategory][$customFieldName]);
							#if ($extdebug >= 1) { watchdog('php','<pre>oldarraystring '.$deltacategory.'      : '.print_r($oldarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (radioselect)      : '.print_r($oldarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldarraystring[$deltacategory][$customFieldName];

				} else {

					if ($extdebug >= 1) { watchdog('php','<pre>oldarray                    : '.print_r($oldarray,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

					if (empty($oldarray))	{
						$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". '(was leeg)';
					} else {

						foreach ($oldarray as $optionvalue) {

						#if ($extdebug >= 1) { watchdog('php','<pre>optionvalue                 : '.print_r($optionvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $optionvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						wachthond($extdebug,7, 'params_optionvalues', 				$params_optionvalues);
						$result_optionvalues = civicrm_api4('OptionValue', 'get', 	$params_optionvalues);
						wachthond($extdebug,9, 'result_optionValues', 				$params_optionvalues);
						$optionlabel = $params_optionvalues[0]['label'] ?? NULL;
   						if ($extdebug >= 3) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
   						$oldarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						if ($extdebug >= 2) { watchdog('php','<pre>oldarraylabels              : '.print_r($oldarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

						if (is_array($oldarraylabels)) {
							$oldarraystring[$deltacategory][$customFieldName] = implode(" / ",$oldarraylabels[$deltacategory][$customFieldName]);
							#if ($extdebug >= 3) { watchdog('php','<pre>oldarraystring '.$deltacategory.'      : '.print_r($oldarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (flatarray)        : '.print_r($oldarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						$newoptionlabel = $oldarraystring[$deltacategory][$customFieldName];
						$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newoptionlabel;
						}
					}
				}

  				##############################
  				#### NEWVALUE ARRAY ####
  				##############################

				$customFields = civicrm_api4('CustomField', 'get', [
					'select' => [
				    	'label',
				    	'data_type',
				    	'html_type',
				    	'option_group_id'
  					],
  					'where' => [
   						['id', '=', $fieldid],
 					],
  					'limit' => 1,
  					'checkPermissions' => FALSE,
				]);
				$customFieldName 		= $customFields[0]['label'] 	?? NULL;
				$customFieldDataType	= $customFields[0]['data_type'] ?? NULL;
				$customFieldHtmlType	= $customFields[0]['html_type'] ?? NULL;
				$customFieldOptionGroup = $customFields[0]['option_group_id'] ?? NULL;
				$messagelenght	= strlen($customFieldName);
				#if ($extdebug >= 3) { watchdog('php', '<pre>### customFieldName (new)   : '.print_r($customFieldName,TRUE).' ('.$customFieldDataType.' / '.$customFieldHtmlType.') '.$customFieldOptionGroup.'</pre>',NULL,WATCHDOG_DEBUG); 	    }

				if (empty($newvalue))	{ $newvalue = '(leeggemaakt)'; 	}

				if (in_array($customFieldDataType, array("Boolean"))) {

					if ($newvalue == '1') 	{ $newvalue = 'ja';  			}
					if ($newvalue == '0') 	{ $newvalue = 'nee'; 			}

					if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (boolean)          : '.print_r($newvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newvalue;

				} elseif (in_array($customFieldHtmlType, array("Select Date"))) {

					if ($newdate == "1970-01-01 01:00:00") {
						$newdate =  '(leeggemaakt)';
					}

					if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (date)              : '.print_r($newdate,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newdate;

				} elseif (in_array($customFieldHtmlType, array("Text","TextArea"))) {
					if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (string)           : '.print_r($newvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newvalue;
				} elseif (in_array($customFieldHtmlType, array("Radio", "Select"))) {

						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $newvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						wachthond($extdebug, 5, 'params_optionvalues', 				$params_optionvalues);
						$params_optionvalues = civicrm_api4('OptionValue', 'get', 	$params_optionvalues);
						wachthond($extdebug, 5, 'result_optionValues', 				$result_optionvalues);
						$optionlabel = $params_optionvalues[0]['label'] ?? NULL;
   						if ($extdebug >= 5) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
   						$newarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						if ($extdebug >= 5) { watchdog('php','<pre>newarraylabels              : '.print_r($newarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

						if (is_array($newarraylabels)) {
							$newarraystring[$deltacategory][$customFieldName] = implode(" / ",$newarraylabels[$deltacategory][$customFieldName]);
							if ($extdebug >= 5) { watchdog('php','<pre>newarraystring '.$deltacategory.'      : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (radioselect)      : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newarraystring[$deltacategory][$customFieldName];

				} else {

					$newarray 	= explode ('', $field['value']);
					if (!empty($newflat))	{
						$newarray	= array_filter($newarray);
					}
					if ($extdebug >= 3) { watchdog('php', '<pre>newarray 1                  : '.print_r($newarray,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

					foreach ($newarray as $optionvalue) {
						#if ($extdebug >= 1) { watchdog('php', '<pre>optionvalue new             : '.print_r($optionvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $optionvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						wachthond($extdebug, 5, 'params_optionvalues', 				$params_optionvalues);
						$result_optionvalues = civicrm_api4('OptionValue', 'get', 	$params_optionvalues);
						wachthond($extdebug, 5, 'result_optionValues', 				$result_optionvalues);
						$optionlabel = $result_optionvalues[0]['label'] ?? NULL;
   						if ($extdebug >= 5) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
   						$newarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						if ($extdebug >= 5) { watchdog('php','<pre>newarraylabels              : '.print_r($newarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

						if (is_array($newarraylabels)) {
							$newarraystring[$deltacategory][$customFieldName] = implode(" / ",$newarraylabels[$deltacategory][$customFieldName]);
							if ($extdebug >= 5) { watchdog('php','<pre>newarraystring '.$deltacategory.'      : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (flatarray)        : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						if (empty($newflat))	{
							$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". '(leeggemaakt)';
						} else {
							$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newarraystring[$deltacategory][$customFieldName];
						}
					}
				}
			}
   		}

		if (!empty($changes)) {

  			$deltadetailsold 		= implode_recursive("<br>",$changes['old']);
  			$deltadetailsnew 		= implode_recursive("<br>",$changes['new']);

			if ($extdebug >= 1) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG);	}
  			if ($extdebug >= 1) { watchdog('php', '<pre>!!! CHANGED velden '.$deltacategory.' OUD :<br>'.$deltadetailsold.'</pre>',NULL,WATCHDOG_DEBUG);}
  			if ($extdebug >= 1) { watchdog('php', '<pre>!!! CHANGED velden '.$deltacategory.' NEW :<br>'.$deltadetailsnew.'</pre>',NULL,WATCHDOG_DEBUG);}
			if ($extdebug >= 1) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG);	}

		$params_contact = [
			'checkPermissions' => FALSE,
    		'limit' => 1,
			'select' => [
    			'id',
    			'contact_id',
    			'first_name',
    			'display_name',
    			'job_title',
    			'external_identifier',
    			'DITJAAR.DITJAAR_cid',
    			'DITJAAR.DITJAAR_pid',
    			'DITJAAR.DITJAAR_eid',
				'DITJAAR.DITJAAR_rol',
    			'DITJAAR.DITJAAR_functie',
    			'DITJAAR.DITJAAR_kampkort',
    			'DITJAAR.DITJAAR_kampjaar',
    			'DITJAAR.DITJAAR_event_start',
    			'DITJAAR.DITJAAR_event_end',
			],
  			'where' => [
    			['id', '=', $entityID],
  			],
		];

		// M61 TODO: de query hierboven beter basseren op participant data, en dat huidig fiscale jaar

		wachthond($extdebug,7, 'params_contactinfo', 		$params_contact);
		$result_contact = civicrm_api4('Contact', 'get', 	$params_contact);
		wachthond($extdebug,2, 'result_contactinfo', 		$result_contact);

 		$actdisplayname		= $result_contact[0]['display_name'] ?? NULL;
// 		$actcontact_cid		= $result_contact[0]['contact_id'] ?? NULL;
 		$actcontact_cid		= $result_contact[0]['DITJAAR.DITJAAR_cid'] ?? NULL;
 		$actcontact_pid		= $result_contact[0]['DITJAAR.DITJAAR_pid'] ?? NULL;
 		$actkampkort 		= $result_contact[0]['DITJAAR.DITJAAR_kampkort'] ?? NULL;
 		$actkamprol			= $result_contact[0]['DITJAAR.DITJAAR_rol'] ?? NULL;
 		$actkampfunctie		= $result_contact[0]['DITJAAR.DITJAAR_functie'] ?? NULL;
 		$actkampjaar 		= $result_contact[0]['DITJAAR.DITJAAR_kampjaar'] ?? NULL;
 		$acteventstart 		= $result_contact[0]['DITJAAR.DITJAAR_event_start'] ?? NULL;
 		$acteventeinde 		= $result_contact[0]['DITJAAR.DITJAAR_event_end'] ?? NULL;
		$acteventstart		= date('Y-m-d H:i:s', strtotime($acteventstart));
		$acteventeinde		= date('Y-m-d H:i:s', strtotime($acteventeinde));
		$actkampkort_low	= preg_replace('/[^ \w-]/','',strtolower(trim($actkampkort)));// keep only letters and numbers and dashes
		$actkampkort_cap 	= preg_replace('/[^ \w-]/','',strtoupper(trim($actkampkort)));// keep only letters and numbers and dashes

		if (empty($prioriteit)) {
			$prioriteit = 'normaal';
		}
		$today_datetime = date("Y-m-d H:i:s");

		//create Activity to record the change
		$params_activity_delta_create = [
			'checkPermissions' => FALSE,
			'values' => [
    			'source_contact_id' 		=> 1,
				'target_contact_id' 		=> $entityID,
#				'activity_type_id' 			=> 5559,
				'activity_type_id:name' 	=> 'Notificatie aandachtspunten',
				'subject' 					=> 'Aanpassing: '. $deltacategory,
				'details' 					=> '<h3><b>OUD :</b></h3>'.$deltadetailsold.'<h3><b>NEW :</b></h3>'.$deltadetailsnew,
				'status_id:name' 			=> 'Completed',
				'priority_id' 				=> $prioriteit_id,
				'AANPASSINGEN.Categorie'	=> $deltacategory,
				'AANPASSINGEN.OUD' 			=> '<pre>'.$deltadetailsold.'</pre>',
				'AANPASSINGEN.NEW' 			=> '<pre>'.$deltadetailsnew.'</pre>',

				'ACT_ALG.prioriteit:label' 	=> $prioriteit,
				'ACT_ALG.modified' 			=> $today_datetime,
				'ACT_ALG.afgerond' 			=> $today_datetime,
			],
		];

		if ($actdisplayname)	{ $params_activity_delta_create['values']['ACT_ALG.actcontact_naam']	= $actdisplayname;	}
		if ($actcontact_cid)	{ $params_activity_delta_create['values']['ACT_ALG.actcontact_cid']		= $actcontact_cid;	}

		if ($actkampkort_low)	{ $params_activity_delta_create['values']['ACT_ALG.kampnaam']			= $actkampkort_cap;	}
		if ($actkampkort_cap)	{ $params_activity_delta_create['values']['ACT_ALG.kampkort']			= $actkampkort_low;	}
		if ($acteventstart)		{ $params_activity_delta_create['values']['ACT_ALG.kampstart']			= $acteventstart;	}
		if ($acteventeinde) 	{ $params_activity_delta_create['values']['ACT_ALG.kampeinde']			= $acteventeinde;	}

		if ($actkampfunctie) 	{ $params_activity_delta_create['values']['ACT_ALG.kampfunctie']		= $actkampfunctie;	}
		if ($actkampjaar) 		{ $params_activity_delta_create['values']['ACT_ALG.kampjaar']			= $actkampjaar;		}

			wachthond($extdebug,7, 'params_activity_delta_create', 				$params_activity_delta_create);
			if ($actcontact_pid AND $actcontact_pid > 0) {
				$result_activity_delta_create = civicrm_api4('Activity', 'create', 	$params_activity_delta_create);
				wachthond($extdebug,9, 'result_activity_delta_create', 				$result_activity_delta_create);
				wachthond($extdebug,2, "result_activity_delta_create CREATED");
			}
  		}
  	}
}

function curriculum_civicrm_fiscalyear($inputdatum) {

		$extdebug			= 0; 	// 1 = basic // 2 = verbose // 3 = params / 4 = results

		$fiscalyear_start 	= NULL;
		$ditevent_fiscalyear_einde 	= NULL;

		$config 			= CRM_Core_Config::singleton( );
		$fiscalYearStart 	= $config->fiscalYearStart;
		$today_datetime 	= date("Y-m-d H:i:s");
		$inputyear 			= date('Y',     strtotime($inputdatum));
		$inputdatum			= date('Y-m-d', strtotime($inputdatum));

		################################################################################################
    	if ($extdebug >= 1) { watchdog('php','<pre>### BEPAAL FISCALE JAAR VAN EEN GEGEVEN DATUM [inputdate: '.$inputdatum.'] ###</pre>',NULL,WATCHDOG_DEBUG);}
		################################################################################################

		### 1 BASIS WAARDEN
		if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_start             : '.print_r($fiscalYearStart,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
		#if ($extdebug >= 2) { watchdog('php','<pre>inputdate                    : '.print_r($inputdatum,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
		#if ($extdebug >= 2) { watchdog('php','<pre>todaydatetime                : '.print_r($today_datetime,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
		$fiscalyear_start = date("$inputyear-$fiscalYearStart[M]-$fiscalYearStart[d]");
		$fiscalyear_einde = date("$inputyear-$fiscalYearStart[M]-$fiscalYearStart[d]");
		$fiscalyear_start = date('Y-m-d', strtotime($fiscalyear_start));
		$fiscalyear_einde = date('Y-m-d', strtotime($fiscalyear_einde));

		### 2 START MOET EERDER ZIJN DAN INPUT DATUM (ANDERS STARTDATE -1)
    	if (strtotime($fiscalyear_start) > strtotime($inputdatum)) {
			if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear_start ('.$fiscalyear_start.') moet minus 1 jaar want is groter dan inputdatum ('.$inputdatum.')</pre>',NULL,WATCHDOG_DEBUG);}
			$fiscalyear_start = date('Y-m-d',(strtotime ( '-1 year' , strtotime ( $fiscalyear_start ) ) ) );  			
  			if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_start -1 year     : '.print_r($fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
  		}

		### 3 END MOET LATER ZIJN DAN INPUT DATUM (ANDERS ENDDATE +1)
		if (strtotime($fiscalyear_einde)   <= strtotime($inputdatum)) {
			if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear_einde ('.$fiscalyear_einde.') moet plus 1 jaar want is kleiner dan inputdatum ('.$inputdatum.')</pre>',NULL,WATCHDOG_DEBUG);}
  			$fiscalyear_einde = date('Y-m-d',(strtotime ( '+1 year' , strtotime ( $fiscalyear_einde ) ) ) );  	
  			if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_end +1 year       : '.print_r($fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
		}

		### 4 CORRIGEER DATUMS OP DAG NAUWKEURIG
		if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear_einde ('.$fiscalyear_einde.') moet minus 1 dag om laatste dag fiscal year te markeren</pre>',NULL,WATCHDOG_DEBUG);}
		$fiscalyear_start 	= date('Y-m-d',(strtotime ( '-0 day' , strtotime ( $fiscalyear_start ) ) ) );
		$fiscalyear_einde 	= date('Y-m-d',(strtotime ( '-1 day' , strtotime ( $fiscalyear_einde ) ) ) );
		if ($extdebug >= 3) { watchdog('php','<pre>fiscalyear_einde -1 day      : '.print_r($fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

		$fiscalyear_array = array(
			'fiscalyear_input' => $inputdatum,
    		'fiscalyear_start' => $fiscalyear_start,
    		'fiscalyear_einde' => $fiscalyear_einde,
		);

		### 5 EINDRESULTAAT
		if ($extdebug >= 1) { watchdog('php','<pre>### fiscalyear resultaat op basis van inputdatum ('.$inputdatum.')</pre>',NULL,WATCHDOG_DEBUG);}
		if ($extdebug >= 1) { watchdog('php','<pre>fiscalyear_start             : '.print_r($fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
		if ($extdebug >= 1) { watchdog('php','<pre>fiscalyear_einde             : '.print_r($fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
		if ($extdebug >= 1) { watchdog('php','<pre>fiscalyear_array             : '.print_r($fiscalyear_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}

		# ATTEMPTY TO RETREIVE FISCAL YEAR START VALUE FROM CACHE

//		Civi::cache()->set('cache_fiscalyear_start', 	$today_fiscalyear_start);
//		Civi::cache()->set('cache_fiscalyear_einde', 	$today_fiscalyear_einde);

		return $fiscalyear_array;
}

function curriculum_civicrm_custom($op, $groupID, $entityID, &$params) {

	#civicrm_api3('Contact', 'getfields', array('cache_clear' => 1));
	#civicrm_api3('Participant', 'getfields', array('cache_clear' => 1));
	#CRM_Core_PseudoConstant::flush();

	$extdebug	= 3; 	// 1 = basic // 2 = verbose // 3 = params / 4 = results
	$apidebug	= FALSE;

	$extcv 		= 1;	// KAMP CV
	$extcvdeep	= 1;	// KAMP CV DEEPDIVE
	$extdjcont 	= 1;	// VALUES DITJAAR
	$extdjpart	= 1;	// VALUES DITEVENT
	$extchk 	= 1;	// TBV CHECKS bij 3.X
	$exttag		= 0;	// TAGS
	$extrel		= 0;	// RELATED CONTACTS
	$exteval 	= 0;	// EVALUATIE	
	$extact		= 1;	// ACTIVITIES
	$extacl 	= 1; 	// ACL & PERMISSIONS (#4 / #5 / #6)
	$extdrupal	= 1;	// DRUPAL NAME / MAIL
	$extint		= 0;
	$extref		= 0;
	$extvog		= 0;
	$testreg	= 0;	// REG TESTACCOUNTS
	$regpast	= 0;	// REG PAST EVENTS
	$extwrite	= 1;

	$profilecont 			= array(225);

	$profilepartgeld		= array(281);

	$profilepartdeel		= array(139);
	$profilepartleid 		= array(190);

	$profilepartref			= array(213);
	$profilepartvog			= array(140);

	$profilepart			= array_merge($profilepartdeel, $profilepartleid);

//	$profilepartintake		= array_merge($profilepartref,  $profilepartvog);
	$profilepartintake		= $profilepartvog;

	$profilecontmax			= array_merge($profilecont);
	$profilepartmax			= array_merge($profilepart, 	$profilepartintake);
	$profilepartleidmax		= array_merge($profilepartleid, $profilepartintake);
	$profilecv				= array_merge($profilecont, 	$profilepart);
	$profilecvmax			= array_merge($profilecontmax,  $profilepartmax);

	if ($op != 'create' && $op != 'edit') { //    did we just create or edit a custom object?

//		wachthond($extdebug,3, "########################################################################");
//		wachthond($extdebug,2, "EXIT: op != create OR op != edit", "(op: $op)");
//		wachthond($extdebug,3, "########################################################################");
		return; //	if not, get out of here
	}

	if (in_array($groupID, $profilepartref)) { // PROFILE LEID PART REF
		return;
	}

//	if (in_array($groupID, $profilepartvog) OR in_array($groupID, $profilepartref)) { // PROFILE LEID PART VOG OR REF
	if (in_array($groupID, $profilepartvog)) { // PROFILE LEID PART VOG OR REF

		wachthond($extdebug,1, "########################################################################");
		wachthond($extdebug,1, "START PROFILE PART LEID VOG / REF", "[groupID: $groupID / op: $op]");
		wachthond($extdebug,3, "########################################################################");

		wachthond($extdebug,2, "entityid",			$entityID);
		wachthond($extdebug,2, "params",			$params);

		foreach($params as $i=>$item) {

			if ( !isset($indexed[$i][$item['id']]) ) {
				$indexed[$i]['key'] 		= $i;
				$indexed[$i]['entity_id'] 	= $item['entity_id'] 	?? NULL;
				$indexed[$i]['column_name'] = $item['column_name'] 	?? NULL;
				$indexed[$i]['table_name'] 	= $item['table_name'] 	?? NULL;
				$indexed[$i]['value'] 		= $item['value'] 		?? NULL;
			}
			if (!isset($key_partvogverzocht[$i]) AND $item['column_name'] == "datum_verzoek_599" AND !empty($item['value'])) {
				$all_part_vog_verzocht[] = $i;
			}
		}

		wachthond($extdebug,4, "indexed", $indexed);

		$key_part_vog_verzocht	= $all_part_vog_verzocht[0];

		if ($key_part_vog_verzocht >= 0) {

	        $pid_part_vog_verzocht 	= $params[$key_part_vog_verzocht]['entity_id'] 	?? NULL;
	        $raw_part_vog_verzocht 	= $params[$key_part_vog_verzocht]['value'] 		?? NULL;
	        $new_part_vog_verzocht 	= strtotime($raw_part_vog_verzocht);
			$fin_part_vog_verzocht 	= date("Y-m-d H:i:s", $new_part_vog_verzocht);  

//			wachthond($extdebug,4, "key_part_vog_verzocht",	$key_part_vog_verzocht);
//			wachthond($extdebug,4, "raw_part_vog_verzocht",	$raw_part_vog_verzocht);
			wachthond($extdebug,1, "fin_part_vog_verzocht",	$fin_part_vog_verzocht);
			wachthond($extdebug,1, "pid_part_vog_verzocht",	$pid_part_vog_verzocht);
		}

		$extcv 		= 1;	// KAMP CV
		$extcvdeep	= 0;	// KAMP CV DEEPDIVE

		$extdjcont 	= 0;	// VALUES DITJAAR
		$extdjpart	= 0;	// VALUES DITEVENT

		$extchk 	= 1;	// TBV CHECKS BIJ 3.X	(TODO: NAW & BIO MOETEN HIERUIT GETROKKEN WORDEN)
		$exttag		= 0;	// TAGS
		$extrel		= 0;	// RELATED CONTACTS
		$extact		= 1;	// ACTIVITIES
		$exteval 	= 0;
		$extacl 	= 0;
		$extdrupal	= 0;	// DRUPAL NAME/MAIL

		$extint		= 1;

		if (in_array($groupID, $profilepartref)) {
			$extref		= 1;
			$extvog		= 0;
		} else {
			$extref		= 0;
		}
		if (in_array($groupID, $profilepartvog)) {
			$extvog		= 1;
			$extref		= 1;
		} else {
			$extvog		= 0;
		}

		$testreg	= 0;	// REG TESTACCOUNTS
		$regpast	= 0;	// REG PAST EVENTS
		$extwrite	= 1;

		// 1.X 	START BEPAAL BASISINFO CONTACT / PARTICIPANT
				// $extcv 		= 1;
				// $extcvdeep 	= 0;
		// 2.X 	START CHECK & REPAIR CURRICULUM
		// 3.X 	START CORRECT MISCELANEOUS VALUES
				// 3.1 A CONSTRUCT USERNAME
				// 3.2 STATUS PROFIELFOTO
				// 3.3 DEFINE POSTAL & EMAIL GREETING
				// 3.4 CREATE EMAIL ADRESSES TBV NOTIFICATIES
				// 3.5 CORRIGEER DATUM BELANG
				// 3.5 NAW & BIO
				// 3.6 WERVING MEE VOLGEND JAAR

		// 4.X 	EVENT - SEGMENT DEEL & LEID DIT EVENT
		// 5.X 	EVENT - SEGMENT PART DIT EVENT & HUIDIG JAAR 	PERMISSIONS - ACL
		// 6.X 	EVENT - SEGMENT HOOFDLEIDING & KAMPSTAF 		PERMISSIONS - ACL
		// 7.X 	START UPDATE PARAMS CONTACT & PART 				PERMISSIONS - ACL
		// 8.X 	EVALUATIE 			$exteval 	= 0	
		// 9.X 	DRUPAL NAME/MAIL 	$extdrupal	= 0
		// 10 	INTAKE

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "EINDE PROFILE PART LEID VOG / REF", "[groupID: $groupID / op: $op]");
		wachthond($extdebug,1, "########################################################################");

	}

//	if (empty($groupID) OR !in_array($groupID, $profilecv)) 	{ // PROFILE CONT & PART (BASIC)
	if (empty($groupID) OR !in_array($groupID, $profilecvmax)) 	{ // PROFILE CONT & PART (BASIC)

//		wachthond($extdebug,3, "########################################################################");
//		wachthond($extdebug,1, "EXIT: groupID ($groupID) not in allowed list (profilecvmax)", $profilecvmax);
//		wachthond($extdebug,3, "########################################################################");
		return; //	if not, get out of here
	}
/*
	if (in_array($groupID, $profilecvmax)) 	{ // PROFILE CONT & PART (BASIC)
	//	if (in_array($groupID, $profilecv)) { // PROFILE CONT & PART (BASIC)
	//	if (in_array($groupID, array("225", "139", "190", "140"))) { // CV & PART
		// 101  EVENT KENMERKEN
		// 139	PART DEEL
		// 190	PART LEID
		// 140	PART LEID VOG
		// 106	TAB  WERVING
		// 103	TAB  CURRICULUM
		// 149  TAB  TALENT
		// 150	TAB  PROMOTIE
