   					$kampkort 	= $eventkamp_event_kampkort;
					$weeknr 	= $eventkamp_event_weeknr;
   				}

				// only letters & numbers and dashes

				$eventkamp_event_kampnaam  		= $eventkamp_event_type_id_label;

				$eventkamp_event_kampkort  		= preg_replace('/[^ \w-]/','',strtolower(trim($eventkamp_event_kampkort)));
				$eventkamp_event_kampkort_low 	= preg_replace('/[^ \w-]/','',strtolower(trim($eventkamp_event_kampkort)));
				$eventkamp_event_kampkort_cap 	= preg_replace('/[^ \w-]/','',strtoupper(trim($eventkamp_event_kampkort)));

				$kampkort  						= preg_replace('/[^ \w-]/','',strtolower(trim($kampkort)));
				$kampkort_low 					= preg_replace('/[^ \w-]/','',strtolower(trim($kampkort)));
				$kampkort_cap 					= preg_replace('/[^ \w-]/','',strtoupper(trim($kampkort)));

