				$vogontvangst_activity_2_status_name	= $result_vogontvangst[0]['status_id:name'] 	?? NULL;
				$vogontvangst_activity_2_datum			= $result_vogontvangst[0]['activity_date_time'] ?? NULL;
  				$vogontvangst_activity_2_kampjaar		= $result_vogontvangst[0]['ACT_ALG.kampjaar'] 	?? NULL;				

				wachthond($extdebug,3, '2 vogontvangst_activity_id', 			$vogontvangst_activity_2_id);
				wachthond($extdebug,3, '2 vogontvangst_activity_status',		$vogontvangst_activity_2_status_name);
				wachthond($extdebug,3, '2 vogontvangst_activity_datum',			$vogontvangst_activity_2_datum);
				wachthond($extdebug,4, '2 vogontvangst_activity_kampjaar', 		$vogontvangst_activity_2_kampjaar);

			} else {
				$vogontvangst_activity_2_id		= NULL;
				$vogontvangst_activity_2_status	= NULL;

				wachthond($extdebug,4, 'result_count_ontvangst', 				$result_vogaanvraag_count);
				wachthond($extdebug,2, "vogontvangst_activity_2_id\tNO ACTIVITY FOUND", "[part_vogontvangst: $part_vogontvangst]");
			}
		}
	}

	##################################################################################################

	if ($params_contact OR $params_part_ditevent) {
		wachthond($extdebug,1, "########################################################################");
		wachthond($extdebug,1, "### 99. WRITE CONTACT & PARTICIPANT DATA TO DB VOOR $displayname", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,1, "########################################################################");
	}

		if ($ditevent_part_rol == 'deelnemer') {
			wachthond($extdebug,2, 'diteventdeelyes', 		$diteventdeelyes);
			wachthond($extdebug,2, 'diteventdeelmss', 		$diteventdeelmss);
			wachthond($extdebug,2, 'ditjaardeelyes', 		$ditjaardeelyes);
			wachthond($extdebug,2, 'ditjaardeelmss', 		$ditjaardeelmss);
			wachthond($extdebug,2, 'ditjaareventdeelyes', 	$ditjaareventdeelyes);
			wachthond($extdebug,2, 'ditjaareventdeelmss', 	$ditjaareventdeelmss);
		}

		if ($ditevent_part_rol == 'leiding') {
			wachthond($extdebug,2, 'diteventleidyes', 		$diteventleidyes);
			wachthond($extdebug,2, 'diteventleidmss', 		$diteventleidmss);
			wachthond($extdebug,2, 'ditjaarleidyes', 		$ditjaarleidyes);
			wachthond($extdebug,2, 'ditjaarleidmss', 		$ditjaarleidmss);
			wachthond($extdebug,2, 'ditjaareventleidyes', 	$ditjaareventleidyes);
			wachthond($extdebug,2, 'ditjaareventleidmss', 	$ditjaareventleidmss);
		}

	##################################################################################################
	## 99. FINAL DATABASE QUERY PARAMS SORT & PREP 
	##################################################################################################

	if ($extwrite == 1 AND !empty($params_contrib) AND $ditevent_participant_contribid > 0 AND $ditevent_kampjaar > 2016) {

		$params_contrib['reload']					= TRUE;
		$params_contrib['checkPermissions']			= FALSE;
		$params_contrib['debug']					= $apidebug;
		wachthond($extdebug,1, 	"params_contrib     DB UPDATE PREPARED VOOR $displayname",
								"bid: $ditevent_participant_contribid \t/ $ditjaar_pos_part_functie $ditjaar_pos_part_kampkort $ditjaar_pos_kampjaar");
	}
	if ($extwrite == 1 AND !empty($params_contact) AND $contact_id > 0) {

		$params_contact['reload']					= TRUE;
		$params_contact['checkPermissions']			= FALSE;
		$params_contact['debug']					= $apidebug;
		wachthond($extdebug,1, 	"params_contact     DB UPDATE PREPARED VOOR $displayname",
								"cid: $contact_id \t/ $ditjaar_pos_part_functie $ditjaar_pos_part_kampkort $ditjaar_pos_kampjaar");

	}
	if ($extwrite == 1 AND !empty($params_part_ditevent) AND $ditevent_part_id > 0) {

		$params_part_ditevent['reload']				= TRUE;
		$params_part_ditevent['checkPermissions']	= FALSE;
		$params_part_ditevent['debug']				= $apidebug;
		wachthond($extdebug,1, 	"params_participant DB UPDATE PREPARED VOOR $displayname",
								"pid: $ditevent_part_id \t/ $ditevent_part_functie $eventkamp_event_kampkort $eventkamp_kampjaar (eid: $ditevent_part_eventid)");
	}

	wachthond($extdebug,1, "########################################################################");

	##################################################################################################
	## 99. FINAL DATABASE QUERY PARAMS DEBUG 
	##################################################################################################

	if ($extwrite == 1 AND !empty($params_contrib) 		 AND $ditevent_participant_contribid > 0 AND $ditevent_kampjaar > 2016) {
//		wachthond($extdebug,1, 'params_contrib', 			$params_contrib);
		ksort($params_contrib['values']);
		wachthond($extdebug,1, 'params_contrib', 			$params_contrib);
	}
	if ($extwrite == 1 AND !empty($params_contact) 		 AND $contact_id > 0) {
//		wachthond($extdebug,1, 'params_contact', 			$params_contact);
		ksort($params_contact['values']);
		wachthond($extdebug,1, 'params_contact', 			$params_contact);
	}
	if ($extwrite == 1 AND !empty($params_part_ditevent) AND $ditevent_part_id > 0) {
//		wachthond($extdebug,1, 'params_part_ditevent', 		$params_part_ditevent);
		ksort($params_part_ditevent['values']);
		wachthond($extdebug,1, 'params_part_ditevent', 		$params_part_ditevent);

	}

	wachthond($extdebug,1, "########################################################################");

	##################################################################################################
	## 99. FINAL DATABASE QUERY PERFORM UPDATES
	##################################################################################################

	if ($extwrite == 1 AND !empty($params_contrib) AND $ditevent_participant_contribid > 0 AND $ditevent_kampjaar > 2016) {

		$result_contrib = civicrm_api4('Contribution', 'update', 		$params_contrib);

		wachthond($extdebug,1, 	"params_contrib     DB UPDATE EXECUTED VOOR $displayname", 
								"bid: $ditevent_participant_contribid \t/ $ditevent_part_functie $eventkamp_event_kampkort $eventkamp_kampjaar");
	} else {
		wachthond($extdebug,1, 	"params_contrib     DB UPDATE SKIPPED  VOOR $displayname", 
								"bid: $ditevent_participant_contribid \t/ $ditevent_part_functie $eventkamp_event_kampkort $eventkamp_kampjaar");		
	}

	if ($extwrite == 1 AND !empty($params_contact) AND $contact_id > 0) {

		$result_contact = civicrm_api4('Contact', 'update', 			$params_contact);

		wachthond($extdebug,1, 	"params_contact     DB UPDATE EXECUTED VOOR $displayname",
								"cid: $contact_id \t/ $ditjaar_pos_part_functie $ditjaar_pos_part_kampkort $ditjaar_pos_kampjaar");
	} else {
		wachthond($extdebug,1, 	"params_contact     DB UPDATE SKIPPED  VOOR $displayname",
								"cid: $contact_id \t/ $ditjaar_pos_part_functie $ditjaar_pos_part_kampkort $ditjaar_pos_kampjaar");		
	}

	if ($extwrite == 1 AND !empty($params_part_ditevent) AND $ditevent_part_id > 0) {

		$result_part_ditevent = civicrm_api4('Participant', 'update', 	$params_part_ditevent);

		wachthond($extdebug,1, 	"params_participant DB UPDATE EXECUTED VOOR $displayname",
								"pid: $ditevent_part_id \t/ $ditevent_part_functie $eventkamp_event_kampkort $eventkamp_kampjaar (eid: $ditevent_part_eventid)");
	} else {
		wachthond($extdebug,1, 	"params_participant DB UPDATE SKIPPED  VOOR $displayname",
								"pid: $ditevent_part_id \t/ $ditevent_part_functie $eventkamp_event_kampkort $eventkamp_kampjaar (eid: $ditevent_part_eventid)");		
	}

	wachthond($extdebug,9, "########################################################################");

	if ($extwrite == 1 AND !empty($params_contrib) AND $ditevent_participant_contribid > 0 AND $ditevent_kampjaar > 2016) {
		wachthond($extdebug,9, 'result_contrib', 		$result_contrib);
	}

	if ($extwrite == 1 AND !empty($params_contact) AND $contact_id > 0) {
		wachthond($extdebug,9, 'result_contact', 		$result_contact);
	}

	if ($extwrite == 1 AND !empty($params_part_ditevent) AND $ditevent_part_id > 0) {
		wachthond($extdebug,9, 'result_part_ditevent',	$result_part_ditevent);
	}

/*
	wachthond($extdebug,1, '1', 					$today_datetime);	
	wachthond($extdebug,1, '12', 					$today_datetime);	
	wachthond($extdebug,1, '123', 					$today_datetime);	
	wachthond($extdebug,1, '1234', 					$today_datetime);	
	wachthond($extdebug,1, '12345', 				$today_datetime);	
	wachthond($extdebug,1, '123456', 				$today_datetime);	
	wachthond($extdebug,1, '1234567', 				$today_datetime);	
	wachthond($extdebug,1, '12345678', 				$today_datetime);	
	wachthond($extdebug,1, '123456789', 			$today_datetime);	
	wachthond($extdebug,1, '1234567890', 			$today_datetime);	
	wachthond($extdebug,1, '12345678901', 			$today_datetime);
	wachthond($extdebug,1, '123456789012', 			$today_datetime);	
	wachthond($extdebug,1, '1234567890123', 		$today_datetime);
	wachthond($extdebug,1, '12345678901234', 		$today_datetime);
	wachthond($extdebug,1, '123456789012345', 		$today_datetime);	
	wachthond($extdebug,1, '1234567890123456', 		$today_datetime);
	wachthond($extdebug,1, '123456789012345678',	$today_datetime);	
	wachthond($extdebug,1, '1234567890123456789',	$today_datetime);	
	wachthond($extdebug,1, '12345678901234567890',	$today_datetime);	
	wachthond($extdebug,1, '123456789012345678901',	$today_datetime);

   	$divider = str_repeat("#", 32);
	wachthond($extdebug,1, $divider,				$today_datetime);
   	$divider = str_repeat("#", 48);
	wachthond($extdebug,1, $divider,				$today_datetime);
   	$divider = str_repeat("#", 64);
	wachthond($extdebug,1, $divider,				$today_datetime);
   	$divider = str_repeat("#", 72);
	wachthond($extdebug,1, $divider,				$today_datetime);
   	$divider = str_repeat("#", 96);
	wachthond($extdebug,1, $divider,				$today_datetime);
*/
	wachthond($extdebug,1, "########################################################################");
	if (in_array($groupID, $profilepartleid)) { 	// PROFILE PARTICIPANT
		wachthond($extdebug,1, "### EINDE EXTENSION INTAKE VOOR $displayname", 	"[GroupID: $groupID] [op: $op]", 
		"[$ditevent_part_functie: $displayname]");
	} else {
		wachthond($extdebug,1, "### EINDE EXTENSION CV VOOR $displayname", 		"[GroupID: $groupID] [op: $op] [entityID: $entityID]", 
		"[$ditevent_part_functie: $displayname]");
	}
	wachthond($extdebug,1, "########################################################################");

}

