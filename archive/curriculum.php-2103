							'ACT_ALG.kampjaar'			=> $eventkamp_kampjaar,

							'ACT_ALG.modified' 			=> $today_datetime,
			    			'ACT_ALG.prioriteit:label'	=> 'Normaal',
						],
					];
					wachthond($extdebug,7, 'params_activity_vogontvangst_create', 		 $params_activity_vogontvangst_create);
					if ($extvog == 1)	{
						$result_vogontvangst_create = civicrm_api4('Activity', 'create', $params_activity_vogontvangst_create);
						wachthond($extdebug,7, 'params_activity_vogontvangst_create', 				"EXECUTED");
						wachthond($extdebug,7, 'params_activity_vogontvangst_create RESULT', 		$result_vogontvangst_create);
						wachthond($extdebug,7, 'params_activity_vogontvangst_create RESULTS 0', 	$result_vogontvangst_create[0]);
						wachthond($extdebug,7, 'params_activity_vogontvangst_create RESULTS 0 ID', 	$result_vogontvangst_create[0]['id']);
					}
				  	if (empty($vogontvangst_activity_id))			{ $vogontvangst_activity_id			= $result_vogontvangst_create[0]['id'] 			?? NULL; }
					if (empty($vogontvangst_activity_status))		{ $vogontvangst_activity_status		= $result_vogontvangst_create[0]['status_id'] 	?? NULL; }
					wachthond($extdebug,2, "(nieuwe) vogontvangst_activity_id", 		$vogontvangst_activity_id);
					wachthond($extdebug,2, "(nieuwe) vogontvangst_activity_status", 	$vogontvangst_activity_status);

				} else {
					wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit VOGONTVANGST aangemaakt", "[ivm waarde vognodig: $new_ditjaar_vognodig]");
				}

			} else {
				wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit VOGONTVANGST aangemaakt", "[aid: $vogontvangst_activity_id]");
				wachthond($extdebug,4, "vogontvangst_activity_id", 	$vogontvangst_activity_id);
				wachthond($extdebug,4, "datum_vogontvangst", 		$ditjaar_vogontvangst_actdatetime);
				wachthond($extdebug,4, "part_vogverzocht", 			$part_vogverzocht);
				wachthond($extdebug,4, "new_ditpart_vognodig", 		$new_ditpart_vognodig);				
				wachthond($extdebug,4, "new_ditjaar_vognodig", 		$new_ditjaar_vognodig);
			}

		} else {
			wachthond($extdebug,1, "########################################################################");
			wachthond($extdebug,1, 'extvog',				$extvog);
			wachthond($extdebug,1, 'extact',				$extact);
			wachthond($extdebug,1, 'ditjaarleidstf',		$ditjaarleidstf);
			wachthond($extdebug,1, 'ditjaareventleidyes',	$ditjaareventleidyes);
			wachthond($extdebug,1, 'profilepartleidmax',	$profilepartleidmax);						
			wachthond($extdebug,1, "### 13.X SKIPPED CREATE INTAKE ACTIVITIES VOG", "[groupID: $groupID]");
		}

		if ($extact == 1 AND in_array($groupID, $profilepartleidmax) AND ($ditjaareventleidyes == 1 OR $ditjaarleidstf == 1)) { // PROFILE PARTICIPANT LEID MAX	

			wachthond($extdebug,1, "########################################################################");
			wachthond($extdebug,1, "### 14. BEPAAL NIEUWE STATUS ONDERDELEN INTAKE $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,1, "########################################################################");
		}

		if ($extref == 1 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND ($ditjaareventleidyes == 1 OR $ditjaarleidstf == 1)) { // PROFILE PARTICIPANT LEID MAX	

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.1 a BEPAAL NEW STATUS ACTIVITEIT REF PERSOON VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			$ditjaar_refpersoon_actstatus	= 'Available';	// DEFAULT TO AVAILABLE (CONCEPT)
			$ditjaar_refpersoon_actprio 	= 'Normaal';	// DEFAULT TO NORMAL

			$part_refpersoon_infiscalyear_ditevent = infiscalyear($part_refpersoon, $ditevent_event_start, 'refpersoon', 'ditevent')	?? 0;

			wachthond($extdebug,3, "- new_ditpart_refnodig", 				$new_ditpart_refnodig);
			wachthond($extdebug,3, "- new_ditjaar_refnodig", 				$new_ditjaar_refnodig);

			wachthond($extdebug,2, "- part_refpersoon", 						"$part_refpersoon");
			wachthond($extdebug,2, "- part_refpersoon_infiscalyear_ditevent", 	"$part_refpersoon_infiscalyear_ditevent [part_refpersoon: $part_refpersoon]");

			wachthond($extdebug,2, "1 new_ditpart_refstatus", 				$new_ditpart_refstatus);
			wachthond($extdebug,2, "1 new_ditjaar_refstatus", 				$new_ditjaar_refstatus);
			wachthond($extdebug,2, "1 ditjaar_refpersoon_actstatus",		$ditjaar_refpersoon_actstatus);

			if (in_array($new_ditjaar_refnodig, array("noggoed"))) {
				$ditjaar_refpersoon_actstatus 	= 'Not Required';
			} else {

				$diffsince_refpersoon 	= NULL;
				$dayssince_refpersoon 	= NULL;
				#if ($part_refpersoon) { $act_refpersoon = $part_refpersoon; } else { $act_refpersoon = $today_datetime; }
				$diffsince_refpersoon	= date_diff(date_create($part_refpersoon),date_create($today_datetime));
				$dayssince_refpersoon	= $diffsince_refpersoon->format('%a');
				wachthond($extdebug,2, "- dayssince_refpersoon", 	$dayssince_refpersoon);

				if ($dayssince_refpersoon >= 0  AND $dayssince_refpersoon < 7)			{ $ditjaar_refpersoon_actstatus = "Pending"; 		} // AFWACHTING
				if ($dayssince_refpersoon >= 7  AND $dayssince_refpersoon < 21)			{ $ditjaar_refpersoon_actstatus = "Left Message";  	} // HERINNERD
				if ($dayssince_refpersoon >= 21 AND $dayssince_refpersoon < 35)			{ $ditjaar_refpersoon_actstatus = "Unreachable"; 	} // ONBEREIKBAAR
				if ($dayssince_refpersoon >= 35)										{ $ditjaar_refpersoon_actstatus = "No_show"; 		} // VERLOPEN
				if ($dayssince_refpersoon >= 270)										{ $ditjaar_refpersoon_actstatus = "Bounced"; 		} // GEFAALD

				if ( date_bigger($today_datetime, $ditevent_event_einde) == 1 AND $ditjaar_refpersoon_actstatus != "Completed") {
//					$ditjaar_refpersoon_actstatus = "Failed";
// 					Failed nadat de laatste dag van kamp gepasseerd is
//					wachthond($extdebug,2, "activity refpersoon > status failed want event inmiddels voorbij");
				}

				// M61 zorg dat de REF persoon activity en mails pas starten zodra de VOG klaargezet is (1 mail met intake todo's)
				if (in_array($new_ditjaar_vognodig, array("eerstex", "elkjaar", "opnieuw")) AND $vogverzoekditjaar == 1) {
					$ditjaar_refpersoon_actstatus 	= 'Scheduled';
					wachthond($extdebug,3, "ditjaar_refpersoon_actstatus: $ditjaar_refpersoon_actstatus", "[vog verzocht dus trigger ook referentie en verstuur bredere intake email");
				}
				// M61 zorg dat de REF persoon activity en mails pas starten zodra de VOG klaargezet is (1 mail met intake todo's)
				if (in_array($new_ditjaar_vognodig, array("eerstex", "elkjaar", "opnieuw")) AND $vogverzoekditjaar != 1) {
					$ditjaar_refpersoon_actstatus 	= 'Available';
					wachthond($extdebug,3, "ditjaar_refpersoon_actstatus: $ditjaar_refpersoon_actstatus", "[in afwachting van VOG verzoek]");
				}

				if ($refpersoon_activity_id AND $referentie_cid) 	{
					$ditjaar_refpersoon_actstatus 	= 'Completed';
					$new_ditjaar_refstatus 			= 'vragen';
				}
				if ($refpersoon_activity_id AND $part_refgevraagd) 	{
					$ditjaar_refpersoon_actstatus 	= 'Completed';
					$new_ditjaar_refstatus 			= 'gevraagd';
				}

				if ($ditjaar_refpersoon_actstatus == "Pending")			{	$ditjaar_refpersoon_actprio = 'Laag';		} 	// AFWACHTING
				if ($ditjaar_refpersoon_actstatus == "Left Message")	{	$ditjaar_refpersoon_actprio = 'Normaal';	} 	// HERINNERD
				if ($ditjaar_refpersoon_actstatus == "Unreachable")		{	$ditjaar_refpersoon_actprio = 'Urgent';		} 	// ONBEREIKBAAR
				if ($ditjaar_refpersoon_actstatus == "No_show")			{	$ditjaar_refpersoon_actprio = 'Urgent';		} 	// VERLOPEN			
				if ($ditjaar_refpersoon_actstatus == "Bounced")			{	$ditjaar_refpersoon_actprio = 'Urgent';		} 	// GEFAALD/GEBOUNCED
			}

			wachthond($extdebug,2, "2 new_ditpart_refstatus", 				$new_ditpart_refstatus);
			wachthond($extdebug,2, "2 new_ditjaar_refstatus", 				$new_ditjaar_refstatus);
			wachthond($extdebug,2, "2 ditjaar_refverzoek_actstatus", 		$ditjaar_refverzoek_actstatus);
			wachthond($extdebug,2, "2 ditjaar_refverzoek_actprio",			$ditjaar_refverzoek_actprio);

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.1 b COPY REFSTATUS DITEVENT > DITJAAR INDIEN EVENT DITJAAR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			if ($ditjaarleidyes == 1 OR $ditjaareventleidstf == 1) {

				wachthond($extdebug,2, 	"REFSTATUS ($new_ditjaar_vogstatus) UIT DITEVENT GEKOPIEERD NAAR DITJAAR", "[WANT EVENT IS IN DITJAAR]");

//				$new_ditjaar_refstatus = $new_ditpart_refstatus;

			} else {

				wachthond($extdebug,2, 'ditjaareventleidyes', 	$ditjaareventleidyes);
				wachthond($extdebug,2, 'ditjaareventleidstf', 	$ditjaareventleidstf);

				wachthond($extdebug,2, 	"REFSTATUS UIT DITEVENT NIET KOPIEREN NAAR DITJAAR WANT EVENT =! DITJAAR");

			}

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.2 a BEPAAL NEW STATUS ACTIVITEIT REF VERZOEK VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			$ditjaar_refverzoek_actstatus	= 'Available';	// DEFAULT TO AVAILABLE (CONCEPT)
			$ditjaar_refverzoek_actprio 	= 'Normaal';	// DEFAULT TO NORMAL
			$part_refgevraagd_infiscalyear_ditevent = infiscalyear($part_refgevraagd, $ditevent_event_start, 'refverzoek', 'ditevent')	?? 0;

			wachthond($extdebug,3, "- new_ditpart_refnodig", 				$new_ditpart_refnodig);
			wachthond($extdebug,3, "- new_ditjaar_refnodig", 				$new_ditjaar_refnodig);

			wachthond($extdebug,2, "- part_refgevraagd", 						$part_refgevraagd);
			wachthond($extdebug,2, "- part_refgevraagd_infiscalyear_ditevent", "$part_refgevraagd_infiscalyear_ditevent [part_refgevraagd: $part_refgevraagd]");

			wachthond($extdebug,2, "1 new_ditpart_refstatus", 				$new_ditpart_refstatus);		
			wachthond($extdebug,2, "1 new_ditjaar_refstatus", 				$new_ditjaar_refstatus);
			wachthond($extdebug,2, "1 ditjaar_refverzoek_actstatus",		$ditjaar_refverzoek_actstatus);

			if (in_array($new_ditjaar_refnodig, array("noggoed"))) {

				$ditjaar_refverzoek_actstatus 	= 'Not Required';

			} else {

				$diffsince_refverzoek 	= NULL;				
				$dayssince_refverzoek 	= NULL;
				$diffsince_refverzoek	= date_diff(date_create($part_refgevraagd),date_create($today_datetime));
				$dayssince_refverzoek	= $diffsince_refverzoek->format('%a');
				wachthond($extdebug,2, "- dayssince_refverzoek", 	$dayssince_refverzoek);

				if ($dayssince_refverzoek >= 0  AND $dayssince_refverzoek < 7)			{ $ditjaar_refverzoek_actstatus = "Pending"; 		} // AFWACHTING
				if ($dayssince_refverzoek >= 7  AND $dayssince_refverzoek < 21)			{ $ditjaar_refverzoek_actstatus = "Left Message";  	} // HERINNERD
				if ($dayssince_refverzoek >= 21 AND $dayssince_refverzoek < 35)			{ $ditjaar_refverzoek_actstatus = "Unreachable"; 	} // ONBEREIKBAAR
				if ($dayssince_refverzoek >= 35)										{ $ditjaar_refverzoek_actstatus = "No_show"; 		} // VERLOPEN
				if ($dayssince_refverzoek >= 270)										{ $ditjaar_refverzoek_actstatus = "Bounced"; 		} // GEFAALD

				if ( date_bigger($today_datetime, $ditevent_event_einde) == 1 AND $ditjaar_refverzoek_actstatus != "Completed") {
//					$status_refaanvraag = "Failed";
					wachthond($extdebug,2, "activity refverzoek > status failed want event inmiddels voorbij");
				}
				if ($refverzoek_activity_id AND ($part_reffeedback OR $referentie_feedback)) {
					$ditjaar_refverzoek_actstatus 	= 'Completed';
					$new_ditjaar_refstatus 	= 'ontvangen';
				}

				if ($ditjaar_refverzoek_actstatus == "Pending")		{	$ditjaar_refverzoek_actprio = 'Laag';	} 	// AFWACHTING
				if ($ditjaar_refverzoek_actstatus == "Left Message"){	$ditjaar_refverzoek_actprio = 'Normaal';} 	// HERINNERD
				if ($ditjaar_refverzoek_actstatus == "Unreachable")	{	$ditjaar_refverzoek_actprio = 'Urgent';	} 	// ONBEREIKBAAR
				if ($ditjaar_refverzoek_actstatus == "No_show")		{	$ditjaar_refverzoek_actprio = 'Urgent';	} 	// VERLOPEN
				if ($ditjaar_refverzoek_actstatus == "Bounced")		{	$ditjaar_refverzoek_actprio = 'Urgent';	} 	// GEFAALD/GEBOUNCED
			}

			wachthond($extdebug,2, "2 new_ditpart_refstatus", 				$new_ditpart_refstatus);
			wachthond($extdebug,2, "2 new_ditjaar_refstatus", 				$new_ditjaar_refstatus);
			wachthond($extdebug,2, "2 ditjaar_refverzoek_actstatus", 		$ditjaar_refverzoek_actstatus);
			wachthond($extdebug,2, "2 ditjaar_refverzoek_actprio",			$ditjaar_refverzoek_actprio);

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.2 b COPY REFSTATUS DITEVENT > DITJAAR INDIEN EVENT DITJAAR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {

				wachthond($extdebug,2, 	"REFSTATUS ($new_ditjaar_vogstatus) UIT DITEVENT GEKOPIEERD NAAR DITJAAR", "[WANT EVENT IS IN DITJAAR]");
				wachthond($extdebug,2, "########################################################################");

//				$new_ditjaar_refstatus = $new_ditpart_refstatus;
			} else {

				wachthond($extdebug,2, 'ditjaareventleidyes', 	$ditjaareventleidyes);
				wachthond($extdebug,2, 'ditjaareventleidstf', 	$ditjaareventleidstf);

				wachthond($extdebug,2, 	"REFSTATUS UIT DITEVENT NIET KOPIEREN NAAR DITJAAR WANT EVENT =! DITJAAR");

			}			
		}

		wachthond($extdebug,1, 'extvog',				$extvog);
		wachthond($extdebug,1, 'extact',				$extact);
		wachthond($extdebug,1, 'ditjaarleidyes',		$ditjaarleidyes);
		wachthond($extdebug,1, 'diteventleidyes',		$diteventleidyes);
		wachthond($extdebug,1, 'ditjaareventleidyes',	$ditjaareventleidyes);

		if ($extvog == 1 AND $extact == 1 AND ($diteventleidyes == 1 OR $diteventleidstf == 1)) {

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.3 a BEPAAL NEW STATUS ACTIVITEIT VOG VERZOEK VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			$ditjaar_vogverzoek_actstatus		= 'Available';	// DEFAULT TO AVAILABLE (CONCEPT)
			$ditjaar_vogverzoek_actprio 		= 'Normaal';	// DEFAULT TO NORMAL
			$vogverzocht_infiscalyear_ditevent 	= infiscalyear($part_vogverzocht,  	$ditevent_event_start, 'vogrecent', 'ditevent')	?? 0;
			$partvogdatum_infiscalyear_ditevent = infiscalyear($part_vogdatum,  	$ditevent_event_start, 'vogrecent', 'ditevent')	?? 0;

			wachthond($extdebug,3, "- partvogdatum_infiscalyear_ditevent", 	"$partvogdatum_infiscalyear_ditevent [partvogdatum: $part_vogdatum]");

			wachthond($extdebug,2, "- new_ditpart_vognodig", 				$new_ditpart_vognodig);
			wachthond($extdebug,2, "- new_ditjaar_vognodig", 				$new_ditjaar_vognodig);

			wachthond($extdebug,2, "- part_vogverzocht", 					$part_vogverzocht);
			wachthond($extdebug,3, "- vogverzocht_infiscalyear_ditevent", 	"$vogverzocht_infiscalyear_ditevent [part_vogverzocht: $part_vogverzocht]");

			wachthond($extdebug,4, "1 new_ditpart_vogstatus", 				$new_ditpart_vogstatus);
			wachthond($extdebug,4, "1 new_ditjaar_vogstatus", 				$new_ditjaar_vogstatus);
			wachthond($extdebug,4, "1 ditjaar_vogverzoek_actstatus", 		$ditjaar_vogverzoek_actstatus);

			if (in_array($new_ditpart_vognodig, array('eerstex','opnieuw','elkjaar','inhaal'))) {

				if (date_bigger($part_vogverzocht, $ditevent_fiscalyear_start) == 1) {

					if ($vogverzocht_infiscalyear_ditevent  == 1)	{
						$new_ditpart_vogstatus 			= 'verzocht';
						$ditjaar_vogverzoek_actstatus	= 'Completed';
					}
					if ($vogingediend_infiscalyear_ditevent == 1) 	{
						$new_ditpart_vogstatus = 'ingediend';
						wachthond($extdebug,2, 	"STATUS VOG_AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Completed", 
												"[WANT part_vogingediend: $part_vogingediend IN EVENT_FISCAL_YEAR");
					}
					if ($vogontvangst_infiscalyear_ditevent == 1) 	{
						$new_ditpart_vogstatus = 'ontvangen';
						wachthond($extdebug,2, 	"STATUS VOG AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Completed",
												"[WANT part_vogontvangst: $part_vogontvangst IN EVENT_FISCAL_YEAR");
					}
					if ($partvogdatum_infiscalyear_ditevent == 1) 	{
						$new_ditpart_vogstatus = 'ontvangen'; 
						wachthond($extdebug,2, 	"STATUS VOG AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Completed",
												"[WANT part_vogdatum: $part_vogdatum IN EVENT_FISCAL_YEAR");
					}

				} elseif (empty($part_vogverzocht))					{
						$new_ditpart_vogstatus = 'klaarzetten';
				}

			} elseif ($new_ditpart_vognodig == 'noggoed' AND $vogrecent) {
						$new_ditpart_vogstatus 			= 'noggoed';
						$ditjaar_vogaanvraag_actstatus	= 'Not Required';
			}

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.3 b COPY VOGSTATUS DITEVENT > DITJAAR INDIEN EVENT DITJAAR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {

				wachthond($extdebug,2, 	"VOGSTATUS ($new_ditjaar_vogstatus) UIT DITEVENT GEKOPIEERD NAAR DITJAAR", "[WANT EVENT IS IN DITJAAR]");

				$new_ditjaar_vogstatus = $new_ditpart_vogstatus;

			} else {

				wachthond($extdebug,2, 'ditjaareventleidyes', 	$ditjaareventleidyes);
				wachthond($extdebug,2, 'ditjaareventleidstf', 	$ditjaareventleidstf);

				wachthond($extdebug,2, "########################################################################");
				wachthond($extdebug,2, 	"VOGSTATUS UIT DITEVENT NIET KOPIEREN NAAR DITJAAR WANT EVENT =! DITJAAR");
				wachthond($extdebug,2, "########################################################################");

			}

			wachthond($extdebug,2, "2 new_ditpart_vogstatus", 				$new_ditpart_vogstatus);
			wachthond($extdebug,2, "2 new_ditjaar_vogstatus", 				$new_ditjaar_vogstatus);
			wachthond($extdebug,2, "2 ditjaar_vogverzoek_actstatus", 		$ditjaar_vogverzoek_actstatus);
			wachthond($extdebug,2, "2 ditjaar_vogverzoek_actprio",			$ditjaar_vogverzoek_actprio);

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.4 a BEPAAL NEW STATUS ACTIVITEIT VOG AANVRAAG VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			$ditjaar_vogaanvraag_actstatus		= 'Available';	// DEFAULT TO AVAILABLE (CONCEPT)
			$ditjaar_vogaanvraag_actprio 		= 'Normaal';	// DEFAULT TO NORMAL
			$vogingediend_infiscalyear_ditevent = infiscalyear($part_vogingediend, 	$ditevent_event_start, 'vogrecent', 'ditevent')	?? 0;

			wachthond($extdebug,2, "- new_ditpart_vognodig", 				$new_ditpart_vognodig);
			wachthond($extdebug,2, "- new_ditjaar_vognodig", 				$new_ditjaar_vognodig);

			wachthond($extdebug,2, "- part_vogingediend", 					$part_vogingediend);
			wachthond($extdebug,3, "- vogingediend_infiscalyear_ditevent", 	$vogingediend_infiscalyear_ditevent);

			wachthond($extdebug,4, "1 new_ditpart_vogstatus", 				$new_ditpart_vogstatus);
			wachthond($extdebug,4, "1 new_ditjaar_vogstatus", 				$new_ditjaar_vogstatus);
			wachthond($extdebug,4, "1 ditjaar_vogaanvraag_actstatus", 		$ditjaar_vogaanvraag_actstatus);

			$diffsince_vogverzoek 	= NULL;
			$dayssince_vogverzoek 	= NULL;
			$diffsince_vogverzoek	= date_diff(date_create($part_vogverzocht),date_create($today_datetime));
			$dayssince_vogverzoek	= $diffsince_vogverzoek->format('%a');	
			wachthond($extdebug,2, "- dayssince_vogverzoek", $dayssince_vogverzoek);

			if ($dayssince_vogverzoek >= 0  AND $dayssince_vogverzoek < 14)			{ $ditjaar_vogaanvraag_actstatus = "Pending"; 		} // AFWACHTING
			if ($dayssince_vogverzoek >= 14 AND $dayssince_vogverzoek < 21)			{ $ditjaar_vogaanvraag_actstatus = "Left Message"; 	} // HERINNERD
			if ($dayssince_vogverzoek >= 21 AND $dayssince_vogverzoek < 30)			{ $ditjaar_vogaanvraag_actstatus = "Unreachable"; 	} // ONBEREIKBAAR
			if ($dayssince_vogverzoek >= 30)										{ $ditjaar_vogaanvraag_actstatus = "No_show"; 		} // VERLOPEN
			if ($dayssince_vogverzoek >= 270)										{ $ditjaar_vogaanvraag_actstatus = "Bounced"; 		} // GEFAALD/GEBOUNCED

			if ($ditjaar_vogaanvraag_actstatus == "Pending")		{	$ditjaar_vogaanvraag_actprio = 'Laag';		} 	// AFWACHTING
			if ($ditjaar_vogaanvraag_actstatus == "Left Message")	{	$ditjaar_vogaanvraag_actprio = 'Normaal';	} 	// HERINNERD
			if ($ditjaar_vogaanvraag_actstatus == "Unreachable")	{	$ditjaar_vogaanvraag_actprio = 'Urgent';	} 	// ONBEREIKBAAR
			if ($ditjaar_vogaanvraag_actstatus == "No_show")		{	$ditjaar_vogaanvraag_actprio = 'Urgent';	} 	// VERLOPEN			
			if ($ditjaar_vogaanvraag_actstatus == "Bounced")		{	$ditjaar_vogaanvraag_actprio = 'Urgent';	} 	// GEFAALD/GEBOUNCED

			if ($vogaanvraag_activity_status_name != 'Completed' AND $ditjaar_vogaanvraag_actstatus == 'Completed') {
				$ditjaar_vogaanvraag_afgerond = $today_datetime;
			} else {
				$ditjaar_vogaanvraag_afgerond = $vogaanvraag_activity_afgerond;
			}

			if (in_array($new_ditpart_vognodig, array('eerstex','opnieuw','elkjaar','inhaal'))) {

				if (date_bigger($part_vogingediend, $ditevent_fiscalyear_start) == 1) {

					if ($vogverzocht_infiscalyear_ditevent  == 1)	{
						$new_ditpart_vogstatus 			= 'verzocht';
						$ditjaar_vogaanvraag_actstatus	= 'Available';
						wachthond($extdebug,2, 	"STATUS VOG_AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Available", 
												"[WANT part_vogverzocht: $part_vogingediend IN EVENT_FISCAL_YEAR]");
					}
					if ($vogingediend_infiscalyear_ditevent == 1) 	{
						$new_ditpart_vogstatus 			= 'ingediend';
						$ditjaar_vogaanvraag_actstatus	= 'Completed';
						wachthond($extdebug,2, 	"STATUS VOG_AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Completed", 
												"[WANT part_vogingediend: $part_vogingediend IN EVENT_FISCAL_YEAR]");
					}
					if ($vogontvangst_infiscalyear_ditevent == 1) 	{
						$new_ditpart_vogstatus 			= 'ontvangen';
						$ditjaar_vogaanvraag_actstatus	= 'Completed';
						wachthond($extdebug,2, 	"STATUS VOG_AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Completed",
												"[WANT part_vogontvangst: $part_vogontvangst IN EVENT_FISCAL_YEAR]");
					}
					if ($partvogdatum_infiscalyear_ditevent == 1) 	{
						$new_ditpart_vogstatus 			= 'ontvangen';
						$ditjaar_vogaanvraag_actstatus	= 'Completed';						 
						wachthond($extdebug,2, 	"STATUS VOG AANVRAAG VAN $ditjaar_vogaanvraag_actstatus NAAR Completed",
												"[WANT part_vogdatum: $part_vogdatum IN EVENT_FISCAL_YEAR]");
					}

				} elseif (empty($part_vogverzocht))					{
						$new_ditpart_vogstatus 	= 'klaarzetten';
				}

			} elseif ($new_ditpart_vognodig == 'noggoed' AND $vogrecent) {
						$new_ditpart_vogstatus 			= 'noggoed';
						$ditjaar_vogaanvraag_actstatus	= 'Not Required';
			}

			wachthond($extdebug,2, "2 new_ditpart_vogstatus", 			$new_ditpart_vogstatus);
			wachthond($extdebug,2, "2 new_ditjaar_vogstatus", 			$new_ditjaar_vogstatus);
			wachthond($extdebug,2, "2 ditjaar_vogaanvraag_actstatus", 	$ditjaar_vogaanvraag_actstatus);
			wachthond($extdebug,2, "2 ditjaar_vogaanvraag_actprio",		$ditjaar_vogaanvraag_actprio);

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.4 b COPY VOGSTATUS DITEVENT > DITJAAR INDIEN EVENT DITJAAR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {

				wachthond($extdebug,2, 	"VOGSTATUS ($new_ditjaar_vogstatus) UIT DITEVENT GEKOPIEERD NAAR DITJAAR", "[WANT EVENT IS IN DITJAAR]");

				$new_ditjaar_vogstatus = $new_ditpart_vogstatus;

			} else {

				wachthond($extdebug,2, 'ditjaareventleidyes', 	$ditjaareventleidyes);
				wachthond($extdebug,2, 'ditjaareventleidstf', 	$ditjaareventleidstf);

				wachthond($extdebug,2, 	"VOGSTATUS UIT DITEVENT NIET KOPIEREN NAAR DITJAAR WANT EVENT =! DITJAAR");
			}

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.5 a BEPAAL NEW STATUS ACTIVITEIT VOG ONTVANGST VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			$ditjaar_vogontvangst_actstatus		= 'Available';	// DEFAULT TO AVAILABLE (CONCEPT)
			$ditjaar_vogontvangst_actprio 		= 'Normaal';	// DEFAULT TO NORMAL

			$vogontvangst_infiscalyear_ditevent = infiscalyear($part_vogontvangst, 	$ditevent_event_start, 'vogontvangst', 	'ditevent')	?? 0;
			$vogdatum_infiscalyear_ditevent 	= infiscalyear($part_vogdatum, 		$ditevent_event_start, 'vogdatum', 		'ditevent')	?? 0;

			wachthond($extdebug,2, "- new_ditpart_vognodig", 				$new_ditpart_vognodig);
			wachthond($extdebug,2, "- new_ditjaar_vognodig", 				$new_ditjaar_vognodig);

			wachthond($extdebug,2, "- ditjaar_vogontvangst_actstatus", 		$ditjaar_vogontvangst_actstatus);
			wachthond($extdebug,3, "- vogontvangst_infiscalyear_ditevent", 	"$vogontvangst_infiscalyear_ditevent [part_vogontvangst: $part_vogontvangst]");
			wachthond($extdebug,3, "- vogdatum_infiscalyear_ditevent", 		"$vogdatum_infiscalyear_ditevent [part_vogdatum: $part_vogdatum]");

			wachthond($extdebug,4, "1 new_ditpart_vogstatus", 				$new_ditpart_vogstatus);
			wachthond($extdebug,4, "1 new_ditjaar_vogstatus", 				$new_ditjaar_vogstatus);
			wachthond($extdebug,4, "1 part_vogontvangst", 					$part_vogontvangst);
			wachthond($extdebug,4, "1 ditevent_part_vogdatum", 				$ditevent_part_vogdatum);

			if (in_array($new_ditjaar_vognodig, array("noggoed"))) {

				$ditjaar_vogontvangst_actstatus 	= 'Not Required';

			} elseif ($part_vogingediend) {

				$diffsince_vogaanvraag 	= NULL;
				$dayssince_vogaanvraag 	= NULL;
				$diffsince_vogaanvraag	= date_diff(date_create($part_vogingediend),date_create($today_datetime));
				$dayssince_vogaanvraag	= $diffsince_vogaanvraag->format('%a');					
				wachthond($extdebug,3, "- dayssince_vogaanvraag", 	$dayssince_vogaanvraag);

				if ($dayssince_vogaanvraag >= 0  AND $dayssince_vogaanvraag < 21)		{ $ditjaar_vogontvangst_actstatus = "Pending"; 	 	} // AFWACHTING
				if ($dayssince_vogaanvraag >= 21 AND $dayssince_vogaanvraag < 35)		{ $ditjaar_vogontvangst_actstatus = "Left Message"; } // HERINNERD
				if ($dayssince_vogaanvraag >= 35)										{ $ditjaar_vogontvangst_actstatus = "Unreachable";  } // ONBEREIKBAAR
				if ($dayssince_vogaanvraag >= 270)										{ $ditjaar_vogontvangst_actstatus = "Bounced"; 	 	} // GEFAALD/GEBOUNCED

				if (date_bigger($today_datetime, $ditevent_event_einde) == 1 AND $ditjaar_vogontvangst_actstatus != "Completed") {
// 					$ditjaar_vogontvangst_actstatus = "Failed";
 					wachthond($extdebug,2, "activity vogaanvraag > status failed want event inmiddels voorbij");				
				}

				// if ($dayssince_vogverzoek  >= 21 AND $ditjaar_vogontvangst_actstatus == "Pending") { $ditjaar_vogontvangst_actstatus = "Left Message"; }
				// Als aanvraag Unreachable of Bounced is -> schedule dan alsnog een reminder rond geplande ontvangstdatum
				
				// Maak status Activiteit ONTVANGST = Available als status AANVRAAG nog niet Completed is (civirules proof?)				
				// LET OP: DE VOLGENDE 1 REGEL NOG EVEN HEEL ERG GOED DUBBELCHECKEN!!!
				if ($ditjaar_vogaanvraag_actstatus != "Completed")	{
					$ditjaar_vogontvangst_actstatus = "Available";
				} 

				// als part_vogdatum binnen huidige fiscal year valt kan activity op completed
				// LET OP: DE VOLGENDE 1 REGEL NOG EVEN HEEL ERG GOED DUBBELCHECKEN!!!
//				if (infiscalyear($part_vogdatum,$ditevent_event_start,'part_vogdatum','ditevent') == 1) {
				if ($vogdatum_infiscalyear_ditevent == 1) {
					$ditjaar_vogontvangst_actstatus = "Completed";
					$new_ditpart_vogstatus 			= 'ontvangen';
 					wachthond($extdebug,2, "PRIMA! part_vogdatum binnen fiscal year van dit event", "DUS: activity vogontvangst > status Completed");
				}

				if ($ditjaar_vogontvangst_actstatus == "Pending")			{	$ditjaar_vogontvangst_actprio = 'Laag';		}	// AFWACHTING
				if ($ditjaar_vogontvangst_actstatus == "Left Message")		{	$ditjaar_vogontvangst_actprio = 'Normaal';	} 	// HERINNERD
				if ($ditjaar_vogontvangst_actstatus == "Unreachable")		{	$ditjaar_vogontvangst_actprio = 'Urgent';	} 	// ONBEREIKBAAR
				if ($ditjaar_vogontvangst_actstatus == "No_show")			{	$ditjaar_vogontvangst_actprio = 'Urgent';	} 	// VERLOPEN			
				if ($ditjaar_vogontvangst_actstatus == "Bounced")			{	$ditjaar_vogontvangst_actprio = 'Urgent';	} 	// GEFAALD/GEBOUNCED
			}

			wachthond($extdebug,2, "2 new_ditpart_vogstatus", 			$new_ditpart_vogstatus);
			wachthond($extdebug,2, "2 new_ditjaar_vogstatus", 			$new_ditjaar_vogstatus);
			wachthond($extdebug,2, "2 ditjaar_vogontvangst_actstatus", 	$ditjaar_vogontvangst_actstatus);
			wachthond($extdebug,2, "2 ditjaar_vogontvangst_actprio",	$ditjaar_vogontvangst_actprio);

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.5 b COPY VOGSTATUS DITEVENT > DITJAAR INDIEN EVENT DITJAAR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {

				wachthond($extdebug,2, 	"VOGSTATUS ($new_ditjaar_vogstatus) UIT DITEVENT GEKOPIEERD NAAR DITJAAR", "[WANT EVENT IS IN DITJAAR]");

				$new_ditjaar_vogstatus = $new_ditpart_vogstatus;

			}

		} else {

			wachthond($extdebug,1, 'ditjaarleidyes',		$ditjaarleidyes);
			wachthond($extdebug,1, 'ditjaareventleidyes',	$ditjaareventleidyes);
			wachthond($extdebug,1, "14.X SKIPPED BEPAAL NIEUWE STATUS ONDERDELEN INTAKE [VOG]");
		}

		if ($extref == 1 AND $extvog == 1 AND $extact == 1 AND $ditjaareventleidyes == 1) {	

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.6 BEPAAL DE STATUS VAN INT / REF / VOG VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			$intakestatusinttodo 	= 0;
			$intakestatusnawtodo 	= 0;
			$intakestatusbiotodo 	= 0;
			$intakestatusreftodo 	= 0;
			$intakestatusvogtodo 	= 0;

			$intakestatusintdone 	= 0;
			$intakestatusnawdone 	= 0;
			$intakestatusbiodone 	= 0;
			$intakestatusrefdone 	= 0;
			$intakestatusvogdone 	= 0;

			$intakeintnodig			= 0;
			$intakenawnodig			= 0;
			$intakebionodig			= 0;
			$intakerefnodig			= 0;
			$intakevognodig			= 0;

			wachthond($extdebug,3, "new_ditjaar_intstatus",	$new_ditjaar_intstatus);
//			wachthond($extdebug,3, "new_ditjaar_nawstatus",	$new_ditjaar_nawstatus);
//			wachthond($extdebug,3, "new_ditjaar_biostatus",	$new_ditjaar_biostatus);
			wachthond($extdebug,3, "new_ditjaar_refstatus",	$new_ditjaar_refstatus);
			wachthond($extdebug,3, "new_ditjaar_vogstatus",	$new_ditjaar_vogstatus);

			if (in_array($new_ditjaar_nawnodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakenawnodig	= 1; }
			if (in_array($new_ditjaar_bionodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakebionodig	= 1; }
			if (in_array($new_ditjaar_refnodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakerefnodig = 1; }
			if (in_array($new_ditjaar_vognodig,array("eerstex","elkjaar","opnieuw","inhaal"))) 	{	$intakevognodig	= 1; }

			wachthond($extdebug,3, "################################################");

			if (in_array($new_ditjaar_nawnodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				!in_array($new_ditjaar_nawstatus, array("noggoed", "bijgewerkt"))) 			{
				$intakestatusnawtodo	= 1;
			}
			if (in_array($new_ditjaar_bionodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				!in_array($new_ditjaar_biostatus, array("noggoed", "bijgewerkt"))) 			{
				$intakestatusbiotodo	= 1;
			}
			if (in_array($new_ditjaar_refnodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND 
				!in_array($new_ditjaar_refstatus, array("noggoed", "vragen", "ontvangen"))) {
				$intakestatusreftodo	= 1;
			}
			if (in_array($new_ditjaar_vognodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				!in_array($new_ditjaar_vogstatus, array("noggoed", "ontvangen"))) 			{
				$intakestatusvogtodo	= 1;
			}

			wachthond($extdebug,3, "intakestatusnawtodo",	$intakestatusnawtodo);
			wachthond($extdebug,3, "intakestatusbiotodo",	$intakestatusbiotodo);
			wachthond($extdebug,3, "intakestatusreftodo",	$intakestatusreftodo);
			wachthond($extdebug,3, "intakestatusvogtodo",	$intakestatusvogtodo);

			wachthond($extdebug,3, "################################################");

			if (in_array($new_ditjaar_nawnodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($new_ditjaar_nawstatus, array("noggoed", "bijgewerkt"))) 				{
				$intakestatusnawdone	= 1;
			}
			if (in_array($new_ditjaar_bionodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($new_ditjaar_biostatus, array("noggoed", "bijgewerkt"))) 				{
				$intakestatusbiodone	= 1;
			}
			if (in_array($new_ditjaar_refnodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND 
				in_array($new_ditjaar_refstatus, array("noggoed", "vragen", "ontvangen"))) 		{		// M61: wat te doen met status: bekend
				$intakestatusrefdone	= 1;
			}
			if (in_array($new_ditjaar_vognodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($new_ditjaar_vogstatus, array("noggoed", "ontvangen"))) 					{	// M61: wat te doen met status: ingediend
				$intakestatusvogdone	= 1;
			}

			wachthond($extdebug,3, "intakestatusnawdone",	$intakestatusnawdone);
			wachthond($extdebug,3, "intakestatusbiodone",	$intakestatusbiodone);
			wachthond($extdebug,3, "intakestatusrefdone",	$intakestatusrefdone);
			wachthond($extdebug,3, "intakestatusvogdone",	$intakestatusvogdone);

			wachthond($extdebug,3, "################################################");

			$intakestatusnodig 	= $intakebionodig  		+ $intakebionodig 		+ $intakerefnodig 		+ $intakevognodig;
			$intakestatustodo 	= $intakestatusnawtodo	+ $intakestatusbiotodo 	+ $intakestatusreftodo 	+ $intakestatusvogtodo;
			$intakestatusdone 	= $intakestatusnawdone	+ $intakestatusbiodone 	+ $intakestatusrefdone 	+ $intakestatusvogdone;

			wachthond($extdebug,3, "intakestatusnodig",		$intakestatusnodig);
			wachthond($extdebug,3, "intakestatustodo",		$intakestatustodo);
			wachthond($extdebug,3, "intakestatusrefdone",	$intakestatusrefdone);

			wachthond($extdebug,3, "################################################");

			##########################################################################################################
			// BEPAAL DE NIEUWE WAARDE VAN INT STATUS
			##########################################################################################################

			if (in_array($new_ditjaar_intnodig,array("eerstex","elkjaar","opnieuw","inhaal"))) {

				if ($intakestatustodo < $intakestatusnodig AND $intakestatustodo > 0) {
					$new_ditjaar_intstatus  	= 'gedeeltelijk';
				}
				if ($intakestatusdone == 0 AND in_array($new_ditjaar_vogstatus, array("verzocht"))) {
					$new_ditjaar_intstatus  	= 'nognix';
				}
//				if ($intakestatusdone == $intakestatusnodig) {
//					$new_ditjaar_intstatus  	= 'compleet';
//				}
				if ($intakestatusdone == $intakestatusnodig AND in_array($new_ditjaar_refstatus, array("gevraagd"))) {
					$new_ditjaar_intstatus  	= 'afwachting';
				}
				if (in_array($new_ditjaar_vogstatus, array("klaarzetten"))) {
					$new_ditjaar_intstatus  	= 'klaarzetten';
				}

			} elseif (in_array($new_ditjaar_intnodig,array("noggoed"))) {
					$new_ditjaar_intstatus  	= 'compleet';			
			} else  {
					$new_ditjaar_intstatus  	= 'onbekend';
			}

			wachthond($extdebug,2, "new_ditjaar_intstatus", $new_ditjaar_intstatus);

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 14.7 UPDATE PARAMS STATUS VAN INT / NAW / BIO VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,2, "########################################################################");

			if ($ditjaarleidyes == 1 OR $ditjaardeelyes OR $ditjaardeeltop == 1 OR ($ditjaarleidstf == 1 AND $ditjaarleidstf == 1)) {

				if ($new_ditjaar_intstatus)	{ $params_contact['values']['INTAKE.INT_status'] 	= $new_ditjaar_intstatus; }
				if ($new_ditjaar_nawstatus)	{ $params_contact['values']['INTAKE.NAW_status'] 	= $new_ditjaar_nawstatus; }
				if ($new_ditjaar_biostatus)	{ $params_contact['values']['INTAKE.BIO_status'] 	= $new_ditjaar_biostatus; }	

				wachthond($extdebug,4, "new_ditjaar_intstatus",		$new_ditjaar_intstatus);
				wachthond($extdebug,2, "new_ditjaar_nawstatus",		$new_ditjaar_nawstatus);
				wachthond($extdebug,2, "new_ditjaar_biostatus",		$new_ditjaar_biostatus);

				wachthond($extdebug,1, 'PERFORM UPDATE CONT STATUS INTAKE (NAW/BIO)', "[ditjaardeeltop: $ditjaardeeltop]");

			}

			if (($diteventleidyes == 1 AND $ditjaarleidyes == 1) OR ($ditjaarleidstf == 1 AND $ditjaarleidstf == 1)) {

				if ($new_ditjaar_intstatus)	{ $params_contact['values']['INTAKE.INT_status'] 	= $new_ditjaar_intstatus; }
				if ($new_ditjaar_refstatus)	{ $params_contact['values']['INTAKE.REF_status'] 	= $new_ditjaar_refstatus; }
				if ($new_ditjaar_vogstatus)	{ $params_contact['values']['INTAKE.VOG_status'] 	= $new_ditjaar_vogstatus; }

				wachthond($extdebug,4, "new_ditjaar_intstatus",		$new_ditjaar_intstatus);
				wachthond($extdebug,2, "new_ditjaar_refstatus",		$new_ditjaar_refstatus);
				wachthond($extdebug,2, "new_ditjaar_vogstatus",		$new_ditjaar_vogstatus);

				wachthond($extdebug,1, 'PERFORM UPDATE CONT STATUS INTAKE (REF/VOG)', "[ditjaarleidyes: $ditjaarleidyes]");

			}

			##########################################################################################################
			// INDIEN DITEVENT & TEVENS PARTEVENT: TREK CONT STATUS EN PART STATUS GELIJK
			##########################################################################################################
/*
			if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {

				$new_ditpart_intstatus = $new_ditjaar_intstatus;
				$new_ditpart_nawstatus = $ditjaar_nawtatus;				
				$new_ditpart_biostatus = $new_ditjaar_biostatus;
				$new_ditpart_refstatus = $new_ditjaar_refstatus;
				$new_ditpart_vogstatus = $new_ditjaar_vogstatus;

				wachthond($extdebug,2, "new_ditpart_intstatus",		$new_ditpart_intstatus);
				wachthond($extdebug,2, "new_ditpart_nawstatus",		$new_ditpart_nawstatus);
				wachthond($extdebug,2, "new_ditpart_biostatus",		$new_ditpart_biostatus);
				wachthond($extdebug,2, "new_ditpart_refstatus",		$new_ditpart_refstatus);
				wachthond($extdebug,2, "new_ditpart_vogstatus",		$new_ditpart_vogstatus);

			}
*/
			if ($diteventleidyes == 1 OR $diteventleidstf == 1) {

				if ($new_ditpart_intstatus)	{ $params_part_ditevent['values']['PART_LEID_INTERN.INT_status'] = $new_ditpart_intstatus; }
				if ($new_ditpart_nawstatus)	{ $params_part_ditevent['values']['PART_LEID_INTERN.NAW_status'] = $new_ditpart_nawstatus; }
				if ($new_ditpart_biostatus)	{ $params_part_ditevent['values']['PART_LEID_INTERN.BIO_status'] = $new_ditpart_biostatus; }	
				if ($new_ditpart_refstatus)	{ $params_part_ditevent['values']['PART_LEID_INTERN.REF_status'] = $new_ditpart_refstatus; }
				if ($new_ditpart_vogstatus)	{ $params_part_ditevent['values']['PART_LEID_INTERN.VOG_status'] = $new_ditpart_vogstatus; }

				wachthond($extdebug,2, "new_ditpart_intstatus",		$new_ditpart_intstatus);
				wachthond($extdebug,2, "new_ditpart_nawstatus",		$new_ditpart_nawstatus);
				wachthond($extdebug,2, "new_ditpart_biostatus",		$new_ditpart_biostatus);
				wachthond($extdebug,2, "new_ditpart_refstatus",		$new_ditpart_refstatus);
				wachthond($extdebug,2, "new_ditpart_vogstatus",		$new_ditpart_vogstatus);

				wachthond($extdebug,1, 'PERFORM UPDATE PART STATUS INTAKE (REF/VOG)', "[diteventleidyes: $diteventleidyes]");
			}

		} else {
			wachthond($extdebug,1, "extref",				$extref);
			wachthond($extdebug,1, "extvog",				$extvog);
			wachthond($extdebug,1, 'ditjaareventleidyes',	$ditjaareventleidyes);
			wachthond($extdebug,1, "14.5 SKIPPED BEPAAL DE STATUS VAN INT / REF / VOG");
		}

		if ($extref == 1 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND ($ditjaareventleidyes == 1 OR $ditjaarleidstf == 1)) { // PROFILE PARTICIPANT LEID MAX

			wachthond($extdebug,1, "########################################################################");
			wachthond($extdebug,1, "### 15.X UPDATE ACTIVITIES REF & VOG VOOR $displayname", "[groupID: $groupID] [op: $op]");

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 15.1 UPDATE ACTIVITY REF PERSOON VOOR $displayname");
			wachthond($extdebug,2, "########################################################################");

			if ($refpersoon_activity_id AND $ditjaar_refpersoon_actstatus) {

				$params_activity_refpersoon_update = [
					'checkPermissions' => FALSE,
					'debug' => $apidebug,
  					'where' => [
						['id', 							   '=',$refpersoon_activity_id],
					],
					'values' => [

						'activity_date_time' 				=> $ditjaar_refpersoon_actdatetime,
						'status_id:name' 					=> $ditjaar_refpersoon_actstatus,
						'subject'							=> 'REF persoon gevraagd',

						'ACT_REF.REF_nodig' 				=> $new_ditjaar_refnodig,

						'ACT_REF.aanvrager_naam'			=> $displayname,
						'ACT_REF.aanvrager_functie'			=> $ditevent_part_functie,
						'ACT_REF.aanvrager_partid'			=> $ditevent_part_id,
						'ACT_REF.aanvrager_cid'				=> $contact_id,

						'ACT_REF.rel_id'					=> $referentie_relid,
						'ACT_REF.referentie_cid'			=> $referentie_cid,
						'ACT_REF.referentie_naam'			=> $referentie_name,
						'ACT_REF.referentie_voornaam'		=> $referentie_fn,
						'ACT_REF.referentie_telefoon'		=> $referentie_phone,

		   				'ACT_ALG.actcontact_naam'			=> $displayname,
		   				'ACT_ALG.actcontact_cid'			=> $contact_id,
		   				'ACT_ALG.actcontact_pid'			=> $ditevent_part_id,
		   				'ACT_ALG.actcontact_eid'			=> $ditevent_part_eventid,

	   					'ACT_ALG.kampnaam'					=> $eventkamp_event_kampkort_cap,
		   				'ACT_ALG.kampkort'					=> $eventkamp_event_kampkort_low,
						'ACT_ALG.kampfunctie' 				=> $ditevent_part_functie,
						'ACT_ALG.kampstart' 				=> $eventkamp_event_start,
						'ACT_ALG.kampeinde' 				=> $eventkamp_event_einde,
						'ACT_ALG.kampjaar'					=> $eventkamp_kampjaar,

						'ACT_ALG.modified' 					=> $today_datetime,
		  				'ACT_ALG.activity_id'				=> $refpersoon_activity_id,
		    			'ACT_ALG.prioriteit:label'			=> $ditjaar_refpersoon_actprio,
					],
				];

				#if ($vogverzoekditjaar == 1) { // M61 indien VOG verzoek trek deze datum REF persoon dan gelijk (= vog verzoek + 30 dagen)
				#	$params_activity_refpersoon_update['values']['activity_date_time'] = $datum_vogaanvraag;
				#}

				wachthond($extdebug,7, 'params_activity_refpersoon_update', 				$params_activity_refpersoon_update);
				if ($extref == 1)	{
					$result_activity_refpersoon_update = civicrm_api4('Activity', 'update', $params_activity_refpersoon_update);
					wachthond($extdebug,1, 'params_activity_refpersoon_update', "EXECUTED");
					wachthond($extdebug,9, 'result_activity_refpersoon_update', 			$result_activity_refpersoon_update);
				}

			} else {
				wachthond($extdebug,4, "refpersoon_activity_id",		$refpersoon_activity_id);
				wachthond($extdebug,4, "part_refpersoon",				$part_refpersoon);
				wachthond($extdebug,4, "ditjaar_refpersoon_actstatus",	$ditjaar_refpersoon_actstatus);
				wachthond($extdebug,1, 'activity_refpersoon_update', "SKIPPED");
			}

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 15.2 UPDATE ACTIVITY REF VERZOEK VOOR $displayname");
			wachthond($extdebug,2, "########################################################################");

			if ($refverzoek_activity_id AND $ditjaar_refverzoek_actstatus) {

				$params_activity_refverzoek_update = [
					'checkPermissions' => FALSE,
					'debug' => $apidebug,
  					'where' => [
						['id', 							   '=',$refverzoek_activity_id],
						],
					'values' => [

						'activity_date_time' 				=> $ditjaar_refverzoek_actdatetime,
						'status_id:name' 					=> $ditjaar_refverzoek_actstatus,
						'subject'							=> 'REF feedback verzocht',

						'ACT_REF.REF_nodig' 				=> $new_ditjaar_refnodig,

						'ACT_REF.aanvrager_naam'			=> $displayname,
						'ACT_REF.aanvrager_functie'			=> $ditevent_part_functie,
						'ACT_REF.aanvrager_partid'			=> $ditevent_part_id,
						'ACT_REF.aanvrager_cid'				=> $contact_id,

						'ACT_REF.rel_id'					=> $referentie_relid,
						'ACT_REF.referentie_cid'			=> $referentie_cid,
						'ACT_REF.referentie_naam'			=> $referentie_name,
						'ACT_REF.referentie_voornaam'		=> $referentie_fn,
						'ACT_REF.referentie_telefoon'		=> $referentie_phone,

		   				'ACT_ALG.actcontact_naam'			=> $displayname,
		   				'ACT_ALG.actcontact_cid'			=> $contact_id,
		   				'ACT_ALG.actcontact_pid'			=> $ditevent_part_id,
		   				'ACT_ALG.actcontact_eid'			=> $ditevent_part_eventid,

	   					'ACT_ALG.kampnaam'					=> $eventkamp_event_kampkort_cap,
		   				'ACT_ALG.kampkort'					=> $eventkamp_event_kampkort_low,
						'ACT_ALG.kampfunctie' 				=> $ditevent_part_functie,
						'ACT_ALG.kampstart' 				=> $eventkamp_event_start,
						'ACT_ALG.kampeinde' 				=> $eventkamp_event_einde,
						'ACT_ALG.kampjaar'					=> $eventkamp_kampjaar,

						'ACT_ALG.modified' 					=> $today_datetime,
		  				'ACT_ALG.activity_id'				=> $refverzoek_activity_id,
		    			'ACT_ALG.prioriteit:label'			=> $ditjaar_refverzoek_actprio,
