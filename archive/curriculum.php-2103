		$bioingevuld				= $result_contact[0]['INTAKE.BIO_ingevuld'] 			?? NULL;
		$org_ditjaar_biogecheckt				= $result_contact[0]['INTAKE.BIO_gecheckt'] 			?? NULL;

		$org_ditjaar_nawgecheckt 	= $ditjaar_nawgecheckt;	// ZET DE NIEUWE PARAMETERS INITIEEL MET WAARDE VAN DE OUDE
		$new_ditjaar_nawgecheckt 	= $ditjaar_nawgecheckt;	// ZET DE NIEUWE PARAMETERS INITIEEL MET WAARDE VAN DE OUDE

		$new_bioingevuld 			= $bioingevuld;	// ZET DE NIEUWE PARAMETERS INITIEEL MET WAARDE VAN DE OUDE

		$org_ditjaar_biogecheckt 	= $ditjaar_biogecheckt;	// ZET DE NIEUWE PARAMETERS INITIEEL MET WAARDE VAN DE OUDE
		$new_ditjaar_biogecheckt 	= $ditjaar_biogecheckt;	// ZET DE NIEUWE PARAMETERS INITIEEL MET WAARDE VAN DE OUDE

		$werving_mee_komendkamp	= $result_contact[0]['WERVING.mee_komendkampjaar'] 		?? NULL;
		$werving_mee_verwachting= $result_contact[0]['WERVING.mee_verwachting'] 		?? NULL;
		$werving_mee_toelichting= $result_contact[0]['WERVING.mee_toelichting'] 		?? NULL;
		$werving_mee_update		= $result_contact[0]['WERVING.mee_update'] 				?? NULL;
		$werving_mee_update_year= date('Y', strtotime($werving_mee_update));
		$werving_mee_notities	= $result_contact[0]['WERVING.mee_notities'] 			?? NULL;

		$laatstekeer			= $result_contact[0]['Curriculum.Laatste_keer'] 		?? NULL; 	// M61: hier tbv berekenen jaar van 'mee komend jaar'		
		$curcv_deel_array	 	= $result_contact[0]['Curriculum.CV_Deel'] 				?? NULL;	// welke jaren deel
		$curcv_leid_array	 	= $result_contact[0]['Curriculum.CV_Leid'] 				?? NULL;	// welke jaren leid	
		$oldcv_deel_array	 	= $result_contact[0]['Curriculum.Welke_jaren_mee_als_deelnemer_'] 				?? NULL;	// welke jaren deel OUD
		$oldcv_leid_array	 	= $result_contact[0]['Curriculum.Welke_jaren_ben_je_als_leiding_meegeweest_'] 	?? NULL;	// welke jaren leid OUD
		$curcv_keer_deel		= $result_contact[0]['Curriculum.Keren_Deel'] 			?? NULL;	// keren deel
		$curcv_keer_leid		= $result_contact[0]['Curriculum.Keren_Leid'] 			?? NULL;	// keren leid

 		wachthond($extdebug,1, 'entityID', 			$entityID);
 		wachthond($extdebug,1, 'contact_id', 		$contact_id);
 		wachthond($extdebug,1, 'birth_date', 		$birth_date);
		wachthond($extdebug,1, 'first_name', 		$first_name);
		wachthond($extdebug,1, 'middle_name', 		$middle_name);
		wachthond($extdebug,1, 'last_name', 		$last_name);
		wachthond($extdebug,1, 'nick_name', 		$nick_name);
		wachthond($extdebug,1, 'displayname', 		$displayname);
		wachthond($extdebug,1, 'crm_drupalnaam',	$crm_drupalnaam);
		wachthond($extdebug,1, 'crm_externalid',	$crm_externalid);

		$privacy_voorkeuren		= $result_contact[0]['PRIVACY.Contactvoorkeuren'] 			?? NULL;	// bv. Verwijder contactgegevens
		$privacy_geheimadres	= $result_contact[0]['PRIVACY.Geheim_adres'] 				?? NULL;	// bv. Ja / Nee
		$privacy_beeldgebruik	= $result_contact[0]['PRIVACY.Toestemming_beeldgebruik'] 	?? NULL;	// Ik geef toestemming voor kampfotos

 		wachthond($extdebug,1, 'privacy', 			$privacy_voorkeuren);
 		wachthond($extdebug,1, 'geheimadres', 		$privacy_geheimadres);
 		wachthond($extdebug,1, 'beeldgebruik', 		$privacy_beeldgebruik);

		$cont_notificatie_deel	= $result_contact[0]['INTAKE.notificatie_deel'] ?? NULL;
		$cont_notificatie_leid	= $result_contact[0]['INTAKE.notificatie_leid'] ?? NULL;
		$cont_notificatie_kamp	= $result_contact[0]['INTAKE.notificatie_kamp'] ?? NULL;
		$cont_notificatie_staf	= $result_contact[0]['INTAKE.notificatie_staf'] ?? NULL;
		
		##################################################################################################
		# LET OP !!!! $contact_id hoort niet leeg te zijn
		##################################################################################################

		if (empty($contact_id)) {
			wachthond($extdebug,1, "ERROR  : CONTACT INFO LEEG > RETURN", "ERROR");
			return; //    if not, get out of here
		}

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "### 1.4 PREPARE PARAMS FOR DB UPDATE", "$displayname]");
		wachthond($extdebug,3, "########################################################################");

		if ($ditjaar_pos_part_id >= 0 AND $result_partditjaar_all_count == 1) {

//			wachthond($extdebug,1, 	"### EVENT DITJAAR  (obv uniek event dit jaar) ###", "[groupID: $groupID]");
			wachthond($extdebug,1, 	"DITJAAR eventid: $ditjaar_pos_event_eventid partid: $ditjaar_pos_part_id", 	
									"$ditjaar_pos_event_title ($ditjaar_pos_part_rol $ditjaar_pos_leid_welkkamp)");

			if ($ditjaar_pos_leid_welkkamp) {
//		 		wachthond($extdebug,3, 'ditjaar_all_leid_welkkamp',	$ditjaar_pos_leid_welkkamp);
//	 			wachthond($extdebug,3, 'ditjaar_all_functie', 		$ditjaar_pos_leid_functie);
	 		}
		}

		if ($ditevent_part_id > 0 AND $result_partditevent_count == 1) {

			wachthond($extdebug,3, 	"########################################################################");		
			wachthond($extdebug,1, 	"DITEVENT eventid: $ditevent_part_eventid partid: $ditevent_part_id",
									"$ditevent_event_title ($ditevent_part_rol $ditevent_leid_welkkamp)");

			if ($ditevent_leid_welkkamp) {
//		 		wachthond($extdebug,3, 'ditevent_leid_welkkamp', 	$ditevent_leid_welkkamp);
//	 			wachthond($extdebug,3, 'ditevent_part_functie', 	$ditevent_leid_functie);
	 		}
		}

		$params_contact = [
			#'reload' 			=> TRUE,
			'checkPermissions' 	=> FALSE,
			'debug' => $apidebug,
  			'where' => [
				['id', 		   '=', $contact_id],
			],
			'values' => [
				'id' 			=> $contact_id,
				'first_name'	=> $first_name,
				'middle_name'	=> $middle_name,
				'last_name'		=> $last_name,
				'display_name'	=> $displayname,			
			],
		];

		$params_part_ditevent = [
			#'reload' 			=> TRUE,
			'checkPermissions' 	=> FALSE,
			'debug' 			=> $apidebug,
  			'where' => [
				['id', 	'=', $ditevent_part_id],
			],
			'values' => [
				'id' 	=> 	 $ditevent_part_id,
			],
		];

		$params_part_ditjaar = [
			#'reload' 			=> TRUE,
			'checkPermissions' 	=> FALSE,
			'debug' 			=> $apidebug,
  			'where' => [
				['id', 	'=', $ditjaar_pos_part_id],
			],
			'values' => [
				'id' 	=> 	 $ditjaar_pos_part_id,
			],
		];

/*
		##################################################################################################
		# 1.5 RETRIEVE EVENT TYPE ID OF THE EVENT (M61: waarom staat dit er eigenlijk in?) 
		# > als input voor volgende event retreive
		# IGV LEIDING DAN ZAL EVENT_TYPE_ID 1 ZIJN & EVENT_ID DAT VAN LEIDING EVENT (EN KAN JUISTE START & EINDE V/H KAMP GEVONDEN WORDEN)
		##################################################################################################

		if ($ditevent_part_eventid) {

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 1.5 RETRIEVE THE EVENT TYPE ID OF THE EVENT", "[ditevent_part_eventid: $ditevent_part_eventid]");
			wachthond($extdebug,3, "########################################################################");		

				$params_event = [
  					'checkPermissions' 	=> FALSE,
					'debug' 			=> $apidebug,
  					'select' => [
    					'id', 'event_type_id', 'start_date', 'end_date',
  					],
  					'where' => [
    					['id', '=', $ditevent_part_eventid],
  					],
				];
				wachthond($extdebug,7, 'params_event', 			$params_event);
				$result_event = civicrm_api4('Event', 'get', 	$params_event);
				wachthond($extdebug,9, 'result_event', 			$result_event);

//    			$part_eventtypeid 	= $result_event[0]['event_type_id'] ?? NULL;

				wachthond($extdebug,3, 'ditevent_part_eventid', 	$ditevent_event_eventid);
				wachthond($extdebug,3, 'ditevent_event_type_id', 	$ditevent_event_type_id);
    	}
*/
		##################################################################################################
		### LAST EVENT BEFORE TODAY
		##################################################################################################
		# DIT STAAT NU EVEN RANDOM HIER OMDAT HET NA RETREIVE EVENT_ID MOET EN VOOR LEEFTIJD DEEL

		if ($ditevent_event_type_id) {
			$current_event_type = $ditevent_event_type_id;
		} else {
			$current_event_type = 1;
		}

		wachthond($extdebug,4, 'today_datetime_past', 	$today_datetime_past);
		wachthond($extdebug,4, 'today_datetime', 		$today_datetime);
		wachthond($extdebug,4, 'today_datetime_next', 	$today_datetime_next);

		$params_lastkampfromtoday = [
			'checkPermissions' => FALSE,
			'debug' 	=> $apidebug,
			'limit' 	=> 1,
				'select' 	=> [
					'title', 
					'end_date',
				],
				'where' => [
					['end_date', 		'>', $today_datetime_past], 
					['end_date', 		'<', $today_datetime],
	   				['event_type_id', 	'=', $current_event_type],
				],
		];
//		wachthond($extdebug,7, 'params_lastkampfromtoday', 			$params_lastkampfromtoday);
		$result_lastkampfromtoday = civicrm_api4('Event', 'get', 	$params_lastkampfromtoday);
//		wachthond($extdebug,9, 'result_lastkampfromtoday', 			$result_lastkampfromtoday);

  		$last_event_einde_date 	= $result_lastkampfromtoday[0]['end_date'] ?? NULL;
  		$last_event_einde_year 	= date('Y', strtotime($last_event_einde_date));

		wachthond($extdebug,3, 'last_event_start_date', 	$last_event_einde_date);
		wachthond($extdebug,3, 'last_event_start_year', 	$last_event_einde_year);

		##################################################################################################
		### NEXT EVENT FROM TODAY
		##################################################################################################

		// ALS DEFAULT CALCULATE NEXT AUGUST 1ST ALS NIEUWE KAMPDATUM
		$d = new DateTime(date('Y').'-08-01 16:00:00');
		if ($d < new DateTime()) {
  			$d = new DateTime((date('Y')+1).'-08-01 16:00:00');
		}
		$next_event_start_date	= $d->format('Y-m-d H:i:s');
  		$next_event_start_year 	= date('Y', strtotime($next_event_start_date));

		// DOE NU EEN QUERY OM EEN ECHTE VOLGENDE KAMPDATUM TE ACHTERHALEN

  		if ($current_event_type) {

			$params_nextkampfromtoday = [
				'checkPermissions' => FALSE,
				'debug' 	=> $apidebug,
				'limit' 	=> 1,
					'select' 	=> [
					'title', 
					'start_date',
					],
					'where' => [
						['start_date', 		'>', $today_datetime],
						['start_date', 		'<', $today_datetime_next],
	   					['event_type_id', 	'=', $current_event_type], // M61: zoek next event van zelfde event_type_id (kan evt missen)
				],
			];

	//		wachthond($extdebug,7, 'params_nextkampfromtoday', 			$params_nextkampfromtoday);
			$result_nextkampfromtoday = civicrm_api4('Event', 'get', 	$params_nextkampfromtoday);
	//		wachthond($extdebug,9, 'result_nextkampfromtoday', 			$result_nextkampfromtoday);

			if ($result_nextkampfromtoday->count() > 0) {
				$next_event_start_date 	= $result_nextkampfromtoday[0]['start_date'] ?? NULL;
		  		$next_event_start_year 	= date('Y', strtotime($next_event_start_date));
			}

		}

		wachthond($extdebug,3, 'next_event_start_date', 	$next_event_start_date);
		wachthond($extdebug,3, 'next_event_start_year', 	$next_event_start_year);

		if (in_array($groupID, $profilecvmax)) { // PROFILE CONT & PART (BASIC)

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 1.5a RETRIEVE CURRENT AGE AND AGE AT EVENT", "$displayname");
			wachthond($extdebug,3, "########################################################################");

			$leeftijd_vantoday_decimalen = NULL;
			$leeftijd_vantoday_rondjaren = NULL;

			if ($birth_date AND $today_datetime) {

				$leeftijd_vantoday = leeftijd_civicrm_diff('vandaag',  $birth_date, $today_datetime, $ditevent_event_kampkort);

				wachthond($extdebug,3, 'leeftijd_vantoday', 			$leeftijd_vantoday);
				$leeftijd_vantoday_decimalen	= $leeftijd_vantoday['leeftijd_decimalen'] ?? NULL;
				$leeftijd_vantoday_rondjaren	= $leeftijd_vantoday['leeftijd_rondjaren'] ?? NULL;
				wachthond($extdebug,2, 'leeftijd_vantoday_decimalen',	$leeftijd_vantoday_decimalen);

			}

			$leeftijd_ditevent_decimalen = NULL;
			$leeftijd_ditevent_rondjaren = NULL;

			if ($birth_date AND $ditevent_event_start) {

				$leeftijd_ditevent = leeftijd_civicrm_diff('ditevent', $birth_date, $ditevent_event_start, $ditevent_event_kampkort);

				wachthond($extdebug,3, 'leeftijd_ditevent', 			$leeftijd_ditevent);
				$leeftijd_ditevent_decimalen	= $leeftijd_ditevent['leeftijd_decimalen'] ?? NULL;
				$leeftijd_ditevent_rondjaren	= $leeftijd_ditevent['leeftijd_rondjaren'] ?? NULL;
				wachthond($extdebug,2, 'leeftijd_ditevent_decimalen', 	$leeftijd_ditevent_decimalen);

			}

			$leeftijd_nextkamp_decimalen = NULL;
			$leeftijd_nextkamp_rondjaren = NULL;
			$leeftijd_nextkamp_rondmaand = NULL;

			if ($birth_date AND $next_event_start_date) {

				$leeftijd_nextkamp = leeftijd_civicrm_diff('nextkamp', $birth_date, $next_event_start_date, $ditevent_event_kampkort);

				$leeftijd_nextkamp_decimalen = $leeftijd_nextkamp['leeftijd_decimalen'] ?? NULL;
				$leeftijd_nextkamp_rondjaren = $leeftijd_nextkamp['leeftijd_rondjaren'] ?? NULL;
				$leeftijd_nextkamp_rondmaand = $leeftijd_nextkamp['leeftijd_rondmaand'] ?? NULL;
				wachthond($extdebug,2, 'leeftijd_nextkamp_decimalen', 	$leeftijd_nextkamp_decimalen);
				wachthond($extdebug,2, 'leeftijd_nextkamp_rondjaren', 	$leeftijd_nextkamp_rondjaren);
				wachthond($extdebug,2, 'leeftijd_nextkamp_rondmaand', 	$leeftijd_nextkamp_rondmaand);
			}
		}

		if (in_array($groupID, $profilepartdeel)) { // PROFILE PART DEEL)

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 1.5b BEOORDEEL LEEFTIJDSCRITERIA", "$displayname");
			wachthond($extdebug,3, "########################################################################");

			$leeftijd_criteria 	= leeftijd_civicrm_criteria('ditevent', $ditevent_event_kampkort, $ditevent_part_groepklas, $leeftijd_ditevent_decimalen, $ditevent_part_criteriaindicatie, $ditevent_part_criteriaoordeel, $groupID, $contact_id, $ditevent_part_id);

			wachthond($extdebug,1, 'leeftijd_criteria', $leeftijd_criteria);

			$criteria_leeftijd 		= $leeftijd_criteria['criteria_leeftijd'] 		?? NULL;
			$criteria_school 		= $leeftijd_criteria['criteria_school'] 		?? NULL;
			$criteria_indicatie 	= $leeftijd_criteria['criteria_indicatie'] 		?? NULL;
			$criteria_beoordeling 	= $leeftijd_criteria['criteria_beoordeling'] 	?? NULL;

			if ($criteria_leeftijd == 'prima' AND $criteria_school == 'prima') {
				$criteria_indicatie 	= 'leeftijdschoolprima';
				$criteria_beoordeling 	= 'oordeelnietnodig';		
			}

			wachthond($extdebug,3, "INDICATIE & OORDEEL CRITERIA OBV HUIDIG EVENEMENT", "$ditevent_event_kampkort $ditevent_kampjaar (nu opgeslagen)");

			wachthond($extdebug,3, 'ditevent_leeftijd_decimalen', 			$leeftijd_ditevent_decimalen);
			wachthond($extdebug,3, 'ditevent_part_groepklas', 				$ditevent_part_groepklas);
			wachthond($extdebug,3, 'org_ditevent_part_criteriaindicatie', 	$ditevent_part_criteriaindicatie);
			wachthond($extdebug,3, 'org_ditevent_part_criteriaoordeel', 	$ditevent_part_criteriaoordeel);

			wachthond($extdebug,1, "INDICATIE & OORDEEL CRITERIA OBV HUIDIG EVENEMENT", "$ditevent_event_kampkort $ditevent_kampjaar (nieuw bepaald)");

			wachthond($extdebug,2, 'new_ditevent_criteria_leeftijd', 		$criteria_leeftijd);
			wachthond($extdebug,2, 'new_ditevent_criteria_school', 			$criteria_school);
			wachthond($extdebug,2, 'new_ditevent_criteria_indicatie', 		$criteria_indicatie);
			wachthond($extdebug,2, 'new_ditevent_criteria_oordeel', 		$criteria_beoordeling);
		}

		##################################################################################################
		### PAS PARTICIPANT STATUS AAN OBV INDICATIE INDIEN DEZE NIET OVEREENKOMT MET CRITERIA VAN HET KAMP
		##################################################################################################
		// M61: correctie Participant Status (onbekend [0], afwachting betaling [5], afgebroken betaling [6] > geregistreerd)
		// M61: TODO: de status hoort sws niet op 0 / Onbekend te kunnen komen
		##################################################################################################

		// ZET DE WAARDE VOOR DE NIEUWE VELDEN DEFAULT OP DE BESTAANDE WAARDE
		if ($ditevent_part_status_id) 		{ $new_ditevent_part_status_id 	= $ditevent_part_status_id 			?? NULL; 	}
		if ($ditevent_part_deelnamestatus) 	{ $new_ditevent_deelnamestatus 	= $ditevent_part_deelnamestatus		?? NULL; 	}
		if ($ditevent_part_criteriaoordeel) { $new_ditevent_criteriaoordeel = $ditevent_part_criteriaoordeel	?? NULL; 	}

		// DE VOLGENDE REGELS ZIJN BEDOELD ALS CORRECTIE CORRECTIE VOOR PART STATUS 0 & 5 OF 6
		if (in_array($ditevent_part_status_id, array(0)) OR in_array($ditevent_part_status_id, array(5,6))) {

			if (in_array($groupID, $profilepartdeel)) { // PROFILE PART DEEL)
				if ($criteria_indicatie == 'leeftijdschoolprima') {
					$new_ditevent_part_status_id 	= 1;
					$new_ditevent_part_status_name 	= 'Registered';
					$new_ditevent_deelnamestatus 	= 'Bevestigd';
					wachthond($extdebug,1, 'ditevent_part_status_id was 0', "updated to 1");
				}

				if ($criteria_indicatie == 'leeftijdschoolafwijkend') {
					$new_ditevent_part_status_id 	= 8;
					$new_ditevent_part_status_name 	= 'Awaiting approval';
					$new_ditevent_deelnamestatus 	= 'Criteriacheck';
					wachthond($extdebug,1, 'ditevent_part_status_id was 0', "updated to 8");
				}
			}
		}

		if (in_array($groupID, $profilepartdeel)) { // PROFILE PART DEEL)

			// DE VOLGENDE REGELS ALLEEN VOOR DEELNEMERS
			if (in_array($ditevent_part_criteriaoordeel, array("leeftijdechttejong","leeftijdechtteoud","leeftijdgeenprobleem"))) {
				$new_ditevent_criteriaoordeel = $ditevent_part_criteriaoordeel;
			} else {
				$new_ditevent_criteriaoordeel = $criteria_beoordeling;
			}

			if (in_array($ditevent_part_criteriaoordeel, array("oordeelnognodig")) AND in_array($ditevent_part_criteriaindicatie, array("leeftijdschoolafwijkend"))) {
				$new_ditevent_part_status_id = 8;					
				$new_ditevent_deelnamestatus = "Criteriacheck";
				wachthond($extdebug,1, "### FORCEER STATUS AFWACHTING OORDEEL TOT HANDMATIG BEOORDEEED ###");
			}

			if (in_array($ditevent_part_criteriaoordeel, array("oordeelnognodig")) AND in_array($ditevent_part_criteriaindicatie, array("schoolmogelijkprobleem")) AND in_array($ditevent_event_kampkort, array("kk1","kk2","bk1","bk2"))) {

				$new_ditevent_part_status_id = 8;
				$new_ditevent_deelnamestatus = "Criteriacheck";
				wachthond($extdebug,1, "### FORCEER STATUS AFWACHTING OORDEEL BIJ AFWIJKING SCHOOL VOOR KK EN BK TOT HANDMATIG BEOORDEEED ###");
			}
		}

		##################################################################################################
		### FORCEER ENKELE STATUSSEN DIE ONVERANDERD MOETEN BLIJVEN
		##################################################################################################

		if ($ditevent_part_status_id == '7') {
			$new_ditevent_part_status_id 	= 7;
			wachthond($extdebug,1, "### FORCEER STATUS WACHTLIJST INDIEN WACHTLIJST ###");
			// M61: Indien wachtlijst & tevens criteriacheck zet dan status event op wachtlijst en deelnamestatus op criteriacheck
		}

		if ($ditevent_part_status_id == '4') {
			$new_ditevent_part_status_id 	= 4;
			$new_ditevent_deelnamestatus 	= "Geannuleerd";
