		} else {
			wachthond($extdebug,1, "### ERROR! GEEN GELDIGE REFERENTIE GEVONDEN VOOR DIT JAAR ###", "[aantal: $result_ref_get_refcount]");
		}

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "### 10.8a CHECK OP REF VERZOEK IN HET HUIDIGE FISCALE JAAR VOOR $displayname", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,3, "########################################################################");

  		$refverzoekditjaar = 0;
		if (infiscalyear($part_refgevraagd,$ditevent_event_start,'part_refgevraagd','ditevent') == 1) {
			$refverzoekditjaar = 1;
		}
		wachthond($extdebug,2, 'refverzoekditjaar', "$refverzoekditjaar $part_refgevraagd");

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,1, "### 10.8b CHECK OP VOG VERZOEK IN HET HUIDIGE FISCALE JAAR VOOR $displayname", "[groupID: $groupID] [op: $op]");
		wachthond($extdebug,3, "########################################################################");

  		$vogverzoekditjaar = 0;
		if (infiscalyear($part_vogverzocht,$ditevent_event_start,'part_vogverzocht','ditevent') == 1) {
			$vogverzoekditjaar = 1;
		}
		wachthond($extdebug,2, 'vogverzoekditjaar', "$vogverzoekditjaar $part_vogverzocht");

    	if ($extref == 1) {

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 10.9 UPDATE TAB INTAKE MBT NIEUWERE DATUMS REF & VOG IGV VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,3, "########################################################################");

			if ($refrecent) {
				$refrecent_infiscalyear_ditjaar  = infiscalyear($refrecent,$today_datetime,		 'refrecent','ditjaar');
				$refrecent_infiscalyear_ditevent = infiscalyear($refrecent,$ditevent_event_start,'refrecent','ditevent');
				wachthond($extdebug,3, "refrecent_infiscalyear_ditjaar",  "$refrecent_infiscalyear_ditjaar\t[refrecent: $refrecent]");
				wachthond($extdebug,3, "refrecent_infiscalyear_ditevent", "$refrecent_infiscalyear_ditevent\t[refrecent: $refrecent]");			
			}

			### NIEUWSTE WAARDE REF KOMT UIT PART 
			if ( ($part_reffeedback 	AND empty($refrecent)) OR date_bigger($part_reffeedback, $refrecent) == 1) {

				$new_refrecent 	= $part_reffeedback;
				$new_refnaam 	= $part_refnaam;

				$params_contact['values']['INTAKE.REF_laatste'] 	= $new_refrecent;
				$params_contact['values']['INTAKE.REF_naam'] 		= $part_refnaam;

  				wachthond($extdebug,2, "WEL UPDATE TAB REFRECENT WANT PART_REFFEEDBACK IS NIEUWER", 	$new_refrecent);
			}

			### NIEUWSTE WAARDE REF KOMT UIT CONT 
			if ( ($referentie_feedback 	AND empty($refrecent)) OR date_bigger($part_reffeedback, $refrecent) == 1) {

				$new_refrecent = $referentie_feedback;

				wachthond($extdebug,2, "WEL UPDATE TAB REFRECENT WANT REFERENTIE_FEEDBACK IS NIEUWER", 	$new_refrecent);
			}

			### DATUM INTAKE REFPERSOON IS LEEG: VUL MET LAATSTE WAARDE REF FEEDBACK 
			if ( empty($refpersoon) AND !empty($new_refrecent) ) {

				$new_refpersoon = $new_refrecent;
				$params_contact['values']['INTAKE.ref_persoon'] 	= $new_refpersoon;

				wachthond($extdebug,2, "WEL UPDATE TAB REFPERSOON WANT LEEG. UPDATE MET REFRECENT", 	$new_refpersoon);
			}

		}	

		if ($vogrecent) {
			$vogrecent_infiscalyear_ditjaar  = infiscalyear($vogrecent,$today_datetime,		 'vogrecent','ditjaar');
			$vogrecent_infiscalyear_ditevent = infiscalyear($vogrecent,$ditevent_event_start,'vogrecent','ditevent');
			wachthond($extdebug,3, "vogrecent_infiscalyear_ditjaar",  "$vogrecent_infiscalyear_ditjaar [vogrecent: $vogrecent]");
			wachthond($extdebug,3, "vogrecent_infiscalyear_ditevent", "$vogrecent_infiscalyear_ditevent [vogrecent: $vogrecent]");			
		}

    	if ($extvog == 1) {

			if ( ($part_vogdatum 		AND empty($vogrecent)) OR date_bigger($part_vogdatum, $vogrecent) == 1) {

				$new_vogrecent = $part_vogdatum;

				$params_contact['values']['INTAKE.VOG_laatste'] 	= $part_vogdatum;
				$params_contact['values']['INTAKE.VOG_kenmerk'] 	= $part_vogkenmerk;
				wachthond($extdebug,2, "WEL UPDATE TAB VOGRECENT WANT PART_VOGDATUM IS NIEUWER", 		$part_vogdatum);
			} else {
				wachthond($extdebug,2, "GEEN UPDATE TAB VOGRECENT WANT PART_VOGDATUM IS NIET NIEUWER", 	$part_vogdatum);
			}
   		}

    	if ($extvog == 1 AND ($ditjaareventleidmss == 1 OR $ditjaareventleidyes == 1)) {

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 10.10 UPDATE INTAKE GEGEVENS IN PART LEID VOG VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,3, "########################################################################");

			// WERK DATUM PART ONTVANGST BIJ INDIEN (HANDMATIG) ALLEEN DATUM VOG WAS INGEVULD
			if (empty($part_vogontvangst) 	AND infiscalyear($part_vogdatum,$ditevent_event_start,'part_vogdatum','ditevent') == 1) {
				$params_part_ditevent['values']['PART_LEID_VOG.Datum_nieuwe_VOG']	= $part_vogdatum;
				wachthond($extdebug,1, "VOGONTVANGST LEEG MAAR VOGDATUM INGEVULD", "[part_vogdatum: $part_vogdatum]");
			}

			// WERK DATUM VOG BIJ INDIEN (HANDMATIG) ALLEEN DATUM ONTVANGST WAS INGEVULD
			if (empty($part_vogdatum) 		AND infiscalyear($part_vogontvangst,$ditevent_event_start,'part_vogontvangst','ditevent') == 1) {
				$params_part_ditevent['values']['PART_LEID_VOG.Datum_aanvraag']		= $part_vogingediend;
				wachthond($extdebug,1, "VOGDATUM LEEG MAAR VOGONTVANGST INGEVULD", "[part_vogontvangst: $part_vogontvangst]");
			}

			// WERK DATUM AANVRAAG BIJ INDIEN DEZE LEEG IS EN ALLEEN DATUM ONTVANGST IS INGEVULD
			if (empty($part_vogingediend) 	AND infiscalyear($part_vogdatum,$ditevent_event_start,'part_vogdatum','ditevent') == 1) {
				$params_part_ditevent['values']['PART_LEID_VOG.Datum_aanvraag']		= $part_vogdatum;
				wachthond($extdebug,1, "VOGAANVRAAG LEEG MAAR VOGDATUM INGEVULD", "[part_vogdatum: $part_vogdatum]");
			}
   		}

    	if ($extref == 1 AND $result_ref_get_refcount == 1 AND ($ditjaareventleidmss == 1 OR $ditjaareventleidyes == 1)) {

			wachthond($extdebug,3, "########################################################################");
			wachthond($extdebug,1, "### 10.11 UPDATE INTAKE GEGEVENS IN PART LEID REF VOOR $displayname", "[groupID: $groupID] [op: $op]");
			wachthond($extdebug,3, "########################################################################");

			if (infiscalyear($referentie_start,$ditevent_event_start,'referentie_start','ditevent') == 1) {
				$params_part_ditevent['values']['PART_LEID_REF.REF_persoon']	= $referentie_start;
				wachthond($extdebug,1, "PART_REF_PERSOON LEEG MAAR DATUM REL_PERSOON_START IN FISCAL YEAR EVENT", "[referentie_start: $referentie_start]");
			}
			if (infiscalyear($referentie_einde,$ditevent_event_einde,'referentie_einde','ditevent') == 1) {
				$params_part_ditevent['values']['PART_LEID_REF.REF_persoon']	= $ditevent_fiscalyear_start;
