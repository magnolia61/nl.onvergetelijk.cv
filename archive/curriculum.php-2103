			$datebigger_birthday_eventstart = date_bigger($birthday_ditjaar, 		$eventkamp_event_start 	);
			$datebigger_birthday_eventeinde = date_bigger($eventkamp_event_einde, 	$birthday_ditjaar 		);

			wachthond($extdebug,3, "datebigger_birthday_eventstart ?", $datebigger_birthday_eventstart);
			wachthond($extdebug,3, "datebigger_birthday_eventeinde ?", $datebigger_birthday_eventeinde);

