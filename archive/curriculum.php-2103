		wachthond($extdebug,1, "########################################################################");
		wachthond($extdebug,1, "### 13.X CREATE INTAKE ACTIVITIES VOOR $displayname", "[groupID: $groupID] [op: $op]");

		if ($extref == 1 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND $ditjaareventleidyes == 1) {

			wachthond($extdebug,2, "########################################################################");
			wachthond($extdebug,1, "### 13.1 CREATE AN ACTIVITY REFPERSOON VOOR $displayname", "[ALS REF PERSOON IS GEVRAAGD]");
			wachthond($extdebug,2, "########################################################################");

			if (empty($refpersoon_activity_id)) {

