						$indexed[$i]['kampkort'] 		= $item['PART.PART_kampkort'];
						$indexed[$i]['kamprol'] 		= $item['PART.PART_kamprol'];
						$indexed[$i]['kampfunctie'] 	= $item['PART.PART_kampfunctie'];
						$indexed[$i]['status_id'] 		= $item['status_id'];
						$indexed[$i]['status_name'] 	= $item['status_id:name'];
	    			}

	    			if (!isset($positiv_all[$i])  	AND in_array($item['status_id'], $status_positive)) {
						$positiv_all[] 	= $i;
	    			}
	    			if (!isset($positiv_deel[$i]) 	AND in_array($item['status_id'], $status_positive) AND in_array($item['event.event_type_id'], $eventtypesdeelandtop)) {
						$positiv_deel[] = $i;
	    			}
	    			if (!isset($positiv_leid[$i]) 	AND in_array($item['status_id'], $status_positive) AND in_array($item['event.event_type_id'], $eventtypesleid)) {
						$positiv_leid[] = $i;
	    			}
	    			if (!isset($pending_deel[$i]) 	AND in_array($item['status_id'], $status_pending)  AND in_array($item['event.event_type_id'], $eventtypesdeelandtop)) {
						$pending_deel[] = $i;
	    			}
	    			if (!isset($pending_leid[$i]) 	AND in_array($item['status_id'], $status_pending)  AND in_array($item['event.event_type_id'], $eventtypesleid)) {
						$pending_leid[] = $i;
	    			}
	    			if ( !isset($allstat_all[$i]) 	AND in_array($item['event.event_type_id'], $eventtypesall)) {
						$allstat_all[] = $i;
	    			}    			
	    			if ( !isset($allstat_deel[$i]) 	AND in_array($item['event.event_type_id'], $eventtypesdeelandtop)) {
