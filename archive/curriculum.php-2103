		if ($result_contact[0]['middle_name']) 	{	$middle_name	= strtolower(trim($result_contact[0]['middle_name']));	}
		if ($result_contact[0]['last_name']) 	{	$last_name		= ucfirst(trim($result_contact[0]['last_name']));		}
		if ($result_contact[0]['nick_name']) 	{	$nick_name		= ucfirst(trim($result_contact[0]['nick_name']));		}

		if ($first_name AND $middle_name AND $last_name) {
			$displayname = $first_name." ".$middle_name." ".$last_name;
		} elseif ($first_name AND empty($middle_name) AND $last_name) {
			$displayname = $first_name." ".$last_name;
		} elseif ($first_name AND empty($middle_name) AND empty($last_name)) {
