    						'Event_Kenmerken.kampweek_nr',		    				

							'Event_Kenmerken.kamplocatie',
		    				'Event_Kenmerken.kampplaats',
							'Event_Kenmerken.kamplocatie:label',
		    				'Event_Kenmerken.kampplaats:label',

		    				'Event_Kenmerken.kamptype_naam',
		    				'Event_Kenmerken.kamptype_naam:label',
		    				'Event_Kenmerken.kamptype_id',
		    				'Event_Kenmerken.kampsoort',

	    					'Event_Kenmerken.brengen',
	    					'Event_Kenmerken.halen',
	    					'Event_Kenmerken.afsluiting',
							'Event_Kenmerken.welkomvideo',
		    				'Event_Kenmerken.kampfotos',
		    				'Event_Kenmerken.playlist',

		    				'Taken_rollen.hoofdleiding_1',
		    				'Taken_rollen.hoofdleiding_2',
		    				'Taken_rollen.hoofdleiding_3',

		    				'Taken_rollen.hoofd_gedrag',
		    				'Taken_rollen.hoofd_keuken',
		    				'Taken_rollen.hoofd_boekje',
	  					],
	  					'where' => $params_var,
					];

					wachthond($extdebug,7, 'params_eventkamp', 			$params_eventkamp);
					$result_eventkamp = civicrm_api4('Event', 'get', 	$params_eventkamp);
					wachthond($extdebug,9, 'result_eventkamp', 			$result_eventkamp);

	    			$eventkamp_event_id 			 	= $result_eventkamp[0]['id'] 									?? NULL;
	    			$eventkamp_event_type_id			= $result_eventkamp[0]['event_type_id'] 						?? NULL;	// bv.21
	    			$eventkamp_event_type_id_label		= $result_eventkamp[0]['event_type_id:label'] 					?? NULL;	// bv.Kinderkamp week 2
	    			$eventkamp_event_type_name			= $result_eventkamp[0]['Event_Kenmerken.typekamp'] 				?? NULL; 	// bv.kinderkamp (lowercase)
	    			$eventkamp_event_type_name_label	= $result_eventkamp[0]['Event_Kenmerken.typekamp:label'] 		?? NULL;	// bv.Kinderkamp (typekamp) 
	   
					$eventkamp_event_kamptype_naam		= $result_eventkamp[0]['Event_Kenmerken.kamptype_naam'] 		?? NULL;
					$eventkamp_event_kamptype_label		= $result_eventkamp[0]['Event_Kenmerken.kamptype_naam:label'] 	?? NULL;
					$eventkamp_event_kamptype_id		= $result_eventkamp[0]['Event_Kenmerken.kamptype_id'] 			?? NULL;
					$eventkamp_event_kampsoort 			= $result_eventkamp[0]['Event_Kenmerken.kampsoort'] 			?? NULL;

					$eventkamp_event_kampnaam 			= $result_eventkamp[0]['Event_Kenmerken.kampnaam'] 			?? NULL;
					$eventkamp_event_kampkort 			= $result_eventkamp[0]['Event_Kenmerken.kampkort'] 			?? NULL;

