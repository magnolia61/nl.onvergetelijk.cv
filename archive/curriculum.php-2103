			$ditjaareventdeelyes = 1;
			$ditjaareventdeeltxt = "YES";
		} else {
			$ditjaareventdeelyes = 0;
			$ditjaareventdeeltxt = "NOT";
		}

		if ($ditjaar_pos_leid_part_id == $ditevent_part_id AND $diteventleidyes == 1) {
			$ditjaareventleidyes = 1;
			$ditjaareventleidtxt = "YES";			
		} else {
			$ditjaareventleidyes = 0;
			$ditjaareventleidtxt = "NOT";
		}

        ################################################################################################

		// ALLEEN ALS ER MAAR 1 AANMELDING DEEL OF LEID IS (NIET >1 MET VERSCHILLENDE STATUSSEN)

		if (infiscalyear($ditevent_event_start,$today_datetime,'ditevent','ditjaar') == 1) {

			if ($diteventdeelmss == 1) {
				$ditjaareventdeelmss = 1;
				$ditjaareventdeeltxt = "MSS";
			} else {
				$ditjaareventdeelmss = 0;
			}
			if ($diteventleidmss == 1) {
				$ditjaareventleidmss = 1;
				$ditjaareventleidtxt = "MSS";
			} else {
				$ditjaareventleidmss = 0;
			}

		}

        ################################################################################################

		if (infiscalyear($ditevent_event_start,$today_datetime,'ditevent','ditjaar') == 1) {

			if ($diteventdeeltst == 1) {
				$ditjaareventdeeltst = 1;
				$ditjaareventdeeltxt = "TST";			
			} else {
				$ditjaareventdeeltst = 0;
			}
			if ($diteventleidtst == 1) {
				$ditjaareventleidtst = 1;
				$ditjaareventleidtxt = "TST";
			} else {
				$ditjaareventleidtst = 0;
			}

		}

		################################################################################################
		# BEPAAL DITJAAR DEEL YES INDIEN EXTCVDEEP = 0 & PROFILE IS PARTICIPANT
		################################################################################################

        if (is_array($eventtypesdeelall) && in_array($ditevent_event_type_id, array_values($eventtypesdeelall))) {

			if (infiscalyear($ditevent_event_start,$today_datetime,'ditevent','ditjaar') == 1) {

		    	if (is_array($status_positive) && $ditevent_part_status_id > 0 && in_array($ditevent_part_status_id, array_values($status_positive))) {
		            $ditjaardeelyes 		= 1;
		            $ditjaardeelnot 		= 0;
		            $ditjaardeelmss 		= 0;
		            $ditjaardeeltxt 		= 'YES';

					$ditjaareventdeelyes 	= 1;
					$ditjaareventdeelnot 	= 0;
					$ditjaareventdeeltxt 	= "YES";

					wachthond($extdebug,2, "SHORTCUT: DITJAAR GAAT $displayname $ditjaardeeltxt MEE ALS DEELNEMER", "[EID $ditevent_part_eventid / TYPE $ditevent_event_type_id]");

				}
			}
		}

		################################################################################################
		# BEPAAL DITJAAR LEID YES INDIEN EXTCVDEEP = 0 & PROFILE IS PARTICIPANT
		################################################################################################

        if (is_array($eventtypesleidall) && in_array($ditevent_event_type_id, array_values($eventtypesleidall))) {

			if (infiscalyear($ditevent_event_start,$today_datetime,'ditevent','ditjaar') == 1) {

		    	if (is_array($status_positive) && $ditevent_part_status_id > 0 && in_array($ditevent_part_status_id, array_values($status_positive))) {
		            $ditjaarleidyes 		= 1;
		            $ditjaarleidnot 		= 0;
		            $ditjaarleidmss 		= 0;
		            $ditjaarleidtxt 		= 'YES';

					$ditjaareventleidyes 	= 1;
					$ditjaareventleidnot 	= 0;
					$ditjaareventleidtxt 	= "YES";

					wachthond($extdebug,2, "SHORTCUT: DITJAAR GAAT $displayname $ditjaarleidtxt MEE ALS $ditevent_part_functie", "[EID $ditevent_part_eventid / TYPE $ditevent_event_type_id]");

				}
			}
		}

		wachthond($extdebug,3, "########################################################################");
		wachthond($extdebug,2, "### 1.6h BEPAAL DE DEELNAMESTATUS DIT JAAR EN DIT EVENT");
		wachthond($extdebug,3, "########################################################################");

		wachthond($extdebug,4, 'status_positive', 	$status_positive);
		wachthond($extdebug,4, 'status_waiting', 	$status_waiting);
		wachthond($extdebug,4, 'status_pending', 	$status_pending);
		wachthond($extdebug,4, 'status_criteria', 	$status_criteria);
		wachthond($extdebug,4, 'status_negative', 	$status_negative);

		if (in_array($ditjaar_one_part_status_id, 	$status_positive)) 		{ $new_ditjaar_deelnamestatus 	= 'Bevestigd';		}
		if (in_array($ditjaar_one_part_status_id, 	$status_waiting)) 		{ $new_ditjaar_deelnamestatus 	= 'Wachtlijst';		}
		if (in_array($ditjaar_one_part_status_id, 	$status_pending)) 		{ $new_ditjaar_deelnamestatus 	= 'Afwachting';		}
		if (in_array($ditjaar_one_part_status_id,	$status_criteria))		{ $new_ditjaar_deelnamestatus 	= 'Criteriacheck';	}
		if (in_array($ditjaar_one_part_status_id, 	$status_negative)) 		{ $new_ditjaar_deelnamestatus 	= 'Geannuleerd';	}

		if (in_array($new_ditevent_part_status_id,	$status_positive)) 		{ $new_ditevent_deelnamestatus	= 'Bevestigd';		}
		if (in_array($new_ditevent_part_status_id,	$status_waiting)) 		{ $new_ditevent_deelnamestatus 	= 'Wachtlijst';		}
		if (in_array($new_ditevent_part_status_id,	$status_pending)) 		{ $new_ditevent_deelnamestatus 	= 'Afwachting';		}
		if (in_array($new_ditevent_part_status_id, 	$status_criteria))		{ $new_ditevent_deelnamestatus 	= 'Criteriacheck';	}
		if (in_array($new_ditevent_part_status_id,	$status_negative)) 		{ $new_ditevent_deelnamestatus 	= 'Geannuleerd';	}

		if ($ditjaareventdeelyes == 1 OR $ditjaareventleidyes == 1) {

			if (in_array($new_ditevent_part_status_id,	$status_positive)) 	{ $new_ditjaar_deelnamestatus	= 'Bevestigd';		}
			if (in_array($new_ditevent_part_status_id,	$status_waiting)) 	{ $new_ditjaar_deelnamestatus 	= 'Wachtlijst';		}
			if (in_array($new_ditevent_part_status_id,	$status_pending)) 	{ $new_ditjaar_deelnamestatus 	= 'Afwachting';		}
			if (in_array($new_ditevent_part_status_id, 	$status_criteria))	{ $new_ditjaar_deelnamestatus 	= 'Criteriacheck';	}
			if (in_array($new_ditevent_part_status_id,	$status_negative)) 	{ $new_ditjaar_deelnamestatus 	= 'Geannuleerd';	}

		}

		// ZET DEELNAMESTATUS VOOR LEIDING ALTIJD OP BEVESTIGD

		if ($ditevent_event_type_id == 1 AND $ditevent_leid_functie) {
//		if ($ditjaarleidyes == 1 AND $leeftijd_ditevent_decimalen > 18) {
			$criteria_indicatie 			= 'leeftijdschoolprima';
			$criteria_beoordeling 			= 'oordeelnietnodig';
			$new_ditevent_criteriaoordeel 	= "";
			$new_ditevent_deelnamestatus 	= 'Bevestigd';
		}

		if ($result_partditjaar_all_count 	>= 1) {
			wachthond($extdebug,3, 'ditjaar_one_part_status_id',		$ditjaar_one_part_status_id);
			wachthond($extdebug,3, 'ditjaar_one_deel_part_status_id',	$ditjaar_one_deel_part_status_id);
			wachthond($extdebug,3, 'ditjaar_one_leid_part_status_id',	$ditjaar_one_leid_part_status_id);
			wachthond($extdebug,2, 'new_ditjaar_deelnamestatus', 		$new_ditjaar_deelnamestatus);
		}

		if ($result_partditevent_count 		>= 1) {
			wachthond($extdebug,3, 'ditevent_part_status_id',			$new_ditevent_part_status_id);
			wachthond($extdebug,3, 'new_ditevent_part_status_name',		$new_ditevent_part_status_name);
			wachthond($extdebug,2, 'new_ditevent_deelnamestatus', 		$new_ditevent_deelnamestatus);
		}

