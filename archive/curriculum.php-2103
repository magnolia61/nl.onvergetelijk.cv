	  				];
	   				$params_var_ditevent_note = "PARAMS_VAR: DITEVENT LEID TEST";
	  			}

				wachthond($extdebug,7, 'params_var_ditevent_note', 	$params_var_ditevent_note);
				wachthond($extdebug,7, 'params_var_ditjaar_note', 	$params_var_ditjaar_note);
				wachthond($extdebug,7, 'params_var_ditevent', 		$params_var_ditevent);
				wachthond($extdebug,7, 'params_var_ditjaar', 		$params_var_ditjaar);

				$params_var = $params_var_ditevent;

	  			if ($params_var) {
					$params_eventkamp = [
					'checkPermissions' => FALSE,
					'debug' => $apidebug,
	  					'select' => [
		    				'id',
		    				'start_date',
		    				'end_date',
		    				'event_type_id',
		    				'event_type_id:label',
