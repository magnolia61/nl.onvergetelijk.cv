					if (empty($vogverzoek_activity_status))		{ $vogverzoek_activity_status		= $result_vogverzoek_create[0]['status_id'] ?? NULL; }
					wachthond($extdebug,2, "(nieuwe) vogverzoek_activity_id", 		$vogverzoek_activity_id);
