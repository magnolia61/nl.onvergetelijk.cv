	if ( ($dateparse_date_source_error + $dateparse_date_target_error) == 0) {

		if ($date_source_unix >= $date_target_unix) {
			wachthond($extdebug,1, "$date_source_string > $date_target_string", "Bigger? YES ($date_source_name >= $date_target_name)");
