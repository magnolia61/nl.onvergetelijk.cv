					$intakestatusvog 	= 'ingediend';
				}

				if (strtotime($part_vogdatum)	  >= strtotime($event_fiscalyear_start) AND $status_vogaanvraag != 'Completed')	{ // hier een between van maken (of liever nog een functie)
					#if ($extdebug >= 2) { watchdog('php','<pre>A. part_vogdatum: '.print_r(strtotime($part_vogdatum),TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					#if ($extdebug >= 2) { watchdog('php','<pre>B. fiscalyear_start: '.print_r(strtotime($event_fiscalyear_start),TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 1) { watchdog('php','<pre>STATUS VOG AANVRAAG AANGEPAST VAN: '.$status_vogaanvraag.' NAAR Completed (omdat part_vogdatum: '.$part_vogdatum.' >= '.$event_fiscalyear_start.')</pre>',NULL,WATCHDOG_DEBUG); }
					$status_vogaanvraag	= "Completed";
					$intakestatusvog 	= 'ingediend';
				}

				#if ($part_vogverzocht)						{ $intakestatusvog = 'verzocht'; 	}
				#if ($part_vogingediend)					{ $intakestatusvog = 'ingediend'; 	}
				if ($part_vogontvangst)						{ $intakestatusvog = 'ontvangen'; 	}

				if (strtotime($part_vogingediend) < strtotime($event_fiscalyear_start) AND strtotime($part_vogdatum) < strtotime($event_fiscalyear_start))	{
					// als part_vogdatum binnen huidige fiscal year valt kan activity op completed (nu alleen later dan fiscal year start)
					if ($extdebug >= 2) { watchdog('php','<pre>a. part_vogverzocht: '.print_r($part_vogverzocht,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					#if ($extdebug >= 2) { watchdog('php','<pre>b. diffsinceverzoek: '.print_r($diffsince_vogverzoek,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 2) { watchdog('php','<pre>b. dagen_sinds_verzoek: '.print_r($dayssince_vogverzoek,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				}

				if ($extdebug >= 2) { watchdog('php','<pre>c. (new) status_aanvraag: '.print_r($status_vogaanvraag,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

