				if ($extdebug >= 1) { watchdog('php','<pre>intakestatusvog  : ' .print_r($intakestatusvog,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			}

			if ($extvog == 1 AND (in_array($groupID, array("140", "213")))) {
