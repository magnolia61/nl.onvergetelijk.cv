						#if ($extdebug >= 2) { watchdog('php','<pre>Current user UFMatch_ufid: '.print_r($ufmatch_ufid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    				} else {
	    				if ($extdebug >= 1) { watchdog('php','<pre>------ f) ERROR  : GEEN UF MATCH GEVONDEN VOOR CONTACT_ID: '.print_r($contact_id,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    					$drupalufmatch_found = 0;
    				}
				}

  				if ($drupalaccount_safe2update == 0 AND $drupalaccount_nameconflict	== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED CREATE WANT DRUPAL ACCOUNT GEVONDEN MET ZELFDE NAAM: ('.$user_name.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($drupalaccount_safe2update == 0 AND $drupalufmatchother_found 	== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED CREATE WANT CONFLICTERENDE UF MATCH GEVONDEN: ('.$ufmatch_ufid.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($drupalaccount_safe2update == 0 AND $drupalname_danger 			== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED CREATE WANT CONNECTED CMS NAME ('.$connected_drupal_name.') != CONSTRUCTED NAME ('.$user_name.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($drupalaccount_safe2update == 0 AND $drupalid_danger 			== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED CREATE WANT CONNECTED CMS ID ('.$connected_drupal_id.') != EXTERNAL IDENTIFIER ('.$cmsidentitier.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
    		}

			##############################################################################################################################
			if ($extdebug >= 1) { watchdog('php','<pre>###### G) UPDATE DRUPAL ACCOUNT & UF_MATCH [IF DRUPALÀCCOUNT     FOUND ('.$drupalaccount_found.') AND UFMATCH     FOUND ('.$drupalufmatch_found.')</pre>',NULL,WATCHDOG_DEBUG); }
			##############################################################################################################################
			if ($drupalaccount_found == 1 AND $drupalufmatch_found == 1) {
			##############################################################################################################################
				if ($extdebug >= 1) { watchdog('php','<pre>*** UPDATE DRUPAL  ACCOUNT  :'.$user_name.' ***</pre>',NULL,WATCHDOG_DEBUG); }	
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL ACCOUNT FOUND    :'.$drupalaccount_found.' ***</pre>',NULL,WATCHDOG_DEBUG); }		
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL NAME    FOUND    :'.$drupalname_found.' ***</pre>',NULL,WATCHDOG_DEBUG); }		
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL MATCH   FOUND    :'.$drupalufmatch_found.' ***</pre>',NULL,WATCHDOG_DEBUG); }		
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL MATCH   CONFLICT :'.$drupalufmatchother_found.' *** (ERROR)</pre>',NULL,WATCHDOG_DEBUG); }	
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL NAME    CONFLICT :'.$drupalaccount_nameconflict.' *** (ERROR)</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL NAME    DANGER   :'.$drupalname_danger.' *** (ERROR)</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 1) { watchdog('php','<pre>*** DRUPAL ID      DANGER   :'.$drupalid_danger.' *** (ERROR)</pre>',NULL,WATCHDOG_DEBUG); }
				if ($drupalaccount_nameconflict == 0 AND $drupalufmatchother_found == 0 AND $drupalname_danger == 0 AND $drupalid_danger == 0) {
					$drupalaccount_safe2update = 1;
				} else {
					$drupalaccount_safe2update = 0;
				}
				#####################################################################################################
				# UPDATE DRUPAL ACCOUNT & EMAIL WITH PRIMARY EMAIL (ONVERGETELIJK.NL VOOR STAF, PLACEHOLDER VOOR DEEL)
				#####################################################################################################
				if ($extdebug >= 2) { watchdog('php','<pre>part_functie     : '.$part_functie.'</pre>',NULL,WATCHDOG_DEBUG); }

				if (in_array($part_functie, array('hoofdleiding', 'bestuurslid', 'kampstaf'))) {
					$user_email = $email_onvr_email;
				}
				if ($extdebug >= 1) { watchdog('php','<pre>------ g) CHANGE DRUPAL MAIL FOR MATCHID: '.print_r($ufmatch_ufid,TRUE) . ' to '.print_r($user_email,TRUE) . ' (PREPARING)</pre>',NULL,WATCHDOG_DEBUG); }

				if ($user_name) { $drupal_name = $user_name; }
				if ($extdebug >= 1) { watchdog('php','<pre>------ g) CHANGE DRUPAL NAME FOR MATCHID: '.print_r($ufmatch_ufid,TRUE) . ' to '.print_r($drupal_name,TRUE) . ' (PREPARING)</pre>',NULL,WATCHDOG_DEBUG); }


				###########################################
				# UPDATE DRUPAL USER USING DRUPAL API
				###########################################

				// load user object
				$existingUser = user_load($ufmatch_ufid);
				#if ($extdebug >= 2) { watchdog('php','<pre>existingUser: '.print_r($existingUser,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$existingUser->mail = $user_email;
				// always update username (for all roles)
				$existingUser->name = $user_name;

				#if ($extdebug >= 2) { watchdog('php','<pre>existingUser 		: '.print_r($existingUser,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 2) { watchdog('php','<pre>existingUser->name 	: '.print_r($existingUser->name,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 2) { watchdog('php','<pre>existingUser->mail 	: '.print_r($existingUser->mail,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 2) { watchdog('php','<pre>existingUser->uid 	: '.print_r($existingUser->uid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

				// save existing user
				if ($existingUser->uid AND $drupalaccount_safe2update == 1) {
					user_save((object) array('uid' => $existingUser->uid), (array) $existingUser);
					if ($extdebug >= 1) { watchdog('php','<pre>------ g) SUCCESS: Changed drupal mail for drupalid: '.print_r($ufmatch_ufid,TRUE) . ' to '.print_r($user_email,TRUE) . ' (UPDATED)</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 1) { watchdog('php','<pre>------ g) SUCCESS: Changed drupal name for drupalid: '.print_r($ufmatch_ufid,TRUE) . ' to '.print_r($user_name,TRUE) . ' (UPDATED)</pre>',NULL,WATCHDOG_DEBUG); }
					$job_title 			= $user_name; // M61: om te updaten later in job_title
				}

				#####################################################################################################
				# UPDATE UF_MATCH WITH PROPER EMAIL
				#####################################################################################################

				// M61: HIER MOET NOG EEN IF OM HET ALLEEN TE UPDATEN ALS HET AFWIJKT
				if ($drupalaccount_safe2update == 1) {

					$params_ufmatchupdate = [
	  					'checkPermissions' => FALSE,
						'debug' => $apidebug,
	 					'where' => [
    						['contact_id', '=', $contact_id],
  						],
  						'values' => [
							'uf_name' => $user_email,
  						],
					];
					if ($extdebug >= 3) { watchdog('php','<pre>params_ufmatchupdate'.print_r($params_ufmatchupdate,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
      				$result 		= civicrm_api4('UFMatch', 'update', $params_ufmatchupdate);
					if ($extdebug >= 4) { watchdog('php','<pre>result_ufmatchupdate: '.print_r($result,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

					if ($extdebug >= 1) { watchdog('php','<pre>------ g) SUCCESS: Changed ufmatch mail for contact_id '.$contact_id.' to '.$user_email.'</pre>',NULL,WATCHDOG_DEBUG); }
				}
 
				#####################################################################################################

				if ($drupalaccount_safe2update == 0 AND $drupalaccount_nameconflict	== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED UPDATE WANT DRUPAL ACCOUNT GEVONDEN MET ZELFDE NAAM: ('.$user_name.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($drupalaccount_safe2update == 0 AND $drupalufmatchother_found 	== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED UPDATE WANT CONFLICTERENDE UF MATCH GEVONDEN: ('.$ufmatch_ufid.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($drupalaccount_safe2update == 0 AND $drupalname_danger 			== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED UPDATE WANT CONNECTED CMS NAME ('.$connected_drupal_name.') != CONSTRUCTED NAME ('.$user_name.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($drupalaccount_safe2update == 0 AND $drupalid_danger 			== 1) {
					if ($extdebug >= 1) { watchdog('php','<pre>WARNING: SKIPPED UPDATE WANT CONNECTED CMS ID ('.$connected_drupal_id.') != EXTERNAL IDENTIFIER ('.$cmsidentitier.')</pre>',NULL,WATCHDOG_DEBUG); }
				}
			}

			##############################################################################################################################
			if ($extdebug >= 1) { watchdog('php','<pre>###### H) REPAIR DRUPAL ACCOUNT & UF_MATCH [IF DRUPALÀCCOUNT     FOUND ('.$drupalaccount_found.') AND UFMATCH NOT FOUND ('.$drupalufmatch_found.')</pre>',NULL,WATCHDOG_DEBUG); }	
			##############################################################################################################################
			if ($drupalaccount_found == 1 AND $drupalufmatch_found == 0) {
			##############################################################################################################################

				if ($drupalaccount_orphan_same_name == 1 AND $drupalaccount_orphan_same_mail == 1) {

					#####################################################################################################
					# CREATE NEW UF MATCH WITH NEWLY CREATED DRUPAL USER (M61: match ook met evt verkeerd dubbeld gevonden uid!!!)
					#####################################################################################################

					$params_ufmatchcreate = [
						'checkPermissions' => FALSE,
						'debug' => $apidebug,
 						'values' => [
							'uf_id'			=> $drupal_uid,
      						'uf_name'		=> $user_email,	
      						'contact_id'	=> $contact_id,
      						'domain_id'		=> 1,
  						],
					];

					if ($extdebug >= 3) { watchdog('php','<pre>params_ufmatchcreate: '.print_r($params_ufmatchcreate,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
      				$result_ufmatchcreate = civicrm_api4('UFMatch', 'create', $params_ufmatchcreate);
    				if ($extdebug >= 4) { watchdog('php','<pre>result_ufmatchcreate: '.print_r($result_ufmatchcreate,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

					// CHECK IF A CURRENT UF MATCH IS NOW PRESENT
					$params_ufmatchget = [
  						'checkPermissions' => FALSE,
						'debug' => $apidebug,
  						'select' => [
    						'id', 
    						'uf_id', 
   							'contact_id',
  						],
  						'where' => [
    						['contact_id', '=', $contact_id],
  						],
					];
					if ($extdebug >= 3) { watchdog('php','<pre>params_ufmatchget: '.print_r($params_ufmatchget,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
      				$result_ufmatchget = civicrm_api4('UFMatch', 'get', $params_ufmatchget);
      				if ($result !== false) {
      					$ufmatch_id 	= $result_ufmatchget[0]['id'];
    					$ufmatch_ufid 	= $result_ufmatchget[0]['uf_id'];
   					}

		    		if ($ufmatch_ufid) {
	    				if ($extdebug >= 1) { watchdog('php','<pre>------ h) PRIMA  : GOEDE UF MATCH GEVONDEN: '.print_r($user_name.' | drupalid: '.$ufmatch_ufid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    					$drupalufmatch_found = 1;
    					if ($drupal_uid == $ufmatch_ufid) {
				    		$params_contact['values']['external_identifier'] = $drupal_uid;
				    	}
    				} else {
	    				if ($extdebug >= 1) { watchdog('php','<pre>------ h) ERROR  : GEEN UF MATCH GEVONDEN VOOR CONTACT_ID: '.print_r($contact_id,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    					$drupalufmatch_found = 0;
    				}
				}
			}

			#####################################################################################################
			if ($drupalufmatchother_found 	== 1) { $drupal_uid = NULL; }
			if ($drupalaccount_nameconflict	== 1) { $drupal_uid = NULL; }
			#####################################################################################################
		}
	}
