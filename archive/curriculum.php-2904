			if ($extdebug >= 2) { watchdog('php','<pre>intnodig_ditjaar : '.print_r($intnodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>bionodig_ditjaar : '.print_r($bionodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>refnodig_ditjaar : '.print_r($refnodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    		if ($extdebug >= 2) { watchdog('php','<pre>vognodig_ditjaar : '.print_r($vognodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    		#if ($extdebug >= 2) { watchdog('php','<pre>vognodig_nextyear: '.print_r($vognodignextyear,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

   			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusint  : '.print_r($intakestatusint,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusbio  : '.print_r($intakestatusbio,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusref  : '.print_r($intakestatusref,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusvog  : '.print_r($intakestatusvog,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }	

			#####################################################################################################
			# BEPAAL DE WAARDE VAN INTAKE STATUS
			#####################################################################################################
			if ($extdebug >= 1) { watchdog('php','<pre>### BEPAAL DE INTAKE STATUS [groupID: '.$groupID.'] [op: '.$op.'] ###</pre>',NULL,WATCHDOG_DEBUG); }

			$intakestatusinttodo = 0;
			$intakestatusintdone = 0;

			if (in_array($bionodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakebionodig	= 1; }
			if (in_array($refnodig,array("eerstex","elkjaar","opnieuw","inhaal")))	{	$intakerefnodig = 1; }
			if (in_array($vognodig,array("eerstex","elkjaar","opnieuw","inhaal"))) 	{	$intakevognodig	= 1; }

			if ($extdebug >= 1) { watchdog('php','<pre>------#########################################################</pre>',NULL,WATCHDOG_DEBUG); }

			if (in_array($bionodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($intakestatusbio, array("noggoed", "bijgewerkt"))) 						{
				$intakestatusbiotodo	= 1;
			}

			if (in_array($refnodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND 
				in_array($intakestatusref, array("noggoed", "bekend", "gevraagd", "ontvangen"))) 	{
				$intakestatusreftodo	= 1;
			}

			if (in_array($vognodig,array("eerstex","elkjaar","opnieuw","inhaal")) AND
				in_array($intakestatusvog, array("noggoed", "ingediend","ontvangen"))) 				{
				$intakestatusvogtodo	= 1;
			}

			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusbiotodo  : ' .print_r($intakestatusbiotodo,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusreftodo  : ' .print_r($intakestatusreftodo,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusvogtodo  : ' .print_r($intakestatusvogtodo,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			$intakestatusnodig 		= $intakebionodig 		+ $intakerefnodig 		+ $intakevognodig;
			$intakestatusinttodo 	= $intakestatusbiotodo 	+ $intakestatusreftodo 	+ $intakestatusvogtodo;

			if ($extdebug >= 1) { watchdog('php','<pre>------#########################################################</pre>',NULL,WATCHDOG_DEBUG); }

			if (in_array($intakestatusbio, array("noggoed", "bijgewerkt"))) 						{	$intakestatusbiodone	= 1;	}
			if (in_array($intakestatusref, array("noggoed", "ontvangen"))) 							{	$intakestatusrefdone	= 1;	}
			if (in_array($intakestatusvog, array("noggoed", "ontvangen"))) 							{	$intakestatusvogdone	= 1;	}

			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusbiodone  : ' .print_r($intakestatusbiodone,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusrefdone  : ' .print_r($intakestatusrefdone,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusvogdone  : ' .print_r($intakestatusvogdone,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			$intakestatusintdone = $intakestatusbiodone + $intakestatusrefdone + $intakestatusvogdone;

			if ($extdebug >= 1) { watchdog('php','<pre>------#########################################################</pre>',NULL,WATCHDOG_DEBUG); }

			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusinttodo  : ' .print_r($intakestatusinttodo,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusintdone  : ' .print_r($intakestatusintdone,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>intakestatusint      : ' .print_r($intakestatusint,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			if ($extdebug >= 1) { watchdog('php','<pre>------#########################################################</pre>',NULL,WATCHDOG_DEBUG); }

			if ($intakestatusinttodo < $intakestatusnodig AND $intakestatusinttodo > 0) {
				$intakestatusint  	= 'gedeeltelijk';
			}
			if ($intakestatusinttodo == 0 AND in_array($intakestatusvog, array("verzocht"))) {
				$intakestatusint  	= 'nognix';
			}
			if ($intakestatusintdone == $intakestatusnodig) {
				$intakestatusint  	= 'compleet';
			}
			if ($intakestatusintdone < $intakestatusnodig AND $intakestatusinttodo == $intakestatusnodig) {
				$intakestatusint  	= 'afwachting';
			}
			if (in_array($intakestatusvog, array("klaarzetten"))) {
				$intakestatusint  	= 'klaarzetten';
			}

			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusinttodo  : ' .print_r($intakestatusinttodo,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusintdone  : ' .print_r($intakestatusintdone,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php','<pre>intakestatusint      : ' .print_r($intakestatusint,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			if ($extdebug >= 1) { watchdog('php','<pre>------#########################################################</pre>',NULL,WATCHDOG_DEBUG); }

