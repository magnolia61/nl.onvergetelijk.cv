   				$result_vogontvangst_count 	= $result_vogontvangst->count();
  				#if ($extdebug >= 4) { watchdog('php','<pre>params_activity_2_vogontvangst_get: '.print_r($result_vogontvangst,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  				#if ($extdebug >= 4) { watchdog('php','<pre>result_count_ontvangst: '.print_r($result_vogaanvraag_count,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  				if ($result_vogontvangst_count == 1) {
  					$vogontvangst_activity_2_id				= $result_vogontvangst[0]['id'];
  					$vogontvangst_activity_2_status			= $result_vogontvangst[0]['status_id'];
  					$vogontvangst_activity_2_status_name	= $result_vogontvangst[0]['status_id:name'];
  					$vogontvangst_activity_2_datum			= $result_vogontvangst[0]['activity_date_time'];
	  				if ($extdebug >= 2) { watchdog('php','<pre>vogontvangst_activity_2_id: '.print_r($vogontvangst_activity_2_id,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					#if ($extdebug >= 2) { watchdog('php','<pre>vogontvangst_activity_2_status: '.print_r($vogontvangst_activity_2_status,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 2) { watchdog('php','<pre>vogontvangst_activity_2_status_name: '.print_r($vogontvangst_activity_2_status_name,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 2) { watchdog('php','<pre>vogontvangst_activity_2_datum: '.print_r($vogontvangst_activity_2_datum,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  				} else {
					$vogontvangst_activity_2_id		= NULL;
  					$vogontvangst_activity_2_status	= NULL;
  					if ($extdebug >= 2) { watchdog('php','<pre>vogaanvraag_activity_2_id: No Activity Found (VOG ontvangst: '.print_r($part_vogontvangst,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  				}
    		}

	###############################################################################################################
	### 99 WRITE CONTACT & PARTICIPANT DATA TO DB
	###############################################################################################################
	if ($extdebug >= 1) { watchdog('php','<pre>### 99. WRITE CONTACT & PARTICIPANT DATA TO DB [groupID: '.$groupID.'] [op: '.$op.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
	###############################################################################################################

	if (!empty($params_contact)) {

		ksort($params_contact['values']);
		#$params_contact['reload']			= TRUE;
		$params_contact['checkPermissions']	= FALSE;
		$params_contact['debug']			= $apidebug;		
		if ($contact_id) {
			if ($extdebug >= 1) { watchdog('php','<pre>params_contact: '.print_r($params_contact,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$result = civicrm_api4('Contact', 'update', $params_contact);
			if ($extdebug >= 1) { watchdog('php','<pre>params_contact CV UPDATE EXECUTED [groupID: '.$groupID.']</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 4) { watchdog('php','<pre>result_contact: '.print_r($result,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		}
	}

	if (!empty($params_participant)) {

		ksort($params_participant);
		#$params_participant['reload']			= TRUE;
		$params_participant['checkPermissions']	= FALSE;
		$params_participant['debug']			= $apidebug;		
		if ($part_id) {
			if ($extdebug >= 1) { watchdog('php','<pre>params_participant: '.print_r($params_participant,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$result = civicrm_api4('Participant', 'update', $params_participant);
			if ($extdebug >= 1) { watchdog('php','<pre>params_participant CV UPDATE EXECUTED [groupID: '.$groupID.']</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 4) { watchdog('php','<pre>result_participant '.print_r($result,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		}
	}
    if (in_array($groupID, array("190", "140"))) { 	// CV & PART
	   	if ($extdebug >= 1) { watchdog('php','<pre>*** END EXTENSION VOG [groupID: '.$groupID.'] [op: '.$op.'] [entityID: '.$entityID.'] '.$part_functie.': '.$displayname.'] ***</pre>',NULL,WATCHDOG_DEBUG); }
	}
    if (in_array($groupID, array("225", "139"))) { // CV & PART
	   	if ($extdebug >= 1) { watchdog('php','<pre>*** END EXTENSION CV [groupID: '.$groupID.'] [op: '.$op.'] [entityID: '.$entityID.'] '.$part_functie.': '.$displayname.'] ***</pre>',NULL,WATCHDOG_DEBUG); }
	}	
}

