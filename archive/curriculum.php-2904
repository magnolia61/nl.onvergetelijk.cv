  				##############################

				$customFields = civicrm_api4('CustomField', 'get', [
					'select' => [
				    	'label',
				    	'data_type',
				    	'html_type',
				    	'option_group_id'
  					],
  					'where' => [
   						['id', '=', $fieldid],
 					],
  					'limit' => 1,
