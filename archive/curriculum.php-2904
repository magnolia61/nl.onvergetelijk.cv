						#if ($extdebug >= 3) { watchdog('php','<pre>params_optionvalues: '.print_r($params_optionvalues,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						$result = civicrm_api4('OptionValue', 'get', $params_optionvalues);
						#if ($extdebug >= 4) { watchdog('php','<pre>result_optionValues: '.print_r($result,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						$optionlabel = $result[0]['label'];
   						#if ($extdebug >= 3) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   						$newarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						#if ($extdebug >= 3) { watchdog('php','<pre>newarraylabels              : '.print_r($newarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

						if (is_array($newarraylabels)) {
							$newarraystring[$deltacategory][$customFieldName] = implode(" / ",$newarraylabels[$deltacategory][$customFieldName]);
							#if ($extdebug >= 3) { watchdog('php','<pre>newarraystring '.$deltacategory.'      : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (radioselect)      : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newarraystring[$deltacategory][$customFieldName];

				} else {

					$newarray 	= explode ('', $field['value']);
					if (!empty($newflat))	{
						$newarray	= array_filter($newarray);
					}
					if ($extdebug >= 3) { watchdog('php', '<pre>newarray 1                  : '.print_r($newarray,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

					foreach ($newarray as $optionvalue) {
						#if ($extdebug >= 1) { watchdog('php', '<pre>optionvalue new             : '.print_r($optionvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $optionvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						#if ($extdebug >= 3) { watchdog('php','<pre>params_optionvalues: '.print_r($params_optionvalues,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						$result = civicrm_api4('OptionValue', 'get', $params_optionvalues);
						#if ($extdebug >= 4) { watchdog('php','<pre>result_optionValues: '.print_r($result,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						$optionlabel = $result[0]['label'];
   						#if ($extdebug >= 3) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   						$newarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						#if ($extdebug >= 3) { watchdog('php','<pre>newarraylabels              : '.print_r($newarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

						if (is_array($newarraylabels)) {
							$newarraystring[$deltacategory][$customFieldName] = implode(" / ",$newarraylabels[$deltacategory][$customFieldName]);
							#if ($extdebug >= 3) { watchdog('php','<pre>newarraystring '.$deltacategory.'      : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>NEWVALUE (flatarray)        : '.print_r($newarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						if (empty($newflat))	{
							$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". '(leeggemaakt)';
						} else {
							$changes['new'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $newarraystring[$deltacategory][$customFieldName];
						}
					}
				}
			}
   		}

		if (!empty($changes)) {

  			$deltadetailsold 		= implode_recursive("<br>",$changes['old']);
  			$deltadetailsnew 		= implode_recursive("<br>",$changes['new']);

			if ($extdebug >= 1) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG);		}
  			if ($extdebug >= 1) { watchdog('php', '<pre>!!! CHANGED velden '.$deltacategory.' OUD :<br>'.$deltadetailsold.'</pre>',NULL,WATCHDOG_DEBUG);	}
  			if ($extdebug >= 1) { watchdog('php', '<pre>!!! CHANGED velden '.$deltacategory.' NEW :<br>'.$deltadetailsnew.'</pre>',NULL,WATCHDOG_DEBUG);	}
			if ($extdebug >= 1) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG);		}

   			//create Activity to record the change
			$params_activity_delta_create = [
				'checkPermissions' => FALSE,
 				'values' => [
	    			'source_contact_id' 	=> 1,
					'target_contact_id' 	=> $entityID,
#					'activity_type_id' 		=> 5559,
 					'activity_type_id:name' => 'Notificatie aandachtspunten',
 					'subject' 				=> 'Aanpassing: '. $deltacategory,
					'details' 				=> '<h3><b>OUD :</b></h3>'.$deltadetailsold.'<h3><b>NEW :</b></h3>'.$deltadetailsnew,
					'status_id:name' 		=> 'Completed',
					'AANPASSINGEN.Categorie'=> $deltacategory,
					'AANPASSINGEN.OUD' 		=> '<pre>'.$deltadetailsold.'</pre>',
					'AANPASSINGEN.NEW' 		=> '<pre>'.$deltadetailsnew.'</pre>',
    				#'ACT_ALG.kampkort'		=> $welkkampkort,
   					#'ACT_ALG.kampfunctie' 	=> $part_functie,		
    				#'ACT_ALG.kampstart' 	=> $event_start_date,
    				#'ACT_ALG.kampeinde' 	=> $event_einde_date,
    				#'ACT_ALG.kampjaar'		=> $event_kampjaar,
					'ACT_ALG.modified' 		=> $today_datetime,
  				],
  			];
			if ($extdebug >= 3) { watchdog('php','<pre>params_activity_delta_create: '.print_r($params_activity_delta_create,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$result_activity_delta_create = civicrm_api4('Activity', 'create', $params_activity_delta_create);
			if ($extdebug >= 4) { watchdog('php','<pre>result_activity_delta_create: '.print_r($result_activity_delta_create,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  		}
  	}
}

function curriculum_civicrm_fiscalyear($inputdatum) {

		$extdebug	= 0; // 1 = basic // 2 = verbose // 3 = params / 4 = results

		$fiscalyear_start = NULL;
		$fiscalyear_einde = NULL;

		$config = CRM_Core_Config::singleton( );
		$fiscalYearStart 	= $config->fiscalYearStart;
		$today_datetime 	= date("Y-m-d H:i:s");
		$inputyear 			= date('Y', strtotime($inputdatum));
		$inputdatum			= date('Y-m-d', strtotime($inputdatum));

		#####################################################################################################
    	if ($extdebug >= 1) { watchdog('php','<pre>### BEPAAL FISCALE JAAR VAN EEN GEGEVEN DATUM [inputdate: '.$inputdatum.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
		#####################################################################################################

		### 1 BASIS WAARDEN
		if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_start             : '.print_r($fiscalYearStart,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		#if ($extdebug >= 2) { watchdog('php','<pre>inputdate                    : '.print_r($inputdatum,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		#if ($extdebug >= 2) { watchdog('php','<pre>todaydatetime                : '.print_r($today_datetime,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		$event_fiscalyear_start = date("$inputyear-$fiscalYearStart[M]-$fiscalYearStart[d]");
		$fiscalyear_einde		= date("$inputyear-$fiscalYearStart[M]-$fiscalYearStart[d]");
		$event_fiscalyear_start	= date('Y-m-d', strtotime($event_fiscalyear_start));
		$fiscalyear_einde		= date('Y-m-d', strtotime($fiscalyear_einde));

		### 2 START MOET EERDER ZIJN DAN INPUT DATUM (ANDERS STARTDATE -1)
    	if (strtotime($event_fiscalyear_start) > strtotime($inputdatum)) {
			if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear_start ('.$event_fiscalyear_start.') moet minus 1 jaar want is groter dan inputdatum ('.$inputdatum.')</pre>',NULL,WATCHDOG_DEBUG); }
			$event_fiscalyear_start = date('Y-m-d',(strtotime ( '-1 year' , strtotime ( $event_fiscalyear_start ) ) ) );  			
  			if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_start -1 year     : '.print_r($event_fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  		}

		### 3 END MOET LATER ZIJN DAN INPUT DATUM (ANDERS ENDDATE +1)
		if (strtotime($fiscalyear_einde)   <= strtotime($inputdatum)) {
			if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear_einde ('.$fiscalyear_einde.') moet plus 1 jaar want is kleiner dan inputdatum ('.$inputdatum.')</pre>',NULL,WATCHDOG_DEBUG); }
  			$fiscalyear_einde = date('Y-m-d',(strtotime ( '+1 year' , strtotime ( $fiscalyear_einde ) ) ) );  	
  			if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_end +1 year       : '.print_r($fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		}

		### 4 CORRIGEER DATUMS OP DAG NAUWKEURIG
		if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear_einde ('.$fiscalyear_einde.') moet minus 1 dag om laatste dag fiscal year te markeren</pre>',NULL,WATCHDOG_DEBUG); }
		$event_fiscalyear_start 	= date('Y-m-d',(strtotime ( '-0 day' , strtotime ( $event_fiscalyear_start ) ) ) );
		$fiscalyear_einde 	= date('Y-m-d',(strtotime ( '-1 day' , strtotime ( $fiscalyear_einde ) ) ) );
		if ($extdebug >= 3) { watchdog('php','<pre>fiscalyear_einde -1 day      : '.print_r($fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

		$fiscalyear_array = array(
			fiscalyear_input => $inputdatum,
    		fiscalyear_start => $event_fiscalyear_start,
    		fiscalyear_einde => $fiscalyear_einde,
		);

		### 5 EINDRESULTAAT
		if ($extdebug >= 2) { watchdog('php','<pre>### fiscalyear resultaat op basis van inputdatum ('.$inputdatum.')</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_start             : '.print_r($event_fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>fiscalyear_einde             : '.print_r($fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 1) { watchdog('php','<pre>fiscalyear_array             : '.print_r($fiscalyear_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

		# ATTEMPTY TO RETREIVE FISCAL YEAR START VALUE FROM CACHE

		Civi::cache()->set('cache_fiscalyear_start', 	$today_fiscalyear_start);
		Civi::cache()->set('cache_fiscalyear_einde', 	$today_fiscalyear_einde);

		return $fiscalyear_array;
}

function curriculum_civicrm_custom($op, $groupID, $entityID, &$params) {

	#civicrm_api3('Contact', 'getfields', array('cache_clear' => 1));
	#civicrm_api3('Participant', 'getfields', array('cache_clear' => 1));
	#CRM_Core_PseudoConstant::flush();

	$extdebug	= 3; // 1 = basic // 2 = verbose // 3 = params / 4 = results
	$apidebug	= FALSE;
	$extcv 		= 1;
	$extdjcont 	= 1;
	$extdjpart	= 1;
	$exttag		= 1;
	$extrel		= 1;
	$extchk		= 1;
	$extvog		= 1;
	$extact		= 1;
	$extref		= 1;
	$testreg	= 1;

	if ($op != 'create' && $op != 'edit') { //    did we just create or edit a custom object?
  		if ($extdebug >= 2) { watchdog('php','<pre>EXIT: op != create OR op != edit</pre>',NULL,WATCHDOG_DEBUG); }
		return; //	if not, get out of here
	}

	if (in_array($groupID, array("225", "139", "190", "140"))) { // CV & PART
//	if (in_array($groupID, array("225", "139", "140"))) { // CV & PART
		// 101  EVENT KENMERKEN
		// 139	PART DEEL
		// 190	PART LEID
		// (140	PART LEID VOG)
		// 106	TAB  WERVING
		// 103	TAB  CURRICULUM
		// 149  TAB  TALENT
		// 150	TAB  PROMOTIE
		// 165	PART REFERENTIE
		// 213  PART LEID REF
		// 205  PART 
		// 225  JAAROVERZICHT
    	$processcurriculum = 1;
    } else {
        return; //	if not, get out of here
    }

    if (in_array($groupID, array("225", "139", "190", "140"))) { // CV & PART
    	if ($extdebug >= 1) { watchdog('php','<pre>*** 1. START EXTENSION CV [groupID: '.$groupID.'] [op: '.$op.'] [entityID: '.$entityID.'] ***</pre>',NULL,WATCHDOG_DEBUG); }

    	$diffyears				= 0;
    	$eventtype 				= 0;
		$tagnr_deel 			= 0;
		$tagcv_deel 			= NULL;
		$tagcv_deel_array		= [];
   		$extcv_deel 			= NULL;
		$evtcv_deel_array 		= [];
   		$tagcv_leid 			= NULL;
   		$tagcv_leid_array 		= [];
   		$extcv_leid 			= NULL;
   		$extcv_leid_array 		= [];
   		$tagnr_leid 			= 0;
   		$tagverschildeel		= 0;
   		$tagverschilleid		= 0;
		$welkkamplang 			= 0;
		$welkkampkort 			= 0;
		$contact_id 			= NULL;
		$event_type_id 			= 0;
		$part_role_id			= NULL;
		$part_status_id			= NULL;
		$part_functie			= NULL;
		$part_eventid			= NULL;

		$diteventdeelyes 		= 0;
		$diteventdeelmss 		= 0;
		$diteventdeelnot 		= 0;
		$diteventleidyes		= 0;
		$diteventleidmss 		= 0;
		$diteventleidnot 		= 0;

		$ditjaardeelyes 		= 0;
		$ditjaardeelmss 		= 0;
		$ditjaardeelnot 		= 0;
		$ditjaarleidyes			= 0;
		$ditjaarleidmss 		= 0;
		$ditjaarleidnot 		= 0;
		$curcv_deel_array 		= [];
		$curcv_leid_array 		= [];
		$curcv_deel_array_nr	= 0;
		$curcv_leid_array_nr	= 0;
		$evtcv_deel_array 		= [];
		$evtcv_deel_top_array 	= [];
		$evtcv_leid_array 		= [];
		$maxcv_deel_array 		= [];

		$ditkaljaar 			= date("Y");
		$partstatusyes 			= array(1,2,5,6,15, 16);			//	PARTICIPANT STATUS BETEKENT DEELNAME = YES
		$partstatusnot 			= array(4,11,17,26);				//	PARTICIPANT STATUS BETEKENT DEELNAME = NO (GECANCELLED, NIET GOEDGEKEURD OF OVERGEDRAGEN)
		$partstatusmss			= array(7,8,9,10);					//	PARTICIPANT STATUS BETEKENT DEELNAME = (NOG) NIET YES (WACHTLIJST OF GOEDKEURING)
		$eventypesdeel 			= array(11, 12, 13, 14, 21, 22, 23, 24, 33, 102);	//	EVENT_TYPE_ID'S VAN DE KAMPEN VAN DIT JAAR 			(- TEST_DEEL)
		$eventypesdeeltop		= array(33);										//	EVENT_TYPE_ID'S VAN DE KAMPEN VAN DIT JAAR 			(- TEST_DEEL)
		$eventypesleid 			= array(1, 101);									//	EVENT_TYPE_ID VAN HET LEIDING EVENT VAN DIT JAAR 	(- TEST_LEID)
		$eventypesmeet 			= array(2);											//	EVENT_TYPE_ID VAN HET KAMPSTAF EVENT VAN DIT JAAR 	(- KAMPSTAF)
		$eventypesdeeltest 		= array(102);
		$eventypesleidtest 		= array(101);
		$intnodig				= NULL;
		$bionodig				= NULL;
		$vognodig 				= NULL;
		$refnodig 				= NULL;
		$vogdatethisyear 		= 0;
		$vogdatenextyear 		= 0;
		$vognodignextyear		= 0;
		$part_reffeedback  		= NULL;
		$drupal_name 			= NULL;
		$part_eventtypeid		= NULL;
		$params_contact 		= NULL;
		$params_participant 	= NULL;
		$drupalufmatch_found 	= 0;
		$part_groepsletter		= NULL;
		$part_groepskleur		= NULL;
		$eerstedeel  			= "";
		$laatstedeel 			= "";
		$eersteleid  			= "";
		$laatsteleid 			= "";
		$eerstexdeel 			= NULL;
		$eerstexleid 			= NULL;
		$group_staf				= 0;
		$group_kamp				= 0;
		$referentie_gevraagd	= NULL;
		$referentie_feedback	= NULL;
		$referentie_bezwaar		= NULL;

		$today_nextkamp_jaar	= NULL; 
		$today_datetime 		= date("Y-m-d H:i:s");
		$today_datetimenext		= date('Y-m-d H:i:s', strtotime('+1 year', strtotime($today_datetime)) );		

		#####################################################################################################
		# 1.0 BEPAAL DE GRENZEN VAN HET HUIDIGE FISCALE JAAR
    	if ($extdebug >= 1) { watchdog('php','<pre>### 1.0 BEPAAL DE GRENZEN VAN HET HUIDIGE FISCALE JAAR [groupID: '.$groupID.'] [op: '.$op.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
		#####################################################################################################

		$today_fiscalyear 		= curriculum_civicrm_fiscalyear($today_datetime);
		$today_fiscalyear_start	= $today_fiscalyear['fiscalyear_start'];
		$today_fiscalyear_einde	= $today_fiscalyear['fiscalyear_einde'];
		$today_kampjaar			= date('Y', strtotime($today_fiscalyear_einde));	// M61 theorerisch niet 100% beter jaar van kampdatum zelf

		wachthond($extdebug, 2, "<pre>XXX today_datetime               : '.print_r($today_datetime,TRUE).");
		wachthond($extdebug, 2, "<pre>YYY today_datetime               : '.$today_datetime.'");
		wachthond($extdebug, 2, "<pre>XXX today_datetime               : $today_datetime");

		if ($extdebug >= 2) { watchdog('php','<pre>today_datetime               : '.print_r($today_datetime,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }	
		if ($extdebug >= 2) { watchdog('php','<pre>today_kampjaar               : '.print_r($today_kampjaar,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }	
		if ($extdebug >= 2) { watchdog('php','<pre>today_fiscalyear_start       : '.print_r($today_fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>today_fiscalyear_einde       : '.print_r($today_fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

		$nexty_fiscalyear 		= curriculum_civicrm_fiscalyear($today_datetimenext);
		$nexty_fiscalyear_start	= $nexty_fiscalyear['fiscalyear_start'];
		$nexty_fiscalyear_einde	= $nexty_fiscalyear['fiscalyear_einde'];
		$nexty_kampjaar			= date('Y', strtotime($nexty_fiscalyear_einde));

		if ($extdebug >= 2) { watchdog('php','<pre>todaydatetimenext            : '.print_r($today_datetimenext,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>nexty_kampjaar               : '.print_r($nexty_kampjaar,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }	
		if ($extdebug >= 2) { watchdog('php','<pre>nexty_fiscalyear_start       : '.print_r($nexty_fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>nexty_fiscalyear_einde       : '.print_r($nexty_fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

  		// zet grens 'NOG GOED OP 1 NOVEMBER - reken te late REF's & VOG's nog bij dat jaar
		$grensvognoggoed 		= date("Y-11-01", strtotime("-3 year")); // VOG noggoed als datum binnen previous 2 fiscal year valt
		$grensvognoggoedplusone = date("Y-11-01", strtotime("-2 year")); // M61 tijdelijk tbv gelijktrekken VOG met REF
		$grensrefnoggoed 		= date("Y-11-01", strtotime("-3 year")); // REF noggoed als datum binnen previous 2 fiscal year valt
  		if ($extdebug >= 2) { watchdog('php','<pre>grensvognoggoed              : '.print_r($grensvognoggoed,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>grensrefnoggoed              : '.print_r($grensrefnoggoed,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

		$cache_fiscalyear_start = Civi::cache()->get('cache_fiscalyear_start');
		$cache_fiscalyear_einde	= Civi::cache()->get('cache_fiscalyear_einde');

		# ATTEMPTY TO RETREIVE FISCAL YEAR START VALUE FROM CACHE
		if ($extdebug >= 2) { watchdog('php','<pre>cache_fiscalyear_start       : '.print_r($cache_fiscalyear_start,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 2) { watchdog('php','<pre>cache_fiscalyear_einde       : '.print_r($cache_fiscalyear_einde,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

		#####################################################################################################
		# 1.1 VIND ALLE EVENTS LEIDING & DEELNEMERS VOOR DIT JAAR
    	if ($extdebug >= 1) { watchdog('php','<pre>### 1.1 VIND ALLE EVENT LEIDING & DEELNEMERS VOOR DIT JAAR [groupID: '.$groupID.'] [op: '.$op.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
		#####################################################################################################

		$params_event_deel = [
  			'checkPermissions' => FALSE,
			'debug' 	=> $apidebug,  			
  			'select' 	=> [
    			'id', 'event_type_id', 'title', 'row_count',
  			],
  			'where' 	=> [
    			['event_type_id', 'IN', $eventypesdeel],
    			['title', 'NOT LIKE', 	'%TEST%'],
    			['start_date', '=', 	'this.fiscal_year'],
  			],
		];

		if ($extdebug >= 3) { watchdog('php','<pre>params_event_deel: '.print_r($params_event,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		$result_deel = civicrm_api4('Event', 'get', $params_event_deel);
		if ($extdebug >= 4) { watchdog('php','<pre>result_event_deel: '.print_r($result_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
		$kampidsdeelcount 	= $result_deel->count();
		$kampidsdeel 		= $result_deel->column('id');  // maakt een array met alleen de velden voor id
		ksort($kampidsdeel);

		$params_event_leid = [
  			'checkPermissions' => FALSE,
  			'debug' => $apidebug,
  			'select' => [
    			'id', 'event_type_id', 'title', 'row_count',
  			],
  			'where' => [
    			['event_type_id', 'IN', $eventypesleid],
    			['title', 'NOT LIKE', 	'%TEST%'],
    			['start_date', '=', 	'this.fiscal_year'],
  			],
		];

		if ($extdebug >= 3) { watchdog('php','<pre>params_event_leid: '.print_r($params_event,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		$result_leid = civicrm_api4('Event', 'get', $params_event_leid);
		if ($extdebug >= 4) { watchdog('php','<pre>result_event_leid: '.print_r($result_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
		$kampidsleid 		= $result_leid->column('id'); // maakt een array met alleen de velden voor id
		ksort($kampidsleid);
  		$kampids_all 		= $kampidsdeel;
  		array_push($kampids_all, $kampidsleid[0]);

		$params_event_meet = [
  			'checkPermissions' => FALSE,
  			'debug' => $apidebug,
  			'select' => [
    			'id', 'event_type_id', 'title', 'row_count',
  			],
  			'where' => [
    			['event_type_id', 'IN', $eventypesmeet],
    			['title', 'NOT LIKE', 	'%TEST%'],
    			['start_date', '>=', 	$today_datetime],
    			['start_date', '<', 	$today_fiscalyear_einde],
  			],
		];

		if ($extdebug >= 3) { watchdog('php','<pre>params_event_meet: '.print_r($params_event_meet,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		$result_meet = civicrm_api4('Event', 'get', $params_event_meet);
		if ($extdebug >= 4) { watchdog('php','<pre>result_event_meet: '.print_r($result_meet,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
		$kampidsmeet = $result_meet->column('id'); // maakt een array met alleen de velden voor id
		ksort($kampidsmeet);

		if ($extdebug >= 1) { watchdog('php','<pre>kampidsdeel: '.print_r($kampidsdeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 1) { watchdog('php','<pre>kampidsleid: '.print_r($kampidsleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 1) { watchdog('php','<pre>kampidsmeet: '.print_r($kampidsmeet,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
		if ($extdebug >= 1) { watchdog('php','<pre>kampids_all: '.print_r($kampids_all,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

		#####################################################################################################
		# 1.2 CHECK PARTICIPANT STATUS FOR ALL KAMPIDS
    	if ($extdebug >= 1) { watchdog('php','<pre>### 1.2 CHECK PARTICIPANT STATUS [groupID: '.$groupID.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
		#####################################################################################################

    	# A. als partitipant wordt bewerkt dan zoek dan de participant info van dat event
    	# B. indien participant die wordt bewerkt is gecancelled dan kijken of er een andere registratie is die niet gecancceled is
    	# C. indien contact wordt geedit (en geen participant), dan kijken of er een actieve registratie in dit fiscal jaar is
    	# D. indien dit allemaal niet het geval is, gewoon basic info ophalen voor het contact

    	if (in_array($groupID, array("139", "190", "140"))) {	// PART DEEL + PART LEID + PART LEID VOG
			$params_var = [
	    		['id', '=', $entityID],
   			];
    	}
		if (in_array($groupID, array("225"))) {					// TAB TALENT
			$params_var = [
	    		['contact_id', 	'=', 	$entityID],
	    		['event_id', 	'IN', 	$kampids_all],
   			];
    	}

		$params_partinfo = [
			'checkPermissions' => FALSE,
			'debug' => $apidebug,
			'select' => [
    			'id', 
    			'contact_id', 
    			'contact_id.first_name',
    			'status_id', 
    			'role_id', 
    			'register_date',

				'event_id',
				'event.event_type_id',
				'event.Event_Kenmerken.Welk_kamp_kort_',
				'event.Event_Kenmerken.Type_kamp',		

        		'PART.PART_welkkamp_lang',
    			'PART.PART_welkkamp_kort',		
    			'PART.PART_1xkeer_deel',
    			'PART.PART_1xkeer_leid',
    			'PART_DEEL.Groep_klas',
    			'PART_DEEL.Voorkeur',
    			'PART.PART_kamptype_id',    			    			
    			'PART_LEID.Welk_kamp',
    			'PART.PART_kampfunctie',
    			'PART_LEID.Functie',
    			'PART.PART_datum_check',

				'PART_EVALUATIE.DATUM_evaluatie',

    			'contact_id.INTAKE.DITJAAR_INT_nodig',
    			'contact_id.INTAKE.Status_INT',

				'contact_id.INTAKE.Intakegesprek_datum',
    			'contact_id.INTAKE.Intakegesprek_persoon',
 
    			'contact_id.INTAKE.DITJAAR_BIO_nodig',
	   			'contact_id.INTAKE.Status_BIO',
				'contact_id.INTAKE.BIO_ingevuld',
				'contact_id.INTAKE.BIO_gecheckt',

    			'contact_id.INTAKE.DITJAAR_REF_nodig',
    			'contact_id.INTAKE.Status_REF',
    			'contact_id.INTAKE.LAATSTE_REF_datum',
    			'contact_id.INTAKE.LAATSTE_REF_naam',
    			'PART_LEID_REF.REF_persoon',
    			'PART_LEID_REF.REF_gevraagd',
    			'PART_LEID_REF.REF_feedback',

	   			'contact_id.INTAKE.DITJAAR_VOG_nodig',
     			'contact_id.INTAKE.Status_VOG',
    			'contact_id.INTAKE.Datum_meest_recente_VOG',
    			'contact_id.INTAKE.Kenmerk_VOG',
    			'PART_LEID_VOG.Datum_verzoek',
    			'PART_LEID_VOG.Datum_aanvraag',
    			'PART_LEID_VOG.Datum_ontvangst',
    			'PART_LEID_VOG.Datum_nieuwe_VOG',
    			'PART_LEID_VOG.Kenmerk_VOG',

    			'PART_DEEL.Tijdslot_brengen',
    			'PART_DEEL.Tijdslot_halen',
    			'PART_INTERN.Groepje',
    			'PART_INTERN.Groepjeskleur',
    			'PART_INTERN.Slaapzaal',

    			'PART_KAMPGELD.Regeling_kampgeld:label',

				'PART_DEEL_INTERN.criteria_indicatie',
				'PART_DEEL_INTERN.criteria_beoordeling',

