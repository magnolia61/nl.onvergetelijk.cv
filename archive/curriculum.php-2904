				}
				// M61 zet refstatus op inhaal voor leiding waarbij die mist die al vaker zijn meegeweest
				if (empty($refrecent) AND $curcv_keer_leid > 1) {
					$refnodig 			= 'inhaal';
					$intakestatusref 	= 'ontbreekt';
				}

				// M61 zet refstatus op ontbreekt voor leiding waarbij die mist die al vaker zijn meegeweest
				if ($vognodignextyear == 1 AND empty($refrecent) AND $curcv_keer_leid >= 10) {
					$status_refpersoon 	= 'Not Required';
					$refnodig 			= 'volgendjaar';
					$intakestatusref 	= 'ontbreekt';
				}
				// M61 trek refnodig gelijk met vognodig voor leiding vaker dan 9 (totdat alles weer gelijk is)
				if (empty($refrecent) AND in_array($vognodig, array("noggoed")) AND $curcv_keer_leid >= 5) {
					$status_refpersoon 	= 'Not Required';
					$refnodig 			= 'noggoed';
					$intakestatusref 	= 'ontbreekt';
				}
				// M61 trek refnodig gelijk met vognodig voor leiding vaker dan 2
				if ($refrecent AND in_array($vognodig, array("noggoed")) AND $curcv_keer_leid > 2) {
					$status_refpersoon 	= 'Not Required';
					$refnodig 			= 'noggoed';
					$intakestatusref 	= 'noggoed';
				}

				// M61 zorg dat de REF persoon activity en mails pas starten zodra de VOG klaargezet is (1 mail met intake todo's)
				if (in_array($vognodig, array("eerstex", "elkjaar", "opnieuw")) AND $vogverzoekditjaar == 1) {
