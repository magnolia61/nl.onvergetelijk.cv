			if ($result_drupal) {
				$connected_drupal_id 	= $result_drupal['values'][0]['id'];
				$connected_drupal_name 	= $result_drupal['values'][0]['name'];			
				if ($extdebug >= 3) { watchdog('php','<pre>connected_drupal_id  	: '.print_r($connected_drupal_id,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 3) { watchdog('php','<pre>connected_drupal_name	: '.print_r($connected_drupal_name,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
