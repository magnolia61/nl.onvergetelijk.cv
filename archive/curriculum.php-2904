	    		# CHECK IF CMS IDENTIFIER ('.$cmsidentitier.') HAS A MATCH
    			if ($extdebug >= 1) { watchdog('php','<pre>###### CHECK IF CMS IDENTIFIER ('.$cmsidentitier.') HAS A MATCH</pre>',NULL,WATCHDOG_DEBUG); }
				#####################################################################################################
				$params_ufmatchget = [
	  				'checkPermissions' => FALSE,
					'debug' => $apidebug,
  					'select' => [
     					'row_count', 
    					'id', 
    					'uf_id', 
    					'uf_name', 
