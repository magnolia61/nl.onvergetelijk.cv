					} else {

						foreach ($oldarray as $optionvalue) {

						#if ($extdebug >= 1) { watchdog('php','<pre>optionvalue                 : '.print_r($optionvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

						$params_optionvalues = [
							'checkPermissions' => FALSE,
  							'select' => [
    							'name', 'label',
  							],
  							'where' => [
								['value', '=', $optionvalue], 
    							['option_group_id', '=', $customFieldOptionGroup]
  							],
						];
						if ($extdebug >= 3) { watchdog('php','<pre>params_optionvalues: '.print_r($params_optionvalues,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						$result = civicrm_api4('OptionValue', 'get', $params_optionvalues);
						if ($extdebug >= 4) { watchdog('php','<pre>result_optionValues: '.print_r($result,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						$optionlabel = $result[0]['label'];
   						if ($extdebug >= 3) { watchdog('php','<pre>optionlabel                 : '.print_r($optionlabel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

   						$oldarraylabels[$deltacategory][$customFieldName][] = $optionlabel;
   						if ($extdebug >= 2) { watchdog('php','<pre>oldarraylabels              : '.print_r($oldarraylabels,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

						if (is_array($oldarraylabels)) {
							$oldarraystring[$deltacategory][$customFieldName] = implode(" / ",$oldarraylabels[$deltacategory][$customFieldName]);
							#if ($extdebug >= 3) { watchdog('php','<pre>oldarraystring '.$deltacategory.'      : '.print_r($oldarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
						}
						if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (flatarray)        : '.print_r($oldarraystring[$deltacategory][$customFieldName],TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
						$newoptionlabel = $oldarraystring[$deltacategory][$customFieldName];
