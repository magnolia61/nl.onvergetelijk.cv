				$customFieldDataType	= $customFields[0]['data_type'];
				$customFieldHtmlType	= $customFields[0]['html_type'];
				$customFieldOptionGroup = $customFields[0]['option_group_id'];
				$customFieldNameLenght	= strlen($customFieldName);

				if ($extdebug >= 2) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG); 	   }
				if ($extdebug >= 2) { watchdog('php', '<pre>### customFieldName (old)   : '.print_r($customFieldName,TRUE).' ('.$customFieldDataType.' / '.$customFieldHtmlType.') '.$customFieldOptionGroup.'</pre>',NULL,WATCHDOG_DEBUG); 	    }
				if ($extdebug >= 2) { watchdog('php', '<pre>################################################################</pre>',NULL,WATCHDOG_DEBUG); 	   }

				if ($extdebug >= 1) { watchdog('php', '<pre>oldvalue 1 ('.$oldvaluetype.')          : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
  				if ($extdebug >= 1) { watchdog('php', '<pre>newvalue 1 ('.$oldvaluetype.')          : '.print_r($newvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

				if ($customFieldNameLenght < 24 AND $customFieldNameLenght >= 16) {
