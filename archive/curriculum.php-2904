			#if ($extdebug >= 1) { watchdog('php', '<pre>field        		: '.print_r($field,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

			$fieldname	= $field['column_name'];
			$fieldid	= $field['custom_field_id'];
  			$newvalue 	= $field['value'];

       		$oldvalue 	= civicrm_api3('Contact', 'getvalue', [
       			'id'     => $field['entity_id'],									// ik denk dat dit alleen klopt bij contact id en niet als het part id is
       			'return' => "custom_{$field['custom_field_id']}",
       		]);

  			if (empty($oldvalue)) {
#  				$oldvalue = NULL;
  			}
  			if (empty($newvalue)) {
#  				$newvalue = NULL;
  			} 

			if (is_array($oldvalue)) {
				$oldflat 		= implode(" / ",$oldvalue);
#				if (!empty($oldflat))	{
#					$oldarray		= array_filter($oldvalue);
					$oldarray		= $oldvalue;
#				}
				$oldvaluetype 	= "array";
			} else {
				$oldflat		= trim($oldvalue);
				$oldvaluetype 	= "strng";
			}

			$newvalue 	= trim($newvalue, '');
			$newvalue 	= str_replace('', ' / ', trim($newvalue));
			$newflat 	= trim($newvalue);

			$newsec = strtotime($newflat);
			#if ($extdebug >= 1) { watchdog('php', '<pre>newsec  ('.$fieldname.')    : '.print_r($newsec,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$newdate = date("Y-m-d H:i:s", $newsec);  
			#if ($extdebug >= 1) { watchdog('php', '<pre>newdate                     : '.print_r($newdate,TRUE).' ('.$fieldname.')</pre>',NULL,WATCHDOG_DEBUG); }
			if ($newdate == $oldflat) {
				$newflat = $newdate;
			}

			#if ($extdebug >= 1) { watchdog('php', '<pre>oldvalue 0 ('.$oldvaluetype.')          : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php', '<pre>oldflat  0 ('.$oldvaluetype.')          : '.print_r($oldflat,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			#if ($extdebug >= 1) { watchdog('php', '<pre>newvalue 0 ('.$oldvaluetype.')          : '.print_r($newvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 1) { watchdog('php', '<pre>newflat  0 ('.$oldvaluetype.')          : '.print_r($newflat,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			if ($oldflat != $newflat) {

  				##############################
  				#### OLDVALUE ARRAY ####
  				##############################

				#if ($extdebug >= 1) { watchdog('php', '<pre>optionvalue old             : '.print_r($optionvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}				
				$customFields = civicrm_api4('CustomField', 'get', [
					'select' => [
				    	'label',
				    	'data_type',
				    	'html_type',
				    	'option_group_id'
  					],
  					'where' => [
