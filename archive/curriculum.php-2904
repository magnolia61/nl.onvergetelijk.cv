				#if ($extdebug >= 3) { watchdog('php', '<pre>### customFieldName (new)   : '.print_r($customFieldName,TRUE).' ('.$customFieldDataType.' / '.$customFieldHtmlType.') '.$customFieldOptionGroup.'</pre>',NULL,WATCHDOG_DEBUG); 	    }

				if (empty($newvalue))	{ $newvalue = '(leeggemaakt)'; 	}

