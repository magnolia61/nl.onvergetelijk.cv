	    		if ($extdebug >= 1) { watchdog('php','<pre>------ a) WARNING: GEVONDEN DRUPALID ('.$connected_drupal_id.') IS NIET GELIJK AAN EXTERNAL IDENTIFIER ('.$cmsidentitier.')</pre>',NULL,WATCHDOG_DEBUG); }			
    			$drupalid_danger = 1;
			} else {
    			$drupalid_danger = 0;
			}			

			#####################################################################################################
    		if ($extdebug >= 1) { watchdog('php','<pre>###### b) CHECK VIA DRUPAL API IF CID: '.$contact_id.' HAS A CONNECTED DRUPAL ACCOUNT</pre>',NULL,WATCHDOG_DEBUG); }
			#####################################################################################################

			#####################################################################################################
	    	# CHECK IF CMS IDENTIFIER ('.$cmsidentitier.') EXIST IN DRUPAL
			#####################################################################################################

			global $connected_account;
//			$connected_account 	 = user_load($connected_drupal_id);
			$connected_account 	 = user_load($cmsidentitier);				
