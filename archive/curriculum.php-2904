				if ($intnodig)		{ $params_participant['values']['PART.PART_intnodig:name']	= $intnodig;	}	#PART NODIG INT
				if ($nawnodig)		{ $params_participant['values']['PART.PART_nawnodig:name']	= $nawnodig;	}	#PART NODIG NAW
				if ($bionodig)		{ $params_participant['values']['PART.PART_bionodig:name']	= $bionodig;	}	#PART NODIG BIO
				if ($refnodig)		{ $params_participant['values']['PART.PART_refnodig:name']	= $refnodig; 	}	#PART NODIG REF
				if ($vognodig)		{ $params_participant['values']['PART.PART_vognodig:name']	= $vognodig;	}	#PART NODIG VOG

				if ($intnodig)		{ $params_contact['values']['INTAKE.DITJAAR_INT_nodig'] 	= $intnodig;	}	#TAB  NODIG INT
// M61: TODO: nawnodig veld is weg bij contact_intake maar staat nog wel in part_intake: TODO: kijken of dit op meer plekken wegkan
#				if ($nawnodig)		{ $params_contact['values']['INTAKE.DITJAAR_NAW_nodig']		= $nawnodig;	}	#TAB  NODIG NAW
				if ($bionodig)		{ $params_contact['values']['INTAKE.DITJAAR_BIO_nodig']		= $bionodig;	}	#TAB  NODIG BIO
				if ($refnodig)		{ $params_contact['values']['INTAKE.DITJAAR_REF_nodig'] 	= $refnodig;	}	#TAB  NODIG VOG
				if ($vognodig)		{ $params_contact['values']['INTAKE.DITJAAR_VOG_nodig'] 	= $vognodig;	}	#TAB  NODIG REF

				if ($extdebug >= 1) { watchdog('php','<pre>intnodig_ditjaar : '.print_r($intnodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 1) { watchdog('php','<pre>nawnodig_ditjaar : '.print_r($nawnodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 1) { watchdog('php','<pre>bionodig_ditjaar : '.print_r($bionodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 1) { watchdog('php','<pre>refnodig_ditjaar : '.print_r($refnodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    			if ($extdebug >= 1) { watchdog('php','<pre>vognodig_ditjaar : '.print_r($vognodig,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

				if ($intakestatusint)	{ $params_contact['values']['INTAKE.Status_INT'] 	= $intakestatusint; }
				if ($intakestatusnaw)	{ $params_contact['values']['INTAKE.Status_NAW'] 	= $intakestatusnaw; }
				if ($intakestatusbio)	{ $params_contact['values']['INTAKE.Status_BIO'] 	= $intakestatusbio; }	
				if ($intakestatusref)	{ $params_contact['values']['INTAKE.Status_REF'] 	= $intakestatusref; }
				if ($intakestatusvog)	{ $params_contact['values']['INTAKE.Status_VOG'] 	= $intakestatusvog; }

				if ($extdebug >= 1) { watchdog('php','<pre>intakestatusint  : ' .print_r($intakestatusint,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 1) { watchdog('php','<pre>intakestatusnaw  : ' .print_r($intakestatusnaw,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
