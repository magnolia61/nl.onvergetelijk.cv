	// ************************************************************************************************************
	$diffsince_evaluatieverzoek	= date_diff(date_create($event_einde_date),date_create($today_datetime));
	$dayssince_evaluatieverzoek	= $diffsince_evaluatieverzoek->format('%a');
	if ($dayssince_evaluatieverzoek >= 0)		{ $status_evaluatie = "Pending"; 		} // AFWACHTING
	if ($dayssince_evaluatieverzoek >= 14)		{ $status_evaluatie = "Left Message";	} // HERINNERD
	if ($dayssince_evaluatieverzoek >= 28)		{ $status_evaluatie = "Unreachable"; 	} // ONBEREIKBAAR
	if ($dayssince_evaluatieverzoek >= 42)		{ $status_evaluatie = "No_show"; 		} // VERLOPEN
	if ($dayssince_evaluatieverzoek >= 270)		{ $status_evaluatie = "Bounced"; 		} // GEFAALD		
	if ($part_evaluatie) 						{ $status_evaluatie = 'Completed';		} // AFGEROND (OVERRULE STATUS ALS EVALUATIE IS INGEVULD)

	$eventendplus30		= strtotime ( '+30 day' , strtotime ($event_einde_date) ) ;
	$eventendplus60		= strtotime ( '+60 day' , strtotime ($event_einde_date) ) ;
	$eventendplus60date = date ( 'Y-m-d H:i' , $eventendplus60 );	
	if ($extdebug >= 2) { watchdog('php','<pre>datum evaluatie                  : '.print_r($part_evaluatie,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
	if ($extdebug >= 2) { watchdog('php','<pre>dayssince_evaluatieverzoek       : '.print_r($dayssince_evaluatieverzoek,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
	if ($extdebug >= 2) { watchdog('php','<pre>event end date                   : '.print_r($event_einde_date,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
	if ($extdebug >= 2) { watchdog('php','<pre>event end date + 60              : '.print_r($eventendplus60date,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

	// ************************************************************************************************************
	// 5.3 CREATE AN ACTIVITY 'EVALUATIE' ALS PERSOON MEEGAAT EN ER IS NOG GEEN BIJBEHORENDE ACTIVITY
	// ************************************************************************************************************

	if ($extdebug >= 1) { watchdog('php','<pre>--- 5.3 CREATE AN ACTIVITY EVALUATIE INDIEN NODIG</pre>',NULL,WATCHDOG_DEBUG); }
	if (empty($evaluatie_activity_id)) {

		$evaluatie_activity_status_name = 'Scheduled';  // initial status ingepland

    	if (($ditjaardeelyes == 1 OR $ditjaarleidyes == 1 ) AND $event_einde_date <= $today_datetime) {
			$params_activity_evaluatie_create = [
  				'checkPermissions' => FALSE,
