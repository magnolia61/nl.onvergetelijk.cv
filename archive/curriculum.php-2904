#  	}

	#if ($extdebug >= 1) { watchdog('php', '<pre>deltacategory       	: '.print_r($deltacategory,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
	#$keys = array_keys(array_combine(array_keys($params), array_column($params, 'table_name')),'civicrm_value_aandachtspunten_gedrag_1');  	
  	#if ($extdebug >= 1) { watchdog('php', '<pre>keys met gedrag       	: '.print_r($keys,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

