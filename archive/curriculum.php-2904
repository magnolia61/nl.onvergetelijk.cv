		#####################################################################################################
		# 1.10 RETRIEVE DRUPAL UID, LOGINNAME & EMAIL
		#####################################################################################################

   		if (in_array($groupID, array("225", "139", "190"))) {	// PART DEEL + PART LEID
			if ($extdebug >= 1) { watchdog('php','<pre>### 1.10. RETRIEVE DRUPAL UID, LOGINNAME & EMAIL [part_eventid: '.$part_eventid.'] ('.$groupID.') ###</pre>',NULL,WATCHDOG_DEBUG); }			

			#####################################################################################################
    		if ($extdebug >= 2) { watchdog('php','<pre>###### a) CHECK VIA CIVICRM API IF CID: '.$contact_id.' HAS A CONNECTED DRUPAL ACCOUNT</pre>',NULL,WATCHDOG_DEBUG); }
			#####################################################################################################

			$params_drupaluser = [
      			'return' 		=> ["id","name"],
      			'contact_id' 	=> $contact_id,
      			'sequential' 	=> 1,
    		];
    	    try{
	   			if ($extdebug >= 3) { watchdog('php','<pre>params_drupaluser: '.print_r($params_drupaluser,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
   				$result_drupal = civicrm_api3('User', 'get', $params_drupaluser);
   				if ($extdebug >= 4) { watchdog('php','<pre>result_drupaluser: '.print_r($result_drupal,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			}
			catch (CiviCRM_API3_Exception $e) {
   				// Handle error here.
   				$errorMessage 	= $e->getMessage();
   				$errorCode 		= $e->getErrorCode();
