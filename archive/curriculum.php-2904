 #  				'activity_type_id' 		=> 150,
    				'activity_type_id:name' => 'Evaluatie',
    				'activity_date_time' 	=> $eventendplus60date,
    				'subject' 				=> 'Evaluatie '. $welkkampkort. ' door '. $displayname,
					'status_id:name' 		=> $evaluatie_activity_status_name,
    				'ACT_ALG.kampkort'		=> $welkkampkort,
   					'ACT_ALG.kampfunctie' 	=> $part_functie,    				
    				'ACT_ALG.kampstart' 	=> $event_start_date,
    				'ACT_ALG.kampeinde' 	=> $event_einde_date, 
    				'ACT_ALG.kampjaar'		=> $event_kampjaar,
					'ACT_ALG.modified' 		=> $today_datetime,	
					'ACT_ALG.afgerond' 		=> $part_evaluatie,
  				],
			];
			if ($extdebug >= 3) { watchdog('php','<pre>params_activity_evaluatie_create: '.print_r($params_activity_evaluatie_create,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
