   			if ($extdebug >= 2) { watchdog('php','<pre>------ b) connected_account_uid   : ' .print_r($connected_account->uid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

   			if ($connected_account->name == $user_name AND $connected_account->name == $drupalnaam) {
				if ($extdebug >= 1) { watchdog('php','<pre>------ b) PRIMA: GEVONDEN DRUPALNAME ('.$connected_account->name.') VIA CMSIDENTIFIER ('.$cmsidentitier.') IS GELIJK AAN CONTRUCTED USERNAME ('.$user_name.') AND civcrm_jobtitle ('.$drupalnaam.')</pre>',NULL,WATCHDOG_DEBUG); }
					$drupalaccount_orphan_same_name = 1;
   			}
   			if ($connected_account->mail == $user_email) {
				if ($extdebug >= 1) { watchdog('php','<pre>------ b) PRIMA: GEVONDEN DRUPALMAIL ('.$connected_account->mail.') VIA CMSIDENTIFIER ('.$cmsidentitier.') IS GELIJK AAN PRIMARY CIVICRM EMAIL ('.$user_email.')</pre>',NULL,WATCHDOG_DEBUG); }
					$drupalaccount_orphan_same_mail = 1;
