  				$drupalname_found = 1;
  			} else {
				if ($extdebug >= 1) { watchdog('php','<pre>------ a) ERROR  : VIA CID: '.$contact_id.' GEEN DRUPAL NAAM GEVONDEN VIA CIVICRM API</pre>',NULL,WATCHDOG_DEBUG); }
