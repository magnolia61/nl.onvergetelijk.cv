					if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (boolean)          : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;	

				} elseif (in_array($customFieldHtmlType, array("Select Date"))) {

					if ($extdebug >= 2) { watchdog('php', '<pre>OLDVALUE (date)              : '.print_r($oldvalue,TRUE).'</pre>',NULL,WATCHDOG_DEBUG);}
					$changes['old'][$deltacategory][$customFieldName] = $customFieldName .$tab.": ". $oldvalue;	

				} elseif (in_array($customFieldHtmlType, array("Text","TextArea"))) {

