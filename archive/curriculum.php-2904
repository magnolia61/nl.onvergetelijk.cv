				#if ($tagcv_leid == '') {$tagcv_leid = NULL; }

				if ($extdebug >= 3) { watchdog('php','<pre>tagcv_leid_array: '.print_r($tagcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 2) { watchdog('php','<pre>tagnr_leid    : '.print_r($tagnr_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($extdebug >= 2) { watchdog('php','<pre>tagcv_leid    : '.print_r($tagcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
    		}

   			#############################################################################################################
   			#############################################################################################################
 			// MAKE SURE EVEN EMPTY ARRAYS ARE ARRAYS
			if (empty($oldcv_deel_array))	{ $oldcv_deel_array = []; }
			if (empty($curcv_deel_array))	{ $curcv_deel_array = []; }
			if (empty($evtcv_deel_array))	{ $evtcv_deel_array = []; }
			if (empty($tagcv_deel_array))	{ $tagcv_deel_array = []; }

			// M61: bij deelnemers geboren na 2007-08-1 is de event_cv de juiste en kan de max_cv overschrijven
			if ($birth_date > "2007-08-1") {
				if ($extdebug >= 2) { watchdog('php','<pre>Birthdate >2007: '.print_r($birth_date,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
/*
				if ($extdebug >= 2) { watchdog('php','<pre>UPDATE DEEL CV 3 want birth_date '.print_r($birth_date,TRUE) . ' is bigger than 2006-08-01 en deze deelnemer kan alleen civicrm hebben gebruik voor registratie: '.print_r($evtcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 
*/				
				$maxcv_deel_array = $evtcv_deel_array;
			} else {
				if ($extdebug >= 2) { watchdog('php','<pre>Birthdate <2007: '.print_r($birth_date,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$maxcv_deel_array 	= array_merge($oldcv_deel_array, $curcv_deel_array, $evtcv_deel_array, $tagcv_deel_array);
//				$maxcv_deel_array 	= array_merge($curcv_deel_array, $evtcv_deel_array, $tagcv_deel_array);
//				$maxcv_deel_array 	= array_merge($curcv_deel_array, $evtcv_deel_array);
			}

			$topcv_deel_array 	= $evtcv_deel_top_array;
   			$oldcv_deel_array 	= array_unique($oldcv_deel_array);
   			$maxcv_deel_array 	= array_unique($maxcv_deel_array);
   			$topcv_deel_array 	= array_unique($topcv_deel_array);

 			#if ($extdebug >= 2) { watchdog('php','<pre>oldcv_deel_0_array: '.print_r($oldcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			#if ($extdebug >= 2) { watchdog('php','<pre>curcv_deel_0_array: '.print_r($curcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			#if ($extdebug >= 2) { watchdog('php','<pre>evtcv_deel_0_array: '.print_r($evtcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			#if ($extdebug >= 2) { watchdog('php','<pre>tagcv_deel_0_array: '.print_r($tagcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			#if ($extdebug >= 2) { watchdog('php','<pre>maxcv_deel_0_array: '.print_r($maxcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

 			#if ($extdebug >= 2) { watchdog('php','<pre>curcv_deel_top_0_array: '.print_r($curcv_deel_top_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			#if ($extdebug >= 2) { watchdog('php','<pre>evtcv_deel_top_0_array: '.print_r($evtcv_deel_top_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			#if ($extdebug >= 2) { watchdog('php','<pre>tagcv_deel_top_0_array: '.print_r($tagcv_deel_top_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			#if ($extdebug >= 2) { watchdog('php','<pre>maxcv_deel_top_0_array: '.print_r($topcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			// SORTEER DE ARRAYS

			$avoid_year_array = array(1970,1971,1972,1973,1974,1975,1976,1977,1978);

			$oldcv_deel_array = array_diff($oldcv_deel_array, $avoid_year_array);
   			$oldcv_deel_array = array_unique($oldcv_deel_array);
   			asort($oldcv_deel_array);
   			$oldcv_deel = implode('', $oldcv_deel_array);
   			$oldcv_deel	= ''.$oldcv_deel.'';

			$curcv_deel_array = array_diff($curcv_deel_array, $avoid_year_array);
   			$curcv_deel_array = array_unique($curcv_deel_array);
   			asort($curcv_deel_array);
   			$curcv_deel = implode('', $curcv_deel_array);
   			$curcv_deel	= ''.$curcv_deel.'';

			$evtcv_deel_array = array_diff($evtcv_deel_array, $avoid_year_array);
			$evtcv_deel_array = array_diff($evtcv_deel_array, array($nonpossiblekampjaren));
   			$evtcv_deel_array = array_unique($evtcv_deel_array);
   			asort($evtcv_deel_array);
   			$evtcv_deel = implode('', $evtcv_deel_array);	
   			$evtcv_deel	= ''.$evtcv_deel.'';

			$maxcv_deel_array = array_diff($maxcv_deel_array, $avoid_year_array);
   			$maxcv_deel_array = array_unique($maxcv_deel_array);
   			asort($maxcv_deel_array);
   			$maxcv_deel = implode('', $maxcv_deel_array);
   			$maxcv_deel	= ''.$maxcv_deel.'';					// ZORG (VOOR CHECKBOX) DAT DE SEPERATOR OOK VOOR & ACHTERAAN STAAT

			$topcv_deel_array = array_diff($topcv_deel_array, $avoid_year_array);
   			$topcv_deel_array = array_unique($topcv_deel_array);
   			asort($topcv_deel_array);
   			$maxcv_deel_top = implode('', $topcv_deel_array);
   			$maxcv_deel_top	= ''.$maxcv_deel_top.'';			// ZORG (VOOR CHECKBOX) DAT DE SEPERATOR OOK VOOR & ACHTERAAN STAAT   			
			// BEPAAL OF HET HUIDIGE JAAR ER JUIST EXTRA BIJ MOET OF AF MOET
			if ($diteventdeelyes == 1) {
				array_push($maxcv_deel_array, $event_kampjaar);
				if ($extdebug >= 2) { watchdog('php','<pre>maxcv_deel (+ '.$event_kampjaar.'] want dit event telt ook mee): '.print_r($maxcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				// VOEG HUIDIG EVENTJAAR TOE AAN ARRAY INDIEN HET ER NOG NIET INZAT
				$maxcv_deel_array = array_unique($maxcv_deel_array);
			} elseif ($diteventdeelmss == 1 OR $diteventdeelnot == 1 AND $event_kampjaar) {
				$maxcv_deel_array = array_diff($maxcv_deel_array, array($event_kampjaar));
				$evtcv_deel_array = array_diff($evtcv_deel_array, array($event_kampjaar)); // gevaarlijk maar terecht als er dit jaar geen deelname is. Misschien  nog een IF voor part_status is geannulleerd
				if ($extdebug >= 2) { watchdog('php','<pre>maxcv_deel (- '.$event_kampjaar.'] want dit event telt niet mee): '.print_r($maxcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				// VERWIJDER HUIDIG EVENTJAAR UIT ARRAY INDIEN HET ER INZAT
			}
  			
			// PREVENT EMPTY VALUES THAT ARE NOT ACCEPTED
			if ($oldcv_deel == '') 	{ $oldcv_deel = NULL; }
			if ($evtcv_deel == '') 	{ $evtcv_deel = NULL; }
			if ($tagcv_deel == '') 	{ $tagcv_deel = NULL; }
			if ($maxcv_deel == '') 	{ $maxcv_deel = NULL; }
			if (empty($oldcv_deel)) { $oldcv_deel = NULL; }
			if (empty($evtcv_deel)) { $evtcv_deel = NULL; }
			if (empty($tagcv_deel)) { $tagcv_deel = NULL; }
			if (empty($maxcv_deel)) { $maxcv_deel = NULL; }

			$oldcv_deel_nr 	= count(array_filter($oldcv_deel_array));
			$curcv_deel_nr 	= count(array_filter($curcv_deel_array));
			$evtcv_deel_nr	= count(array_filter($evtcv_deel_array));
			$tagcv_deel_nr	= count(array_filter($tagcv_deel_array));
			$maxcv_deel_nr	= count(array_filter($maxcv_deel_array));
			$deel_nr_diff  	= abs($maxcv_deel_nr - $curcv_deel_nr);

 			if ($extdebug >= 3) { watchdog('php','<pre>avoid_year_array: '.print_r($avoid_year_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			if ($extdebug >= 3) { watchdog('php','<pre>oldcv_deel_array: '.print_r($oldcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			if ($extdebug >= 3) { watchdog('php','<pre>curcv_deel_array: '.print_r($curcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			if ($extdebug >= 3) { watchdog('php','<pre>evtcv_deel_array: '.print_r($evtcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 3) { watchdog('php','<pre>tagcv_deel_array: '.print_r($tagcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			if ($extdebug >= 3) { watchdog('php','<pre>maxcv_deel_array: '.print_r($maxcv_deel_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			if ($extdebug >= 1) { watchdog('php','<pre>oldcv_deel     : '.print_r($oldcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>curcv_deel     : '.print_r($curcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_deel     : '.print_r($evtcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>cancv_deel     : '.print_r($cancv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>tagcv_deel     : '.print_r($tagcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>maxcv_deel     : '.print_r($maxcv_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}

			if ($extdebug >= 1) { watchdog('php','<pre>oldcv_deel_nr  : '.print_r($oldcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>curcv_deel_nr  : '.print_r($curcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_deel_nr  : '.print_r($evtcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>tagcv_deel_nr  : '.print_r($tagcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>maxcv_deel_nr  : '.print_r($maxcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 1) { watchdog('php','<pre>deel_nr_diff   : '.print_r($deel_nr_diff,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}

			$eerstedeel  = min(array_filter($maxcv_deel_array));
			if ($extdebug >= 1) { watchdog('php','<pre>eerstedeel     : '.print_r($eerstedeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }			
   			// M61: #1 GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALLEEN ALS ER BIJKOMT, VERMINDER ALLEEN ALS DE NIEUWE WAARDE SLECHTS 1 JAAR AFWIJKT		
			if (($maxcv_deel_nr > $curcv_deel_nr) OR ($maxcv_deel_nr < $curcv_deel_nr AND $deel_nr_diff == 1)) {
				if ($extdebug >= 2) { watchdog('php','<pre>UPDATE DEEL CV 1 want maxcv_deel_nr: '.print_r($maxcv_deel_nr,TRUE) . ' differs with ['.$deel_nr_diff.'] from curcv_deel_nr: '.print_r($curcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($maxcv_deel_nr == 0) { $maxcv_deel = NULL; } // gevaarlijk maar wel terecht hier ingebed
				$welkedeel 		= $maxcv_deel;
				$kerendeel 		= $maxcv_deel_nr;
			} else {
				$welkedeel 		= $curcv_deel;
				$kerendeel 		= $curcv_deel_nr;
				if ($extdebug >= 2) { watchdog('php','<pre>CANCEL UPDATE van DEEL CV want zou omlaag gaan met slechts '.$deel_nr_diff.' t.o.v. curcv_deel_nr: '.print_r($curcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }			
			}		

/*
			// M61: #2 GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALS DIT JAAR MEE + DIFF = 1 EN (TODO) EEN OF ANDERE STAFFEL
			if ($evtcv_deel_nr < $curcv_deel_nr AND $ditjaardeelyes == 1 AND $evtcv_deel_nr < 5 AND $curcv_deel_nr < 6 AND $maxcv_deel_nr < 7 AND $deel_nr_diff <= 1 AND $eerstedeel > 2015) {
				if ($extdebug >= 2) { watchdog('php','<pre>UPDATE DEEL CV 2 want evtcv_deel_nr: '.print_r($evtcv_deel_nr,TRUE) . ' differs with ['.$deel_nr_diff.'] from curcv_deel_nr: '.print_r($curcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }	
				if ($maxcv_deel_nr == 0) { $maxcv_deel = NULL; } // gevaarlijk maar wel terecht hier ingebed (M61: TODO: klopt dit?)
				$welkedeel 		= $evtcv_deel;
			}

			// M61: #3 GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALS DIT JAAR MEE + DIFF = 1 EN EERSTE KEER MEE > 2015
			if ($evtcv_deel_nr == 1 AND $ditjaardeelyes == 1 AND $deel_nr_diff = 1 AND $eerstedeel > 2015) {
				if ($extdebug >= 2) { watchdog('php','<pre>UPDATE DEEL CV 3 want evtcv_deel_nr: '.print_r($evtcv_deel_nr,TRUE) . ' differs with ['.$deel_nr_diff.'] from curcv_deel_nr: '.print_r($curcv_deel_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }	
				if ($maxcv_deel_nr == 0) {
					$maxcv_deel = NULL;		// gevaarlijk maar wel terecht hier ingebed
				}
				$welkedeel 		= $evtcv_deel;
			}
*/
			// M61: bij deelnemers geboren na 2007-08-1 is de event_cv de juiste en kan de max_cv overschrijven
			if ($birth_date > "2007-08-1") {
				if ($extdebug >= 2) { watchdog('php','<pre>Birthdate >2007: '.print_r($birth_date,TRUE).' (event_cv is leidend)</pre>',NULL,WATCHDOG_DEBUG); }
				$welkedeel 		= $evtcv_deel;
				$kerendeel 		= $evtcv_deel_nr;
			} else {
				if ($extdebug >= 2) { watchdog('php','<pre>Birthdate <2007: '.print_r($birth_date,TRUE).' (event_cv niet leidend)</pre>',NULL,WATCHDOG_DEBUG); }
			}

			// M61: tbv checks
			if ($extdebug >= 1) { watchdog('php','<pre>welkedeel      : '.print_r($welkedeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 2) { watchdog('php','<pre>kerendeel      : '.print_r($kerendeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

 			#############################################################################################################
			# 2.1e bereken x mee als kampstaf obv event registraties
    		if ($extdebug >= 1) { watchdog('php','<pre>### 2.1e bereken x mee als kampstaf obv event registraties [groupID: '.$groupID.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
			######	MEET  ###############################################################################################
			# poging om array te maken van geregistreerde events meeting kampstaf voor leiding
			#############################################################################################################

			$params_part_meet = [
  				'select' => [
    				'event_id',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesmeet],
    				['event_id.start_date',	   '>',  $today_fiscalyear_start],
    				['contact_id', 		 	   '=',  $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];
			if ($extdebug >= 3) { watchdog('php','<pre>params_part_meet: '.print_r($params_part_meet,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$result_meet = civicrm_api4('Participant', 'get', $params_part_meet);
			if ($extdebug >= 4) { watchdog('php','<pre>result_meet: '.print_r($result_meet,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			$meetcount 			= $result_meet->count();
			$evtcv_meet_array	= $result_meet->column('event_id');  // maakt een array met alleen de velden voor id
			asort($evtcv_meet_array); // sort by value

			if ($extdebug >= 3) { watchdog('php','<pre>meetcount: '.print_r($meetcount,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>evtcv_meet_array: '.print_r($evtcv_meet_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

 			#############################################################################################################
			# 2.1f bereken x geannuleerd als leiding obv geannuleerde event registraties
    		if ($extdebug >= 1) { watchdog('php','<pre>### 2.1f bereken x geannuleerd als leiding obv geannuleerde event registraties [groupID: '.$groupID.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
			######	LEID  ###############################################################################################
			# poging om totaal aantal keren mee als leiding te berekenen obv GEANNULEERDE event registraties
			#############################################################################################################
			$cancv_leid_array = [];
			$params_part_leid_canceled = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesleid],
    				['status_id', 	'IN', [4]], 		 // gebruik GEANNULEERDE event registraties
    				['is_test', 	'IN', [TRUE, FALSE]], 
    				['contact_id', 	'=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];			
			if ($extdebug >= 3) { watchdog('php','<pre>params_part_leid_canceled: '.print_r($params_part_leid_canceled,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$part_leid_canceled = civicrm_api4('Participant', 'get', $params_part_leid_canceled);
			if ($extdebug >= 4) { watchdog('php','<pre>result_part_leid_canceled: '.print_r($part_leid_canceled,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			foreach ($part_leid_canceled as $participant_leid_canceled) {
				$line_leid_canceled = $participant_leid_canceled['event_id.start_date'];
				if ($extdebug >= 5) { watchdog('php','<pre>line_leid_canceled: '.print_r($line_leid_canceled,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$cancv_leid_array[] = date('Y', strtotime($line_leid_canceled));
				if ($extdebug >= 5) { watchdog('php','<pre>participant_leid_canceled: '.print_r($participant_leid_canceled,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			}
 			if ($cancv_leid_array) 	{
 				arsort($cancv_leid_array);
 				$cancv_leid = implode('', $cancv_leid_array);
 				if ($extdebug >= 2) { watchdog('php','<pre>cancv_leid_array: '.print_r($cancv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			} else {
 				$cancv_leid_array 	= [];
 				$cancv_leid 		= NULL;
 			}
			######	LEID  ###############################################################################################
			# poging om totaal aantal keren mee als leiding te berekenen obv event registraties met als functie kampstaf
			#############################################################################################################
			$evtcv_staf_array = [];
			$params_part_leid_stafjaar = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id', 'IN', $eventypesleid],
    				['PART_LEID.Functie', 'IN', ['bestuurslid', 'kampstaf']],
    				['status_id', 	'IN', [1, 2, 5, 6, 15]], 
    				['is_test', 	'IN', [TRUE, FALSE]], 
    				['contact_id', 	'=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];			
			if ($extdebug >= 3) { watchdog('php','<pre>params_part_leid_stafjaar: '.print_r($params_part_leid_stafjaar,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$part_leid_stafjaar = civicrm_api4('Participant', 'get', $params_part_leid_stafjaar);
			if ($extdebug >= 4) { watchdog('php','<pre>result_part_leid_stafjaar: '.print_r($part_leid_stafjaar,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			foreach ($part_leid_stafjaar as $participant_leid_stafjaar) {
				$line_leid_stafjaar = $participant_leid_stafjaar['event_id.start_date'];
				if ($extdebug >= 5) { watchdog('php','<pre>line_leid_stafjaar: '.print_r($line_leid_stafjaar,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$evtcv_staf_array[] = date('Y', strtotime($line_leid_stafjaar));
				if ($extdebug >= 5) { watchdog('php','<pre>participant_leid_stafjaar: '.print_r($participant_leid_stafjaar,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			}
 			if ($evtcv_staf_array) 	{
 				arsort($evtcv_staf_array);
 				$evtcv_staf = implode('', $evtcv_staf_array);
 				if ($extdebug >= 2) { watchdog('php','<pre>evtcv_staf_array: '.print_r($evtcv_staf_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			} else {
 				$evtcv_staf_array 	= [];
 				$evtcv_staf 		= NULL;
 			} 			
 			#############################################################################################################
			# 2.1g bereken x mee als leiding obv event registraties
    		if ($extdebug >= 1) { watchdog('php','<pre>### 2.1g bereken x mee als leiding obv event registraties [groupID: '.$groupID.'] ###</pre>',NULL,WATCHDOG_DEBUG); }
			######	LEID  ###############################################################################################
			# poging om totaal aantal keren mee als leiding te berekenen obv event registraties
			#############################################################################################################
			$params_part_leid = [
  				'select' => [
    				'contact_id.display_name', 'event_id.start_date',
  				],
  				'where' => [
    				['event_id.event_type_id',  'IN', $eventypesleid],
    				['status_id', 	'IN', [1, 2, 5, 6, 15]],
    				['is_test', 	'IN', [TRUE, FALSE]],
    				['contact_id', 	'=', $contact_id],
  				],
  				'checkPermissions' => FALSE,
  				'debug' => $apidebug,
			];			
			if ($extdebug >= 3) { watchdog('php','<pre>params_part_leid: '.print_r($params_part_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$part_leid = civicrm_api4('Participant', 'get', $params_part_leid);
			if ($extdebug >= 4) { watchdog('php','<pre>result_part_leid: '.print_r($part_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			foreach ($part_leid as $participant_leid) {
				$line_leid = $participant_leid['event_id.start_date'];
				if ($extdebug >= 5) { watchdog('php','<pre>line_leid: '.print_r($line_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$evtcv_leid_array[] = date('Y', strtotime($line_leid));
				if ($extdebug >= 5) { watchdog('php','<pre>participant_leid: '.print_r($participant_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			}
			if ($extdebug >= 2) { watchdog('php','<pre>evtcv_leid_array                 : '.print_r($evtcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			#############################################################################################################			
			### VERMINDER DE LEIDING ARRAY MET DE JAREN ALS STAF (NIET FYSIEK MEE, WEL ACTIEF ALS STAF) 
			$evtcv_leid_array = array_diff($evtcv_leid_array, $evtcv_staf_array);
			#if ($extdebug >= 2) { watchdog('php','<pre>evtcv_leid_array (minus stafjaren): '.print_r($evtcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			#############################################################################################################

 			if ($oldcv_leid_array)	{
 				arsort($oldcv_leid_array); // M61 not sure if this sort works 	
 				$oldcv_leid 		= implode('', $oldcv_leid_array);
 			} else {
 				$oldcv_leid_array 	= [];
 				$oldcv_leid 		= NULL;
 			}
 			if ($curcv_leid_array)	{
 				arsort($curcv_leid_array); // M61 not sure if this sort works 	
 				$curcv_leid 		= implode('', $curcv_leid_array);
 			} else {
 				$curcv_leid_array 	= [];
 				$curcv_leid 		= NULL;
 			}
 			if ($evtcv_leid_array) 	{
 				arsort($evtcv_leid_array);
 				$evtcv_leid 		= implode('', $evtcv_leid_array);
 			} else {
 				$evtcv_leid_array 	= [];
 				$evtcv_leid 		= NULL;
 			}
 			if ($evtcv_staf_array) 	{
 				arsort($evtcv_staf_array);
 				$evtcv_staf 		= implode('', $evtcv_staf_array);
 			} else {
 				$evtcv_staf_array 	= [];
 				$evtcv_staf 		= NULL;
 			} 			
   			if ($tagcv_leid_array)	{
   				arsort($tagcv_leid_array);
   				$tagcv_leid 		= implode("", $tagcv_leid_array);
   			} else {
 				$tagcv_leid_array 	= [];
 				$tagcv_leid 		= NULL; 			
   			}
 
 			// MAKE SURE EVEN EMPTY ARRAYS ARE ARRAYS
			if (empty($oldcv_leid_array))	{ $oldcv_leid_array = []; }
			if (empty($curcv_leid_array))	{ $curcv_leid_array = []; }
			if (empty($evtcv_leid_array))	{ $evtcv_leid_array = []; }
			if (empty($evtcv_staf_array))	{ $evtcv_staf_array = []; }
			if (empty($evtcv_meet_array))	{ $evtcv_meet_array = []; }
			if (empty($tagcv_leid_array))	{ $tagcv_leid_array = []; }

			// M61: bij leiding met eerstejaar leid >=2013 is de event_cv de juiste en kan de max_cv overschrijven
			$maxcv_leid_array = array_merge($oldcv_leid_array, $curcv_leid_array, $evtcv_leid_array, $tagcv_leid_array);
			$eersteleid  = min(array_filter($maxcv_leid_array));
			if ($eersteleid >= 2013) {
				if ($extdebug >= 2) { watchdog('php','<pre>Eerste keer leiding >=2013: '.print_r($eersteleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$maxcv_leid_array = $evtcv_leid_array;
			} else {
				if ($extdebug >= 2) { watchdog('php','<pre>Eerste keer leiding <=2013: '.print_r($eersteleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
//				$maxcv_leid_array = array_merge($oldcv_leid_array, $curcv_leid_array, $evtcv_leid_array, $tagcv_leid_array);
				$maxcv_leid_array = array_merge($curcv_leid_array, $evtcv_leid_array, $tagcv_leid_array);
//				$maxcv_leid_array = array_merge($curcv_leid_array, $evtcv_leid_array);
			}

 			if ($extdebug >= 3) { watchdog('php','<pre>curcv_leid_0_array: '.print_r($curcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
 			if ($extdebug >= 3) { watchdog('php','<pre>evtcv_leid_0_array: '.print_r($evtcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 3) { watchdog('php','<pre>tagcv_leid_0_array: '.print_r($tagcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			if ($extdebug >= 3) { watchdog('php','<pre>maxcv_leid_0_array: '.print_r($maxcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			// BEPAAL OF HET HUIDIGE JAAR ER JUIST EXTRA BIJ MOET OF AF MOET
			if ($diteventleidyes == 1) {
				array_push($maxcv_leid_array, $event_kampjaar);
				if ($extdebug >= 2) { watchdog('php','<pre>maxcv_leid (+ '.$event_kampjaar.'] want dit event telt ook mee): '.print_r($maxcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				// VOEG HUIDIG EVENTJAAR TOE AAN ARRAY INDIEN HET ER NOG NIET INZAT
				$maxcv_leid_array = array_unique($maxcv_leid_array);
			} elseif ($diteventleidmss == 1 OR $diteventleidnot == 1) {
				$maxcv_leid_array = array_diff($maxcv_leid_array, array($event_kampjaar));
				$evtcv_leid_array = array_diff($evtcv_leid_array, array($event_kampjaar)); // gevaarlijk maar terecht als er dit jaar geen deelname is. Misschien hier nog een IF voor part_status is geannulleerd
				if ($extdebug >= 2) { watchdog('php','<pre>maxcv_leid (- '.$event_kampjaar.'] want dit event telt niet mee): '.print_r($maxcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				// VERWIJDER HUIDIG EVENTJAAR UIT ARRAY INDIEN HET ER INZAT
			}

			$avoid_year_array = array(1970,1971,1972,1973,1974,1975,1976,1977,1978);

			$oldcv_leid_array = array_diff($oldcv_leid_array, $avoid_year_array);
   			$oldcv_leid_array = array_unique($oldcv_leid_array);
   			asort($oldcv_leid_array);
   			$oldcv_leid = implode('', $oldcv_leid_array);
   			$oldcv_leid	= ''.$oldcv_leid.'';

			$curcv_leid_array = array_diff($curcv_leid_array, $avoid_year_array);
   			$curcv_leid_array = array_unique($curcv_leid_array);
   			asort($curcv_leid_array);
   			$curcv_leid = implode('', $curcv_leid_array);
   			$curcv_leid	= ''.$curcv_leid.'';

			$evtcv_leid_array = array_diff($evtcv_leid_array, $avoid_year_array);
   			$evtcv_leid_array = array_unique($evtcv_leid_array);
   			asort($evtcv_leid_array);
   			$evtcv_leid = implode('', $evtcv_leid_array);
   			$evtcv_leid	= ''.$evtcv_leid.'';

			$evtcv_staf_array = array_diff($evtcv_staf_array, $avoid_year_array);
			$evtcv_staf_array = array_unique($evtcv_staf_array);
			asort($evtcv_staf_array);
   			$evtcv_staf = implode('', $evtcv_staf_array);
   			$evtcv_staf	= ''.$evtcv_staf.'';   			

			$evtcv_meet_array = array_diff($evtcv_meet_array, $avoid_year_array);
   			$evtcv_meet_array = array_unique($evtcv_meet_array);
   			asort($evtcv_meet_array);
   			$evtcv_meet = implode('', $evtcv_meet_array);
   			$evtcv_meet	= ''.$evtcv_meet.'';

			$maxcv_leid_array = array_diff($maxcv_leid_array, $avoid_year_array);
   			$maxcv_leid_array = array_unique($maxcv_leid_array);
   			asort($maxcv_leid_array);
   			$maxcv_leid = implode('', $maxcv_leid_array);
   			$maxcv_leid	= ''.$maxcv_leid.'';

   			#if ($extdebug >= 2) { watchdog('php','<pre>maxcv_leid_array: '.print_r($maxcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>maxcv_leid      : '.print_r($maxcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
   			
			// PREVENT EMPTY VALUES THAT ARE NOT ACCEPTED
			if ($oldcv_leid == '') 	{ $oldcv_leid = NULL; }
			if ($evtcv_leid == '') 	{ $evtcv_leid = NULL; }
			if ($evtcv_staf == '') 	{ $evtcv_staf = NULL; }
			if ($evtcv_meet == '') 	{ $evtcv_meet = NULL; }
			if ($tagcv_leid == '') 	{ $tagcv_leid = NULL; }
			if ($maxcv_leid == '') 	{ $maxcv_leid = NULL; }
			if (empty($oldcv_leid)) { $oldcv_leid = NULL; }
			if (empty($evtcv_leid)) { $evtcv_leid = NULL; }
			if (empty($evtcv_staf)) { $evtcv_staf = NULL; }
			if (empty($evtcv_meet)) { $evtcv_meet = NULL; }
			if (empty($tagcv_leid)) { $tagcv_leid = NULL; }
			if (empty($maxcv_leid)) { $maxcv_leid = NULL; }

			$oldcv_leid_nr 	= count(array_filter($oldcv_leid_array));
			$curcv_leid_nr 	= count(array_filter($curcv_leid_array));
			$evtcv_leid_nr	= count(array_filter($evtcv_leid_array));
			$evtcv_staf_nr	= count(array_filter($evtcv_staf_array));
			$evtcv_meet_nr	= count(array_filter($evtcv_meet_array));
			$tagcv_leid_nr	= count(array_filter($tagcv_leid_array));
			$maxcv_leid_nr	= count(array_filter($maxcv_leid_array));
			$leid_nr_diff  	= abs($maxcv_leid_nr - $curcv_leid_nr);

 			if ($extdebug >= 3) { watchdog('php','<pre>avoid_year_array: '.print_r($avoid_year_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
 			if ($extdebug >= 3) { watchdog('php','<pre>oldcv_leid_array: '.print_r($oldcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
 			if ($extdebug >= 3) { watchdog('php','<pre>curcv_leid_array: '.print_r($curcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
 			if ($extdebug >= 3) { watchdog('php','<pre>evtcv_leid_array: '.print_r($evtcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
 			if ($extdebug >= 3) { watchdog('php','<pre>evtcv_staf_array: '.print_r($evtcv_staf_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
 			if ($extdebug >= 3) { watchdog('php','<pre>evtcv_meet_array: '.print_r($evtcv_meet_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
			if ($extdebug >= 3) { watchdog('php','<pre>tagcv_leid_array: '.print_r($tagcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
   			if ($extdebug >= 3) { watchdog('php','<pre>maxcv_leid_array: '.print_r($maxcv_leid_array,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}

			if ($extdebug >= 1) { watchdog('php','<pre>oldcv_leid      : '.print_r($oldcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>curcv_leid      : '.print_r($curcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_leid      : '.print_r($evtcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_staf      : '.print_r($evtcv_staf,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_meet      : '.print_r($evtcv_meet,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>cancv_leid      : '.print_r($cancv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_staf      : '.print_r($evtcv_staf,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>tagcv_leid      : '.print_r($tagcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>maxcv_leid      : '.print_r($maxcv_leid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}

			if ($extdebug >= 1) { watchdog('php','<pre>oldcv_leid_nr   : '.print_r($oldcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>curcv_leid_nr   : '.print_r($curcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_leid_nr   : '.print_r($evtcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_staf_nr   : '.print_r($evtcv_staf_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>evtcv_meet_nr   : '.print_r($evtcv_meet_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>tagcv_leid_nr   : '.print_r($tagcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>maxcv_leid_nr   : '.print_r($maxcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 		}
			if ($extdebug >= 1) { watchdog('php','<pre>leid_nr_diff    : '.print_r($leid_nr_diff,TRUE).'</pre>',NULL,  WATCHDOG_DEBUG); 	}

   			// M61: GEVAARLIJKE REGEL MAAR FIJN MET HET NODIGE DENKWERK
			// VERANDER CURCV ALLEEN ALS ER BIJKOMT, VERMINDER ALLEEN ALS DE NIEUWE WAARDE SLECHTS 1 JAAR AFWIJKT			
			if (($maxcv_leid_nr > $curcv_leid_nr) OR ($maxcv_leid_nr < $curcv_leid_nr AND $leid_nr_diff == 1)) {
				if ($extdebug >= 2) { watchdog('php','<pre>UPDATE LEID CV want maxcv_leid_nr: '.print_r($maxcv_leid_nr,TRUE) . ' differs with ['.$leid_nr_diff.'] from curcv_leid_nr: '.print_r($curcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				if ($maxcv_leid_nr == 0) { $maxcv_leid = NULL; } // gevaarlijk maar wel terecht hier ingebed
				$welkeleid 		= $maxcv_leid;
				$kerenleid 		= $maxcv_leid_nr;
			} else {
				$welkeleid 		= $curcv_leid;
				$kerenleid 		= $curcv_leid_nr;
				if ($extdebug >= 2) { watchdog('php','<pre>CANCEL UPDATE LEID CV want zou omlaag gaan met meer dan 1 (nl: '.$leid_nr_diff.') t.o.v. curcv_leid_nr: '.print_r($curcv_leid_nr,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }					
			}

			// M61: bij leiding met eerstejaar leid >=2013 is de event_cv de juiste en kan de max_cv overschrijven
			$eersteleid  = min(array_filter($maxcv_leid_array));
			if ($eersteleid >= 2013) {
				if ($extdebug >= 2) { watchdog('php','<pre>Eerste keer leiding >=2013: '.print_r($eersteleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				$welkeleid 		= $evtcv_leid;
				$welkeleid 		= $evtcv_leid_nr;
			} else {
				if ($extdebug >= 2) { watchdog('php','<pre>Eerste keer leiding <=2013: '.print_r($eersteleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			}

			#asort($welkeleid);
			if ($extdebug >= 2) { watchdog('php','<pre>welkeleid        : '.print_r($welkeleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			if ($extdebug >= 2) { watchdog('php','<pre>kerenleid        : '.print_r($kerenleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			// poging om totaal aantal keren mee als deelnemer van het Topkamp te berekenen obv event registraties
			$params_countpart_top = [
				'status_id'  	=> array("Registered", "Deelgenomen", "Pending from pay later", "Pending from incomplete transaction", "Partially paid"),
      			'role_id' 	 	=> "Deelnemer Topkamp",
      			'contact_id' 	=> $contact_id,
      			#'fee_amount' => ['>' => 1],
			];
			#if ($extdebug >= 3) { watchdog('php','<pre>params_countpart_deel: '.print_r($params_countpart_deel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
			$kereneventtop = civicrm_api3('Participant', 'getcount', $params_countpart_top);
   			if ($extdebug >= 1) { watchdog('php','<pre>kereneventtop    : '.print_r($kereneventtop,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }

			#####################################################################################################
			// BEPAAL EERSTE EN LAATSTE JAAR DEEL
			#####################################################################################################
			if (!empty($maxcv_deel_array)) {
				if ($maxcv_deel_nr > 0) {
					$eerstedeel  = min(array_filter($maxcv_deel_array));
					$laatstedeel = max(array_filter($maxcv_deel_array));
					if ($extdebug >= 2) { watchdog('php','<pre>eerstedeel       : '.print_r($eerstedeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 2) { watchdog('php','<pre>laatstedeel      : '.print_r($laatstedeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($maxcv_deel_nr == 1) {
					$eerstexdeel 			= 'eerstex';
					$part_ditjaar1stdeel 	= 'eerstex';
					if ($extdebug >= 2) { watchdog('php','<pre>eerstexdeel      : '.print_r($eerstexdeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				} else {
					$eerstexdeel 			= NULL;
					$part_ditjaar1stdeel 	= NULL;
				}
			}
			// BEPAAL EERSTE EN LAATSTE JAAR DEEL_TOP
			if (!empty($topcv_deel_array)) {
				if ($maxcv_deel_nr > 0) {
					$eerstedeeltop  = min(array_filter($topcv_deel_array));
					$laatstedeeltop = max(array_filter($topcv_deel_array));
					if ($extdebug >= 1) { watchdog('php','<pre>eerstedeeltop    : '.print_r($eerstedeeltop,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 1) { watchdog('php','<pre>laatstedeeltop   : '.print_r($laatstedeeltop,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				}
			}
   			// BEPAAL EERSTE EN LAATSTE JAAR LEID
			if (!empty($maxcv_leid_array)) {
				if ($maxcv_leid_nr > 0) {
					$eersteleid  = min(array_filter($maxcv_leid_array));
					$laatsteleid = max(array_filter($maxcv_leid_array));
					if ($extdebug >= 2) { watchdog('php','<pre>eersteleid       : '.print_r($eersteleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
					if ($extdebug >= 2) { watchdog('php','<pre>laatsteleid      : '.print_r($laatsteleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				}
				if ($maxcv_leid_nr == 1) {
					$eerstexleid 			= 'eerstex';
					$part_ditjaar1stleid 	= 'eerstex';
					if ($extdebug >= 2) { watchdog('php','<pre>eerstexleid      : '.print_r($eerstexleid,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); }
				} else {
					$eerstexleid 			= NULL;
					$part_ditjaar1stleid 	= NULL;
				}
			}

			// BEPAAL EERSTE EN LAATSTE JAAR TOTAAL
			$totaalmee   = $kerendeel + $kerenleid;
			$eerstekeer  = $maxcv_deel_nr > 0 ? $eerstedeel  : $eersteleid;
			$laatstekeer = $maxcv_leid_nr > 0 ? $laatsteleid : $laatstedeel;

			#if ($extdebug >= 2) { watchdog('php','<pre>eerstedeel      : '.print_r($eerstedeel,TRUE).'</pre>',NULL,WATCHDOG_DEBUG); 	}
